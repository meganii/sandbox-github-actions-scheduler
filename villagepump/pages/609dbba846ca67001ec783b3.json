      "userId": "62a91a7a083437001de60035",
      "created": 1660385366,
      "updated": 1660385366
    },
    {
      "id": "62f77855e6003500006506ec",
      "text": "[https://www.jma.go.jp/bosai/map.html#4/42.779/146.162/&elem=root&typhoon=all&contents=typhoon 気象庁｜台風情報]",
      "userId": "62a91a7a083437001de60035",
