      "updated": 1771902281
    },
    {
      "id": "699d15490000000000baa031",
      "text": "上代特殊仮名遣いの甲乙は e₁ e₂ のように表す",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902282,
      "updated": 1771904152
    },
    {
      "id": "699d15490000000000baa030",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902281,
      "updated": 1771902281
    },
    {
      "id": "699d1ca10000000000baa057",
      "text": "a に i が後続した ai が合体して e になったのではないかと言われている",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771904162,
      "updated": 1771904196
    },
    {
      "id": "699d1ca10000000000baa058",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771904162,
      "updated": 1771904162
    },
    {
      "id": "699d133c0000000000baa020",
      "text": "table:露出形と被覆形",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901757,
      "updated": 1771901829
    },
    {
      "id": "699d17510000000000baa03b",
      "text": " 手（て）`[1]`\t手綱（た―）`[1]`\t",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902802,
      "updated": 1771902911
    },
    {
      "id": "699d13120000000000baa01a",
      "text": " 目（め₂）`[1]`\tまぶた`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901714,
      "updated": 1771902334
    },
    {
      "id": "699d13960000000000baa021",
      "text": " 酒（さけ₂）`[1]`\t酒屋（さか―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901847,
      "updated": 1771902335
    },
    {
      "id": "699d139b0000000000baa022",
      "text": " 風（かぜ）`[1]`\t風向き（かざ―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901851,
      "updated": 1771902353
    },
    {
      "id": "699d13c20000000000baa023",
      "text": " 金（かね）`[1]`\t金物（かな―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901890,
      "updated": 1771902355
    },
    {
      "id": "699d13d40000000000baa024",
      "text": " 船（ふね）`[1]`\t船大工（ふな―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901909,
      "updated": 1771902356
    },
    {
      "id": "699d13330000000000baa01e",
      "text": " 胸（むね）`[1]`\t胸毛（むな―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901748,
      "updated": 1771902357
    },
    {
      "id": "699d14250000000000baa025",
      "text": " 上（うえ₂）`[1]`\t上の空（うわ―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771901990,
      "updated": 1771902337
    },
    {
      "id": "699d14460000000000baa027",
      "text": " 雨（あめ₂）`[1]`\t雨宿り（あま―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902023,
      "updated": 1771902338
    },
    {
      "id": "699d14590000000000baa028",
      "text": " 爪（つめ₂）`[1]`\t爪弾き（つま―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902042,
      "updated": 1771902926
    },
    {
      "id": "699d14770000000000baa029",
      "text": " 声（こゑ）`[1]`\t声色（こわ―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902072,
      "updated": 1771902925
    },
    {
      "id": "699d15fe0000000000baa034",
      "text": " 飴（あめ₂）`[1]`\t甘い（あま―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902462,
      "updated": 1771902924
    },
    {
      "id": "699d16290000000000baa035",
      "text": " 岳（たけ₂）`[1]`\t高い（たか―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902506,
      "updated": 1771902924
    },
    {
      "id": "699d16640000000000baa036",
      "text": " 音（ね）`[1]`\t鳴る（な―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902565,
      "updated": 1771902923
    },
    {
      "id": "699d16860000000000baa037",
      "text": " 音（ね）`[1]`\t泣く（な―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902599,
      "updated": 1771902923
    },
    {
      "id": "699d16ad0000000000baa038",
      "text": " 影（かげ）`[1]`\t鏡（かがみ）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902637,
      "updated": 1771902923
    },
    {
      "id": "699d1c3f0000000000baa055",
      "text": " 月（つき）`[1]`\t月読（つく―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771904064,
      "updated": 1771904088
    },
    {
      "id": "699d148f0000000000baa02a",
      "text": " 小菅（―すげ₂）`[1]`\t菅原（すが―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902095,
      "updated": 1771902937
    },
    {
      "id": "699d14d70000000000baa02b",
      "text": " 道真（―さね）`[1]`\t真田（さな―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902167,
      "updated": 1771902363
    },
    {
      "id": "699d14fb0000000000baa02c",
      "text": " 三宅（―やけ₂）`[1]`\t家持（やか―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902204,
      "updated": 1771902342
    },
    {
      "id": "699d17c10000000000baa03f",
      "text": "\t毛（け₂）`[1]`\tか`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902914,
      "updated": 1771902920
    },
    {
      "id": "699d17c20000000000baa040",
      "text": " 毛（け₂）`[1]`\t白髪（―が）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902915,
      "updated": 1771902915
    },
    {
      "id": "699d178d0000000000baa03e",
      "text": " 髪（かみ）`[1]`\tか`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902861,
      "updated": 1771902914
    },
    {
      "id": "699d17550000000000baa03c",
      "text": " 端（はし）`[1]`\t端数（は―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902806,
      "updated": 1771902932
    },
    {
      "id": "699d175a0000000000baa03d",
      "text": " 足（あし）`[1]`\t足掻く（あ―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902811,
      "updated": 1771902953
    },
    {
      "id": "699d17ec0000000000baa043",
      "text": " 鶏（とり）`[1]`\t鳥羽（とば）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771902957,
      "updated": 1771903006
    },
    {
      "id": "699d185e0000000000baa045",
      "text": " 薬（くすり）`[1]`\t薬師（くすし）`[1]`\t`[1]`には医師（くすし）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903071,
      "updated": 1771903106
    },
    {
      "id": "699d189c0000000000baa046",
      "text": " 沖（おき）`[1]`\t奥（おく）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903133,
      "updated": 1771903160
    },
    {
      "id": "699d18b90000000000baa047",
      "text": " 石（いし）`[1]`\t明石（あかし）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903161,
      "updated": 1771903263
    },
    {
      "id": "699d19200000000000baa048",
      "text": " 内（うち）`[1]`\t河内（かはち）`[1]`\t→かわち",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903265,
      "updated": 1771903405
    },
    {
      "id": "699d196b0000000000baa049",
      "text": " 内（うち）`[1]`\t河内（かふち）`[1]`\t→かうち→こうち",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903340,
      "updated": 1771903404
    },
    {
      "id": "699d19ae0000000000baa04b",
      "text": " 肩（かた）`[1]`\t担ぐ（かつ―）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903407,
      "updated": 1771903439
    },
    {
      "id": "699d1b230000000000baa04e",
      "text": " 四日（―か）`[1]`\t暦（こよみ）`[1]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903780,
      "updated": 1771903780
    },
    {
      "id": "699d1b310000000000baa050",
      "text": " 木（き）`[2]`\t木の葉（こ―）`[2]`",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903793,
      "updated": 1771903842
    },
    {
      "id": "699d1b470000000000baa051",
      "text": " 火（ひ）`[2]`\t炎（ほのお）`[2]`\t`[2]`には「ほ」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1771903815,
      "updated": 1771903854
    },
    {
      "id": "699d1b6f0000000000baa052",
      "text": " 火（ひ）`[2]`\t焔（ほむら）`[2]`\t`[2]`には「ほ」",
      "userId": "6436266c7ac3c0001bed60e6",
