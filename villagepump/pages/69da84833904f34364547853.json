    {
      "id": "69da84833904f34364547853",
      "text": "2026/04/12",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775928452,
      "updated": 1775928452
    },
    {
      "id": "69da84846eb406000000ce46ac",
      "text": "第16週: [[日]]月火水木金土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775928452,
      "updated": 1775928452
    },
    {
      "id": "69da84846eb406000000cce807",
      "text": "2026年 27.95％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775928452,
      "updated": 1775928452
    },
    {
      "id": "69db138c0000000000902109",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775965068,
      "updated": 1775965068
    },
    {
      "id": "69daf40100000000007ed42d",
      "text": "試しに今日の n 年前を消してみる。[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775956993,
      "updated": 1775965068
    },
    {
      "id": "69db138d000000000090210a",
      "text": "\t誰かの pin-diary の中に n 年前のテンプレートが残っており、定期的に復活する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775965070,
      "updated": 1775965111
    },
    {
      "id": "69da84846eb4060000000d0dd2",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775928452,
      "updated": 1775928452
    },
    {
      "id": "69db161c0000000000259ef1",
      "text": "[hr.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775965726,
      "updated": 1775965734
    },
    {
      "id": "69da99750000000000ac7a19",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775933814,
      "updated": 1775933816
    },
    {
      "id": "69da99780000000000ac7a1a",
      "text": " 寝てたけど起きちゃった。たぶんもう1回寝る。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775933817,
      "updated": 1775933842
    },
    {
      "id": "69da99c800000000004897a5",
      "text": " 👀[/crapbox/AIと購買力]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775933897,
      "updated": 1775933911
    },
    {
      "id": "69da99d700000000004897a6",
      "text": "  おもしろい。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775933912,
      "updated": 1775933916
    },
    {
      "id": "69da9e010000000000981608",
      "text": " ✂ to [人間の認識する情報には重複はないとする立場]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775934978,
      "updated": 1775935719
    },
    {
      "id": "69db2b040000000000b895b2",
      "text": " 推し活素材提供ゲームという指摘。なるほどなあ。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775971076,
      "updated": 1775971079
    },
    {
      "id": "69db2b070000000000b895b3",
      "text": " \t[https://note.com/kaburagi_wakana/n/n277a20e7035b 【推し活時代が生んだ虚無ゲー】Pokémon LEGENDS Z-A　感想・レビュー｜鏑木和奏]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775971079,
      "updated": 1775971081
    },
    {
      "id": "69db36bf0000000000263cc8",
      "text": "  \t自分はzaは戦国無双みたいな戦闘を楽しむゲームだと思っていた[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775974079,
      "updated": 1775974143
    },
    {
      "id": "69db37260000000000263cc9",
      "text": "  \t 言われてみるとたしかにzaの2次創作よく見かけるかも",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775974182,
      "updated": 1775974212
    },
    {
      "id": "69db9ac90000000000e6c8a5",
      "text": " 第1話で衝撃展開疲れ: [~ [日本三國], [とんがり帽子のアトリエ], [あかね噺], [スノウボールアース]]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775999690,
      "updated": 1775999826
    },
    {
      "id": "69db9b250000000000e6c8a8",
      "text": " \tイントロ短い言われがちな最近の曲的な。[~ [【推しの子】]]の最初的な。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775999781,
      "updated": 1775999910
    },
    {
      "id": "69db9ad10000000000e6c8a6",
      "text": " \t（原作未読の）[~ [MAO]]はそんな衝撃展開ってわけじゃなかったけど不思議と引き込まれる。さすが大御所。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775999697,
      "updated": 1775999860
    },
    {
      "id": "69da84846eb4060000003c0f95",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775928452,
      "updated": 1775928452
    },
    {
      "id": "69daca940000000000f62f09",
      "text": "[suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775946388,
      "updated": 1775946390
    },
    {
      "id": "69dacaa40000000000f62f0c",
      "text": "　単なる思いつき",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775946404,
      "updated": 1775946417
    },
    {
      "id": "69daca970000000000f62f0a",
      "text": "　　今日のn年前のページ、[04/12]みたいなページを作って、そっちに移したらどうなるだろう？",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775946391,
      "updated": 1775946521
    },
    {
      "id": "69dad0ef0000000000a1b91c",
      "text": "　　ページを2つ更新する必要があるか",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775948015,
      "updated": 1775948072
    },
    {
      "id": "69db768d0000000000b3a1a8",
      "text": "　　2026/04/12 19:40:18 それで、今日のn年前のページはどうすることになったの？",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775990413,
      "updated": 1775990456
    },
    {
      "id": "69db76c30000000000b3a1a9",
      "text": "　infobox日記の方でなにかくだらない企画をやりたい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775990467,
      "updated": 1775990523
    },
    {
      "id": "69db76fb0000000000b3a1aa",
      "text": "　　ネタ募集",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775990524,
      "updated": 1775990534
    },
    {
      "id": "69daca970000000000f62f0b",
      "text": "　#2026-04-12",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775946391,
      "updated": 1776009208
    },
    {
      "id": "69dbbfe800000000005bfd33",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776009193,
      "updated": 1776009193
    },
    {
      "id": "69dad4f10000000000b1168b",
      "text": "[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775949041,
      "updated": 1775949043
    },
    {
      "id": "69dad4f30000000000b1168c",
      "text": " 変な時間に寝たので微妙に徹夜感",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775949043,
      "updated": 1775949080
    },
    {
      "id": "69dad5db0000000000b1168e",
      "text": " [今日のn年前]ってどうすれば面白くなるんだろうなぁ",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775949275,
      "updated": 1775949310
    },
    {
      "id": "69dad67c0000000000024334",
      "text": "  要約して一覧する？",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775949436,
      "updated": 1775949441
    },
    {
      "id": "69dad6600000000000024333",
      "text": "   やはりinfoboxか",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775949408,
      "updated": 1775949445
    },
    {
      "id": "69db654100000000001da2b9",
      "text": " 新スマホセットアップ",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775985986,
      "updated": 1775985992
    },
    {
      "id": "69db66d10000000000bf185b",
      "text": "  [yak shaving]の塊",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775986386,
      "updated": 1775986401
    },
    {
      "id": "69dad4f30000000000b1168d",
      "text": "",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775949043,
      "updated": 1775949043
    },
    {
      "id": "69dae3570000000000fc963b",
      "text": "[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1775952728,
      "updated": 1775952728
    },
    {
      "id": "69dae3580000000000fc963c",
      "text": " 今日のn年前のセクションのせいで日記ページの[2 hop links]が大きくなっている所があると思う",
      "userId": "688c296691686a314f82fb52",
      "created": 1775952729,
      "updated": 1775952829
    },
    {
      "id": "69dae3850000000000fc963d",
      "text": "\t なのでこれは[日記ページが流石に重い]問題の対策の一つになり得る",
      "userId": "688c296691686a314f82fb52",
      "created": 1775952773,
      "updated": 1775952891
    },
    {
      "id": "69dafd7800000000005301a0",
      "text": " \t\t[日記ページが流石に重い]の理由は見当がついていて、テーブルです。[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959416,
      "updated": 1775959417
    },
    {
      "id": "69dafd7800000000005301a1",
      "text": " \t\t\tたしか、その頃に[Summer498.icon]がよくテーブルを載せていました。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959416,
      "updated": 1775959417
    },
    {
      "id": "69dafd7800000000005301a2",
      "text": " \t\t\t日記に限らずですが、テーブルの載ったページを編集する際には異常に重くなります。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959416,
      "updated": 1775959417
    },
    {
      "id": "69dafd8600000000005301a3",
      "text": " \t\tそれ以外の原因は「重い」の原因ではなく、別の不満の原因になっていると思います。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959431,
      "updated": 1775959462
    },
    {
      "id": "69dafda500000000005301a4",
      "text": " \t\t\t「長い」とか、「下のリンクが多すぎる」とか「下のリンクの情報密度が薄い」とか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959462,
      "updated": 1775959516
    },
    {
      "id": "69dafde000000000005301a5",
      "text": " \t\t\t「重い」のはテーブルです（と言い切れるくらいテーブルが重いです）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959520,
      "updated": 1775959568
    },
    {
      "id": "69db44d200000000005daec1",
      "text": " \t\t\tこの話題、[sta.icon]さんが[日記ページが流石に重い#69c709060000000000b31c06]で言及してた[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1775977683,
      "updated": 1775977751
    },
    {
      "id": "69dae4030000000000fc963f",
      "text": "\t [hoagecko.icon]は支持します",
      "userId": "688c296691686a314f82fb52",
      "created": 1775952899,
      "updated": 1775952908
    },
    {
      "id": "69dae40f0000000000fc9640",
      "text": "\t \t本格的に導入すれば一時的に井戸端の新着記事がこれ系のページで埋まることになる",
      "userId": "688c296691686a314f82fb52",
      "created": 1775952911,
      "updated": 1775953134
    },
    {
      "id": "69dae43d0000000000fc9641",
      "text": "\t \t\tが、そこはしょうがない",
      "userId": "688c296691686a314f82fb52",
      "created": 1775952958,
      "updated": 1775952960
    },
    {
      "id": "69daf7ff00000000000baf44",
      "text": "\t \t\tこれ系のページで埋まるのをしょうがないにする派[hoagecko.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958016,
      "updated": 1775958067
    },
    {
      "id": "69daf83500000000000baf45",
      "text": "\t \t\tこれ系のページで埋まるのはイヤ派[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958069,
      "updated": 1775958082
    },
    {
      "id": "69db2dc20000000000392cae",
      "text": "\t \t\t毎日1枚ずつ作るスタイルにすればそのようなことにならなそう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775971779,
      "updated": 1775971810
    },
    {
      "id": "69db833700000000005edf08",
      "text": "\t \t\t古い生成日時のJSONを作ってインポートすれば新着は埋まらずに新規ページ追加ができます[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775993656,
      "updated": 1775993693
    },
    {
      "id": "69db8f400000000000cc803a",
      "text": "\t \t\t [知見.icon][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775996736,
      "updated": 1775996745
    },
    {
      "id": "69dba1af0000000000183c86",
      "text": "\t \t\t 前に既存のタイトルと同じページをインポートして、前に書いてたこと丸っと無くなっちゃって焦った操作[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1776001455,
      "updated": 1776001484
    },
    {
      "id": "69dc207f000000000026d0b6",
      "text": "\t \t\t 補足情報： owner/admin しかできません。[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776033919,
      "updated": 1776034017
    },
    {
      "id": "69dc20ec000000000026d0b8",
      "text": " \t \t\t [JSON import でページを sage る技]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776034028,
      "updated": 1776034034
    },
    {
      "id": "69daf86c00000000000baf46",
      "text": "\t そもそも[- 隣接する日付のリンク]n年前も昨日も明日も廃止しても良いと思ってる[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958124,
      "updated": 1775959139
    },
    {
      "id": "69dafbd20000000000530197",
      "text": "\t \t\t伝わらない言い回しになってる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958994,
      "updated": 1775959005
    },
    {
      "id": "69dafbdf0000000000530198",
      "text": "\t \t\t\t隣接する日付が「今日の n 年前」と「昨日」「明日」の全てを表すとは見えない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959007,
      "updated": 1775959057
    },
    {
      "id": "69daf89c00000000000baf47",
      "text": "\t \t面白いんだけど量が量なだけに",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958172,
      "updated": 1775958183
    },
    {
      "id": "69dae3560000000000fc963a",
      "text": "\t\t\t自分は個人プロジェクトで長年きのうあしたリンクつけていたが昨年から消した[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775952727,
      "updated": 1775958236
    },
    {
      "id": "69daf8ce0000000000f5a3bc",
      "text": "\t\t\t\t理由を覚えていない",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958223,
      "updated": 1775958227
    },
    {
      "id": "69daf9780000000000f5a3c4",
      "text": "\t\t\t\t\t毎日手動で書いてたからか？",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958393,
      "updated": 1775958410
    },
    {
      "id": "69daf8aa0000000000f5a3ba",
      "text": "\t\t\t\t消して何か（悪い）変化はあった？[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958187,
      "updated": 1775958243
    },
    {
      "id": "69daf8aa0000000000f5a3bb",
      "text": " \t\t\tじぶんは井戸端のきのうあしたリンクもわりによく使うし不便にはなった…やりかたを変えるのを面倒がっている[はるひ.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958187,
      "updated": 1775970912
    },
    {
      "id": "69daf9160000000000f5a3be",
      "text": " \t\t\t\tユースケース",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958295,
      "updated": 1775958347
    },
    {
      "id": "69daf9210000000000f5a3bf",
      "text": " \t\t\t\t\t週の振り返り",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958306,
      "updated": 1775958333
    },
    {
      "id": "69daf93f0000000000f5a3c0",
      "text": " \t\t\t\t\tきのうの話を思い出す時",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958336,
      "updated": 1775958356
    },
    {
      "id": "69daf8dd0000000000f5a3bd",
      "text": "\t\t\t\t\tここに需要あったか[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958238,
      "updated": 1775958290
    },
    {
      "id": "69daf92300000000003c04c4",
      "text": "\t\t\t\t\t[caki.icon]もわりとつかってる[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775958307,
      "updated": 1775958318
    },
    {
      "id": "69daf95d0000000000f5a3c3",
      "text": "\t\t\t\tどうだろう。ないならないでリンク飛べばいいし[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958366,
      "updated": 1775958426
    },
    {
      "id": "69daf98f0000000000f5a3c5",
      "text": "\t\t\t\t\t一発で隣接する日付のページに飛べるとノートをめくる感覚になるのがよい",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958415,
      "updated": 1775958475
    },
    {
      "id": "69daf9ca0000000000f5a3c6",
      "text": " \t\t\t\t\tScrapboxのページをこのように(場所っぽく？)移動したいということを思っている",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775958475,
      "updated": 1775958518
    },
    {
      "id": "69daf90600000000000baf48",
      "text": "\t\t\t\t流石に昨日明日を消すのはやりすぎたか。数日後にやっぱ欲しいとなったら復活させてみる。[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958278,
      "updated": 1775958380
    },
    {
      "id": "69daf98c00000000000baf4a",
      "text": "\t\t\t\t\tいや、即座に解決できる方法があるからやってみよう。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958412,
      "updated": 1775958424
    },
    {
      "id": "69dafb5b0000000000530195",
      "text": "\t\t\t\t\tアイコンリンクなら直接遷移できるし下にリンクが生成されない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958876,
      "updated": 1775958910
    },
    {
      "id": "69daffc100000000003c04c5",
      "text": "\t\t\t\t\t 良い！[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775960002,
      "updated": 1775960215
    },
    {
      "id": "69dafce60000000000530199",
      "text": " [核爆発]",
      "userId": "688c296691686a314f82fb52",
      "created": 1775959271,
      "updated": 1775994574
    },
    {
      "id": "69db86cf0000000000227e66",
      "text": " \t確か[手塚治虫]の漫画(1950年代作)で「人為的な[核爆発]が確認できた」から今このタイミングで宇宙人が襲来したという説明があって感嘆した記憶がある",
      "userId": "688c296691686a314f82fb52",
      "created": 1775994576,
      "updated": 1775994698
    },
    {
      "id": "69db86c80000000000227e65",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1775994569,
      "updated": 1775994569
    },
    {
      "id": "69daedc5000000000035c040",
      "text": "[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955397,
      "updated": 1775955399
    },
    {
      "id": "69daedc6000000000035c042",
      "text": "　今まで[洋楽]にほぼ全く興味がなかったが、今朝たまたま流れてきた[Swell Maps]の[Real Shocks]を聴いて、めっちゃかっこいいやんけとなっている",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955399,
      "updated": 1775955444
    },
    {
      "id": "69daedf7000000000035c043",
      "text": "　打ち上げで作った料理を写真に収めようと思うが、いつも忘れてしまう",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955448,
      "updated": 1775955461
    },
    {
      "id": "69daee4c000000000035c044",
      "text": "　一昨日は刺繍とか衣類プリントの工場を見学したのですが、機械を見るのがあまりにも楽しくてもう少しで「俺はものづくりが大好きだ〜！」と叫びだすところだった",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955532,
      "updated": 1775955570
    },
    {
      "id": "69daee71000000000035c045",
      "text": "　子どもの頃、というか高校生くらいまでは、図工や美術の成績が悪かったし、本当に全く苦手だったので、俺はものづくりができないんだなと思っていたが、コンピュータを手にしてから自分で作ることの楽しさがわかってきたような気がする",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955570,
      "updated": 1775955686
    },
    {
      "id": "69daeee6000000000035c046",
      "text": "　\t上手さと楽しさは必ずしも相関があるわけではないと思うが、こうして眺めてみてみると、やはり下手だから楽しくないという気持ちがあったんだろうな",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955686,
      "updated": 1775955722
    },
    {
      "id": "69daef0a000000000035c047",
      "text": "　\tものづくりが好きな気持は当時もあったと思うけど、それよりも周りと比較して落ち込むことの方が多かったというか",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955722,
      "updated": 1775955741
    },
    {
      "id": "69daef4c000000000035c048",
      "text": "　昨日はお酒を飲んで体がだるいが、朝のルーティンから始めることで少しずつ体を戻していくか（10:03）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955788,
      "updated": 1775955816
    },
    {
      "id": "69daef67000000000035c049",
      "text": "　朝に散歩をしたいが、何か目的がほしいよな",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955816,
      "updated": 1775958594
    },
    {
      "id": "69dafa41000000000035c04a",
      "text": "　\tコンビニに行ってコーヒーを買うなどが考えられるが、毎日コンビニでコーヒーを買うのは経済的ではないので、何か別のものを考えている",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775958594,
      "updated": 1775958624
    },
    {
      "id": "69dafe3c00000000005301a6",
      "text": "　\t酒を飲んで体がだるい中でカフェインを飲むとは[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959612,
      "updated": 1775959625
    },
    {
      "id": "69dafe4b00000000005301a7",
      "text": "　\t\t利尿作用で余計しんどそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959628,
      "updated": 1775959636
    },
    {
      "id": "69dafed4000000000035c04d",
      "text": "　\t\tこれは今日ではなく、普段のルーティンをどうしようかなというやつですね[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775959765,
      "updated": 1775959777
    },
    {
      "id": "69daff8300000000005301a9",
      "text": "　\t\t家の前の道の石を拾って一箇所に集める[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775959940,
      "updated": 1775960040
    },
    {
      "id": "69daffe900000000005301aa",
      "text": "　\t\t\tルーチンにすると謎のオブジェが増えて怪しい人になってしまうが、そういうのを気にしない土地柄ならアリかも",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775960042,
      "updated": 1775960128
    },
    {
      "id": "69db004400000000005301ab",
      "text": "　\t\t\t石積みの人として認知されそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775960133,
      "updated": 1775960146
    },
    {
      "id": "69db00700000000000697df6",
      "text": "\t\t安い自販機見つけてそこで買う案[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775960177,
      "updated": 1775960245
    },
    {
      "id": "69dafa60000000000035c04b",
      "text": "　まだだるい、水を多めに飲むか（11:04）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775958624,
      "updated": 1775959502
    },
    {
      "id": "69dafe5a00000000005301a8",
      "text": "　\t[二日酔い]にはスポーツドリンク[Summer498.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775959643,
      "updated": 1776016552
    },
    {
      "id": "69dafee3000000000035c04e",
      "text": "　\t飲まないと[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775959780,
      "updated": 1775959784
    },
    {
      "id": "69dafdca000000000035c04c",
      "text": "　作業タイムに入ったので、[コンテンポラリーな生活]を聴こうかな",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775959502,
      "updated": 1775976037
    },
    {
      "id": "69db3e650000000000816bfd",
      "text": "　[ショップカード]を本のしおりにすると良いのか、なるほどな",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1775976037,
      "updated": 1775981044
    },
    {
      "id": "69db53230000000000816bfe",
      "text": "　何もしていないのに1日が終わりそう",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775981347,
      "updated": 1775981352
    },
    {
      "id": "69db53270000000000816bff",
      "text": "　\tまあ図書館に行って本借りてきたし……",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775981352,
      "updated": 1775981364
    },
    {
      "id": "69db538f0000000000816c00",
      "text": "　[KODAK PIXPRO C1]かわいい",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775981456,
      "updated": 1775981461
    },
    {
      "id": "69db539b0000000000816c01",
      "text": "　\t背面はあんまりかわいくないかもしれない",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775981467,
      "updated": 1775981473
    },
    {
      "id": "69db66bc0000000000816c02",
      "text": "　Twitterのホーム画面が自動更新されるようになっている気がする",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775986365,
      "updated": 1775986382
    },
    {
      "id": "69db66cd0000000000816c03",
      "text": "　\t以前はクリックしないと新着ツイートを読み込まなかったはず",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775986382,
      "updated": 1775986393
    },
    {
      "id": "69db66d60000000000816c04",
      "text": "　\tしかし何かしらのChrome拡張でこうなった可能性も？",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775986393,
      "updated": 1775986404
    },
    {
      "id": "69db66de0000000000816c05",
      "text": "　\tまあいずれにせよ便利だからいいか",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775986404,
      "updated": 1775986404
    },
    {
      "id": "69db66e40000000000816c06",
      "text": "　[サーマルプリンター]欲しくなってきた",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775986404,
      "updated": 1775990494
    },
    {
      "id": "69db67600000000000816c07",
      "text": "　\tまあとりあえず買ってみるかくらいの価格のやつが多い気がする",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775986528,
      "updated": 1775986547
    },
    {
      "id": "69db68000000000000816c08",
      "text": "　\tこの記事かなり良かったんだよな",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775986688,
      "updated": 1775986693
    },
    {
      "id": "69db68040000000000816c09",
      "text": "　\t\t[サーマルプリンタを子育てに活用してみた - m1104m Blog https://m1104m.hatenablog.com/entry/2025/12/15/132956]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775986693,
      "updated": 1775990489
    },
    {
      "id": "69db68080000000000816c0a",
      "text": "　4ポモドーロ分作業したのでえらい",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775986696,
      "updated": 1775989951
    },
    {
      "id": "69db764d0000000000b3a1a7",
      "text": "　　[[えらい！.icon]][suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775990349,
      "updated": 1775990378
    },
    {
      "id": "69db75380000000000816c0b",
      "text": "　打ち上げ用に大量に料理を作る時に服が汚れるのが嫌だなと思っていたけど、そうかエプロンを使えば良いのか",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775990073,
      "updated": 1775990093
    },
    {
      "id": "69db8e970000000000816c0c",
      "text": "　雨が降っていると運動に対するやる気が如実に減少するということがわかった",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775996568,
      "updated": 1775996588
    },
    {
      "id": "69db8eac0000000000816c0d",
      "text": "　\t今日は3kmくらい走ったので、これで許しといてやらあ",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775996588,
      "updated": 1775996598
    },
    {
      "id": "69db930400000000000e22e0",
      "text": "　iOSで物理キーボードを触ることの何がつらいのかを思い出すために、つないでみた",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997701,
      "updated": 1775997745
    },
    {
      "id": "69db933000000000000e22e1",
      "text": "　\tIMEの変換候補の出し方がきにくわない",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997745,
      "updated": 1775997815
    },
    {
      "id": "69db937800000000000e22e2",
      "text": "　\tタイピング速度が上がると、入力がたまに反応しないことがあるな",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997816,
      "updated": 1775997839
    },
    {
      "id": "69db938f00000000000e22e3",
      "text": "　\tしかしこれは、井戸端に書き込んでいるからという可能性もある",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997839,
      "updated": 1775997868
    },
    {
      "id": "69db93bf00000000000e22e4",
      "text": "　\t試しにTwitterに書いてみたら、めっちゃ快適に打ち込めた、うける",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997888,
      "updated": 1775997903
    },
    {
      "id": "69db93cf0000000000816c0f",
      "text": "　\t他のCosenseプロジェクトでも使ってみたけど、あんまり反応が良くないな",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997903,
      "updated": 1775997973
    },
    {
      "id": "69db94150000000000816c10",
      "text": "　\tChrome上で何か文字を書くのを諦めた方が良いかもしれない",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997973,
      "updated": 1775997986
    },
    {
      "id": "69db94210000000000816c11",
      "text": "　\t他のところでも書いてみたが、やっぱりChrome上で書くのが良くない",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775997986,
      "updated": 1775998072
    },
    {
      "id": "69db94780000000000816c12",
      "text": "　\tSafariは……？",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998072,
      "updated": 1775998076
    },
    {
      "id": "69db94b30000000000816c13",
      "text": "　\t\tダメっぽい",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998131,
      "updated": 1775998134
    },
    {
      "id": "69db96260000000000816c14",
      "text": "　\t今の作業スタイルを考えると、スマホから井戸端に書き込めないのであれば、物理キーボードを使う意味があんまり無い気がする",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998503,
      "updated": 1775998524
    },
    {
      "id": "69db963c0000000000816c15",
      "text": "　\tiPad miniと一緒に使うのは良い感じなんだけどなあ",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998524,
      "updated": 1775998537
    },
    {
      "id": "69db96480000000000816c16",
      "text": "　\t\tまあ、iPad miniとキーボードをセットで持ち歩くという選択肢もある",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998537,
      "updated": 1775998554
    },
    {
      "id": "69db96590000000000816c17",
      "text": "　\tというわけで、iPad miniから書き込んでみる",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998553,
      "updated": 1775998823
    },
    {
      "id": "69db976700000000008c2158",
      "text": "　\t\tめっちゃ重い",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998824,
      "updated": 1775998833
    },
    {
      "id": "69db977100000000008c2159",
      "text": "　\t\tあきらめた",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998833,
      "updated": 1775998837
    },
    {
      "id": "69db977500000000008c215a",
      "text": "　\t\tしかし、ネイティブアプリに入力する場合は、iOS端末に比べてかなりマシなような気がする",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998837,
      "updated": 1775998861
    },
    {
      "id": "69db97e60000000000816c18",
      "text": "　\t\t当たり前だが、Chromeからnoteに何か書こうとするのもかなりつらい",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998951,
      "updated": 1775998966
    },
    {
      "id": "69db97f60000000000816c1a",
      "text": "　\tそもそも、テキスト入力する作業はだいたいブラウザ上でなるべく完結させたいので、ここの体験が最悪なのでは、やはり外で物理キーボードを使う気になれなさそう",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775998966,
      "updated": 1775999284
    },
    {
      "id": "69db992900000000009d03b2",
      "text": "　\tというわけで、久しぶりにCHUWI MiniBook X を引っ張り出して使ってみているけど、慣れていないとミスタッチが連発する",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775999284,
      "updated": 1775999347
    },
    {
      "id": "69db996900000000009d03b3",
      "text": "　\t\tしかし、3分くらい入力していると慣れてくるかも",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775999348,
      "updated": 1775999362
    },
    {
      "id": "69db997f00000000009d03b4",
      "text": "　\t本当に外出先でテキスト入力作業をしたいならMac持っていくでしょうという話なのですが、何か思いついた時にがっと書き込めるような態勢にしておきたいという願望があるんだよなあ",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775999370,
      "updated": 1775999429
    },
    {
      "id": "69db99c800000000009d03b5",
      "text": "　\tテキスト入力をする頻度は高くないにしても、書く時は思考を漏らさないように高速に書きたい、という",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775999443,
      "updated": 1775999481
    },
    {
      "id": "69db99ee00000000009d03b6",
      "text": "　\t読書メモとかの用途がそれ",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775999481,
      "updated": 1775999485
    },
    {
      "id": "69dbe5130000000000316803",
      "text": "　\tiOS端末と物理キーボードをセットするのとMacを開くのとではむしろ後者のほうが楽なように思える[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1776018708,
      "updated": 1776018752
    },
    {
      "id": "69dc2b8900000000005b7706",
      "text": "　\t\t本当にそうなんですよ。ただ、小さい方が良い場面もあるので、Appleが小さめのMacを出してくれれば……[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1776036746,
      "updated": 1776036769
    },
    {
      "id": "69dc5d0b00000000001616ee",
      "text": "\t\tiOS端末と物理キーボードの相性は、実際に試してみないと分からないかもしれない[koyoshi.icon]",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1776049419,
      "updated": 1776049512
    },
    {
      "id": "69dc5d2c00000000001616ef",
      "text": " \t\t人によって許容できる部分と許容できない部分が違う",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1776049452,
      "updated": 1776049502
    },
    {
      "id": "69db99f400000000009d03b7",
      "text": "　8インチクラスの[UMPC]なども検討したい",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775999487,
      "updated": 1776016582
    },
    {
      "id": "69db9a1600000000009d03b8",
      "text": "　\tそれで高速にタイピングができるのかは謎",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775999520,
      "updated": 1775999533
    },
    {
      "id": "69db9a2300000000009d03b9",
      "text": "　\t",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775999534,
      "updated": 1775999534
    },
    {
      "id": "69daedc5000000000035c041",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1775955397,
      "updated": 1775955397
    },
    {
      "id": "69daf2f20000000000a382d7",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775956724,
      "updated": 1775956726
    },
    {
      "id": "69daf2f50000000000a382d9",
      "text": " 結局近所で遊ぶ日",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775956726,
      "updated": 1775956739
    },
    {
      "id": "69daff2100000000008f1bfa",
      "text": " 新学期の備品のデコ材料を買う日",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775959842,
      "updated": 1775959857
    },
    {
      "id": "69db1a4400000000001f41a3",
      "text": " 今年、夫婦ともに花粉症の症状が出ない",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775966790,
      "updated": 1775966802
    },
    {
      "id": "69db1a5200000000001f41a4",
      "text": "  妻は薬を飲んでるので効いてるのかも",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775966803,
      "updated": 1775966812
    },
    {
      "id": "69db1a5c00000000001f41a5",
      "text": "  自分はたまに目薬をさす程度",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775966813,
      "updated": 1775966822
    },
    {
      "id": "69db59200000000000b489c5",
      "text": " [/fab-wiki/20260405週fabnews]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775982880,
      "updated": 1775982881
    },
    {
      "id": "69db59220000000000b489c6",
      "text": " \t先週のモノづくり系気になったニュースまとめました",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775982883,
      "updated": 1775982942
    },
    {
      "id": "69db592a0000000000b489c7",
      "text": " \t記事の追加・感想、大歓迎です",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775982890,
      "updated": 1775982896
    },
    {
      "id": "69db7be300000000004741a8",
      "text": " [ダイソー]で[ひらがな・カタカナドリル]を買ったら5歳の娘が超集中してやってる",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775991780,
      "updated": 1776016600
    },
    {
      "id": "69db7c0200000000004741a9",
      "text": "  もう勉強しすぎ！！という謎の怒られが発生",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775991812,
      "updated": 1775991832
    },
    {
      "id": "69db7c1800000000004741aa",
      "text": "  この調子で勉強してくれる、、わけはないだろうなぁ、この時期固有のやつだと思う",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775991833,
      "updated": 1775991862
    },
    {
      "id": "69db09620000000000ceebdd",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1775962466,
      "updated": 1775962473
    },
    {
      "id": "69db141500000000008f1b38",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775965205,
      "updated": 1775965207
    },
    {
      "id": "69db141600000000008f1b39",
      "text": "\t2-hop リンクってなんであんな仕様なんだろう。同じ単語にリンクされた用例をパッと見でわかるようにするためだろうか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775965207,
      "updated": 1775965304
    },
    {
      "id": "69db2ac20000000000470e60",
      "text": "\tn年前が復活する原因、まだ私かもしれない（）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775971010,
      "updated": 1775971036
    },
    {
      "id": "69db3040000000000051e752",
      "text": "\t冷戦やろっと。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775972416,
      "updated": 1775972421
    },
    {
      "id": "69db542d000000000051e7b4",
      "text": "\t\t参戦国多すぎ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981614,
      "updated": 1775981619
    },
    {
      "id": "69dba5e3000000000051ea70",
      "text": "\tある程度日記の内容が増えてから下のリンクを見ると結構内容に即した感じになっている。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776002532,
      "updated": 1776002586
    },
    {
      "id": "69da84846eb4060000008ee754",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775928452,
      "updated": 1775957343
    },
    {
      "id": "69db177100000000004f28b5",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1775966067,
      "updated": 1775966068
    },
    {
      "id": "69db177300000000004f28b6",
      "text": "\t天気は良いが花粉のせいで眼と鼻の蛇口が解放され辛い",
      "userId": "65e1289acd012200235729c0",
      "created": 1775966068,
      "updated": 1775966101
    },
    {
      "id": "69db17a200000000004f28b7",
      "text": "\t\t部屋にしばらくいると治まるので、外に漂う何かであることには間違いない",
      "userId": "65e1289acd012200235729c0",
      "created": 1775966116,
      "updated": 1775966142
    },
    {
      "id": "69db17fc00000000004f28b8",
      "text": "\t\t花粉ではなく、黄砂かもしれないが、どっちにしろ粉塵に変わりない",
      "userId": "65e1289acd012200235729c0",
      "created": 1775966205,
      "updated": 1775966222
    },
    {
      "id": "69db673300000000006f4cb1",
      "text": "\t季節の変わり目だからか、猫様の毛繕いするとバチクッッソ大量に抜けて巨大毛玉が発生する",
      "userId": "65e1289acd012200235729c0",
      "created": 1775986484,
      "updated": 1775986517
    },
    {
      "id": "69db31720000000000fc1625",
      "text": "",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1775972723,
      "updated": 1775972723
    },
    {
      "id": "69db31730000000000fc1627",
      "text": "[kumoridai.icon]",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1775972724,
      "updated": 1775972725
    },
    {
      "id": "69db31750000000000fc1628",
      "text": " [ゆる言語学ラジオ - 離席したら悪口を言われるのか、検証しました。 https://www.youtube.com/watch?v=0J3SC17Dau8&t=9028s]",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1775972726,
      "updated": 1775972962
    },
    {
      "id": "69db317e0000000000fc1629",
      "text": "  優しさと表現できる要素には「親切」と「寛容」の相反する2要素がある、という論がかなり良かった",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1775972735,
      "updated": 1775972835
    },
    {
      "id": "69db59a400000000009c7528",
      "text": "  　大波[ぷの字.icon]",
      "userId": "69b01b4ce87c5b863b9cfc92",
      "created": 1775983013,
      "updated": 1775983028
    },
    {
      "id": "69db162f0000000000259ef2",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775965746,
      "updated": 1775965746
    },
    {
      "id": "69db32de0000000000392caf",
      "text": "[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775973086,
      "updated": 1775973088
    },
    {
      "id": "69db32e00000000000392cb0",
      "text": " 同人誌を引き続きやる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775973088,
      "updated": 1775973097
    },
    {
      "id": "69db32e90000000000392cb1",
      "text": "  登場人物の幸せがぶち壊しになるシーンを描いていて辛い",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775973097,
      "updated": 1775973119
    },
    {
      "id": "69db37650000000000263cca",
      "text": " ぽこポケ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775974246,
      "updated": 1775974251
    },
    {
      "id": "69db376b0000000000263ccb",
      "text": "  まっさら島のでっかい建築キットを建てる場所がない",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775974251,
      "updated": 1775974272
    },
    {
      "id": "69db378a0000000000263ccc",
      "text": "  ああいう神殿みたいなのは居住エリアからのアクセスが悪い土地に作りたいが、そういう場所を整地するのが面倒",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775974283,
      "updated": 1775974350
    },
    {
      "id": "69db83a000000000005edf09",
      "text": "  　わかる、砂浜を整地した[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775993761,
      "updated": 1775993778
    },
    {
      "id": "69db924c0000000000cc803b",
      "text": "  　氷室のために台地を整地したけど面倒だったのでピラミッドみたいなのは砂浜につくろう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775997516,
      "updated": 1775997568
    },
    {
      "id": "69db965e0000000000cc803c",
      "text": " [たらみのみかんゼリー]超好きなんだけど、今日間違って濃いほう買ったらゼリーの固さが普通の方よりも固くてこれじゃない！てなった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775998558,
      "updated": 1776016684
    },
    {
      "id": "69db37cf0000000000263ccd",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775974351,
      "updated": 1775974360
    },
    {
      "id": "69db3bf40000000000b8c263",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775975413,
      "updated": 1775975414
    },
    {
      "id": "69db3bf40000000000b8c264",
      "text": "\tpin-diary自体を廃止してみてもいいと思う",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775975414,
      "updated": 1775975422
    },
    {
      "id": "69db3bfc0000000000b8c265",
      "text": "\t\t日付ページをプレーンにしたらどうなるか",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775975422,
      "updated": 1775975432
    },
    {
      "id": "69db3c090000000000b8c266",
      "text": "\t\tただ、このためには「今pin-diaryを入れてる人全員」が外す必要がある",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775975434,
      "updated": 1775975449
    },
    {
      "id": "69db3c180000000000b8c267",
      "text": "\t\t\tひとりでもやってくれない人がいると成立しない",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775975449,
      "updated": 1775975454
    },
    {
      "id": "69db53e4000000000051e7b3",
      "text": "\t\t上にある情報と下にある画像は欲しい[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981540,
      "updated": 1775981551
    },
    {
      "id": "69db3bf30000000000b8c262",
      "text": "\t[ビューが一つしかない問題]難しいよね",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775975412,
      "updated": 1775975490
    },
    {
      "id": "69db3c770000000000b8c26c",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775975545,
      "updated": 1775975545
    },
    {
      "id": "69db52470000000000c551e5",
      "text": "[hoshihara.icon]",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1775981127,
      "updated": 1775981128
    },
    {
      "id": "69db52480000000000c551e7",
      "text": "\t平たいものをストックしておいてしおりとしてつかうための引き出しがある",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1775981128,
      "updated": 1775981202
    },
    {
      "id": "69db52790000000000c551e8",
      "text": "\t\tほとんどが紙片だがコンビニでもらえるアイスクリームのスプーンも入っている",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1775981178,
      "updated": 1775981215
    },
    {
      "id": "69db52c20000000000c551e9",
      "text": "\t\t今見たら台紙付きのフレークシール、うどん屋の割引券などもあった",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1775981251,
      "updated": 1775981273
    },
    {
      "id": "69db52470000000000c551e6",
      "text": "",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1775981127,
      "updated": 1775981127
    },
    {
      "id": "69db552400000000002d9dae",
      "text": "[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1775981851,
      "updated": 1775981853
    },
    {
      "id": "69db552500000000002d9db0",
      "text": "\t[Microsoft Lens]が使えなくなったので、音がならない自作スキャナアプリをつくった",
      "userId": "649a24da357c4d001c518c25",
      "created": 1775981853,
      "updated": 1775982097
    },
    {
      "id": "69db55b200000000002d9db1",
      "text": "\t Gyazoにそのままアップロードできるようになったので満足",
      "userId": "649a24da357c4d001c518c25",
      "created": 1775981993,
      "updated": 1775982091
    },
    {
      "id": "69db6cd5000000000011b696",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775987927,
      "updated": 1775987927
    },
    {
      "id": "69db6cd6000000000011b697",
      "text": "[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775987927,
      "updated": 1775987927
    },
    {
      "id": "69db6cd6000000000011b698",
      "text": "\t[infobox頭悪すぎる]！どーしよ！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775987927,
      "updated": 1776016701
    },
    {
      "id": "69db6cfa000000000011b69b",
      "text": "\t",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775987963,
      "updated": 1775987963
    },
    {
      "id": "69db552400000000002d9daf",
      "text": "",
      "userId": "649a24da357c4d001c518c25",
      "created": 1775981851,
      "updated": 1775981851
    },
    {
      "id": "69db970d0000000000b551d9",
      "text": "[imo.icon]",
      "userId": "5ad57975d54cd50014068484",
      "created": 1775998735,
      "updated": 1775998735
    },
    {
      "id": "69db970e0000000000b551da",
      "text": "\t今日のクロッキー",
      "userId": "5ad57975d54cd50014068484",
      "created": 1775998736,
      "updated": 1775998740
    },
    {
      "id": "69db97130000000000b551db",
      "text": "\t[https://gyazo.com/38487ced44764a5aef1ba93555b2c303]",
      "userId": "5ad57975d54cd50014068484",
      "created": 1775998740,
      "updated": 1775998749
    },
    {
      "id": "69db971c0000000000b551dd",
      "text": "",
      "userId": "5ad57975d54cd50014068484",
      "created": 1775998749,
      "updated": 1775998749
    },
    {
      "id": "69db97130000000000b551dc",
      "text": "",
      "userId": "5ad57975d54cd50014068484",
      "created": 1775998740,
      "updated": 1775998740
    },
    {
      "id": "69db162f0000000000259ef3",
      "text": "[hr.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775965746,
      "updated": 1775965753
    },
    {
      "id": "69daf562000000000035b803",
      "text": "試しに昨日明日のリンクを消してみる[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775957346,
      "updated": 1775957361
    },
    {
      "id": "69daf71b0000000000f5a3b8",
      "text": "[/ugo/Cosenseのデイリーページから前日と翌日にリンクするUserScript]代わりにこれをつけられるだろうか[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775957787,
      "updated": 1775957872
    },
    {
      "id": "69daf7660000000000f5a3b9",
      "text": "\t余計重くなるか",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775957863,
      "updated": 1775957867
    },
    {
      "id": "69dafb340000000000530194",
      "text": "細かいことは抜きにしてダイレクトにアイコンとして設置してみる[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958837,
      "updated": 1775958856
    },
    {
      "id": "69daf644ed60e6000000341558",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775957572,
      "updated": 1775957572
    },
    {
      "id": "69daf7860000000000d764c7",
      "text": "全くどうでもいい話ですが下のカレンダーの画像をクリックすると、[井戸端カレンダー]のページ（[2026/04]）へ移動します[suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775957895,
      "updated": 1775959319
    },
    {
      "id": "69dafaf2ed60e600000011d414",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775958770,
      "updated": 1775958770
    },
    {
      "id": "69dafadd0000000000b12851",
      "text": "[2026/04/11.icon] ← 2026/04/12 → [2026/04/13.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
