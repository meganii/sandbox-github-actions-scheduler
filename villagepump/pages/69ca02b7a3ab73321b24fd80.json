  "updated": 1774868989,
  "lines": [
    {
      "id": "69ca02b7a3ab73321b24fd80",
      "text": "2026/03/30 cak",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774846653,
      "updated": 1774846668
    },
    {
      "id": "69ca0f490000000000a23fc1",
      "text": "#2026-03-30",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774849866,
      "updated": 1774849866
    },
    {
      "id": "69ca02ba0000000000cff3f1",
      "text": " 昨日日光を浴びすぎて脳みそふわふわ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774846653,
      "updated": 1774846683
    },
    {
      "id": "69ca02bc0000000000cff3f3",
      "text": "  日光と相性悪い",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774846653,
      "updated": 1774846682
    },
    {
      "id": "69ca02bc0000000000cff3f5",
      "text": "  適度なお付き合いをしたい",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774846653,
      "updated": 1774846680
    },
    {
      "id": "69ca04070000000000cff3f6",
      "text": "  ふわふわの脳みそにはほかの人の日記の負荷が高すぎて書きにこれないので独立した",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774846983,
      "updated": 1774847025
    },
    {
      "id": "69ca04380000000000cff3f8",
      "text": "   ややさみしさがある",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774847033,
      "updated": 1774847040
    },
    {
      "id": "69ca04460000000000cff3f9",
      "text": " カフェに行って作業も何もせずコーヒー飲んでぼーっとして帰って来たいという憧れ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774847046,
      "updated": 1774847086
    },
    {
      "id": "69ca04720000000000cff3fa",
      "text": "  やろうと思えばできるはずだが効率厨すぎてできない",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774847090,
      "updated": 1774847122
    },
    {
      "id": "69ca59e1000000000059d786",
      "text": "   わかる。「旅行でゆっくりする」も同様にできない[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1774868962,
      "updated": 1774868989
    },
    {
      "id": "69ca0c3a0000000000672fff",
      "text": "  見通しのいい広いカフェに来た",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774849082,
      "updated": 1774849110
    },
    {
      "id": "69ca0c560000000000673000",
      "text": "   向こう側の席の人を観察している",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774849110,
      "updated": 1774849111
    },
    {
      "id": "69ca0f8f0000000000673001",
      "text": "   旅行中らしき人々がいる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774849936,
      "updated": 1774849942
    },
    {
      "id": "69ca0f9d0000000000673002",
      "text": "    服装などをみると日本の人のように思える",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774849949,
      "updated": 1774849995
    },
    {
      "id": "69ca0fcb0000000000673003",
      "text": "    もしかして春休みかも",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774849995,
      "updated": 1774849995
    },
    {
      "id": "69ca040b0000000000cff3f7",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1774846988,
      "updated": 1774846988
    }
  ]
}