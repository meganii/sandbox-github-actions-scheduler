    {
      "id": "6a22aab400000000003b1266",
      "text": "[ActivityPub]対応の[リンクアグリゲータ]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1780656821,
      "updated": 1780656994
    },
    {
      "id": "6a22ab6400000000003b1268",
      "text": " 要するに分散型[Reddit]と捉えている[zatsma.icon]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1780656997,
      "updated": 1780657024
