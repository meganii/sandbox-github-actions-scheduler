    },
    {
      "id": "693c40261280f0000000321ae1",
      "text": "第50週: 日月火水木金[[土]]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1765556262,
      "updated": 1765556262
    },
    {
      "id": "693c40261280f0000000f97a30",
      "text": "2025年 95.07％経過",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1765556262,
      "updated": 1765556262
    },
    {
      "id": "693c40261280f0000000f0dd94",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1765556262,
      "updated": 1765556262
    },
    {
      "id": "693c40261280f00000000a14a3",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1765556262,
      "updated": 1765556262
    },
    {
      "id": "693c982a00000000004987aa",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1765578796,
      "updated": 1765578796
    },
    {
      "id": "693e7bba000000000017f618",
      "text": " [いつかやるをCosenseでやる]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1765702585,
      "updated": 1765702594
    },
    {
      "id": "693cb9a70000000000bc3d81",
      "text": "\t散髪、どうしようか迷う",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1765587368,
      "updated": 1765591778
    },
    {
      "id": "693ccb0f0000000000e07aca",
      "text": "\t\t7日ごとにバリカンするタスクを入れているが、もう3回はスキップしてしまってる",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1765591824,
      "updated": 1765591841
    },
    {
      "id": "693ccae10000000000e07ac8",
      "text": "\t\t坊主マンだが今日から一段と寒くなったので迷ってる",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1765591778,
      "updated": 1765591847
    },
    {
      "id": "693ccaf30000000000e07ac9",
      "text": "\t\t\t温度変化鈍いマンなのでこの違いで体調崩すことがある",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1765591796,
      "updated": 1765591848
    },
    {
      "id": "693d05fc000000000058734a",
      "text": "\t\t冬は髪伸ばしたら？[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765606908,
      "updated": 1765606937
    },
    {
      "id": "693d0619000000000058734b",
      "text": "\t\t\t坊主からほったらかしにするとバサバサになるから手入れは必要",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765606938,
      "updated": 1765606968
    },
    {
      "id": "693d112100000000000f52b1",
      "text": "\t\t\t迷ってる[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1765609762,
      "updated": 1765609763
    },
    {
      "id": "693ccadd0000000000e07ac7",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1765591774,
      "updated": 1765591774
    },
    {
      "id": "693cb6910000000000adb350",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1765586578,
      "updated": 1765586581
    },
    {
      "id": "693cb6940000000000adb352",
      "text": " [クリスマス飾り]を作るための材料を探すための散歩に行く",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765586581,
      "updated": 1765607290
    },
    {
      "id": "693cf29d000000000044be0f",
      "text": " 5歳の娘の1歳年下のお友だちが遊びに来ている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1765601950,
      "updated": 1765601984
    },
    {
      "id": "693d170f000000000044be10",
      "text": "  わけあって預かってるが、子供二人見るのはなかなかにハード！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1765611280,
      "updated": 1765611302
    },
    {
      "id": "693cbe720000000000bc3d8e",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765588595,
      "updated": 1765588595
    },
    {
      "id": "693cbe720000000000bc3d8f",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765588595,
      "updated": 1765588595
    },
    {
      "id": "693cbd590000000000b3d868",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765588317,
      "updated": 1765588317
    },
    {
      "id": "693cbd5a0000000000b3d869",
      "text": "\tおしごとぅ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765588317,
      "updated": 1765588323
    },
    {
      "id": "693cc9bf000000000010a889",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1765591486,
      "updated": 1765591486
    },
    {
      "id": "693cc9bf000000000010a88a",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1765591486,
      "updated": 1765591488
    },
    {
      "id": "693cc9c2000000000010a88b",
      "text": " 散髪",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1765591489,
      "updated": 1765591492
    },
    {
      "id": "693cb6910000000000adb351",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1765586578,
      "updated": 1765586578
    },
    {
      "id": "693cdd0b00000000003ee395",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765596427,
      "updated": 1765596429
    },
    {
      "id": "693cdd0d00000000003ee396",
      "text": "　日本人のための日本語教室、ウケる",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765596429,
      "updated": 1765596446
    },
    {
      "id": "693cdd1200000000003ee397",
      "text": "　　https://x.com/takachihoharuka/status/1999618211416056114?s=46&t=gkSZtjGEtUZPO0JCzBxCBw",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765596434,
      "updated": 1765596436
    },
    {
      "id": "693cdd1f00000000003ee398",
      "text": "\t[みいちゃんと山田さん]を3巻まで読んだ",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765596448,
      "updated": 1765608025
    },
    {
      "id": "693d0a590000000000c8ce5c",
      "text": "\t\tマオくんとシゲオくんがでてきた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765608025,
      "updated": 1765608052
    },
    {
      "id": "693d0a730000000000c8ce5d",
      "text": "\t\t読み進めるのが重たくなってきた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765608052,
      "updated": 1765608059
    },
    {
      "id": "693d0a7b0000000000c8ce5e",
      "text": "\t最近タバコを吸いたい気持ちになってる、これは単にストレスの兆候",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765608059,
      "updated": 1765622248
    },
    {
      "id": "693d0a7b0000000000c8ce5f",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1765608059,
      "updated": 1765608059
    },
    {
      "id": "693cdd2000000000003ee399",
      "text": "[着地鳩.icon]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765596448,
      "updated": 1765598433
    },
    {
      "id": "693ce4e200000000008dd082",
      "text": " 今年読んだ本の特集をするとまあまあ長いリストになる、かも。",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765598434,
      "updated": 1765598468
    },
    {
      "id": "693cebe20000000000aaa37f",
      "text": "  [井戸端の人の本棚 2025]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765600226,
      "updated": 1765600274
    },
    {
      "id": "693ce4ff00000000008dd083",
      "text": " マンガばかり読んでいたきがする",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765598462,
      "updated": 1765598524
    },
    {
      "id": "693cea990000000000aaa376",
      "text": "  普段ジャンププラスやコミックDAYSなどのメジャーなところしか読んでいない",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599898,
      "updated": 1765599922
    },
    {
      "id": "693ce8880000000000aaa367",
      "text": " めちゃくちゃトンビが飛んでいてこわい",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599367,
      "updated": 1765599385
    },
    {
      "id": "693ce9ae0000000000aaa368",
      "text": " 最近のよんだマンガ",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599661,
      "updated": 1765599718
    },
    {
      "id": "693ce9d90000000000aaa371",
      "text": "  [月のお寿司を抱えてねむる]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599704,
      "updated": 1765599713
    },
    {
      "id": "693ceadb0000000000f4a5c9",
      "text": "  \t悪くない[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765599964,
      "updated": 1765599965
    },
    {
      "id": "693d12910000000000b9cdb8",
      "text": "  \t好き[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765610130,
      "updated": 1765610133
    },
    {
      "id": "693ce9ee0000000000aaa372",
      "text": "  [誰でもないところからの眺め]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599726,
      "updated": 1765599736
    },
    {
      "id": "693cea7d0000000000aaa374",
      "text": "   https://www.ohtabooks.com/sp/daredemonai/",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599868,
      "updated": 1765599869
    },
    {
      "id": "693ceab90000000000aaa377",
      "text": "  ちいかわ 島編",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599928,
      "updated": 1765599933
    },
    {
      "id": "693cead60000000000aaa378",
      "text": "  [伴天連怪談]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599961,
      "updated": 1765599976
    },
    {
      "id": "693ceb000000000000aaa379",
      "text": "   https://shonenjumpplus.com/episode/17107094910795721445",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765600001,
      "updated": 1765600001
    },
    {
      "id": "693ceba60000000000aaa37b",
      "text": "  [復讐が足りない]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765600165,
      "updated": 1765600180
    },
    {
      "id": "693cebac0000000000aaa37c",
      "text": "   https://comic-days.com/episode/2550912965979474364",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765600171,
      "updated": 1765600172
    },
    {
      "id": "693cebb70000000000aaa37e",
      "text": "   途中から想像してた話と変わってきて気になってる",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765600183,
      "updated": 1765600214
    },
    {
      "id": "693d0c5700000000006e76b3",
      "text": "  事務しゃに",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765608535,
      "updated": 1765608539
    },
    {
      "id": "693d0db400000000006e76ba",
      "text": "   [アイドルマスター シャイニーカラーズ 事務的光空記録]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765608884,
      "updated": 1765608889
    },
    {
      "id": "693d0c5c00000000006e76b4",
      "text": "   https://www.sunday-webry.com/episode/14079602755326184493",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765608539,
      "updated": 1765608556
    },
    {
      "id": "693d0d7b00000000006e76b6",
      "text": "  [運命の人、絶対に炬燵の布団みたいなアウター着てない]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765608826,
      "updated": 1765608879
    },
    {
      "id": "693d0d7c00000000006e76b7",
      "text": "   https://bigcomics.jp/episodes/775e58ae53402/",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765608827,
      "updated": 1765608840
    },
    {
      "id": "693d1f980000000000996f96",
      "text": "  父を焼く",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765613464,
      "updated": 1765613466
    },
    {
      "id": "693d1f9b0000000000996f97",
      "text": "   https://bigcomics.jp/episodes/01fead3e80f43/",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765613467,
      "updated": 1765613468
    },
    {
      "id": "693ce9fb0000000000aaa373",
      "text": " [『特性のない男』]が書店の棚に並んでいて[イタロー.icon]さんじゃんってなった",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765599738,
      "updated": 1765599771
    },
    {
      "id": "693cffba0000000000aaa3a9",
      "text": " 図書館で借られて帰ってきたばかりの本のごとく他の人の読んだ本というのわ読まれたという折り紙が添えてあるように感じられ、しかも読んだ人の人となりも多少添っている",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765605305,
      "updated": 1765605414
    },
    {
      "id": "693d072c0000000000aaa3aa",
      "text": " バッタクリボー",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607211,
      "updated": 1765607216
    },
    {
      "id": "693d077f00000000006e76a9",
      "text": " チャーリー・ブラウンのクリスマスのチャーリー・ブラウンの死ぬほど貧相なクリスマスツリーが売られていることの悲しさ",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607295,
      "updated": 1765607456
    },
    {
      "id": "693d082100000000006e76aa",
      "text": "  https://amzn.asia/d/hZqRJbZ",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607494,
      "updated": 1765607494
    },
    {
      "id": "693d084700000000006e76ab",
      "text": " 〜の〜さ",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607494,
      "updated": 1765607509
    },
    {
      "id": "693d085700000000006e76ac",
      "text": "  [人も　馬も　道ゆきつかれ死にゝけり。旅寝かさなるほどの　かそけさ]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607510,
      "updated": 1765607517
    },
    {
      "id": "693d090100000000006e76ae",
      "text": " サンタとコカ・コーラ",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607680,
      "updated": 1765607685
    },
    {
      "id": "693d090600000000006e76af",
      "text": "  https://www.coca-cola.com/jp/ja/media-center/christmas",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607685,
      "updated": 1765607686
    },
    {
      "id": "693d095400000000006e76b2",
      "text": " 師匠が将棋に熱中している。なのでチェスでも始めようかと思っている",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607763,
      "updated": 1765607783
    },
    {
      "id": "693d090700000000006e76b0",
      "text": "",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607686,
      "updated": 1765607687
    },
    {
      "id": "693ceb0d0000000000f4a5ca",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765600013,
      "updated": 1765600013
    },
    {
      "id": "693ceb0d0000000000f4a5cb",
      "text": "[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765600013,
      "updated": 1765600013
    },
    {
      "id": "693ceb0d0000000000f4a5cc",
      "text": "\thttps://abema.tv/channels/hiphop/slots/8ZHHQYk2WmiG4o",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765600014,
      "updated": 1765600234
    },
    {
      "id": "693ceb180000000000f4a5ce",
      "text": "\tデライトがおすすめ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765600025,
      "updated": 1765600029
    },
    {
      "id": "693d1b3700000000009e8a8c",
      "text": "\t小さい頃は天井イコール屋根だと思ってて天井裏が屋上と違うのかわからなかった。",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765612343,
      "updated": 1765612403
    },
    {
      "id": "693d1bc800000000009e8a8d",
      "text": "\t>われわれが、ある音楽なり舞踏なりを好きになるきっかけは、はっきりしている。それは、その曲を歌うなり口笛で吹くなりしはじめる時なのである。いいかえれば、その曲を憶えはじめる時なのである。",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765612489,
      "updated": 1765612492
    },
    {
      "id": "693d1bcb00000000009e8a8e",
      "text": " > ─シェーンベルク音楽論選 様式と思想",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765612492,
      "updated": 1765612495
    },
    {
      "id": "693d5e63000000000064c84d",
      "text": " 今年一冊も読めなかったわーと思いきやめちゃくちゃ読んでて俺の記憶とは一体何",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765629539,
      "updated": 1765631583
    },
    {
      "id": "693ce4e000000000008dd081",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765598431,
      "updated": 1765598881
    },
    {
      "id": "693ce69c0000000000f4a5c0",
      "text": "[nomadoor.icon]",
      "userId": "5f0ae250e8cd56001ee2dacc",
      "created": 1765598876,
      "updated": 1765602442
    },
    {
      "id": "693cf4880000000000299152",
      "text": "　[/work4ai/Comfy に使う ComfyUI]",
      "userId": "5f0ae250e8cd56001ee2dacc",
      "created": 1765602442,
      "updated": 1765602448
    },
    {
      "id": "693cf48f0000000000299154",
      "text": "　　なんとか人様に見せられるまでにはサイトをまとめられた",
      "userId": "5f0ae250e8cd56001ee2dacc",
      "created": 1765602449,
      "updated": 1765602472
    },
    {
      "id": "693cf4a60000000000299155",
      "text": "　　誰かの役に立ってくれれば嬉しいな(´ε｀ )",
      "userId": "5f0ae250e8cd56001ee2dacc",
      "created": 1765602473,
      "updated": 1765602493
    },
    {
      "id": "693cf4bc0000000000299156",
      "text": "　　今日からしばらく家を離れるのでなんとか間に合ってよかった…危なかった…",
      "userId": "5f0ae250e8cd56001ee2dacc",
      "created": 1765602494,
      "updated": 1765602520
    },
    {
      "id": "693cf71e000000000096a993",
      "text": "　　すっご！！！！[はるひ.icon][W7kA9pX2.icon][caki.icon][sta.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765603103,
      "updated": 1765609824
    },
    {
      "id": "693cf4880000000000299153",
      "text": "",
      "userId": "5f0ae250e8cd56001ee2dacc",
      "created": 1765602442,
      "updated": 1765602442
    },
    {
      "id": "693cf64b00000000001ce866",
      "text": "[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1765602892,
      "updated": 1765602893
    },
    {
      "id": "693cf64d00000000001ce867",
      "text": " いいページができてたので今読んでる本を追加した",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1765602894,
      "updated": 1765602911
    },
    {
      "id": "693cf65f00000000001ce868",
      "text": "  [井戸端の人の本棚 2025]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1765602911,
      "updated": 1765602928
    },
    {
      "id": "693cf67100000000001ce869",
      "text": " もう2度とこんなスケジュールで同人誌出さない",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1765602930,
      "updated": 1765602944
    },
    {
      "id": "693cff3f0000000000aaa3a7",
      "text": "  🍵[着地鳩.icon][Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1765605182,
      "updated": 1765623457
    },
    {
      "id": "693cf68000000000001ce86a",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1765602945,
      "updated": 1765602945
    },
    {
      "id": "693cff380000000000b9cdb5",
      "text": "[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765605177,
      "updated": 1765605178
    },
    {
      "id": "693cff3b0000000000b9cdb7",
      "text": "　他人の本棚のを見て自分は本（物質）最近所持してないな〜て思ったが本（電子）はぼちぼちあるなした",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765605179,
      "updated": 1765605256
    },
    {
      "id": "693d12a70000000000b9cdb9",
      "text": "　今読んでる本　『魚で始まる世界史』",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765610152,
      "updated": 1765610184
    },
    {
      "id": "693d12c90000000000b9cdba",
      "text": "　　図書館で借りた",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765610186,
      "updated": 1765610191
    },
    {
      "id": "693d12cf0000000000b9cdbb",
      "text": "　　面白い",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765610191,
      "updated": 1765610222
    },
    {
      "id": "693d17b60000000000be629f",
      "text": "　[月のお寿司を抱えてねむる]を読んで寿司が食べたくなったのでスーパーで買った",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765611446,
      "updated": 1765611466
    },
    {
      "id": "693d17ca0000000000be62a0",
      "text": "　　近場にはま寿司がないのだなあ",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765611466,
      "updated": 1765611480
    },
    {
      "id": "693cff390000000000b9cdb6",
      "text": "",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1765605177,
      "updated": 1765605177
    },
    {
      "id": "693d00de0000000000115c10",
      "text": "[カイト.icon]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765605599,
      "updated": 1765605601
    },
    {
      "id": "693d00e10000000000115c11",
      "text": " [京セラドーム大阪]の座席に到着",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765605601,
      "updated": 1765605844
    },
    {
      "id": "6940b3d400000000009b50a4",
      "text": "  今日の現場は[MOIW2025] Day1",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765848020,
      "updated": 1765848020
    },
    {
      "id": "693d01d50000000000115c14",
      "text": "\t\t[https://gyazo.com/dd9e4914230fdf5df09bf2534fd55a03]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765605845,
      "updated": 1765847864
    },
    {
      "id": "6940b33d00000000009b50a0",
      "text": "\t\t\t撮影OKの楽曲時の写真",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765847870,
      "updated": 1765847890
    },
    {
      "id": "6940b35500000000009b50a1",
      "text": "\t\t\t披露楽曲は[vα-liv(ヴイアライヴ)]の[リローディング]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765847893,
      "updated": 1765848018
    },
    {
      "id": "693d6c5b00000000003dd8cc",
      "text": "  ライブが最高すぎて、酒が止まらない",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765633116,
      "updated": 1765633190
    },
    {
      "id": "693d01290000000000115c13",
      "text": "",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1765605674,
      "updated": 1765605674
    },
    {
      "id": "693d0672000000000058734c",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765607027,
      "updated": 1765607028
    },
    {
      "id": "693d0674000000000058734e",
      "text": " ボッタクリ〇〇って怖いな～って思ってたけど、経験しておくと色々見えてくるものがある。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765607028,
      "updated": 1765607946
    },
    {
      "id": "693d071d000000000058734f",
      "text": "  経営者とかの立場になる人はそういう場所に行ってみた方が良いかもしれない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765607198,
      "updated": 1765607944
    },
    {
      "id": "693d19880000000000587375",
      "text": "  手口が上手すぎる。あれは感動する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765611912,
      "updated": 1765611950
    },
    {
      "id": "693d08ec0000000000587350",
      "text": " 最近汚い街を遊び歩いている。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765607661,
      "updated": 1765607928
    },
    {
      "id": "693d09cc0000000000587351",
      "text": "  なんで今まで遊んでこなかったんだろうって思えるほど学びが多い。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765607885,
      "updated": 1765607942
    },
    {
      "id": "693d0c150000000000587352",
      "text": " 金欠喫煙者とおしゃべりしたのでタバコを一箱奢って一本タカることで人生初の喫煙を成功。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608469,
      "updated": 1765610240
    },
    {
      "id": "693d0cee0000000000587355",
      "text": " \tしかもシッカリ喋ったので、吸い方も教えてもらえた。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608687,
      "updated": 1765608712
    },
    {
      "id": "693d0c6d0000000000587353",
      "text": " \t12本も要らんからどうにかして1本だけ貰う方法がないかと結構昔から考えていたんだけど、上手いこと行った。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608558,
      "updated": 1765608650
    },
    {
      "id": "693d0cca0000000000587354",
      "text": " \t損得で言うとパッと見向こうの得にしかならない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608650,
      "updated": 1765608806
    },
    {
      "id": "693d0ddc000000000058735a",
      "text": " \t\t人生の悩みみたいなのを吐露させてもらえる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608924,
      "updated": 1765608941
    },
    {
      "id": "693d0d3e0000000000587356",
      "text": "  \tタバコを奢って貰える。1本くらい誤差。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608767,
      "updated": 1765608802
    },
    {
      "id": "693d0d6d0000000000587357",
      "text": "  \t吸い方を教えることで[自己効力感]も貰える。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1765608814,
      "updated": 1768123915
    },
    {
      "id": "693d0dc40000000000587359",
      "text": "  しかし、私からすると、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608901,
      "updated": 1765609418
    },
    {
      "id": "693d0e00000000000058735b",
      "text": "  \t他人の人生の悩みは興味深いので話を聞くこと自体がメリット。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608960,
      "updated": 1765609054
    },
    {
      "id": "693d0e18000000000058735c",
      "text": "  \t500円がもったいないという感情よりも、面倒くさい残り11本を処理できるメリット。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608985,
      "updated": 1765609053
    },
    {
      "id": "693d0e46000000000058735d",
      "text": "  \t吸い方がわからないので教えてもらえる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765609030,
      "updated": 1765609052
    },
    {
      "id": "693d0d830000000000587358",
      "text": "  取引当事者の物事に対する価値感覚が上手く噛み合う例やね。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765608836,
      "updated": 1765609072
    },
    {
      "id": "693d131d0000000000587369",
      "text": "   あまり理解されないから「キミは損する性格だね」と言われるが。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765610270,
      "updated": 1765610295
    },
    {
      "id": "693d0eba000000000058735e",
      "text": " 「タバコ一箱奢るから1本くれ & 吸い方も教えてくれ」だけだと不審人物なんよ。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765609146,
      "updated": 1765609409
    },
    {
      "id": "693d0eec000000000058735f",
      "text": " \t友人であっても不審ではあるんよ。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765609196,
      "updated": 1765609369
    },
    {
      "id": "693d0f090000000000587360",
      "text": " \tでも上手いこと文脈が出来上がると、「知り合いの金欠喫煙者にタバコを奢る」「その見返りに1本要求する」という自然なストーリーになる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765609226,
      "updated": 1765610219
    },
    {
      "id": "693d10ab0000000000587363",
      "text": " 「もういい。二度と吸わない」と思うほど不味かったが、後々「また吸いたいな」とちょっと思っている。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765609644,
      "updated": 1765609884
    },
    {
      "id": "693d119b0000000000587365",
      "text": " \t流石依存性物質だなと思う。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765609884,
      "updated": 1765609890
    },
    {
      "id": "693d122f0000000000587367",
      "text": " 酒は旨いから飲んでいるが、タバコは無理だ～。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765610031,
      "updated": 1765610075
    },
    {
      "id": "693d12640000000000587368",
      "text": "  苦みを感じる対象の物質が人によって違うんかな。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765610085,
      "updated": 1765610137
    },
    {
      "id": "693d1a4c00000000009e8a8b",
      "text": "  何本か？一箱か？ある程度吸わないとうまくならない！ブランクがあるとまたまずくなる。長年のヘビースモーカーでも何年か禁煙するとダメになるそうだ。そこからまた慣らそうとするのも意味わからんが。ともかく最初は全員まずいと感じるらしい[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1765612108,
      "updated": 1765612331
    },
    {
      "id": "693d1a610000000000587377",
      "text": "\t\t\t[\" 何本か？一箱か？ある程度吸わないとうまくならない]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765612130,
      "updated": 1765612224
    },
    {
      "id": "693d1abf0000000000587379",
      "text": " \t\t\t酒は初めてでも美味かったからいいよもう……[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765612224,
      "updated": 1765612225
    },
    {
      "id": "693d1a920000000000587378",
      "text": "\t\t禁煙成功したら一生禁煙できるやん[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765612178,
      "updated": 1765612214
    },
    {
      "id": "693d1419000000000058736a",
      "text": " 自分のために頑張る事ができないが、他人のために頑張るのは無限にできる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765610522,
      "updated": 1765612130
    },
    {
      "id": "693d14b5000000000058736b",
      "text": "  [返応性の法則]を利用することで生き延びる道しかないかもしれない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765610677,
      "updated": 1765610834
    },
    {
      "id": "693d1556000000000058736c",
      "text": "  返したくなる感情がよくわからないので、相手が返そうとしたものを突っぱねて「キミは何でそんなにいい人なの！？」と言われがち。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765610839,
      "updated": 1765611002
    },
    {
      "id": "693d15c0000000000058736d",
      "text": "  \t多分人として不自然なくらい give をしている。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765610944,
      "updated": 1765610986
    },
    {
      "id": "693d1600000000000058736e",
      "text": "  \t逆に借りも返させてもらえずに一方的に恵まれ続けるという風に見ると、相手のプライドをジワジワ削っているようでもある。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765611009,
      "updated": 1765611130
    },
    {
      "id": "693d19e80000000000587376",
      "text": "  「お前は俺からの施しを受け取るしかねえ。俺は与えるも与えないも自由だ。今すぐお前を捨て置いても良い。どうだ、そんな俺から施しを受け続けるのは惨めだろう？」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765612009,
      "updated": 1765612467
    },
    {
      "id": "693d1b33000000000058737a",
      "text": "   みたいなヒールっぽいセリフが好き。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765612340,
      "updated": 1765612427
    },
    {
      "id": "693d1bbf000000000058737c",
      "text": "   無限に収入があったらなぁ。アイツらに無限の恵みを与え続けられるのに。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765612479,
      "updated": 1765612479
    },
    {
      "id": "693d0672000000000058734d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1765607027,
      "updated": 1765607027
    },
    {
      "id": "693d469c0000000000b0750a",
      "text": "[hoshihara.icon]",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623453,
      "updated": 1765623454
    },
    {
      "id": "693d469e0000000000b0750c",
      "text": " 今年読んだ本",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623454,
      "updated": 1765623478
    },
    {
      "id": "693d46b50000000000b0750d",
      "text": "  『ライオンハート』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623478,
      "updated": 1765623606
    },
    {
      "id": "693d495a00000000002b96d9",
      "text": "   時空越えるロマンチック系ラヴでいい",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624154,
      "updated": 1765624189
    },
    {
      "id": "693d473600000000002b96c6",
      "text": "  佐賀に行ったのでその旅行雑誌るるぶとかをTSUTAYAで漁った。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623606,
      "updated": 1765623971
    },
    {
      "id": "693d474c00000000002b96c7",
      "text": "   その時に、全国の美しい場所みたいな写真集も読んだ。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623628,
      "updated": 1765623646
    },
    {
      "id": "693d475e00000000002b96c8",
      "text": "  『幼年期の終わり』一章読んで、飽きた",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623646,
      "updated": 1765623677
    },
    {
      "id": "693d477d00000000002b96ca",
      "text": "  『現代文解釈の基礎』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623677,
      "updated": 1765623760
    },
    {
      "id": "693d47d000000000002b96cb",
      "text": "  『うつヌケ』Kindleで見かけて読んだ。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623760,
      "updated": 1765624211
    },
    {
      "id": "693d47e900000000002b96cd",
      "text": "  『まったく新しい〜の教科書』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623824,
      "updated": 1765624226
    },
    {
      "id": "693d4a3b00000000002b96dd",
      "text": "   反証可能性のある主張を事実から徐々に抽象度を高めた文を重ねて論証するというプロセスの説明が面白かった。uneven uの話とか。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624380,
      "updated": 1765624459
    },
    {
      "id": "693d480700000000002b96ce",
      "text": "  『身近な薬物の話』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623824,
      "updated": 1765623887
    },
    {
      "id": "693d485000000000002b96d0",
      "text": "   著者の、依存性薬物の合法違法の線引きは特に自明じゃないという主張が面白かった（この人は喫煙者で煙草擁護気味なのもおもろい）",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623889,
      "updated": 1765627300
    },
    {
      "id": "693d48e700000000002b96d6",
      "text": "  『生きる勇気（ティリッヒ）』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624040,
      "updated": 1765624049
    },
    {
      "id": "693d4a2f00000000002b96dc",
      "text": "  \tラディカルな懐疑は人を[自殺]へと至らしめるが、そのこと自体が存在の範囲で存在からくる問題を克服できないことを示している",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624368,
      "updated": 1765624656
    },
    {
      "id": "693d4b5000000000002b96e1",
      "text": "  \tそのことに気づいて自殺の試みは断念される",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624657,
      "updated": 1765624674
    },
    {
      "id": "693d4b6100000000002b96e2",
      "text": "  \t まじそれなと思いました。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624674,
      "updated": 1765624684
    },
    {
      "id": "693d48d800000000002b96d4",
      "text": "  『現代日本の政治（改定新版）』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624024,
      "updated": 1765624024
    },
    {
      "id": "693d4bc700000000002b96e3",
      "text": "  『ABC殺人事件』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624776,
      "updated": 1765624784
    },
    {
      "id": "693d4bff00000000002b96e7",
      "text": "   ポアロが推理するのが終盤で焦る",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624831,
      "updated": 1765624865
    },
    {
      "id": "693d4d9a00000000002b96eb",
      "text": "  『オリエント急行殺人事件』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625243,
      "updated": 1765625253
    },
    {
      "id": "693d4dad00000000002b96ed",
      "text": "   ミステリ初心者なのでオチに普通に面食らった",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625261,
      "updated": 1765625284
    },
    {
      "id": "693d6a20000000000024adc5",
      "text": "    『そして誰もいなくなった』も読んで面食らってほしい[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1765632544,
      "updated": 1765632573
    },
    {
      "id": "693d506400000000002b96f7",
      "text": "   ポアロが髭整えるためにコテ持ち歩いてるのめっちゃ前髪気にしてるギャルみたいだな？と思った",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625957,
      "updated": 1765626047
    },
    {
      "id": "693d509200000000002b96f9",
      "text": "    ギャル探偵とか、良いんじゃないんでしょうか。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626003,
      "updated": 1765626014
    },
    {
      "id": "693d4da500000000002b96ec",
      "text": "  『国宝』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625254,
      "updated": 1765625412
    },
    {
      "id": "693d4ef200000000002b96f1",
      "text": "   徳治というキャラクターが良い",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625586,
      "updated": 1765625727
    },
    {
      "id": "693d4f7f00000000002b96f2",
      "text": "   喜久雄もリアルな感じで、全体的にキャラクターがリアルな感じで良い",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625728,
      "updated": 1765625756
    },
    {
      "id": "693d4bd000000000002b96e4",
      "text": "  『小説以外』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624785,
      "updated": 1765624790
    },
    {
      "id": "693d4bd700000000002b96e5",
      "text": "   エッセイは頭使わずに読める",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624791,
      "updated": 1765624841
    },
    {
      "id": "693d4bdd00000000002b96e6",
      "text": "   色々著者のおすすめ本が載っており（おもにミステリ）ブックリストとしてよい",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624798,
      "updated": 1765624826
    },
    {
      "id": "693d4c7900000000002b96e8",
      "text": "  『死後の恋 夢野久作傑作選』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624953,
      "updated": 1765624973
    },
    {
      "id": "693d4c7e00000000002b96e9",
      "text": "   全話面白い！短編で読みやすいしおすすめ",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624959,
      "updated": 1765624998
    },
    {
      "id": "693d4cdd00000000002b96ea",
      "text": "   奇妙系",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625054,
      "updated": 1765625083
    },
    {
      "id": "693d491100000000002b96d7",
      "text": "  鬼滅全巻",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624082,
      "updated": 1765624085
    },
    {
      "id": "693d491400000000002b96d8",
      "text": "   無惨を倒すというスッキリした目的があり、登場人物の価値観もその通りで、ブレずに最後までいくので気持ちいい。逆に無惨は生きることにしか興味がなく、ここがブレないのもいい。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624085,
      "updated": 1765624515
    },
    {
      "id": "693d503000000000002b96f6",
      "text": "  あと『経済評論家の〜手紙』",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765625905,
      "updated": 1765625905
    },
    {
      "id": "693d47db00000000002b96cc",
      "text": "  cancanの今出てる号",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623824,
      "updated": 1765623824
    },
    {
      "id": "693d481300000000002b96cf",
      "text": "   ジュエリーなどが特集されていた。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623827,
      "updated": 1765623848
    },
    {
      "id": "693d66660000000000c551a0",
      "text": "   CanCamやったわ",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765631591,
      "updated": 1765631600
    },
    {
      "id": "693d4adf00000000002b96e0",
      "text": "  家の本棚にあるダヴィンチの伝記が何年も読めてない",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765624544,
      "updated": 1765624575
    },
    {
      "id": "693d519e00000000002b96fb",
      "text": "   本棚にある本と実際読んでいる本に隔たりがある。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626271,
      "updated": 1765626309
    },
    {
      "id": "693d469c0000000000b0750b",
      "text": " 博多でオペラ座の怪人を観てきた。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765623453,
      "updated": 1765626496
    },
    {
      "id": "693d546000000000002b9705",
      "text": "  劇は良いものだ",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626976,
      "updated": 1765626985
    },
    {
      "id": "693d550a00000000002b970b",
      "text": "  歌うますぎ",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765627147,
      "updated": 1765627152
    },
    {
      "id": "693d527f00000000002b96fc",
      "text": "  舞台装置がすごい。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626496,
      "updated": 1765626828
    },
    {
      "id": "693d53cd00000000002b9700",
      "text": "   超デカいシャンデリアなど",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626830,
      "updated": 1765626876
    },
    {
      "id": "693d54bf00000000002b9709",
      "text": "   こういうのはめっちゃ地方のホールだと再現できないよなー",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765627072,
      "updated": 1765627126
    },
    {
      "id": "693d53cc00000000002b96ff",
      "text": "  ミュージカルなどほとんど見たことがなかったが、かなり楽しめた。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626828,
      "updated": 1765626828
    },
    {
      "id": "693d540b00000000002b9703",
      "text": "  カーテンコールがめっちゃ長い。5回以上は出てきたんじゃないか。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626891,
      "updated": 1765626929
    },
    {
      "id": "693d52da00000000002b96fe",
      "text": "  とちゅう休憩に入った途端、みんなすごい勢いで席を立ち、女子トイレに列を作る。めちゃ並んでいた。",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626587,
      "updated": 1765627050
    },
    {
      "id": "693d54a900000000002b9708",
      "text": "   最後尾のプラカード担当のスタッフがいた",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765627050,
      "updated": 1765627060
    },
    {
      "id": "693d54a400000000002b9706",
      "text": "   トイレの中までも誘導の女性が立っており、個室が開くたびに次の人に声をかけて即入らせる。レジみたいな感じで声かけで急かして回転を最高効率にしていた。（外が声かけではよ出ろとうるさいと個室に長居する気にもならない）",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765627045,
      "updated": 1765627421
    },
    {
      "id": "693d586700000000002b970c",
      "text": "  1人すごくかわいい女優さんがいた",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765628008,
      "updated": 1765628030
    },
    {
      "id": "693d588000000000002b970d",
      "text": "   私がそう思っただけかもしれないが、際立って可愛かった",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765628033,
      "updated": 1765628056
    },
    {
      "id": "693d515300000000002b96fa",
      "text": " 今日はほんとに寒いな！",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765626196,
      "updated": 1765628533
    },
    {
      "id": "693d5a6600000000007d91f1",
      "text": "",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1765628518,
      "updated": 1765628518
    },
    {
      "id": "693d70b400000000009d494d",
      "text": "[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1765634229,
      "updated": 1765634230
    },
    {
      "id": "693d70b500000000009d494f",
      "text": " テキストに対して音声入力をしていると「あー」とか「うんうん」みたいなテキストデータとしてはただのノイズになりがちなフィードバックが生成AIとの対話のインタフェースに組み込まれる必要があるなと感じた",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1765634230,
      "updated": 1765634276
    },
    {
      "id": "693d70e300000000009d4950",
      "text": " \t長時間何のフィードバックもなしに喋り続けるのはなんか気持ち悪さがある",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1765634276,
      "updated": 1765635471
    },
    {
      "id": "693d759100000000007d55f6",
      "text": " \tラジオとかみたいに訓練するとできるようになる類いのもの",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1765635473,
      "updated": 1765635490
    },
    {
      "id": "693d70b400000000009d494e",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1765634229,
      "updated": 1765634229
    },
    {
      "id": "693c40261280f00000002384b6",
      "text": "[2025/12/12]←2025/12/13→[2025/12/14]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1765556262,
      "updated": 1765556262
    },
    {
      "id": "693c40261280f0000000443a4e",
      "text": "[/ [2025/12.icon]]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1765556262,
      "updated": 1765556262
    }
  ]
}