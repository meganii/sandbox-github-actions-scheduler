    {
      "id": "69f26e95000000000057eebc",
      "text": "[infobox日記]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777495702,
      "updated": 1777495723
    },
    {
      "id": "69f273a9000000000057eec6",
      "text": "　人数が集まらない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777497002,
      "updated": 1777497017
    },
    {
      "id": "69f273b9000000000057eec7",
      "text": "　　たぶん、10人くらい集まらないと楽しくならない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777497017,
      "updated": 1777497054
    },
    {
      "id": "69f26ead000000000057eebd",
      "text": " 試してくれた人はいる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777495725,
      "updated": 1777495897
    },
    {
      "id": "69f26ed6000000000057eebf",
      "text": "　 続かなかったみたい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777495767,
      "updated": 1777497060
    },
    {
      "id": "69f26ee7000000000057eec0",
      "text": "　 肯定的であれ否定的であれフィードバックがほしい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777495783,
      "updated": 1777497064
    },
    {
      "id": "69f26f1e000000000057eec1",
      "text": "　 改善すべき点が明らかになるから",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777495838,
      "updated": 1777497066
    },
    {
      "id": "69f271bc000000000057eec2",
      "text": "　とりあえず、マンパワーが足りない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777496509,
      "updated": 1777496532
    },
    {
      "id": "69f271d5000000000057eec3",
      "text": "　　マンパワーが足りないのでメンテナンスが十分にできない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777496534,
      "updated": 1777497068
    },
    {
      "id": "69f27222000000000057eec5",
      "text": "　　やりたい気持ちが空回りしている感がある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777496610,
      "updated": 1777497070
    },
    {
      "id": "69f27422000000000057eec8",
      "text": "　　アイデアはまだある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777497122,
      "updated": 1777497139
    },
    {
      "id": "69f271e8000000000057eec4",
