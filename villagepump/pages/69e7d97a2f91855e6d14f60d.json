  "lines": [
    {
      "id": "69e7d97a2f91855e6d14f60d",
      "text": "横長アイコンのメリット",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776802172,
      "updated": 1776802172
    },
    {
      "id": "69e7da0b00000000004ae6c8",
      "text": "　文字を表示しやすい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776802322,
      "updated": 1776802337
    },
    {
      "id": "69e7da0700000000004ae6c7",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776802312,
      "updated": 1776802312
    },
    {
      "id": "69e7d99300000000004ae6c4",
      "text": "　[suto3.icon]は、infoboxのあるページへのリンク（ハッシュタグ）の代替として使っている",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776802196,
      "updated": 1776803037
    },
    {
      "id": "69e7da6f00000000004ae6c9",
      "text": "　　リンクだとinfoboxに登録される",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776802416,
      "updated": 1776802455
    },
    {
      "id": "69e7da9900000000004ae6ca",
      "text": "　　アイコンリンクだとinfoboxに登録されない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776802458,
      "updated": 1776802520
    },
    {
      "id": "69e7dba000000000004ae6cb",
      "text": "　　例: [infobox日記.icon] ← ハッシュタグっぽい記号「#」を使っている",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776802721,
      "updated": 1776802971
    },
    {
      "id": "69e7d9e400000000004ae6c5",
      "text": "",
