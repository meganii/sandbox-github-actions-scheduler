      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781467429,
      "updated": 1781467442
    },
    {
      "id": "6a2fa7af00000000004af0e0",
      "text": "2026-06-15-16:20:14 [info.icon][著作者人格権]のページとかどこまで書いたらいいかわからない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781508015,
      "updated": 1781508079
    },
    {
      "id": "6a2fa8030000000000a50a04",
      "text": "2026-06-15-16:21:38 [info.icon][コトバンク]説明がシンプルでいい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781508100,
      "updated": 1781508139
    }
  ]
}