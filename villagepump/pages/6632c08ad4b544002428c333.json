    },
    {
      "id": "6635abce1280f000002b61a5",
      "text": " 2024-04-17 11:41:09 `.quick-launch .project-home .title {`を`.project-home .title {`に変更[per_terra.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1714793421,
      "updated": 1714793447
    },
    {
      "id": "6a49b16a0000000000dd829c",
      "text": "　2026-07-05 CSS変数`--project-title-font`を導入[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783214442,
      "updated": 1783215007
    },
    {
      "id": "6a49b4550000000000dd82b0",
      "text": "　　`font-family: serif;`→`font-family: var(--project-title-font, \"\"), serif;`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783215190,
      "updated": 1783215235
    },
    {
      "id": "6a4a3beb0000000000da7c98",
      "text": "　 UserCSSでフォントを変更するための変数です",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783249900,
      "updated": 1783514904
    },
    {
      "id": "6a4a404b0000000000da7c9a",
      "text": "  UserCSSのサンプル：[BIZ UD明朝]に変更する",
