    },
    {
      "id": "6a000d3c0000000000c518b5",
      "text": "　[フェミおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778388284,
      "updated": 1778388288
    },
    {
      "id": "6a000d410000000000c518b6",
      "text": "　\t[わたしたちは無痛恋愛がしたい ～鍵垢女子と星屑男子とフェミおじさん～]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778388290,
      "updated": 1778388294
    },
    {
      "id": "69fe6ff20000000000448501",
      "text": "　[風船おじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282482,
      "updated": 1778282482
    },
    {
      "id": "69fe73a600000000004489f9",
      "text": "　[プロセカおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283430,
      "updated": 1778283430
    },
    {
      "id": "69fe70d4000000000044860f",
      "text": "\t[ぶつかりおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282709,
      "updated": 1778282709
    },
    {
      "id": "69fe71040000000000448651",
      "text": " [フライデーおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282757,
      "updated": 1778282757
    },
    {
      "id": "6a000c880000000000c518a0",
      "text": " [別名登録記法おじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778388104,
      "updated": 1778388107
    },
    {
      "id": "69fe701d0000000000448524",
      "text": "　[ベンおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282526,
      "updated": 1778282526
    },
    {
      "id": "69fe705c000000000044855b",
      "text": "　[変なおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282589,
      "updated": 1778282589
    },
    {
      "id": "69fe70670000000000448566",
      "text": "　[ぼくのおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282600,
      "updated": 1778282600
    },
    {
      "id": "69fe71c500000000004486a0",
      "text": "[*** マ行]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282950,
      "updated": 1778282953
    },
    {
      "id": "6a000cbe0000000000c518a8",
      "text": " [まじめなサラリーマン風おじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778388159,
      "updated": 1778388162
    },
    {
      "id": "6a000c6b0000000000c5189c",
      "text": " [ミールスおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778388076,
      "updated": 1778388079
    },
    {
      "id": "6a000add0000000000ec7e56",
      "text": "\t[メンヘラおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778387677,
      "updated": 1778387680
    },
    {
      "id": "69fe7092000000000044859c",
      "text": "　[モンベルおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282643,
      "updated": 1778282950
    },
    {
      "id": "69fe723300000000004486d3",
      "text": "[*** ヤ行]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283060,
      "updated": 1778283067
    },
    {
      "id": "69fe722d00000000004486d2",
      "text": "　[要はバランスおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283053,
      "updated": 1778283060
    },
    {
      "id": "69fe74800000000000448a63",
      "text": "[*** ラ行]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283649,
      "updated": 1778283649
    },
    {
      "id": "69fe70c300000000004485ea",
      "text": " [りくろーおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778282692,
      "updated": 1778282959
    },
    {
      "id": "6a000ce20000000000c518ac",
      "text": " [レゼダンスを踊るおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778388194,
      "updated": 1778388197
    },
    {
      "id": "69fe752e0000000000448a87",
      "text": "　[レレレのおじさん]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283823,
      "updated": 1778283823
    },
    {
      "id": "69fe7a2a0000000000ddfde7",
      "text": "　[令和おじさん]",
      "userId": "688c296691686a314f82fb52",
      "created": 1778285098,
      "updated": 1778285103
    },
    {
      "id": "69fe74a00000000000448a78",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283681,
      "updated": 1778283681
    },
    {
      "id": "69577eee00000000001ac8b5",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283674,
      "updated": 1778283674
    },
    {
      "id": "637c93fa5e90c000008f1ef2",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283674,
      "updated": 1778283674
    },
    {
      "id": "69fe702a000000000089605d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283674,
      "updated": 1778283674
    },
    {
      "id": "69fe702a000000000089605e",
      "text": " おじさんは何にでもなれる…！[seibe.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778283674,
      "updated": 1778283674
    },
    {
      "id": "69fe702b000000000089605f",
      "text": "",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1778282539,
      "updated": 1778282539
    },
    {
      "id": "69fe78360000000000ddfde1",
      "text": "[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1778284598,
      "updated": 1778284598
    },
    {
      "id": "69fe78370000000000ddfde3",
      "text": "　[ニコニコ大百科]にありそう、と思ったら既出だった",
      "userId": "688c296691686a314f82fb52",
      "created": 1778284599,
      "updated": 1778284614
    },
    {
      "id": "69fe78460000000000ddfde4",
      "text": "　\t[https://dic.nicovideo.jp/a/%E3%81%8A%E3%81%98%E3%81%95%E3%82%93%E3%81%AE%E4%B8%80%E8%A6%A7 おじさんの一覧とは (オジサンノイチランとは) 単語記事 - ニコニコ大百科]",
      "userId": "688c296691686a314f82fb52",
      "created": 1778284614,
      "updated": 1778284620
    },
    {
      "id": "69fe7a720000000000ddfde8",
      "text": "　[男女平等]が進んだら「○○おばさん」もキツイ蔑称じゃなくなるのかな",
      "userId": "688c296691686a314f82fb52",
      "created": 1778285170,
      "updated": 1778285214
    },
    {
      "id": "69fe7acf0000000000ddfdea",
      "text": "　あと[菅義偉]氏、○○おじさん系のあだ名が二つあるのか…",
      "userId": "688c296691686a314f82fb52",
      "created": 1778285263,
      "updated": 1778285289
    },
    {
      "id": "69fe7ae90000000000ddfdeb",
      "text": "　\tおじいさんとも呼べる歳じゃないか、とちょっと不思議に思った",
      "userId": "688c296691686a314f82fb52",
      "created": 1778285289,
      "updated": 1778285312
    },
    {
      "id": "69fe7b000000000000ddfdec",
      "text": "　\t\tまあ最近晩婚化がすごいしおじいさんラインも段々上がっているのだろう",
      "userId": "688c296691686a314f82fb52",
      "created": 1778285312,
      "updated": 1778285331
    },
    {
      "id": "69fe78360000000000ddfde2",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1778284598,
      "updated": 1778284598
    }
  ]
}