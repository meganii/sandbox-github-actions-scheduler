    {
      "id": "69a785fe00000000006eaa20",
      "text": "[[歓迎.icon]] いらっしゃいませ！ [suto3.icon][vlzs.icon][koyoshi.icon][nyarla.icon][Hiro Aki.icon][mtane0412.icon][sta.icon][Summer498.icon][nomadoor.icon][はるひ.icon][caki.icon][W7kA9pX2.icon][hoagecko.icon][meganii.icon][wogikaze.icon][seibe.icon][Nrem.icon][HelloPeople.icon]",
