    },
    {
      "id": "69c646540000000000571e66",
      "text": " [Maho ONLINE]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774601812,
      "updated": 1774601831
    },
    {
      "id": "69c646580000000000571e67",
      "text": " \thttps://maho.online",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774601817,
      "updated": 1774601823
    },
    {
      "id": "69c6465f0000000000571e68",
      "text": " [https://kazudorei.hatenablog.com/entry/2015/01/19/120215 BUMPから「オーイエアハーン」を取ると○○曲残った - 数の奴隷]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774601824,
      "updated": 1774601894
    },
    {
      "id": "69c646a50000000000571e69",
      "text": " \t[https://nlab.itmedia.co.jp/cont/articles/3240817/ BUMP OF CHICKENの曲から「オーイエアハーン」を取ると何が残る？→実際に調べてみた結果がすごい | ねとらぼ]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774601894,
      "updated": 1774601905
    },
    {
      "id": "69c646b10000000000571e6a",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774601905,
      "updated": 1774602343
    },
    {
      "id": "69c6491e0000000000571e81",
      "text": "[**** 趣味・興味]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602527,
      "updated": 1774603594
    },
    {
      "id": "69c649240000000000571e83",
      "text": " [読書]（主に[文芸]の話）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602533,
      "updated": 1774603137
    },
    {
      "id": "69c649600000000000571e85",
      "text": " \t文学部文学科に行ったので、人類の平均よりは好きなはず",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602593,
      "updated": 1774602974
    },
    {
      "id": "69c649710000000000571e86",
      "text": " \t卒業論文は[太宰治]でした。昔から好きな作家は[綿矢りさ]、[森見登美彦]、[伊坂幸太郎]、[森絵都]などです",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602610,
      "updated": 1774602648
    },
    {
      "id": "69c6499b0000000000571e87",
      "text": " [日本語]と、それに付随する[人文]的興味",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602652,
      "updated": 1774603145
    },
    {
      "id": "69c649a70000000000571e88",
      "text": " \t大学時代の授業で[日本語学]の面白さに目覚めました",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602664,
      "updated": 1774602686
    },
    {
      "id": "69c649bd0000000000571e89",
      "text": " \t[類義語]とか好きです",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602686,
      "updated": 1774602690
    },
    {
      "id": "69c649c10000000000571e8a",
      "text": " \t主な興味は[意味論]と[語用論]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602690,
      "updated": 1774602699
    },
    {
      "id": "69c649cb0000000000571e8b",
      "text": " \t頑張って[統語論]と[認知言語学]は追いたいと思っています",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602700,
      "updated": 1774602720
    },
    {
      "id": "69c649df0000000000571e8c",
      "text": " \t[レトリック]や[修辞学]にも興味があります",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602720,
      "updated": 1774602732
    },
    {
      "id": "69c649eb0000000000571e8d",
      "text": " \t[言語行為論]や[言語哲学]も勉強したい",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602732,
      "updated": 1774602740
    },
    {
      "id": "69c64a310000000000571e90",
      "text": " \t[倫理学]も興味がある",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602801,
      "updated": 1774602811
    },
    {
      "id": "69c64a3a0000000000571e91",
      "text": " [演劇]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602811,
      "updated": 1774603599
    },
    {
      "id": "69c64a6f0000000000571e92",
      "text": " \t大学時代は[演劇部]に入っていました",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602864,
      "updated": 1774603201
    },
    {
      "id": "69c64a780000000000571e93",
      "text": " \t卒業後は、[熊本]にある[転回社]という[劇団]に関わったり関わらなかったりしています",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602873,
      "updated": 1774603619
    },
    {
      "id": "69c64a8b0000000000571e94",
      "text": " \t最近（2026年）は割とよく出演しています",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602891,
      "updated": 1774602912
    },
    {
      "id": "69c64aa10000000000571e95",
      "text": " \t出演しない時は[ミラーレス一眼]で[写真]を撮っています",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602913,
      "updated": 1774603625
    },
    {
      "id": "69c64ab80000000000571e96",
      "text": " \t好きな劇作家は[上田誠]です",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774602937,
      "updated": 1774603026
    },
    {
      "id": "69c64b110000000000571e97",
      "text": " \t最近は頑張って戯曲を読んでいます",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774603026,
      "updated": 1774603086
    },
    {
      "id": "69c64b1d0000000000571e98",
      "text": " \t\t2026年に読んでいるやつ → [シェイクスピア]、[チェーホフ]、[ブレヒト]、[別役実]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774603038,
      "updated": 1776216951
    },
    {
      "id": "69c64b3b0000000000571e9a",
      "text": " \t戯曲を読むワークショップをやっています",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774603067,
      "updated": 1774603079
    },
    {
      "id": "69c649f40000000000571e8e",
