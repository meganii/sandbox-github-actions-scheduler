{
  "id": "6a01892a7fb9af47ae0c7db7",
  "title": "かっこいい名前の料理",
  "created": 1778485550,
  "updated": 1778488044,
  "lines": [
    {
      "id": "6a01892a7fb9af47ae0c7db7",
      "text": "かっこいい名前の料理",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485550,
      "updated": 1778485550
    },
    {
      "id": "6a01892d0000000000dac6ad",
      "text": "[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485550,
      "updated": 1778485553
    },
    {
      "id": "6a0189300000000000dac6af",
      "text": "　つくったことがある",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485553,
      "updated": 1778485557
    },
    {
      "id": "6a0189350000000000dac6b0",
      "text": "　\tガイヤーン",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485557,
      "updated": 1778485560
    },
    {
      "id": "6a0189370000000000dac6b1",
      "text": "　\tシュラハトプラット",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485560,
      "updated": 1778485563
    },
    {
      "id": "6a018e8e0000000000d22d21",
      "text": "\t [御御御付][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1778486926,
      "updated": 1778486931
    },
    {
      "id": "6a01893e0000000000dac6b2",
      "text": "　つくったことがない",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485567,
      "updated": 1778485570
    },
    {
      "id": "6a0189420000000000dac6b3",
      "text": "　\tザッハトルテ",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485570,
      "updated": 1778485575
    },
    {
      "id": "6a018dfa0000000000d22d1e",
      "text": "　\t ホテルザッハーがそもそも強そう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1778486778,
      "updated": 1778486791
    },
    {
      "id": "6a0189470000000000dac6b4",
      "text": "　\tビーフストロガノフ",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485576,
      "updated": 1778485580
    },
    {
      "id": "6a01900c0000000000d22d23",
      "text": "　\t[バインセオ][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1778487308,
      "updated": 1778487314
    },
    {
      "id": "6a0192e90000000000dac6b6",
      "text": "　\t\tつくりたい！[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778488041,
      "updated": 1778488044
    },
    {
      "id": "6a0189300000000000dac6ae",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778485553,
      "updated": 1778485553
    },
    {
      "id": "6a018a9900000000007d4319",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778485914,
      "updated": 1778485915
    },
    {
      "id": "6a018a7d00000000007d4316",
      "text": " あげるだけ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778485886,
      "updated": 1778485920
    },
    {
      "id": "6a018b4a00000000007d4323",
      "text": " \tストライクゾーンが広い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778486091,
      "updated": 1778486097
    },
    {
      "id": "6a018aca00000000007d431c",
      "text": " スクランブルエッグ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778485962,
      "updated": 1778485966
    },
    {
      "id": "6a018ade00000000007d431d",
      "text": " チェダーチーズ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778485983,
      "updated": 1778485986
    },
    {
      "id": "6a018af700000000007d431e",
      "text": " ブラッド・ソーセージ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778486008,
      "updated": 1778486012
    },
    {
      "id": "6a018b0400000000007d4321",
      "text": " デスソース",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778486020,
      "updated": 1778486024
    },
    {
      "id": "6a018a9f00000000007d431a",
      "text": " ザワークラウト",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778485920,
      "updated": 1778485920
    },
    {
      "id": "6a0192b40000000000dac6b5",
      "text": " \tつくったことがある[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1778487989,
      "updated": 1778487992
    },
    {
      "id": "6a018a7f00000000007d4318",
      "text": "\tインジェラ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778485888,
      "updated": 1778485956
    },
    {
      "id": "6a018ac300000000007d431b",
      "text": "\tボルシチ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778485956,
      "updated": 1778486066
    },
    {
      "id": "6a018b3b00000000007d4322",
      "text": "\tチャンジャ",
      "userId": "6436266c7ac3c0001bed60e6",
