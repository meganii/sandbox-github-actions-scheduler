    {
      "id": "6a0c5c3dc18b8af5e3db116a",
      "text": "Resonite",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779194959,
      "updated": 1779194959
    },
    {
      "id": "6a0c5c4e0000000000e7dcb1",
      "text": " [VRSNS]",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779194959,
      "updated": 1779195026
    },
    {
      "id": "6a0c5c910000000000e7dcb3",
      "text": " 特徴としてアイテムという概念が一級",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779195026,
      "updated": 1779206158
    },
    {
      "id": "6a0c880f0000000000a635bd",
      "text": " \tユーザーや[アバター]やワールドは全てアイテムと見れる",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779206159,
      "updated": 1779206204
    },
    {
      "id": "6a0c883d0000000000a635be",
      "text": " [protoflux]という[ビジュアルプログラミング言語]がゲーム内にある",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779206205,
      "updated": 1779206269
    },
    {
      "id": "6a0c88520000000000a635bf",
      "text": " 画像や動画や[3Dモデル]などをその場で出して見ながらコミュニケーションできる",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779206226,
      "updated": 1779206383
    },
    {
      "id": "6a0c88f00000000000a635c0",
      "text": " \tどんなファイルでもアップロードして共有できる",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779206384,
      "updated": 1779206411
    },
    {
      "id": "6a0c89220000000000a635c3",
      "text": "",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779206435,
      "updated": 1779206435
    },
    {
      "id": "6a0c89190000000000a635c1",
      "text": " [P2P]で[遅延]が少ない",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779206425,
      "updated": 1779206454
    },
    {
      "id": "6a0c89350000000000a635c4",
      "text": " \t代わりにホストが重い",
      "userId": "690c90d1fcfe38635ed1fae8",
      "created": 1779206454,
      "updated": 1779206494
    },
