{
  "id": "69e21313803d825702948467",
  "title": "トピック指向ブックマーク",
  "created": 1776423701,
  "updated": 1776585938,
  "lines": [
    {
      "id": "69e21313803d825702948467",
      "text": "トピック指向ブックマーク",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776423701,
      "updated": 1776423701
    },
    {
      "id": "69e215770000000000f7d200",
      "text": "[文芸的データベース]を用いたブックマーク機能",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776424311,
      "updated": 1776424647
    },
    {
      "id": "69e300410000000000c6cc0d",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484417,
      "updated": 1776484417
    },
    {
      "id": "69e48bb600000000002b517d",
      "text": "ある特定のトピックのブックマークを集める",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776585655,
      "updated": 1776585716
    },
    {
      "id": "69e48bb600000000002b517e",
      "text": "トピックのページを作る",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776585655,
      "updated": 1776585790
    },
    {
      "id": "69e48c3400000000002b5180",
      "text": "infoboxの設定をする",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776585781,
      "updated": 1776585824
    },
    {
      "id": "69e48c1500000000002b517f",
      "text": "ハッシュタグ `#トピック`で、ブックマークを集める",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776585749,
      "updated": 1776585924
    },
    {
      "id": "69e48c8300000000002b5181",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776585859,
      "updated": 1776585859
    },
    {
      "id": "69e48cc700000000002b5182",
      "text": "[[例]]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776585927,
      "updated": 1776585938
    },
    {
      "id": "69e214ca0000000000f7d1f7",
      "text": "例えば 「しおり」いうトピックに関するブックマークを作る場合",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776424139,
      "updated": 1776484524
    },
    {
      "id": "69e300b90000000000c6cc10",
      "text": "「しおり」という名前のページをつくる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484537,
      "updated": 1776585739
    },
    {
      "id": "69e3011d0000000000c6cc16",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484637,
      "updated": 1776484637
    },
    {
      "id": "69e300f70000000000c6cc11",
      "text": "table:infobo",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484600,
      "updated": 1776484637
    },
    {
      "id": "69e301140000000000c6cc12",
      "text": " リンク\t外部リンク、URLなど",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484629,
      "updated": 1776484629
    },
    {
      "id": "69e301140000000000c6cc13",
      "text": " メモ\t説明、注釈、要約、コメント、ツッコミなど",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484629,
      "updated": 1776484629
    },
    {
      "id": "69e301140000000000c6cc14",
      "text": " 日付\t#YYYY-MM-DD",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484629,
      "updated": 1776484629
    },
    {
      "id": "69e301140000000000c6cc15",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484629,
      "updated": 1776484629
    },
    {
      "id": "69e3005d0000000000c6cc0e",
      "text": "ハッシュタグ`#しおり`で infobox に登録される",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484445,
      "updated": 1776585733
    },
    {
      "id": "69e301a60000000000c6cc17",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776484775,
      "updated": 1776484775
    },
    {
      "id": "69e213150000000000f7d1e3",
      "text": "[しおり.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776423701,
      "updated": 1776484775
    },
    {
      "id": "69e213160000000000f7d1e4",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776423702,
      "updated": 1776423702
    },
    {
      "id": "69e215080000000000f7d1ff",
      "text": "[ソーシャルブックマーク]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776424200,
      "updated": 1776424200
    },
    {
      "id": "69e215050000000000f7d1fc",
      "text": "[スクマ]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776424197,
      "updated": 1776424197
    }
  ]
}