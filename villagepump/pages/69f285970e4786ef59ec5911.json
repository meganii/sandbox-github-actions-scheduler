      "created": 1777502117,
      "updated": 1777502117
    },
    {
      "id": "69f285c20000000000e4a06c",
      "text": "例えば、こんなサムネがあったとします。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501634,
      "updated": 1777502117
    },
    {
      "id": "69f285be0000000000e4a06a",
