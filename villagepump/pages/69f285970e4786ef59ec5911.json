    },
    {
      "id": "69f2880a0000000000e4a088",
      "text": "\tこういう細長い画像を目一杯表示する UserCSS",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777502218,
      "updated": 1777502239
    },
    {
      "id": "69f288030000000000e4a086",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777502211,
      "updated": 1777502211
    },
    {
      "id": "69f285d30000000000e4a06d",
      "text": "code:style.css",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501652,
      "updated": 1777501659
    },
    {
      "id": "69f285db0000000000e4a070",
      "text": " .content .icon img {",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501659,
      "updated": 1777501659
    },
    {
      "id": "69f285db0000000000e4a071",
      "text": " \t\tmin-width: 100%;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501659,
      "updated": 1777501659
    },
    {
      "id": "69f285db0000000000e4a072",
      "text": " \t\tmin-height: 100%;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501659,
      "updated": 1777501659
    },
    {
      "id": "69f285db0000000000e4a073",
      "text": " \t\tobject-fit: cover;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501659,
      "updated": 1777501659
    },
    {
      "id": "69f285db0000000000e4a074",
      "text": "\t\t\tobject-position: left;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501659,
      "updated": 1777501659
    },
    {
      "id": "69f285db0000000000e4a075",
      "text": " }",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501659,
      "updated": 1777501659
    },
    {
      "id": "69f285db0000000000e4a076",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501659,
      "updated": 1777501659
    },
    {
      "id": "69f286710000000000e4a079",
      "text": "code:minimize.css",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501810,
      "updated": 1777501838
    },
    {
      "id": "69f285d40000000000e4a06f",
      "text": " .content .icon img{min-width:100%;min-height:100%;object-fit: cover;object-position:left;}",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501652,
      "updated": 1777501884
    },
    {
      "id": "69f286850000000000e4a07f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777501829,
      "updated": 1777501829
    },
    {
