{
  "id": "69ca013e4756aa84838baee3",
  "title": "要はバランスファミリー",
  "created": 1774846273,
  "updated": 1774851176,
  "lines": [
    {
      "id": "69ca013e4756aa84838baee3",
      "text": "要はバランスファミリー",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1774846273,
      "updated": 1774846273
    },
    {
      "id": "69ca0b9b0000000000872bc5",
      "text": " 要はバランスひいおじいさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848923,
      "updated": 1774848934
    },
    {
      "id": "69ca0ba50000000000872bc6",
      "text": " 要はバランスひいおばあさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848934,
      "updated": 1774848947
    },
    {
      "id": "69ca0b820000000000872bc3",
      "text": " 要はバランスおじいさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848898,
      "updated": 1774848911
    },
    {
      "id": "69ca0b8f0000000000872bc4",
      "text": " 要はバランスおばあさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848911,
      "updated": 1774848920
    },
    {
      "id": "69ca0be30000000000872bc8",
      "text": " 要はバランスおおおじさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848995,
      "updated": 1774849044
    },
    {
      "id": "69ca0bf30000000000872bc9",
      "text": " 要はバランスおおおばさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849011,
      "updated": 1774849049
    },
    {
      "id": "69ca014000000000004983e7",
      "text": " [要はバランスおじさん]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1774846273,
      "updated": 1774846296
    },
    {
      "id": "69ca014300000000004983ea",
      "text": " 要はバランスおばさん",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1774846277,
      "updated": 1774846290
    },
    {
      "id": "69ca0b5b0000000000872bbf",
      "text": " 要はバランスおとうさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848860,
      "updated": 1774848877
    },
    {
      "id": "69ca0b6d0000000000872bc0",
      "text": " 要はバランスおかあさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848877,
      "updated": 1774848886
    },
    {
      "id": "69ca014300000000004983ec",
      "text": " 要はバランスおにいさん",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1774846277,
      "updated": 1774846290
    },
    {
      "id": "69ca0b780000000000872bc1",
      "text": " 要はバランスおねえさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848889,
      "updated": 1774848889
    },
    {
      "id": "69ca0b4b0000000000872bbe",
      "text": "\t要はバランスおとうと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848843,
      "updated": 1774848855
    },
    {
      "id": "69ca0b7b0000000000872bc2",
      "text": "\t要はバランスいもうと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774848892,
      "updated": 1774848892
    },
    {
      "id": "69ca0ca80000000000872bcd",
      "text": "\t要はバランスいとこ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849193,
      "updated": 1774849199
    },
    {
      "id": "69ca0caf0000000000872bce",
      "text": "\t要はバランスはとこ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849199,
      "updated": 1774849207
    },
    {
      "id": "69ca0cb70000000000872bcf",
      "text": "\t要はバランスまたいとこ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849207,
      "updated": 1774849216
    },
    {
      "id": "69ca0dc10000000000872bd7",
      "text": "\t要はバランスおっと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849473,
      "updated": 1774849488
    },
    {
      "id": "69ca0dd00000000000872bd8",
      "text": "\t要はバランスつま",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849488,
      "updated": 1774849495
    },
    {
      "id": "69ca015100000000004983f0",
      "text": " 要はバランスむすこ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774846291,
      "updated": 1774849138
    },
    {
      "id": "69ca0c710000000000872bca",
      "text": " 要はバランスむすめ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849138,
      "updated": 1774849146
    },
    {
      "id": "69ca0c7a0000000000872bcb",
      "text": " 要はバランスおいっこ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849146,
      "updated": 1774849177
    },
    {
      "id": "69ca0c8e0000000000872bcc",
      "text": " 要はバランスめいっこ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849166,
      "updated": 1774849180
    },
    {
      "id": "69ca0cf90000000000872bd2",
      "text": " 要はバランスいとこおい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849274,
      "updated": 1774849280
    },
    {
      "id": "69ca0cff0000000000872bd3",
      "text": " 要はバランスいとこめい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849280,
      "updated": 1774849288
    },
    {
      "id": "69ca014100000000004983e8",
      "text": " 要はバランスまごむすこ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774846275,
      "updated": 1774849383
    },
    {
      "id": "69ca0d580000000000872bd6",
      "text": " 要はバランスまごむすめ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849368,
      "updated": 1774849379
    },
    {
      "id": "69ca0d1d0000000000872bd4",
      "text": " 要はバランスまたおい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849310,
      "updated": 1774849339
    },
    {
      "id": "69ca0d4f0000000000872bd5",
      "text": " 要はバランスまためい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774849359,
      "updated": 1774849367
    },
    {
      "id": "69ca14630000000000bc2169",
      "text": " 要はバランスペット",
      "userId": "65e1289acd012200235729c0",
      "created": 1774851171,
      "updated": 1774851176
    },
