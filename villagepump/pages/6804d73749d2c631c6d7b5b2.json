      "userId": "5b5e7121417cf700145b98c2",
      "created": 1771932047,
      "updated": 1771932086
    },
    {
      "id": "699d89b6000000000068f78b",
      "text": "  　みんなでよってたかってadmin[takker.icon]を管理してる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1771932086,
      "updated": 1771932136
    },
    {
      "id": "699d89ea000000000068f78c",
