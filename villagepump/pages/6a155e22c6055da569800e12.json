  "lines": [
    {
      "id": "6a155e22c6055da569800e12",
      "text": "カンロ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785253,
      "updated": 1779785253
    },
    {
      "id": "6a155e2400000000007d4edc",
      "text": "カンロ株式会社は、キャンディやグミを主力とする日本の大手菓子メーカーである。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785253,
      "updated": 1779785335
    },
    {
      "id": "6a155e7700000000007d4ee5",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785336,
      "updated": 1779785336
    },
    {
      "id": "6a155e7700000000007d4ee4",
      "text": "1912年に山口県で「宮本製菓所」として創業し、110年以上の歴史を持つ。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785335,
      "updated": 1779785341
    },
    {
      "id": "6a155e7d00000000007d4ee6",
      "text": "1955年に発売した「カンロ飴」が大ヒットし、1960年に現社名へと変更した。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785341,
      "updated": 1779785348
    },
    {
      "id": "6a155e8300000000007d4ee7",
      "text": "看板商品である「カンロ飴」のほか、日本初の「健康のど飴」や、独自の食感で市場を牽引する「ピュレグミ」「カンデミーナグミ」など、数々のヒット商品を製造・販売している。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785348,
      "updated": 1779785357
    },
    {
      "id": "6a155e8c00000000007d4ee8",
      "text": "現在は東京都新宿区に本社を置き、東証スタンダード市場に上場している。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785357,
      "updated": 1779785357
    },
    {
      "id": "6a155e6700000000007d4ee3",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785320,
      "updated": 1779785320
    },
    {
      "id": "6a155e6700000000007d4ee2",
      "text": "近年は、直営店「ヒトツブカンロ」の運営やECサイトの展開に加え、海外市場の開拓や環境に配慮したアップサイクル事業など、時代に合わせた新たな領域への挑戦を続けている。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785319,
      "updated": 1779785320
    },
    {
      "id": "6a155e2700000000007d4ede",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1779785256,
      "updated": 1779785256
    },
    {
