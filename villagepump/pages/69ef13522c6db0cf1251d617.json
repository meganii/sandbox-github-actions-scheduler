{
  "id": "69ef13522c6db0cf1251d617",
  "title": "2026/04/27inajobの父のパソコン選び",
  "created": 1777275741,
  "updated": 1777561810,
  "lines": [
    {
      "id": "69ef13522c6db0cf1251d617",
      "text": "2026/04/27inajobの父のパソコン選び",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275741,
      "updated": 1777275752
    },
    {
      "id": "69ef1368000000000046aadb",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275753,
      "updated": 1777275756
    },
    {
      "id": "69ef136c000000000046aadd",
      "text": " バッテリーがヘタってるとのことで、新しいのを買いたいとのこと",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275757,
      "updated": 1777275770
    },
    {
      "id": "69ef138b000000000046aade",
      "text": " 現行機種 [ThinkPad E430]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1777275788,
      "updated": 1777561783
    },
    {
      "id": "69ef13c9000000000046aadf",
      "text": "  第三世代intel",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275850,
      "updated": 1777275856
    },
    {
      "id": "69ef1434000000000046aae4",
      "text": "  14インチディスプレイ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275957,
      "updated": 1777275965
    },
    {
      "id": "69ef14ad000000000046aae7",
      "text": "  日本語キーボード",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777276078,
      "updated": 1777276087
    },
    {
      "id": "69ef53970000000000720be0",
      "text": "  メモリ4GB",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777292185,
      "updated": 1777292189
    },
    {
      "id": "69ef539f0000000000720be1",
      "text": "  ストレージ500GB",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777292192,
      "updated": 1777292204
    },
    {
      "id": "69f33166000000000002a39b",
      "text": "  光学ドライブあり",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545575,
      "updated": 1777545578
    },
    {
      "id": "69f3316a000000000002a39c",
      "text": "   ごく稀に使うがなくても良いとのこと",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545579,
      "updated": 1777545592
    },
    {
      "id": "69f19e160000000000e16910",
      "text": "  いつ買ったんだこれ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777442328,
      "updated": 1777442335
    },
    {
      "id": "69f19e4d0000000000e16911",
      "text": "   10年以上前だな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777442383,
      "updated": 1777442388
    },
    {
      "id": "69ef13cf000000000046aae0",
      "text": " 使い方",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275856,
      "updated": 1777275871
    },
    {
      "id": "69ef13df000000000046aae1",
      "text": "  インターネットに接続していない",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275872,
      "updated": 1777275878
    },
    {
      "id": "69f370ca0000000000b584f7",
      "text": "   !?[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1777561801,
      "updated": 1777561810
    },
    {
      "id": "69ef13e6000000000046aae2",
      "text": "  Word/Excel/PowerPoint",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275879,
      "updated": 1777275898
    },
    {
      "id": "69ef1454000000000046aae5",
      "text": "   Officeバンドルのが良さそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275989,
      "updated": 1777275996
    },
    {
      "id": "69ef13f9000000000046aae3",
      "text": "  写真加工、写真管理",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275898,
      "updated": 1777275905
    },
    {
      "id": "69ef146d000000000046aae6",
      "text": "   写真加工のアプリが変わってしまうのは仕方ないかな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777276014,
      "updated": 1777276068
    },
    {
      "id": "69f199950000000000e168fe",
      "text": "  周辺機器",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441174,
      "updated": 1777441180
    },
    {
      "id": "69f1999b0000000000e168ff",
      "text": "   HDD",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441180,
      "updated": 1777441184
    },
    {
      "id": "69f1999e0000000000e16900",
      "text": "   プリンタ、スキャナ複合機",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441184,
      "updated": 1777441192
    },
    {
      "id": "69f199b70000000000e16902",
      "text": "   デジカメ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441208,
      "updated": 1777441210
    },
    {
      "id": "69f199c90000000000e16903",
      "text": "   USB有線マウス",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441226,
      "updated": 1777441238
    },
    {
      "id": "69f199ac0000000000e16901",
      "text": "   多分標準のドライバで動くだろう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441197,
      "updated": 1777441206
    },
    {
      "id": "69f19a760000000000e16907",
      "text": "  プロジェクターへ繋げたいことが極稀にある",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441399,
      "updated": 1777441414
    },
    {
      "id": "69f19a850000000000e16908",
      "text": "   もうこれはHDMIで良かろう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441414,
      "updated": 1777441423
    },
    {
      "id": "69f19a940000000000e16909",
      "text": "   Mustではない",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441429,
      "updated": 1777441433
    },
    {
      "id": "69ef1369000000000046aadc",
      "text": " なんでも良すぎるな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777275754,
      "updated": 1777276105
    },
    {
      "id": "69ef29db0000000000465e87",
      "text": " 地域振興券が使いたいらしい",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777281500,
      "updated": 1777281506
    },
    {
      "id": "69ef29e10000000000465e88",
      "text": "  かなり絞れそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777281507,
      "updated": 1777281512
    },
    {
      "id": "69f195920000000000e168f6",
      "text": " 10万円くらいかなぁ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777440147,
      "updated": 1777440157
    },
    {
      "id": "69f199100000000000e168f8",
      "text": " スペックを考える",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441041,
      "updated": 1777441049
    },
    {
      "id": "69f199180000000000e168f9",
      "text": "  メモリは今や16GBは欲しいか？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441050,
      "updated": 1777441067
    },
    {
      "id": "69f1994e0000000000e168fb",
      "text": "   なぜそんなに必要なのか謎だなぁ、、とは思うけど、、",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441103,
      "updated": 1777441118
    },
    {
      "id": "69f19a690000000000b18041",
      "text": "   余裕を持たせるために16GBの方が良いに一票。特にメモリ節約とか器用なことが厳しいならばなおさら[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1777441385,
      "updated": 1777441418
    },
    {
      "id": "69f1992a0000000000e168fa",
      "text": "  ストレージは500GB以上なら良さそう(外付けHDDがすでに家にある)",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441067,
      "updated": 1777441093
    },
    {
      "id": "69f1996e0000000000e168fc",
      "text": "  Officeバンドルのほうが個別に買うよりやすかろう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441136,
      "updated": 1777441149
    },
    {
      "id": "69f1997c0000000000e168fd",
      "text": "   PowerPointは別で買うのが良いかな？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441149,
      "updated": 1777441158
    },
    {
      "id": "69f19b500000000000e1690a",
      "text": "    Word/Excelのみのバンドルが多い気がする",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441617,
      "updated": 1777441630
    },
    {
      "id": "69f19ac20000000000b18042",
      "text": "   一体物の方が楽、という意味で個別よりバンドルに一票。特に初回起動時のアカウント作成が面倒。既に持っていて個人で管理が出来ているなら安上がりになる個別購入に一票。[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1777441474,
      "updated": 1777441541
    },
    {
      "id": "69f2fd4600000000009fb277",
      "text": "  USB Aの口の数が問題になることに気づいた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532231,
      "updated": 1777532248
    },
    {
      "id": "69f2fd5800000000009fb278",
      "text": "   A2口、C1口のものが多い",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532249,
      "updated": 1777532352
    },
    {
      "id": "69f2fd7a00000000009fb27a",
      "text": "   マウス+HDD2台つなげたいことがある",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532283,
      "updated": 1777532299
    },
    {
      "id": "69f2fd8e00000000009fb27b",
      "text": "   とりあえずUSBハブを買うか",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532303,
      "updated": 1777532312
    },
    {
      "id": "69f199f00000000000e16904",
      "text": " やらないけど、自分で激安で揃えるなら、、",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441265,
      "updated": 1777532231
    },
    {
      "id": "69f199fb0000000000e16905",
      "text": "  メモリ8GBでLInuxでLibreOffice？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441276,
      "updated": 1777441295
    },
    {
      "id": "69f19a0f0000000000e16906",
      "text": "  中古で買ってバッテリーを換装する or 外付けバッテリー前提の運用にする？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441296,
      "updated": 1777441323
    },
    {
      "id": "69f19d060000000000b18043",
      "text": "  \tどんなに激安狙いでもバッテリーは安上がりの方向に走りたくない。ノートであってもデスクトップであっても、電源が死ぬと他もイロイロ死ぬので[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1777442054,
      "updated": 1777442114
    },
    {
      "id": "69f198340000000000b18036",
      "text": " テキトーに記述してみる[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1777440821,
      "updated": 1777440830
    },
    {
      "id": "69f1983e0000000000b18037",
      "text": " \t会社で選ぶパソコンは基本dellなのでとりあえずdellで考える",
      "userId": "65e1289acd012200235729c0",
      "created": 1777440830,
      "updated": 1777440843
    },
    {
      "id": "69f199190000000000b1803e",
      "text": " \t\t会社の場合法人割引が適用されるためのdellであって、別に好きとかこだわりがあるわけではないのでどこでもいいんじゃないかなとも思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1777441055,
      "updated": 1777441089
    },
    {
      "id": "69f1984b0000000000b18038",
      "text": " \tサイズ14インチは画面小さいような気がする＆最近は16インチも各社ががんばって勝負しているからコスパいい感じなのあると勝手に思っているのでこっちのほうが良い気がする",
      "userId": "65e1289acd012200235729c0",
      "created": 1777440843,
      "updated": 1777440885
    },
    {
      "id": "69f198be0000000000b1803d",
      "text": " \t\t持ち運びを考えない、考えたとしても家の中だけならば14よりも16じゃないかなと思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1777440959,
      "updated": 1777440989
    },
    {
      "id": "69f198e60000000000e168f7",
      "text": " \t\tそう思う[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777440999,
      "updated": 1777441004
    },
    {
      "id": "69f198750000000000b18039",
      "text": " \tとなるとこれあたりか",
      "userId": "65e1289acd012200235729c0",
      "created": 1777440885,
      "updated": 1777440890
    },
    {
      "id": "69f1987a0000000000b1803a",
      "text": " \t\thttps://www.dell.com/ja-jp/shop/dellのノートパソコン/dell-16ノートパソコン/spd/dell-dc16255-laptop",
      "userId": "65e1289acd012200235729c0",
      "created": 1777440891,
      "updated": 1777440898
    },
    {
      "id": "69f198840000000000b1803b",
      "text": " \tとはいえoffice入れると結構なお値段になるしどうしましょ",
      "userId": "65e1289acd012200235729c0",
      "created": 1777440900,
      "updated": 1777441224
    },
    {
      "id": "69f199c70000000000b1803f",
      "text": " \t少し前に買ったのは、家の近くのパソコンショップで出されていた、中古ゲーミングノートPCだったなと思い出す",
      "userId": "65e1289acd012200235729c0",
      "created": 1777441224,
      "updated": 1777441810
    },
    {
      "id": "69f199e40000000000b18040",
      "text": " \t中古とはいえ腐ってもゲーミングノートなのでスペック十分、そこそこ古ければそれなりにお得という意味でアリだと思うがタイミングと店の状況次第の運ゲーでオススメできないか",
      "userId": "65e1289acd012200235729c0",
      "created": 1777441253,
      "updated": 1777441286
    },
    {
      "id": "69ef14c2000000000046aae8",
      "text": " [親のパソコン]買う時、日本語のちゃんとしたサポート窓口があるメーカーを選ぶ[caki.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777276099,
      "updated": 1777441871
    },
    {
      "id": "69f19baf000000000063d65f",
      "text": "  いちいち呼ばれると大変なので…",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777441711,
      "updated": 1777441731
    },
    {
      "id": "69f19c1b0000000000e1690b",
      "text": "  使い方変わらずなのでうちのケースはここは気にしなくて良さそう[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441820,
      "updated": 1777441849
    },
    {
      "id": "69f19c380000000000e1690c",
      "text": "   ややこしい時期はクリア済みで、親は自力で解決できる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441850,
      "updated": 1777441864
    },
    {
      "id": "69f1a0e20000000000e16912",
      "text": "   インターネット接続がないことでトラブルの原因の大半がなくなる気がする",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777443043,
      "updated": 1777443073
    },
    {
      "id": "69f1a2fa0000000000bf2efd",
      "text": "    Wikipediaダウンロードしたやつをローカルで見れるようにするとか面白そう[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1777443578,
      "updated": 1777443643
    },
    {
      "id": "69f1a3070000000000bf2efe",
      "text": "     インターネットのない地域の子どもたちにUSBに入れて配ってる話があった",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1777443591,
      "updated": 1777443631
    },
    {
      "id": "69f1a3140000000000bf2eff",
      "text": "     Wikipedia 2026 5月号みたいな感じで毎月届けるとか",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1777443605,
      "updated": 1777443631
    },
    {
      "id": "69f1a3c70000000000e16914",
      "text": "     田舎のスタンドアローン環境と[ポストアポカリプス]の類似性を感じる[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777443784,
      "updated": 1777443821
    },
    {
      "id": "69f1a5b200000000001fc8e7",
      "text": "    \t[Wikipedia のダンプ]がある[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777444274,
      "updated": 1777446164
    },
    {
      "id": "69f19c970000000000e1690d",
      "text": "\tプリインストールソフトをどうするか[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777441944,
      "updated": 1777543306
    },
    {
      "id": "69f32888000000000090a4ac",
      "text": "\t\t今回買ったものがどうかはわからないけど、バスターさんなど 3rd party の要らないものもひっついてくる",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777543306,
      "updated": 1777543350
    },
    {
      "id": "69f330f8000000000002a398",
      "text": "\t\t日本のメーカーのパソコンにはそういうの多いイメージ[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545465,
      "updated": 1777545485
    },
    {
      "id": "69f3310c000000000002a399",
      "text": "\t\t Lenovoはどうかな？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545485,
      "updated": 1777545495
    },
    {
      "id": "69f328b9000000000090a4ad",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777543355,
      "updated": 1777543359
    },
    {
      "id": "69f2fe8100000000009fb27c",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532547,
      "updated": 1777532547
    },
    {
      "id": "69f2fe8100000000009fb27d",
      "text": " 買った[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532547,
      "updated": 1777532968
    },
    {
      "id": "69f3022400000000009fb281",
      "text": "  ノートパソコン、外付けHDD、有線マウス、USBハブ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777533478,
      "updated": 1777533513
    },
    {
      "id": "69f31a2e00000000002706a7",
      "text": "   [IdeaPad Slim 3]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777539632,
      "updated": 1777541158
    },
    {
      "id": "69f3312f000000000002a39a",
      "text": "   メモリ16GBで最安で店頭にあったもの",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545520,
      "updated": 1777545537
    },
    {
      "id": "69f3317d000000000002a39d",
      "text": "    SDカードスロットがあったのも加点",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545598,
      "updated": 1777545609
    },
    {
      "id": "69f331d6000000000002a39e",
      "text": "     実家に[inajob.icon]がデータを送るときに使ってるため",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545687,
      "updated": 1777545700
    },
    {
      "id": "69f2fe8600000000009fb27e",
      "text": "  MS Officeのアクティベーションにインターネット接続が必要そう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532551,
      "updated": 1777532570
    },
    {
      "id": "69f3002000000000009fb27f",
      "text": "   テザリングでできるかなぁ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777532961,
      "updated": 1777532966
    },
    {
      "id": "69f3209b000000000002a394",
      "text": "  外付けHDDにバックアップを試みる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777541277,
      "updated": 1777541291
    },
    {
      "id": "69f33230000000000002a3a3",
      "text": "   バックアップのバックアップだね",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545778,
      "updated": 1777545784
    },
    {
      "id": "69f320ab000000000002a395",
      "text": "   20時間と出ている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777541292,
      "updated": 1777541296
    },
    {
      "id": "69f331e8000000000002a39f",
      "text": "    8時間30分に減った",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545706,
      "updated": 1777545715
    },
    {
      "id": "69f331f2000000000002a3a0",
      "text": "    片方のHDDが USB 2.0のポートに刺さってるのがまずそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545715,
      "updated": 1777545738
    },
    {
      "id": "69f33219000000000002a3a2",
      "text": "     この作業は新しいマシンでやったほうがスムーズだったろう、、",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545754,
      "updated": 1777545771
    },
    {
      "id": "69f3320a000000000002a3a1",
      "text": "    まぁ一晩で終わるならいいか、、",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777545739,
      "updated": 1777545746
    },
    {
      "id": "69f3358d0000000000f41486",
      "text": "  定常的に2台のHDDを同期する作業を自動化する方法を伝えたい",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777546638,
      "updated": 1777546657
    },
    {
      "id": "69f335a10000000000f41487",
      "text": "   何か簡単なツールを導入すればよさそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777546658,
      "updated": 1777546671
    },
    {
      "id": "69f335e40000000000f4148a",
      "text": "    Geminiに聞いたところFastCopyが良さそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777546725,
      "updated": 1777546737
    },
    {
      "id": "69f335f10000000000f4148b",
      "text": "    玄人ならRobocopyでも良いのだがCLIは流石に父親にはつらかろう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777546738,
      "updated": 1777546771
    },
    {
      "id": "69f335af0000000000f41488",
      "text": "   今の人間が判断をするようなやり方をしっかりヒアリングする必要あり",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777546672,
      "updated": 1777546688
    },
    {
      "id": "69f335c10000000000f41489",
      "text": "    機械的にあっちをこっちにコピーする、というやり方に切り替えてもらう必要あり",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777546691,
      "updated": 1777546707
    },
    {
      "id": "69f19c970000000000e1690e",
      "text": " 話に乗ってきてくれる方がいて楽しい[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441944,
      "updated": 1777441959
    },
    {
      "id": "69f19c9c0000000000e1690f",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777441949,
      "updated": 1777441949
    }
  ]
}