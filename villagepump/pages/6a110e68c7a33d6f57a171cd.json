      "updated": 1779502697
    },
    {
      "id": "6a110e6800000000005d9426",
      "text": "\t[https://gyazo.com/0d3ad70d9d6c6748a7ae8acdbc59b3a1]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1779502697,
      "updated": 1779502697
    },
    {
      "id": "6a110e6800000000005d9427",
      "text": "\t人によって違いが出るんだろうか？",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1779502697,
      "updated": 1779502697
    },
    {
      "id": "6a110e6800000000005d9428",
