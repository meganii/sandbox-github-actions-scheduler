  "updated": 1772864367,
  "lines": [
    {
      "id": "69ab9f7f0827214dee498d7b",
      "text": "不必要に重い言葉",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f9500000000002976ff",
      "text": "参考：[重い言葉のインターネットスラング - yozba https://scrapbox.io/yozba/%E9%87%8D%E3%81%84%E8%A8%80%E8%91%89%E3%81%AE%E3%82%A4%E3%83%B3%E3%82%BF%E3%83%BC%E3%83%8D%E3%83%83%E3%83%88%E3%82%B9%E3%83%A9%E3%83%B3%E3%82%B0]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297700",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69aba00c0000000000297726",
      "text": "[不必要に重い言葉 - hoagecko https://scrapbox.io/hoagecko/%E4%B8%8D%E5%BF%85%E8%A6%81%E3%81%AB%E9%87%8D%E3%81%84%E8%A8%80%E8%91%89]からの転載です[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855309,
      "updated": 1772855330
    },
    {
      "id": "69aba00c0000000000297727",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855309,
      "updated": 1772855309
    },
    {
      "id": "69ab9fb10000000000297725",
      "text": "#書いてけ",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855217,
      "updated": 1772855229
    },
    {
      "id": "69ab9fb00000000000297724",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855216,
      "updated": 1772855216
    },
    {
      "id": "69ab9f950000000000297701",
      "text": "[強い言葉]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69aba1330000000000297741",
      "text": "[不必要性]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855603,
      "updated": 1772855630
    },
    {
      "id": "69ab9f950000000000297702",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297703",
      "text": "反対: [不必要に軽い言葉]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297704",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297705",
      "text": "一般的な俗語",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297706",
      "text": "　[ゲリラ豪雨]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297707",
      "text": "　お通夜ムード",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297708",
      "text": "　[死票]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855643
    },
    {
      "id": "69ab9f950000000000297709",
      "text": "　震源地",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029770a",
      "text": "　\t話題の〜",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029770b",
      "text": "　\t流行の〜",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029770c",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029770d",
      "text": "野球",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029770e",
      "text": "　死球",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855651
    },
    {
      "id": "69ab9f95000000000029770f",
      "text": "　盗塁",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297710",
      "text": "　[https://mainichi.jp/articles/20260305/k00/00m/050/264000c 「刺せ」「殺せ」なんで野球は当たり前?　高校球児が疑問を深掘り | 毎日新聞]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297711",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297712",
      "text": "インターネットスラング",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297713",
      "text": "　テロ",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297714",
      "text": "  [飯テロ]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297715",
      "text": "  [バイトテロ]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297716",
      "text": " [地雷系]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297717",
      "text": " [人権]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297718",
      "text": "\t　人権キャラ",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69aba1c10000000000297743",
      "text": "\t　[人権(ゲーム用語)]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855745,
      "updated": 1772855745
    },
    {
      "id": "69ab9f950000000000297719",
      "text": "\t難民",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029771a",
      "text": "\t\t「Twitter難民」",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029771b",
      "text": "　脳死",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029771c",
      "text": "　　無思考に行動するという意味",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029771d",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029771e",
      "text": "関連？",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f95000000000029771f",
      "text": " [~ おちんちん]に相当する[女性器の俗称]がない問題",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772855189,
      "updated": 1772864367
    },
    {
      "id": "69ab9f950000000000297720",
      "text": " \t必要だが存在しない[弱い言葉]への言い換え",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
      "id": "69ab9f950000000000297721",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1772855189,
      "updated": 1772855189
    },
    {
