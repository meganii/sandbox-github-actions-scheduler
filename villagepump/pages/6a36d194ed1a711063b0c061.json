  "lines": [
    {
      "id": "6a36d194ed1a711063b0c061",
      "text": "僭越ながら",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977495,
      "updated": 1781977495
    },
    {
      "id": "6a36d1970000000000604238",
      "text": "[https://img.shields.io/badge/😦-僭越ながら-ccc.svg?style=social#.svg]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977495,
      "updated": 1781977510
    },
    {
      "id": "6a36d1980000000000604239",
      "text": "「本来は自分の立場を超えた出過ぎた発言（行動）であると承知しつつ、あえて申し上げる」という[謙遜]の意を示す[クッション言葉]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977496,
      "updated": 1781977654
    },
    {
      "id": "6a36d237000000000060423d",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977655,
      "updated": 1781977655
    },
    {
      "id": "6a36d235000000000060423c",
      "text": "恐れながら",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977654,
      "updated": 1781977658
    },
    {
      "id": "6a36d22c000000000060423b",
      "text": "差し出がましいようですが",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977644,
      "updated": 1781977678
    },
    {
      "id": "6a36d248000000000060423e",
      "text": "不躾ながら",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977672,
      "updated": 1781977710
    },
    {
      "id": "6a36d263000000000060423f",
      "text": "微力ながら",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977700,
      "updated": 1781977749
    },
    {
      "id": "6a36d2910000000000604240",
      "text": "及ばずながら",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781977745,
      "updated": 1781977761
    },
