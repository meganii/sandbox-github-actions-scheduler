    {
      "id": "6a257b5706a12dab80490d5f",
      "text": "Joniel",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841306,
      "updated": 1780841306
    },
    {
      "id": "6a257bf60000000000bd2893",
      "text": "#member",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841461,
      "updated": 1780841464
    },
    {
      "id": "6a257ba70000000000bd288f",
      "text": "[https://gyazo.com/6671d83800f4cce8015b7cfaa90c1fd7]",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841383,
      "updated": 1780841458
    },
    {
      "id": "6a257bf20000000000bd2892",
      "text": "",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841458,
      "updated": 1780841458
    },
    {
      "id": "6a257dee0000000000bd2899",
      "text": "　なまえ：Joniel（じょにえる）",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841966,
      "updated": 1780841976
    },
    {
      "id": "6a2584780000000000bd28c1",
      "text": "[井戸端に来た日]は[2026/06/07]",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780843639,
      "updated": 1780843653
    },
    {
      "id": "6a2584790000000000bd28c2",
      "text": "",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780843641,
      "updated": 1780843641
    },
    {
      "id": "6a257dee0000000000bd289a",
      "text": "　来歴",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841966,
      "updated": 1780842038
    },
    {
      "id": "6a257e370000000000bd289c",
      "text": "　　19卒。つまり翌年にアレが来た。",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842039,
      "updated": 1780842203
    },
    {
      "id": "6a257e5c0000000000bd289d",
      "text": "　　口減らしとかでなんか退職し、一年半くらい生き延びたり死にかけたりした",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842076,
      "updated": 1780842234
    },
    {
      "id": "6a257e7a0000000000bd289f",
      "text": "　　その後今の会社に非正規で入社。給料やっすいけど大手サイコー",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842106,
      "updated": 1780842145
    },
    {
      "id": "6a257e850000000000bd28a0",
      "text": "　　今の仕事を一生やる気になってきたので、がんばりたいです",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842116,
      "updated": 1780842151
    },
    {
      "id": "6a257e700000000000bd289e",
      "text": "",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842096,
      "updated": 1780842098
    },
    {
      "id": "6a257ba70000000000bd2890",
      "text": "Cosense歴",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841383,
      "updated": 1780841966
    },
    {
      "id": "6a257ba80000000000bd2891",
      "text": " 2020年～くらい",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841383,
      "updated": 1780842352
    },
    {
      "id": "6a257da30000000000bd2898",
      "text": "  個人用、家族用、たまにコミュニティの研究ノートに書くくらい",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841891,
      "updated": 1780841930
    },
    {
      "id": "6a257d7c0000000000bd2895",
      "text": " 公開用のScrapbox",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841851,
      "updated": 1780841889
    },
    {
      "id": "6a257d980000000000bd2897",
      "text": "  準備中どす。",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841880,
      "updated": 1780842427
    },
    {
      "id": "6a257fbb0000000000bd28a2",
      "text": " 　 転職活動するときのポートフォリオみたいなのを兼ねる感じでやりたい",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842427,
      "updated": 1780842429
    },
    {
      "id": "6a257d8f0000000000bd2896",
      "text": " 趣味指向",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780841870,
      "updated": 1780842480
    },
    {
      "id": "6a2580080000000000bd28a5",
      "text": " 　2026年3月～デュエマに復帰してドはまり中。",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842504,
      "updated": 1780842527
    },
    {
      "id": "6a2580210000000000bd28a6",
      "text": " 　　レギュレーションはデュエパ、TCGの好きじゃなかった所が全部無くて快適",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842528,
      "updated": 1780842553
    },
    {
      "id": "6a25803a0000000000bd28a7",
      "text": " 　2024～から中古の少女漫画を大量に買っては読んでいる",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842554,
      "updated": 1780842568
    },
    {
      "id": "6a25805e0000000000bd28a9",
      "text": " 　自分の弱点の大部分をAIが補ってくれるようになったので色々やっている",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842590,
      "updated": 1780842626
    },
    {
      "id": "6a2580890000000000bd28aa",
      "text": " 　音楽もやっている。コンテンポラリーブレイクビーツメタルみたいなのをボカコレに投稿しては大滑りしている",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842632,
      "updated": 1780842667
    },
    {
      "id": "6a25864b0000000000bd28ca",
      "text": " 　2025年はサプリメントにハマっていた。合うものが見つかったので今は固定",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780844107,
      "updated": 1780844178
    },
    {
      "id": "6a257fd00000000000bd28a3",
      "text": " 仕事",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842447,
      "updated": 1780842749
    },
    {
      "id": "6a2581030000000000bd28ac",
      "text": " 　ゲーム関係。あんま書くとすぐ身バレしそうでこわい",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842755,
      "updated": 1780842782
    },
    {
      "id": "6a2581280000000000bd28ae",
      "text": " 　転職先も同業の予定",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842792,
      "updated": 1780842805
    },
    {
      "id": "6a257fd00000000000bd28a4",
      "text": " 専攻",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842447,
      "updated": 1780842818
    },
    {
      "id": "6a2581430000000000bd28b0",
      "text": "　　経済学部。なんだかんだ役に立ってる気がする",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842819,
      "updated": 1780844863
    },
    {
      "id": "6a25816f0000000000bd28b2",
      "text": "　Joinした理由",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842862,
      "updated": 1780842875
    },
    {
      "id": "6a25817d0000000000bd28b3",
      "text": "　　（※現代のインターネットに関する愚痴が3000文字省略されました※）",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842876,
      "updated": 1780842902
    },
    {
      "id": "6a25839f0000000000bd28bf",
      "text": "　　SNSに欲しいものが現代のSNSに無く、ここにありそうだったから",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780843422,
      "updated": 1780843434
    },
    {
      "id": "6a25818d0000000000bd28b4",
      "text": "　　他人から観測可能な形で連続性がある記録をしたくなった",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842892,
      "updated": 1780843257
    },
    {
      "id": "6a2581bd0000000000bd28b5",
      "text": "　　　これまで個人が実在しないかのように振舞っていたのでその真逆",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842941,
      "updated": 1780842967
    },
    {
      "id": "6a2581570000000000bd28b1",
      "text": "　　個人用[* Scrapbox]を更新するモチベが落ちてきたとか",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842838,
      "updated": 1780843044
    },
    {
      "id": "6a2582250000000000bd28ba",
      "text": "　　他人が十分理解できる形で文章を書くモチベが上がってきたとか。",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780843045,
      "updated": 1780843114
    },
    {
      "id": "6a2581da0000000000bd28b6",
      "text": "　　　誰にわかるように書くか？という問いがやって来まして。",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842971,
      "updated": 1780843750
    },
    {
      "id": "6a25828e0000000000bd28bb",
      "text": "　　気が付いたらここに参加してたってワケ。",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780843149,
      "updated": 1780843159
    },
    {
      "id": "6a25829a0000000000bd28bc",
      "text": "　　　さっきの出来事なのにどうやってたどり着いたか本当に覚えてない",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780843162,
      "updated": 1780843174
    },
    {
      "id": "6a2581db0000000000bd28b7",
      "text": "",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842971,
      "updated": 1780842971
    },
    {
      "id": "6a2581db0000000000bd28b8",
      "text": "",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842971,
      "updated": 1780842971
    },
    {
      "id": "6a2581db0000000000bd28b9",
      "text": "",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842971,
      "updated": 1780842971
    },
    {
      "id": "6a257d740000000000bd2894",
      "text": "こんばんは ようこそ😃[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1780841843,
      "updated": 1780842257
    },
    {
      "id": "6a257f250000000000bd28a1",
      "text": "　うわおリアタイで書き込まれてるの始めてみた、よろしゅうです[Joniel.icon]",
      "userId": "6a257912c40c8afba490c3cc",
      "created": 1780842277,
      "updated": 1780842307
    },
    {
      "id": "6a257f0800000000004485a9",
      "text": "  そっか Cosense歴めっちゃ長いのに[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1780842248,
      "updated": 1780842315
    },
    {
      "id": "6a2582d200000000004485af",
      "text": "  多人数projectに参加してたりするユーザ特有の体験をもっとたくさんのcosenseユーザーに広めたい気持ちがある",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1780843218,
      "updated": 1780843232
    },
    {
      "id": "6a2582f400000000004485b0",
      "text": "   個人用にcosenseを使っていると共同編集用の機能を足かせに感じることもあるが…",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1780843253,
      "updated": 1780843290
    },
    {
      "id": "6a2580b80000000000bd28ab",
      "text": " この感じ[小学生の時に憧れてたインターネット]ぽくて興奮する[Joniel.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1780842679,
      "updated": 1780874388
    },
    {
      "id": "6a257f9000000000004485ac",
