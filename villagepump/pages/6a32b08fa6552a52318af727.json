      "updated": 1781706900
    },
    {
      "id": "6a32b09300000000003e1b0e",
      "text": "[UserCSS.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781706900,
      "updated": 1781706912
    },
    {
      "id": "6a5623840000000000850d13",
      "text": "#Scrapboxの引用記法",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030085,
      "updated": 1784030111
    },
    {
      "id": "6a5623a50000000000850d15",
      "text": "#引用ブロック",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030118,
      "updated": 1784030118
    },
    {
      "id": "6a32b0a100000000003e1b10",
      "text": "　> 引用ブロック",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781706913,
      "updated": 1781710141
    },
    {
      "id": "6a32b0b700000000003e1b12",
      "text": "[インライン引用記法]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781706935,
      "updated": 1781707048
    },
    {
      "id": "6a32b12a00000000003e1b22",
      "text": " [\" インライン引用]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781707050,
      "updated": 1781710144
    },
    {
      "id": "6a4dc68600000000009d0ac1",
      "text": " [>_ インライン引用]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783481990,
      "updated": 1783482001
    },
    {
      "id": "6a32b1af00000000003e1b26",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781707183,
      "updated": 1784030222
    },
    {
      "id": "6a32b0ab00000000003e1b11",
      "text": " code:style.css",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781706923,
      "updated": 1781706946
    },
    {
      "id": "6a32b0c200000000003e1b13",
      "text": "  html {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781706946,
      "updated": 1781706962
    },
    {
      "id": "6a32b0da00000000003e1b16",
      "text": "   \t--quote-border-color: light-dark(hsl(216 15% 74%), hsl(196 10% 44%));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781706970,
      "updated": 1783481726
    },
    {
      "id": "6a32b15200000000003e1b23",
      "text": "  \t--quote-border-width: 2.5px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781707090,
      "updated": 1783138985
    },
    {
      "id": "6a32b15200000000003e1b24",
      "text": "  \t--inline-quote-border-width: 2px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781707090,
      "updated": 1783481733
    },
    {
      "id": "6a32b0d200000000003e1b15",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781706963,
      "updated": 1781706963
    },
    {
      "id": "6a5623c30000000000850d27",
      "text": "  .quote {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d28",
      "text": "  \t.line & {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d29",
      "text": " \t\t\tdisplay: block; box-sizing: border-box;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d2a",
      "text": " \t\t\tborder-left: solid var(--quote-border-width, 1px) var(--quote-border-color, #a0a0a0);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d2b",
      "text": " \t\t\t/* padding-left: 3px; */",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d2c",
      "text": " \t\t\t--quote-padding-left: calc(2px + var(--quote-border-width, 1px));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d2d",
      "text": " \t\t\tpadding-left: var(--quote-padding-left, 3px);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d2e",
      "text": " \t\t\tpadding-right: var(--quote-padding-end, var(--quote-padding-left, 3px));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030216
    },
    {
      "id": "6a5624070000000000850d3f",
      "text": " \t\t\tbackground-color: var(--quote-bg-color, rgba(0, 0, 0, 0.05));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030216,
      "updated": 1784030216
    },
    {
      "id": "6a5623c30000000000850d2f",
      "text": " \t\t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d30",
      "text": " \t\t.line & > .tag {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d31",
      "text": "\t\t\t\tdisplay: inline-block;\tvertical-align: top;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d32",
      "text": "\t\t\t\twidth: calc(var(--indent-width, 1.5em) - var(--quote-padding-left, 3px) - var(--quote-border-width, 1px));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d33",
      "text": "\t\t\t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d34",
      "text": "\t\t\t.line.cursor-line & > .tag {\twidth: unset;\t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5623c30000000000850d35",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030148,
      "updated": 1784030148
    },
    {
      "id": "6a5624100000000000850d40",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030225,
      "updated": 1784030225
    },
    {
      "id": "6a5624100000000000850d41",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030225,
      "updated": 1784030225
    },
    {
      "id": "6a5624120000000000850d43",
      "text": "[2026-07-14] [/customize/引用ブロック記法の字下げ幅をインデント幅と同じにする]を導入した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030227,
      "updated": 1784030289
    },
    {
      "id": "6a5624340000000000850d44",
      "text": " cf. [引用記法内のバレット位置が縦に揃わない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030261,
      "updated": 1784030267
    },
    {
      "id": "6a5624c00000000000e34703",
      "text": "2026-07-08 再調整",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030401,
      "updated": 1784030401
    },
    {
      "id": "6a5624c00000000000e34704",
      "text": "　`--quote-border-color:`を`light-dark(hsl(216 10% 75%), ...)`から`light-dark(hsl(216 15% 74%), ...)`に変更した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030401,
      "updated": 1784030401
    },
    {
      "id": "6a5624c00000000000e34705",
      "text": "　`--inline-quote-border-width`を`2.5px`→`2px`に変更した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030401,
      "updated": 1784030719
    },
    {
      "id": "6a5625df0000000000db8737",
      "text": "2026-07-04 `--quote-border-width`を`3px`→`2.5px`に変更した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030688,
      "updated": 1784030701
    },
    {
      "id": "6a5624c00000000000e34708",
      "text": "2026-06-23 `--quote-border-width`を`3px`に修正",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030401,
      "updated": 1784030711
    },
    {
      "id": "6a5624c00000000000e34709",
      "text": "2026-06-19 有効化",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030401,
      "updated": 1784030424
    },
    {
      "id": "6a5624c00000000000e3470a",
      "text": "2026-06-18 12:30ごろ 無効化",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030401,
      "updated": 1784030401
    },
    {
      "id": "6a5625340000000000e3470c",
      "text": "2026-06-17 23:30ごろ Settingsに適用",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784030517,
      "updated": 1784030564
    },
