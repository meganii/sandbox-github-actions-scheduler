    {
      "id": "6a066bdb7c52a7cc879cddff",
      "text": "マインドクラフト",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778805726,
      "updated": 1778805726
    },
    {
      "id": "6a10ea130000000000bc5140",
      "text": "[デライト.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1779493396,
      "updated": 1779493397
    },
    {
      "id": "6a10ea150000000000bc5141",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1779493398,
      "updated": 1779493398
    },
    {
      "id": "6a066bc700000000005eb912",
      "text": " 一時よく使っていた[デライト]のキャッチコピーの一つ[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778805726,
      "updated": 1778805742
    },
    {
      "id": "6a066d5000000000005eb91a",
      "text": "  英語表記は Mindcraft",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778806120,
      "updated": 1778806687
    },
    {
      "id": "6a066bd700000000005eb914",
      "text": "  デライトは「[個人知識管理サービス]」として売り込んでいた印象が強い人が多いだろう",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778805742,
      "updated": 1778805771
    },
    {
      "id": "6a066bf500000000005eb916",
      "text": "  それも実は仮の姿で、「デライトはデライトである」としか言えないような独自性の塊のようなデライトを売り込むためにありとあらゆる手段を考えていた",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778805772,
      "updated": 1778805969
    },
    {
      "id": "6a066c5600000000005eb918",
      "text": "  その一つが[マインクラフト]のような感覚で自分の知識を育てられる「知的箱庭[ブラウザゲーム]」として売り込むという手段である",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778805870,
      "updated": 1778806267
    },
    {
      "id": "6a066be500000000005eb915",
      "text": "   この売り方は成功こそしなかったが、「マインドクラフト」という造語は捨て難いのでどこかで活用したいと思っている",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778805756,
      "updated": 1778806090
    },
    {
      "id": "6a066cd400000000005eb919",
      "text": "",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1778805996,
      "updated": 1778805996
    }
  ]
}