    {
      "id": "6a27938c65202385f6391150",
      "text": "Cotoami",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978673,
      "updated": 1780978673
    },
    {
      "id": "6a2793ee0000000000aab521",
      "text": "https://cotoami.app/",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978673,
      "updated": 1780978675
    },
    {
      "id": "6a2793fd0000000000aab522",
      "text": "[https://github.com/cotoami/cotoami-remake GitHub - cotoami/cotoami-remake: Connect ideas and places in a knowledge graph. Designed for both private use and real-time collaboration through networked databases. · GitHub]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978687,
      "updated": 1780978692
    },
    {
      "id": "6a2794020000000000aab523",
      "text": "> Cotoami (言編み・言網) is a note-taking application that helps your personal and team knowledge naturally evolve into a concept-based knowledge base. It's a standalone, cross-platform application with offline support.",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978692,
      "updated": 1780978726
    },
    {
      "id": "6a2794240000000000aab525",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978726,
      "updated": 1780978727
    },
    {
      "id": "6a2794a00000000000aab528",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978850,
      "updated": 1780978850
    },
    {
      "id": "6a2794290000000000aab526",
      "text": "\t使ったことはないが気になっている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978731,
      "updated": 1780978861
    },
    {
      "id": "6a2794a70000000000aab529",
      "text": "\tremake版になっていた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978857,
      "updated": 1780978857
    },
    {
      "id": "6a2794d70000000000aab52a",
      "text": "\t\t位置情報に重きが置かれる改修がなされている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978906,
      "updated": 1780978916
    },
    {
      "id": "6a2796ba0000000000aab52f",
      "text": "\t\t[https://zenn.dev/marubinotto/articles/cotoami-remake 自作のWebアプリをLocal-firstなデスクトップアプリとして作り直した話（Elixir+ElmからRust+Scala.jsへ）]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780979387,
      "updated": 1780979393
    },
    {
      "id": "6a2796c00000000000aab530",
      "text": "  \tリメイクの記事発見",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780979393,
      "updated": 1780979397
    },
    {
      "id": "6a27987500000000002bc2da",
      "text": "  \t旧版のフロントエンド[Elm]なんだ[zatsma.icon]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1780979830,
      "updated": 1780979857
    },
    {
      "id": "6a27948c0000000000aab527",
      "text": "\tストック情報とフロー情報を組み合わせて扱うことができるツールと理解している",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780978831,
      "updated": 1780978849
    },
    {
      "id": "6a27b5c20000000000df222f",
      "text": "\tデスクトップアプリしかないのがつらそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780987331,
      "updated": 1780987339
    },
    {
      "id": "6a27986a00000000002bc2d8",
