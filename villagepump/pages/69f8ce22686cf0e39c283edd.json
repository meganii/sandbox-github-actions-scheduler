      "id": "69f8ce22686cf0e39c283edd",
      "text": "2026/05/05",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777913378,
      "updated": 1777913378
    },
    {
      "id": "69f8ce236eb406000000394135",
      "text": "第19週: 日月[[火]]水木金土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777913380,
      "updated": 1777913380
    },
    {
      "id": "69f8ce236eb406000000d2d054",
      "text": "2026年 34.25％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777913380,
      "updated": 1777913380
    },
    {
      "id": "69f8ce236eb406000000b7feb6",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1777913380,
      "updated": 1777913380
    },
    {
      "id": "69f8ce236eb4060000008d1593",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777913380,
      "updated": 1777924082
    },
    {
      "id": "69f8f7f30000000000b60a91",
      "text": " 睡眠リズムが前倒しになっている",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777924083,
      "updated": 1777924132
    },
    {
      "id": "69f9a03b0000000000f0239f",
      "text": " ✂ [デライトの人が来たのをキッカケにデライト談義が始まる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967163,
      "updated": 1777967224
    },
    {
      "id": "69f96db90000000000be5e86",
      "text": "\t[情報の量をどう測るか]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777954233,
      "updated": 1778113582
    },
    {
      "id": "69f9c0290000000000f399f6",
      "text": " 自律的反省会",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975337,
      "updated": 1777975745
    },
    {
      "id": "69f9c1b90000000000f399fd",
      "text": " ツッコむ時に証明的なやり方をするのがそもそも私のダメコミュニケーション",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975738,
      "updated": 1777975738
    },
    {
      "id": "69f9c05e0000000000f399f7",
      "text": " \t自分に対してやると強いんだけど、他人の話の内容に対してやるのはイカン。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975390,
      "updated": 1777975638
    },
    {
      "id": "69f9c09b0000000000f399f8",
      "text": " \t\tプラトンしよう。ソクラテスになったらドクニンジンで殺される。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975452,
      "updated": 1777975469
    },
    {
      "id": "69f9c0c70000000000f399f9",
      "text": " \tガソリンが満たされているとはまた違うダメさ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975495,
      "updated": 1777975512
    },
    {
      "id": "69f9c1740000000000f399fb",
      "text": " 問を提起しているっぽい感じと、ほぼ否定してるっぽい感じの違い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975668,
      "updated": 1777975723
    },
    {
      "id": "69f9c1af0000000000f399fc",
      "text": "  あんまりない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975728,
      "updated": 1777975969
    },
    {
      "id": "69f9c2430000000000f399fe",
      "text": "  \tだってタイムマシンに載って過去の自分の変な言動に「そうか？」って言ったら怒るだろうし（唐突な自刃）。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777975876,
      "updated": 1777975943
    },
    {
      "id": "69f9c38c0000000000f39a02",
      "text": " 根本的に違和に注意がずっと向き続けるような認知特性あるいはそこら辺の何かがイカン気がする。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777976204,
      "updated": 1777976331
    },
    {
      "id": "69f9c51f0000000000f39a07",
      "text": "   [ストレスに対する反応]の図",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777976607,
      "updated": 1777976609
    },
    {
      "id": "69f9c4680000000000f39a05",
      "text": "  ここらへんの切り替え方というか、自己の人格構造が根本的に平和寄りに変わるやり方を調べたりするものの結局制御しきれていない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777976424,
      "updated": 1777976545
    },
    {
      "id": "69f9f2a900000000007c20fb",
      "text": " アタフタしている。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777988266,
      "updated": 1777988273
    },
    {
      "id": "69f9f4ab00000000007c20fd",
      "text": " 寝よう。そしてみんなゆっくり休んで欲しい。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777988779,
      "updated": 1777988809
    },
    {
      "id": "69f8f9c100000000007ca351",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777924547,
      "updated": 1777924547
    },
    {
      "id": "69f8f9c200000000007ca352",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777924547,
      "updated": 1777924547
    },
    {
      "id": "69f8f9c600000000007ca355",
      "text": "\tやっぱ昨日強風エグかったのか、チャリも大変だった",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777924550,
      "updated": 1777924561
    },
    {
      "id": "69f8f9d200000000007ca356",
      "text": "\t\t向かい風の平地が実質坂道みたいで心折れそうだった",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777924563,
      "updated": 1777924575
    },
    {
      "id": "69f8f9c200000000007ca353",
      "text": "\t\t[「5月の嵐」全国的に今年一番の強風　青森・八戸市で最大瞬間風速28.7メートル、千葉市で28.5メートル（FNNプライムオンライン）｜ｄメニューニュース（NTTドコモ） https://topics.smt.docomo.ne.jp/article/fnn/nation/fnn-1039726]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777924547,
      "updated": 1777924561
    },
    {
      "id": "69f91a63000000000064b1a1",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1777932897,
      "updated": 1777932962
    },
    {
      "id": "69f91ea300000000003fece6",
      "text": "[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1777933986,
      "updated": 1777933987
    },
    {
      "id": "69f91ea500000000003fece7",
      "text": " [https://www.shinmai.co.jp/news/article/gf01d7rh9mr0a7t8vjjviemg 【動画付き】白馬村出身の人気ゲームクリエーター､「東方Project」故郷にあった創作の源泉｜信濃毎日新聞デジタル　信州・長野県のニュースサイト]",
      "userId": "688c296691686a314f82fb52",
      "created": 1777933988,
      "updated": 1777933989
    },
    {
      "id": "69f91eca00000000003fecea",
      "text": " \t[https://www.youtube.com/watch?v=XLH7-kHne88]",
      "userId": "688c296691686a314f82fb52",
      "created": 1777934026,
      "updated": 1777934027
    },
    {
      "id": "69f91ea600000000003fece8",
      "text": " \t[ZUN]さん、ついに地元紙([信濃毎日新聞])デビュー！！",
      "userId": "688c296691686a314f82fb52",
      "created": 1777933990,
      "updated": 1777971975
    },
    {
      "id": "69f91eb400000000003fece9",
      "text": " \t[めでたい.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1777934004,
      "updated": 1777934008
    },
    {
      "id": "69f9afbc0000000000f923d1",
      "text": " \tやはり一般向けに東方Projectの顔はゆっくり霊夢になるのか",
      "userId": "688c296691686a314f82fb52",
      "created": 1777971132,
      "updated": 1777971159
    },
    {
      "id": "69f9a0810000000000f023a1",
      "text": "\t✂ [デライトの人が来たのをキッカケにデライト談義が始まる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967234,
      "updated": 1777967258
    },
    {
      "id": "69f9add40000000000f923c8",
      "text": "\t新聞の縮刷版、昭和前期以前のものでも何故かデジコレにない",
      "userId": "688c296691686a314f82fb52",
      "created": 1777970644,
      "updated": 1777971080
    },
    {
      "id": "69f9af8c0000000000f923d0",
      "text": "\t\t明治期の[京都新聞]姉妹紙の[中外電報]([中外日報]に非ず)を読もうとしたら無くて驚いた",
      "userId": "688c296691686a314f82fb52",
      "created": 1777971085,
      "updated": 1777971967
    },
    {
      "id": "69f8ce236eb406000000f3cda0",
      "text": " [posfie]で10年以上前に消えたネット発のアーティストの情報を漁る意地悪い趣味をしている",
      "userId": "688c296691686a314f82fb52",
      "created": 1777913380,
      "updated": 1777976642
    },
    {
      "id": "69f92bc10000000000ed7037",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777937344,
      "updated": 1777937344
    },
    {
      "id": "69f92bc10000000000ed7038",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777937344,
      "updated": 1777937346
    },
    {
      "id": "69f92bc40000000000ed703a",
      "text": " [おは.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777937347,
      "updated": 1777937360
    },
    {
      "id": "69f92bd20000000000ed703b",
      "text": " いい天気。洗濯物をたくさん洗うぞ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777937361,
      "updated": 1777937373
    },
    {
      "id": "69f9a0af0000000000f023a3",
      "text": " ✂ [デライトの人が来たのをキッカケにデライト談義が始まる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967280,
      "updated": 1777967312
    },
    {
      "id": "69f92bc20000000000ed7039",
      "text": " ルノアールのモーニングウマウマ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777937344,
      "updated": 1777943782
    },
    {
      "id": "69f94caa0000000000de51f8",
      "text": " [円城塔]の[土人形と動死体]を読み始める",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777945769,
      "updated": 1777945801
    },
    {
      "id": "69f94ccb0000000000de51f9",
      "text": "  タイトルや最初の話から、[屍者の帝国]がどうしても頭にチラチラしちゃう",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777945802,
      "updated": 1777945867
    },
    {
      "id": "69f97c8f000000000094c9a4",
      "text": "  一緒に読み始めちゃお[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777958032,
      "updated": 1777958040
    },
    {
      "id": "69f94d140000000000de51fa",
      "text": " 今日は夏日感",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777945875,
      "updated": 1777952590
    },
    {
      "id": "69f9674f00000000005a96d2",
      "text": "  日差しがあっちーね。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777952590,
      "updated": 1777952598
    },
    {
      "id": "69f97bdb00000000001162ba",
      "text": " [麦茶の容器]\t\t\t",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777957852,
      "updated": 1777963525
    },
    {
      "id": "69f9674300000000005a96d1",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1777952577,
      "updated": 1777952577
    },
    {
      "id": "69f939090000000000eaccaa",
      "text": "[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777940746,
      "updated": 1777940749
    },
    {
      "id": "69f9390e0000000000eaccac",
      "text": " Cursirが使えれば別に良いと思っているが、別の課金方法が効率良い場合もあると思うので、VS Code と Claudeの組み合わせを試してみる。",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777940750,
      "updated": 1777940823
    },
    {
      "id": "69f939570000000000eaccad",
      "text": " ターミナルでClaude Codeくん動かすのはあんまり肌に合わないな。",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777940823,
      "updated": 1777940854
    },
    {
      "id": "69f9399a0000000000eaccae",
      "text": "  IDEの上で動いてくれやという気持ちになる",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777940890,
      "updated": 1777940916
    },
    {
      "id": "69f958a9000000000063c8b2",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1777948842,
      "updated": 1777948842
    },
    {
      "id": "69f958a9000000000063c8b3",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1777948842,
      "updated": 1777948846
    },
    {
      "id": "69fbef3900000000003a0d25",
      "text": " ✂ [左大腿骨骨幹部骨折、入院して手術します]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778118457,
      "updated": 1778118507
    },
    {
      "id": "69f959ab00000000004a6b0c",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777949100,
      "updated": 1777949100
    },
    {
      "id": "69f959ab00000000004a6b0d",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777949100,
      "updated": 1777949100
    },
    {
      "id": "69f959ac00000000004a6b0e",
      "text": "\tコツコツ[ゲムマ2026春]準備",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777949101,
      "updated": 1777949138
    },
    {
      "id": "69f95aaa00000000004a6b0f",
      "text": "\t\t[黙談 -Silentalk-.icon]の素人画像編集。レイアウトむずい…",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777949355,
      "updated": 1777949399
    },
    {
      "id": "69f95abb00000000004a6b10",
      "text": "\t\t[https://gyazo.com/8f5646fa43f50b468b04d333ec48a760]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777949372,
      "updated": 1777949373
    },
    {
      "id": "69f958a0000000000063c8b0",
      "text": "   [加油.icon][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777948833,
      "updated": 1777949470
    },
    {
      "id": "69f9c717000000000021efad",
      "text": "   [/emoji/thx.icon] [terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777977112,
      "updated": 1777977114
    },
    {
      "id": "69f9e39200000000003fc5b1",
      "text": "  ゲームマーケット公式ページで[ブログを書いて公開した https://gamemarket.jp/blog/197292]。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777984403,
      "updated": 1777984447
    },
    {
      "id": "69f9e3a100000000003fc5b2",
      "text": "  \tエディタがとても使いづらい🥲 もうHTMLでベタ打ちさせて欲しい🥲🥲",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777984418,
      "updated": 1777985074
    },
    {
      "id": "69f9c71f000000000021efae",
      "text": " 自分の何かの輪郭たちは、言語や平面（スクリーン上）だけでは不充分である直観",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777977119,
      "updated": 1777977259
    },
    {
      "id": "69f9c753000000000021efaf",
      "text": " \tたとえば[黙談 -Silentalk-.icon]自体（ルール、プロダクトデザイン等）も、[黙談 -Silentalk-.icon]をリリース（世に放流した）したという行為も輪郭の1つ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777977172,
      "updated": 1777977230
    },
    {
      "id": "69f9d47100000000003fc5b0",
      "text": " その分野の系統的知識理解の前に、意欲・主体性・協調性などを発揮したくなる誘惑に負けるとき、逆説的に社会から逸脱する。学校には、このために塀と門があるという論者も。「子ども」に[禁固刑]相当を与える[正当性]。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980530,
      "updated": 1778108657
    },
    {
      "id": "69f95b050000000000570d12",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777949446,
      "updated": 1777949446
    },
    {
      "id": "69f9d4d50000000000f39a27",
      "text": "> その分野の系統的知識理解の前に、意欲・主体性・協調性などを発揮したくなる誘惑に負けるとき、逆説的に社会から逸脱する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980630,
      "updated": 1777980644
    },
    {
      "id": "69f9d4e40000000000f39a29",
      "text": "\tこれの中に「協調性」が入ってるのが面白い[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980645,
      "updated": 1777980676
    },
    {
      "id": "69f9d51c0000000000f39a2b",
      "text": "\t前者2つはわかる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980701,
      "updated": 1777980711
    },
    {
      "id": "69f9d5030000000000f39a2a",
      "text": "\t協調性も入っているのは「なぁなぁ」だけではやっていけないということだろうか。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980676,
      "updated": 1777980740
    },
    {
      "id": "69f9d5560000000000f39a2c",
      "text": " \tもうちょっと色んな物が連想された。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980758,
      "updated": 1777980774
    },
    {
      "id": "69f9d5650000000000f39a2d",
      "text": " \t\t迎合、ゴマすり、駄サイクル",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980774,
      "updated": 1777980809
    },
    {
      "id": "69f9d5a40000000000f39a2e",
      "text": " \t協調性が包括的でとても良き。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980837,
      "updated": 1777980873
    },
    {
      "id": "69f9d5ca0000000000f39a2f",
      "text": " 味わい深い。美味しかった。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980875,
      "updated": 1777980882
    },
    {
      "id": "69f9d4d50000000000f39a28",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777980630,
      "updated": 1777980630
    },
    {
      "id": "69f95ad50000000000570d0e",
      "text": "[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777949397,
      "updated": 1777949399
    },
    {
      "id": "69f9a0ec0000000000f023a5",
      "text": "\t✂ [デライトの人が来たのをキッカケにデライト談義が始まる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967341,
      "updated": 1777967379
    },
    {
      "id": "69f95ded0000000000570d14",
      "text": "\tジャワティーベビーユーザー",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777950227,
      "updated": 1777950586
    },
    {
      "id": "69f95f930000000000570d19",
      "text": "\t その辺で買える紅茶飲料の中でいちばんうまいと思っている",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777950612,
      "updated": 1777950650
    },
    {
      "id": "69f9770500000000006ffcf8",
      "text": "\t✂ [デライトの人が来たのをキッカケにデライト談義が始まる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777956613,
      "updated": 1777967598
    },
    {
      "id": "69f9789000000000006ffcfc",
      "text": "\t自分はといえば、ある単語に紐付く概念の変動幅がわりに大きい世界に生きていて、その定義は時、場合、相手などによって変動する",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777957008,
      "updated": 1777957395
    },
    {
      "id": "69f979f200000000006ffcff",
      "text": "\t 変動幅が大きな単語と小さな単語があるなあ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777957369,
      "updated": 1777957415
    },
    {
      "id": "69f97a4100000000006ffd00",
      "text": " \t 変動幅を小さくすることは可能性の幅を縮めて自分というものを定義することにつながる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777957442,
      "updated": 1777957606
    },
    {
      "id": "69f97b5000000000006ffd01",
      "text": "\t  どの単語の変動幅が小さいかを自覚すると、何が自分にとって大事なのか、ということがわかりそう",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777957713,
      "updated": 1777957739
    },
    {
      "id": "69f9a1b800000000004d7625",
      "text": "\t ✂[同一の単語が複数の概念を示すときのcosenseのやりかたとデライトのやりかた]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777967544,
      "updated": 1778123311
    },
    {
      "id": "69f9800500000000006ffd03",
      "text": "\t[何もかもうまくいかない日、あきらめて「なにもかもうまくいかない！」と認めるとそのあとうまくいく]みたいなのある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777958917,
      "updated": 1778118551
    },
    {
      "id": "69f995e700000000006ffd29",
      "text": "\t最近気付いたけど、私はメタル系素材が大好きだな",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777964519,
      "updated": 1777964549
    },
    {
      "id": "69f9a0bd00000000004d7623",
      "text": " [独自の語がいっぱいあるときにおこる問題と、既存の語に一般的でない意味を付与して話されるときにおこる問題]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967295,
      "updated": 1778118602
    },
    {
      "id": "69f97a4e000000000094c9a1",
      "text": " [雑に学ぶMCP]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777957454,
      "updated": 1777970155
    },
    {
      "id": "69f9abe800000000006ffd3f",
      "text": "  MCP完全理解かも",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777970152,
      "updated": 1777970155
    },
    {
      "id": "69f9ac0d00000000006ffd40",
      "text": "  なーんで向こう側もLLMじゃないんだ、と思ったけど向こう側もLLMなのがA2Aか？",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777970189,
      "updated": 1777970227
    },
    {
      "id": "69f9ac6000000000006ffd41",
      "text": "  掃除AI→バケツ用意AI、モップ操作AI",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777970272,
      "updated": 1777970367
    },
    {
      "id": "69f9aca100000000006ffd43",
      "text": "   バケツ用意AI→蛇口アプリ ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777970337,
      "updated": 1777970373
    },
    {
      "id": "69f9acc400000000006ffd44",
      "text": "    これがA2Aか？",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777970373,
      "updated": 1777970378
    },
    {
      "id": "69f9ac9500000000006ffd42",
      "text": "     たぶんそう",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777970325,
      "updated": 1777970378
    },
    {
      "id": "69f9c7310000000000c62d2e",
      "text": " ✂[switch用のソフトはswich2に差して使える]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777977138,
      "updated": 1777987268
    },
    {
      "id": "69f9dfc00000000000c62d36",
      "text": " [うどん札]入手",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777983424,
      "updated": 1777983434
    },
    {
      "id": "69f9dfca0000000000c62d37",
      "text": "  半熟たまご天はおいしい",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777983434,
      "updated": 1777983447
    },
    {
      "id": "69f9abdb00000000006ffd3e",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777970139,
      "updated": 1777970141
    },
    {
      "id": "69f97b170000000000be5eb5",
      "text": "> [可能性の幅を縮めて自分というものを定義する]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777957655,
      "updated": 1777967821
    },
    {
      "id": "69f97b1d0000000000be5eb7",
      "text": "\t自分の定義はデカルトから引っ張ってきて「存在するもの」がマックスに広いかもしれん[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777957661,
      "updated": 1777957695
    },
    {
      "id": "69f97b4e0000000000be5eb8",
      "text": "\t\t「ここに存在するもの」でもいいかもしれない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777957710,
      "updated": 1777957795
    },
    {
      "id": "69f97ba40000000000be5eba",
      "text": "\t\tダメかも知れない。「心ここにあらず」をできるから。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777957795,
      "updated": 1777957822
    },
    {
      "id": "69f9807600000000006ffd04",
      "text": "\t\t「[我思う、ゆえに我あり]」のやつか[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777959031,
      "updated": 1777965199
    },
    {
      "id": "69f9a2160000000000f023a9",
      "text": "\t\t今見たら[デライトの話をしている日にデカルトの話をする]のはマズいな。[ケブンリッジだがいく]の研究によると文字列が混同されてしまう可能性がある。",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777967639,
      "updated": 1777967780
    },
    {
      "id": "69f97b170000000000be5eb6",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777957655,
      "updated": 1777957655
    },
    {
      "id": "69f9a2780000000000f023ac",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967737,
      "updated": 1777967737
    },
    {
      "id": "69f9a2760000000000f023ab",
      "text": " ✂ [デライトの人が来たのをキッカケにデライト談義が始まる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967735,
      "updated": 1777967760
    },
    {
      "id": "69f9c9000000000000f39a0b",
      "text": " ✂ [任天堂ハードの互換性は企業努力の多摩モノレール]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777977600,
      "updated": 1778118688
    },
    {
      "id": "69fbf16200000000003a0d2b",
      "text": " \t情報量が凄い。用語多すぎて真っ青になってる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778119011,
      "updated": 1778119042
    },
    {
      "id": "69f9d0e5000000000096ea9a",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777979622,
      "updated": 1777979622
    },
    {
      "id": "69f9d0e5000000000096ea9b",
      "text": "> 企業努力の多摩モノレール",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777979622,
      "updated": 1777979630
    },
    {
      "id": "69f9e41700000000003fc5b3",
      "text": "✂ to [企業努力の多摩モノレール]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777984536,
      "updated": 1777984542
    },
    {
      "id": "69f976dd0000000000be5ea5",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777956573,
      "updated": 1777956573
    },
    {
      "id": "69f9652f000000000070594f",
      "text": "[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777952048,
      "updated": 1777952049
    },
    {
      "id": "69f965cd0000000000705953",
      "text": " うーん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777952205,
      "updated": 1777952209
    },
    {
      "id": "69f96b500000000000705956",
      "text": " 朝冷え込んでいたが[春の陽気]だ！あちい",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777953622,
      "updated": 1777956740
    },
    {
      "id": "69f96b8d0000000000705959",
      "text": "  [ショウブ]ほぼつぼみみたいな閉じかたしてたけど、30分くらい外歩いて持ってたら、きれいに開いた",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777953677,
      "updated": 1777953979
    },
    {
      "id": "69f96b98000000000070595a",
      "text": " 帰っていけるの楽しみだ。",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777953688,
      "updated": 1777953833
    },
    {
      "id": "69f96b5d0000000000705957",
      "text": " [https://gyazo.com/2b6ada3e3b602a7698c3639e49233567]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777953629,
      "updated": 1777953639
    },
    {
      "id": "69f978a9000000000094c99b",
      "text": "  扱い方がだいぶ変わりそうだ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777957033,
      "updated": 1777957051
    },
    {
      "id": "69f978c4000000000094c99c",
      "text": "  背を低めにしてみるといいかも？",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777957060,
      "updated": 1777957073
    },
    {
      "id": "69f979b8000000000094c99d",
      "text": "  うまくしなってくれない！黄色いのを正面からバーンと見せたいが",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777957305,
      "updated": 1777957326
    },
    {
      "id": "69f98ca10000000000908224",
      "text": "  夜やろ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777962146,
      "updated": 1777962148
    },
    {
      "id": "69f9bd640000000000df2be0",
      "text": "  あら素敵[onuma.icon][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777974629,
      "updated": 1777975572
    },
    {
      "id": "69f98c9b0000000000908222",
      "text": " グラス類 一新したいがずっと使ってるのがシンプルだし安いんでまた買い足してしまってうーん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777962140,
      "updated": 1777962197
    },
    {
      "id": "69fa04ea00000000002812e6",
      "text": " フリースタイルに投げ入れた",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777992938,
      "updated": 1777993001
    },
    {
      "id": "69fa04ed00000000002812e7",
      "text": " [https://gyazo.com/74e230e1b41fd7f8496894f6f5dbaddb]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777992941,
      "updated": 1777992954
    },
    {
      "id": "69fa069000000000004e86fb",
      "text": "  きれい[vlzs.icon][基素.icon][imo.icon][onuma.icon]",
      "userId": "67bf02ec874ae1ce04e71b08",
      "created": 1777993361,
      "updated": 1778020727
    },
    {
      "id": "69fa33c50000000000f686a4",
      "text": "  なんか慣れてる感じがある。バランスとか[imo.icon]",
      "userId": "5ad57975d54cd50014068484",
      "created": 1778004934,
      "updated": 1778004947
    },
    {
      "id": "69fa04f900000000002812e8",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777992954,
      "updated": 1777992954
    },
    {
      "id": "69f96b670000000000705958",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777953639,
      "updated": 1777953639
    },
    {
      "id": "69f95ade0000000000570d11",
      "text": "[baku3.icon]",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1777949406,
      "updated": 1777954607
    },
    {
      "id": "69f96f300000000000d18a33",
      "text": " 昼夜逆転",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1777954608,
      "updated": 1777954613
    },
    {
      "id": "69f96fc00000000000570d1c",
      "text": "  フクロウっぽいアイコンなので説得力がある[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777954753,
      "updated": 1777954768
    },
    {
      "id": "69f96f380000000000d18a34",
      "text": " 眠い",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1777954616,
      "updated": 1777954619
    },
    {
      "id": "69f97bb6000000000044ca81",
      "text": "",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1777957815,
      "updated": 1777957815
    },
    {
      "id": "69f97bb6000000000044ca82",
      "text": "[seibe.icon]",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1777957815,
      "updated": 1777957817
    },
    {
      "id": "69f97bb8000000000044ca84",
      "text": " おなかすいた",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1777957817,
      "updated": 1777957818
    },
    {
      "id": "69f97bb7000000000044ca83",
      "text": "\t\t[肉、喰ってるか？][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777957815,
      "updated": 1777957896
    },
    {
      "id": "69f984c400000000003e52ab",
      "text": "\t\t食べた！[seibe.icon]",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1777960133,
      "updated": 1777960136
    },
    {
      "id": "69f96f2c0000000000d18a32",
      "text": "　[DAWのリアルタイム入力とWYSIWYG]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777954604,
      "updated": 1778119095
    },
    {
      "id": "69f9e24b0000000000c7747a",
      "text": " トンネルなどでネット接続が断続的な状態だが、割とCosense使える（共同編集もできる）の、すごいなーと思った",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1777984086,
      "updated": 1777984882
    },
    {
      "id": "69f9e4f20000000000facdc6",
      "text": " [対機説法はもっと知られても良いのかも]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777984761,
      "updated": 1778120110
    },
    {
      "id": "69f9e4f20000000000facdc7",
      "text": "",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1777984761,
      "updated": 1777984761
    },
    {
      "id": "69f97f320000000000eff824",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1777958715,
      "updated": 1777958716
    },
    {
      "id": "69f97f330000000000eff825",
      "text": "\t昨日に続いて今日も掃除",
      "userId": "65e1289acd012200235729c0",
      "created": 1777958716,
      "updated": 1777958716
    },
    {
      "id": "69f97f3a0000000000eff826",
      "text": "\t\t今日はクルマを高圧洗浄機で掃除",
      "userId": "65e1289acd012200235729c0",
      "created": 1777958716,
      "updated": 1777958726
    },
    {
      "id": "69f97f4d0000000000eff827",
      "text": "\t\t終わった後の現在、面倒だから洗車機でいいか、という気分",
      "userId": "65e1289acd012200235729c0",
      "created": 1777958736,
      "updated": 1777958752
    },
    {
      "id": "69f980d30000000000eff828",
      "text": "\tデライト、使ったことがないけど、その関連話を楽しく読む",
      "userId": "65e1289acd012200235729c0",
      "created": 1777959125,
      "updated": 1777959165
    },
    {
      "id": "69f9a2a50000000000f023ad",
      "text": "\t\t→ [デライトの人が来たのをキッカケにデライト談義が始まる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777967782,
      "updated": 1777967792
    },
    {
      "id": "69f97f310000000000eff823",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1777958707,
      "updated": 1777958707
    },
    {
      "id": "69f9af75000000000026731b",
      "text": "[suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777971063,
      "updated": 1777971066
    },
    {
      "id": "69fbf8c800000000003a0d32",
      "text": " [押忍.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120905,
      "updated": 1778120956
    },
    {
      "id": "69f9af640000000000267319",
      "text": "　[個人用のpinもどき]つくった",
