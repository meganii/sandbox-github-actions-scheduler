    },
    {
      "id": "69d7bdd80000000000d24e0b",
      "text": "https://anchor.main.jp/warizannkuku.htm",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746520,
      "updated": 1775746521
    },
    {
      "id": "69d7bdd80000000000d24e0c",
      "text": "出典によって五の段の内容が異なる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746521,
      "updated": 1775746521
    },
    {
      "id": "69d7bdd80000000000d24e0d",
      "text": "\tそろばんの計算順序によって覚えるべき内容が異なるためか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746521,
      "updated": 1775746521
    },
    {
      "id": "69d7bdd80000000000d24e0e",
      "text": " 五一加一　\tごいちかいち",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746521,
      "updated": 1775746521
    },
    {
      "id": "69d7bdd80000000000d24e0f",
      "text": " 五二加二　\tごにかに",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746521,
      "updated": 1775746521
    },
    {
      "id": "69d7bdd80000000000d24e10",
      "text": " 五三加三　\tごさんかさん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746521,
      "updated": 1775746521
    },
    {
      "id": "69d7bdd80000000000d24e11",
      "text": " 五四加四　\tごしかし",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746521,
      "updated": 1775746521
    },
    {
      "id": "69d7bdd80000000000d24e12",
      "text": " 五進一十　\tごしんのいちじゅう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775746521,
      "updated": 1775746521
