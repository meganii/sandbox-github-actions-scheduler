{
  "id": "69a14152be53b43da2027e83",
  "title": "30分タイマー",
  "created": 1772175752,
  "updated": 1772176230,
  "lines": [
    {
      "id": "69a14152be53b43da2027e83",
      "text": "30分タイマー",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175752,
      "updated": 1772175752
    },
    {
      "id": "69a141d6000000000022f9e1",
      "text": " 針は60秒で一周",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175832,
      "updated": 1772176223
    },
    {
      "id": "69a14352000000000022f9ec",
      "text": " 色変化",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772176210,
      "updated": 1772176223
    },
    {
      "id": "69a141fc000000000022f9e2",
      "text": "  初期値は赤",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175869,
      "updated": 1772176230
    },
    {
      "id": "69a14218000000000022f9e3",
      "text": "  5分後に黄色",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175896,
      "updated": 1772176230
    },
    {
      "id": "69a14236000000000022f9e4",
      "text": "  10分後に緑",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175927,
      "updated": 1772176230
    },
    {
      "id": "69a14267000000000022f9e6",
      "text": "  15分後に水色",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175976,
      "updated": 1772176230
    },
    {
      "id": "69a14280000000000022f9e7",
      "text": "  20分後に青",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772176000,
      "updated": 1772176230
    },
    {
      "id": "69a14287000000000022f9e8",
      "text": "  25分後に紫",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772176007,
      "updated": 1772176230
    },
    {
      "id": "69a142b5000000000022f9e9",
      "text": "  30分後に赤（初期値）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772176053,
      "updated": 1772176230
    },
    {
      "id": "69a142f3000000000022f9ea",
      "text": "  以下、同じ色の変化を無限ループする",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772176116,
      "updated": 1772176230
    },
    {
      "id": "69a14243000000000022f9e5",
      "text": "  　30分に同じ色になる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175940,
      "updated": 1772176230
    },
    {
      "id": "69a14323000000000022f9eb",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772176164,
      "updated": 1772176164
    },
    {
      "id": "69a1418b000000000022f9e0",
      "text": "[https://svg-hosting.vercel.app/api/svg?url=https://scrapbox.io/api/code/villagepump/30分タイマー/r.svg]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175756,
      "updated": 1772175819
    },
    {
      "id": "69a14187000000000022f9c9",
      "text": "code:r.svg",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175752,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9ca",
      "text": " <svg width=\"200\" height=\"200\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\">",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9cb",
      "text": "   <circle cx=\"50\" cy=\"50\" r=\"45\" fill=\"lightblue\" stroke=\"black\" stroke-width=\"5\">",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9cc",
      "text": "     <animate",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9cd",
      "text": "       attributeName=\"fill\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9ce",
      "text": "       values=\"red;yellow;lime;cyan;blue;magenta;red\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9cf",
      "text": "       dur=\"1800s\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d0",
      "text": "       fill=\"freeze\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d1",
      "text": "       repeatCount=\"indefinite\" />",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d2",
      "text": "     />",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d3",
      "text": "   </circle>",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d4",
      "text": "   <line x1=\"50\" y1=\"5\" x2=\"50\" y2=\"50\" fill=\"none\" stroke=\"black\" stroke-width=\"5\" >",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d5",
      "text": "     <!-- 60秒で0度から360度まで回転 -->",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d6",
      "text": "     <animateTransform ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d7",
      "text": "       attributeName=\"transform\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d8",
      "text": "       type=\"rotate\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9d9",
      "text": "       from=\"0 50 50\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9da",
      "text": "       to=\"360 50 50\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9db",
      "text": "       dur=\"60s\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9dc",
      "text": "       repeatCount=\"indefinite\" />",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9dd",
      "text": "   </line> ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9de",
      "text": " </svg>",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    },
    {
      "id": "69a14189000000000022f9df",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772175753,
      "updated": 1772175753
    }
  ]
}