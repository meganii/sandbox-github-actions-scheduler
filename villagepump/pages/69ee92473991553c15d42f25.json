      "text": "   5  .  .  | .  .  . |  .  .  .",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257038,
      "updated": 1777257415
    },
    {
      "id": "69eeca4d0000000000538efa",
      "text": "\t数字の設定",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257038,
      "updated": 1777257742
    },
    {
      "id": "69eecd080000000000538f0e",
      "text": " \t2区8区の列区は",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257737,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f04",
      "text": " \t\t{1, 4, 7} のうち2つ以上を持つ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f05",
      "text": " \t\t{2, 5, 8} のうち2つ以上を持つ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f06",
      "text": " \t\t{3, 6, 9} のうち2つ以上を持つ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f07",
      "text": " \t\tように設定する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f08",
      "text": " \t4区6区の列区は",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f09",
      "text": " \t\t{1, 2, 3} のうち2つ以上を持つ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f0a",
      "text": " \t\t{4, 5, 6} のうち2つ以上を持つ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f0b",
      "text": " \t\t{7, 8, 9} のうち2つ以上を持つ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eecced0000000000538f0c",
      "text": " \t\tように設定する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777257745
    },
    {
      "id": "69eefc550000000000d387c3",
      "text": " \tと思ったができない場合がある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777269846,
      "updated": 1777269874
    },
    {
      "id": "69eecced0000000000538f0d",
      "text": " こうすると同じ構造の盤面の中でもかなり限定される。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257709,
      "updated": 1777258048
    },
    {
      "id": "69eecd9c0000000000538f10",
      "text": "\t\tと思ったがまだまだ多い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777257885,
      "updated": 1777269889
    },
    {
      "id": "69eefc800000000000d387c4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777269889,
      "updated": 1777269890
    },
