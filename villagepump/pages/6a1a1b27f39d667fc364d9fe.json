    {
      "id": "6a1a1b27f39d667fc364d9fe",
      "text": "イノベーション",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095801,
      "updated": 1780095801
    },
    {
      "id": "6a1a1b380000000000d69287",
      "text": ">１ 新機軸。革新。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095801,
      "updated": 1780095806
    },
    {
      "id": "6a1a1b3a0000000000d69288",
      "text": ">２ 新製品の開発、新生産方式の導入、新市場の開拓、新原料・新資源の開発、新組織の形成などによって、経済発展や景気循環がもたらされるとする概念。シュンペーターの用語。また、狭義には技術革新の意に用いる。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095802,
      "updated": 1780095808
    },
    {
      "id": "6a1a1b3f0000000000d69289",
      "text": "[https://kotobank.jp/word/%E3%81%84%E3%81%AE%E3%81%B9%E3%83%BC%E3%81%97%E3%82%88%E3%82%93-3143283 イノベーションとは？ 意味や使い方 - コトバンク]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095808,
      "updated": 1780095828
    },
    {
      "id": "6a1a1b530000000000d6928a",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095828,
      "updated": 1780095828
    },
    {
      "id": "6a1a1b710000000000d6928d",
      "text": "[ヨーゼフ・シュンペーター]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095857,
      "updated": 1780111235
    },
    {
      "id": "6a1a394f0000000000a1d5d5",
      "text": "\tneue Kombinationen",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780103504,
      "updated": 1780103504
    },
    {
      "id": "6a1a48cd000000000062a89c",
      "text": "\t　[新結合]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780107470,
      "updated": 1780107474
    },
    {
      "id": "6a1a1bdb0000000000d69291",
      "text": "[クレイトン・クリステンセン]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095964,
      "updated": 1780111329
    },
    {
      "id": "6a1a1b810000000000d6928e",
      "text": "[持続的イノベーション]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095873,
      "updated": 1780095904
    },
    {
      "id": "6a1a1b9e0000000000d6928f",
      "text": "[破壊的イノベーション]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095902,
      "updated": 1780095934
    },
    {
      "id": "6a1a1bbb0000000000d69290",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780095931,
      "updated": 1780095931
    },
    {
      "id": "6a1a1b550000000000d6928b",
      "text": "https://ja.wikipedia.org/wiki/イノベーション",
      "userId": "5b5e7121417cf700145b98c2",
