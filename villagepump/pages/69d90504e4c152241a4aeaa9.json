      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
    {
      "id": "69d905050000000000cba431",
      "text": "　下位の価値側面が同じ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
    {
      "id": "69d905050000000000cba432",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
    {
      "id": "69d905050000000000cba433",
      "text": "1V2L vs. 1L2V",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
    {
      "id": "69d905050000000000cba434",
      "text": "　意志において個人的かつ論議において譲歩的な人物と、論理面において独断的かつ合意をが民主主義的な人物の組み合わせ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
    {
      "id": "69d905050000000000cba435",
      "text": "　　手段の検討過程において客観的・中立的か（2L、VLEF）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
    {
      "id": "69d905050000000000cba436",
      "text": "　　論理面において独断論的か（1L、LVEF）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
    {
      "id": "69d905050000000000cba437",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1775830280,
      "updated": 1775830280
    },
