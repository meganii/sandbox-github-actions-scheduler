    {
      "id": "69d3b51bafccb65e669c106f",
      "text": "募集",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482182,
      "updated": 1775482507
    },
    {
      "id": "69d3b5460000000000558c98",
      "text": "[https://gyazo.com/6dfaba33128f7fd16e2ffc84ae3fd0c5]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482182,
      "updated": 1775482499
    },
    {
      "id": "69d3b67c0000000000558c9a",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482493,
      "updated": 1775482493
    },
    {
      "id": "69d3b5470000000000558c99",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482184,
      "updated": 1775482184
    },
    {
      "id": "69d3b6960000000000558c9b",
      "text": "[N=1] や [N=2] の意見の対立意見を募る時に",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482519,
      "updated": 1775482559
    },
    {
      "id": "69d3b6ea0000000000558ca2",
      "text": "\tアイコンを末尾につけたいけど自分のアイコンを置くと自分が投票したことになってしまうジレンマを現在無人で人を募集していることがわかるアイコンで解決",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482602,
      "updated": 1775482698
    },
    {
      "id": "69d3b6ca0000000000558c9d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482571,
      "updated": 1775482571
    },
    {
      "id": "69df0ea90000000000f07b9c",
      "text": "募っているという表明の他、「いません」という意味にもなる（募っているのに人が集まっていない場合）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776225962,
      "updated": 1776226020
    },
    {
      "id": "69df0ea90000000000f07b9d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776225962,
      "updated": 1776225962
    },
    {
      "id": "69d3b6cc0000000000558c9e",
      "text": "用例",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482572,
      "updated": 1775482575
    },
    {
      "id": "69d3b6cf0000000000558c9f",
      "text": "\t生きてる？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482575,
      "updated": 1775482586
    },
    {
      "id": "69d3b6da0000000000558ca0",
      "text": "\t\t生きてる[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482586,
      "updated": 1775482590
    },
    {
      "id": "69d3b6dd0000000000558ca1",
      "text": "\t\t死んでる[募集.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482590,
      "updated": 1775482596
    },
