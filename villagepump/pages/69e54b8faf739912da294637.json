      "created": 1776634768,
      "updated": 1776634813
    },
    {
      "id": "69e54b8f000000000080695a",
      "text": "from [まあ人それぞれだから]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776634768,
      "updated": 1776634768
    },
    {
      "id": "69e54b8f000000000080695b",
      "text": "ページの削除したいという意思とページにりんくしたいという意思",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776634768,
      "updated": 1776634768
    },
    {
      "id": "69e54b8f000000000080695c",
      "text": "（元のページは削除されました）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776634768,
      "updated": 1776634768
    },
    {
      "id": "69e54b8f000000000080695d",
      "text": "",
