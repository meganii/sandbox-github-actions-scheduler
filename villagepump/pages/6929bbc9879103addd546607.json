    {
      "id": "6929bbc9879103addd546607",
      "text": "2025/11/29",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764342736,
      "updated": 1764342736
    },
    {
      "id": "6929bbd16eb40600000051a913",
      "text": "第48週: 日月火水木金[[土]]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764342738,
      "updated": 1764342738
    },
    {
      "id": "6929bbd16eb4060000008a0045",
      "text": "2025年 91.23％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764342738,
      "updated": 1764342738
    },
    {
      "id": "6929bbd16eb406000000d3b502",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764342738,
      "updated": 1764342738
    },
    {
      "id": "6929bbd16eb406000000999bb6",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764342738,
      "updated": 1764342738
    },
    {
      "id": "6929bbd16eb40600000004c0cf",
      "text": "[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764342738,
      "updated": 1764344711
    },
    {
      "id": "6929c387000000000046d28c",
      "text": " やっと帰国",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764344712,
      "updated": 1764344720
    },
    {
      "id": "6929c390000000000046d28d",
      "text": "  さむい",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764344720,
      "updated": 1764344737
    },
    {
      "id": "6929c3e0000000000046d28f",
      "text": "  [陰キャの国日本]の快適な生活に戻ろう",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1764344800,
      "updated": 1764370921
    },
    {
      "id": "692a29ea0000000000958618",
      "text": "   [陰キャの国]という表現いい[seibe.icon][W7kA9pX2.icon][sta.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764370922,
      "updated": 1764389905
    },
    {
      "id": "692a29fd0000000000958619",
      "text": "    陽キャの国はどこだろう",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1764370941,
      "updated": 1764370956
    },
    {
      "id": "692af7900000000000c92ef3",
      "text": "     やはりU☆S☆Aではないか[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764423568,
      "updated": 1764423621
    },
    {
      "id": "692ab3fe000000000045fd73",
      "text": "   乙[imo.icon]",
      "userId": "5ad57975d54cd50014068484",
      "created": 1764406271,
      "updated": 1764406274
    },
    {
      "id": "6929c3a1000000000046d28e",
      "text": "  またこれまで通りの日常が始まるのかと思うと、それはそれで少しげんなりするものがある",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764344737,
      "updated": 1764344900
    },
    {
      "id": "692af9a5000000000041d95b",
      "text": " もつ煮込みとたらこで一杯",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764424100,
      "updated": 1764424118
    },
    {
      "id": "692af9b7000000000041d95c",
      "text": "  うめぇ～",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764424118,
      "updated": 1764424122
    },
    {
      "id": "6929bbd16eb40600000096a1e2",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764342738,
      "updated": 1764342738
    },
    {
      "id": "6929ca210000000000ef8177",
      "text": "[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1764346402,
      "updated": 1764346403
    },
    {
      "id": "6929ca220000000000ef8178",
      "text": "",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1764346403,
      "updated": 1764346403
    },
    {
      "id": "692a21aa00000000006b2359",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764368810,
      "updated": 1764368812
    },
    {
      "id": "692a21ac00000000006b235a",
      "text": "　たくさん寝たかったのに4時間台で目覚めてしまった、眠い",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764368813,
      "updated": 1764368847
    },
    {
      "id": "692a21c700000000006b235b",
      "text": "　唐突に思いついて個人批判の投稿者を調べてみたら両方同一人物だったw",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764368839,
      "updated": 1764371459
    },
    {
      "id": "692a2c0500000000006f29f3",
      "text": "　\t最近のPolisはExportタブから時系列データをCSV取り出せる",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764371462,
      "updated": 1764371489
    },
    {
      "id": "692a2c2300000000006f29f4",
      "text": "　\tPolisの仕様上、コメント投稿は同時にそのコメントへの賛成投票として処理される",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764371491,
      "updated": 1764371521
    },
    {
      "id": "692a2c4000000000006f29f5",
      "text": "　\tなので問題のコメントのIDに最初に投票している人を調べれば投稿者ということになる",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764371521,
      "updated": 1764371554
    },
    {
      "id": "692a2c6100000000006f29f6",
      "text": "　\t「西尾さん」「西尾くん」と表現を変えて複数人のフリをしたかったのだろうけど同一人物だとわかってウケている",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764371554,
      "updated": 1764371596
    },
    {
      "id": "692a372b0000000000298433",
      "text": "　\t\t[草.icon][Hiro Aki.icon][W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764374316,
      "updated": 1764380020
    },
    {
      "id": "692a374a00000000002a6bdc",
      "text": "　\t\t人間って面白い[wogikaze.icon]",
      "userId": "64099110a39a5c001c8a016e",
      "created": 1764374346,
      "updated": 1764374354
    },
    {
      "id": "692a21c700000000006b235c",
      "text": "\t\tしかしまあ現状のPolisは一人の人が表現を変えてたくさんの意見を投稿できてしまう、という問題点があるわけだな",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764368839,
      "updated": 1764371822
    },
    {
      "id": "692a2ffd0000000000c62c7f",
      "text": "\t\tスマートフォンとPCで見てしまう事が良くあるけど、これはIDが別になりますか？[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764372478,
      "updated": 1764372524
    },
    {
      "id": "692a2d6300000000006f29f7",
      "text": "\t\t\tアカウントを作ってログインしていない場合はCookieで区別してる[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764371811,
      "updated": 1764373059
    },
    {
      "id": "692a324500000000006f29fb",
      "text": "\t\t\t\tので別になるし、シークレットモードとかでも別になる",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764373061,
      "updated": 1764373062
    },
    {
      "id": "692a318800000000006f29f9",
      "text": "\t\t\t\tなので技術がわかってる人が複数人のフリをしようとしたら簡単にできてしまうね",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764372873,
      "updated": 1764373321
    },
    {
      "id": "692a31c800000000006f29fa",
      "text": "\t早いけどぼちぼち出かけよう",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764372937,
      "updated": 1764373338
    },
    {
      "id": "692a39590000000000c47767",
      "text": "\tしまった、みんなマスクしてるな",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764374873,
      "updated": 1764374885
    },
    {
      "id": "692a71e500000000007cafcd",
      "text": "\t自分の発表は終わった、疲れた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764389350,
      "updated": 1764389357
    },
    {
      "id": "692a71ed00000000007cafce",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764389358,
      "updated": 1764389358
    },
    {
      "id": "692a334d00000000006f29fc",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764373325,
      "updated": 1764373325
    },
    {
      "id": "692a2fd40000000000c62c7c",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764372437,
      "updated": 1764372437
    },
    {
      "id": "692a2fd50000000000c62c7d",
      "text": "\t咳が続いている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764372437,
      "updated": 1764372443
    },
    {
      "id": "692a2fdb0000000000c62c7e",
      "text": "\t\t気持ちは元気だが、咳が出ることと、活動可能時間が7割くらいになっている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764372443,
      "updated": 1764372568
    },
    {
      "id": "692a30570000000000c62c81",
      "text": "\t\t午後に眠気が出るのだが、そこで寝ると夜眠れない",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764372567,
      "updated": 1764372579
    },
    {
      "id": "692a30670000000000c62c82",
      "text": "\t\t\t寝たほうが良いのか 起きていた方が良いのか・・",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764372583,
      "updated": 1764372593
    },
    {
      "id": "692a38220000000000298434",
      "text": "\t\t\tコーヒー飲んで数十分寝る、に一票[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1764374563,
      "updated": 1764374574
    },
    {
      "id": "692a3f610000000000b93119",
      "text": "\t\t\t 咳の時にコーヒーってどうでしたっけ？[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764376419,
      "updated": 1764376551
    },
    {
      "id": "692a3fd70000000000b9311a",
      "text": "\t\t\t  適量なら咳の緩和になりそうとGeminiが言ってる。試してみるか。",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764376536,
      "updated": 1764376567
    },
    {
      "id": "692a3ff90000000000b9311b",
      "text": "\t\t\t  単にいつも飲むコーヒーを飲んでないので眠いだけという説もあるな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764376570,
      "updated": 1764376584
    },
    {
      "id": "692a38310000000000dfd36c",
      "text": "\t\t\t[パワーナップ]にも似たノウハウが集まっていると思う[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764374579,
      "updated": 1764374588
    },
    {
      "id": "692a2d6300000000006f29f8",
      "text": "\t公園で小三のこの知識ひけらかしを聞いている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764371811,
      "updated": 1764382887
    },
    {
      "id": "692a58a800000000009d9558",
      "text": "\t\t記憶細胞をご存じ。はたらく細胞の影響との事",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764382888,
      "updated": 1764382906
    },
    {
      "id": "692a5f190000000000f20a5f",
      "text": "\t\tハチドリ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764384538,
      "updated": 1764384541
    },
    {
      "id": "692a58b600000000009d9559",
      "text": "\t\t[SCP]を知っているっぽい なんの影響だろう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764382902,
      "updated": 1764382963
    },
    {
      "id": "692a58f400000000009d955a",
      "text": "\t\t\t[https://cocreco.kodansha.co.jp/aoitori/news/56Tx5 「SCP」って何？ 小学生から大人まで大人気！ 今さら聞けない「現代の都市伝説」を楽しむための豆知識 - 青い鳥文庫]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764382965,
      "updated": 1764382967
    },
    {
      "id": "692aa66e0000000000d8c415",
      "text": "\t\t\t 子供まで届いたら人気になるのはわかるけど、届くルートはたしかに謎。youtube動画もたくさんあるけど、それか？？[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764402797,
      "updated": 1764402867
    },
    {
      "id": "692a589800000000009d9557",
      "text": " 仕事でのAI活用",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764382872,
      "updated": 1764385032
    },
    {
      "id": "692a61040000000000f20a62",
      "text": "  ローコード、ノーコードの話の続きに見える",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764385032,
      "updated": 1764385039
    },
    {
      "id": "692a61100000000000f20a63",
      "text": "  裾野を広げる話と、些細なツールの開発コストを小さくする話",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764385041,
      "updated": 1764385074
    },
    {
      "id": "692a64a00000000000dfc368",
      "text": "  非エンジニアの定型業務のシステム化",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764385953,
      "updated": 1764385962
    },
    {
      "id": "692a64a90000000000dfc369",
      "text": "  エンジニア業務で",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764385962,
      "updated": 1764386043
    },
    {
      "id": "692a64fa0000000000dfc36b",
      "text": "   絶妙に人の手が必要な煩雑ケースの自動化",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764386043,
      "updated": 1764386044
    },
    {
      "id": "692a64e30000000000dfc36a",
      "text": "   工数不足で自動化できない定型業務の自動化",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764386020,
      "updated": 1764386039
    },
    {
      "id": "692a60fa0000000000f20a60",
      "text": "\t[/fab-wiki/20251123週fabnews]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764385019,
      "updated": 1764393658
    },
    {
      "id": "692a82bb00000000009d955c",
      "text": "\t\t今週のモノづくり系気になったニュースまとめました",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764393659,
      "updated": 1764393669
    },
    {
      "id": "692a82c500000000009d955d",
      "text": "\t\t記事の追加・感想、大歓迎です！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764393669,
      "updated": 1764393677
    },
    {
      "id": "692ab651000000000034c5f7",
      "text": "\t[ためろく]10000ダウンロード！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764406866,
      "updated": 1764406889
    },
    {
      "id": "692ab668000000000034c5f8",
      "text": "\t 1エピソードあたり78回くらい",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764406889,
      "updated": 1764406913
    },
    {
      "id": "692ab6a8000000000034c5f9",
      "text": "\t  まぁこの数字は普通？そこまでヒットしてないとこんなもんかなという感じかな？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764406953,
      "updated": 1764407024
    },
    {
      "id": "692ab6f0000000000034c5fa",
      "text": "\t 継続できてるのが褒めポイント",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764407025,
      "updated": 1764407038
    },
    {
      "id": "692ab73d00000000006af6db",
      "text": "\t \tすごい[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764407102,
      "updated": 1764407103
    },
    {
      "id": "692ab99d00000000006af6de",
      "text": "\t \t\t僕も励みにしている（ダンスだけど）",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764407710,
      "updated": 1764407723
    },
    {
      "id": "692a60fa0000000000f20a61",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764385019,
      "updated": 1764385019
    },
    {
      "id": "692a31de00000000002b635c",
      "text": "[blu3mo.icon]",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1764372958,
      "updated": 1764372959
    },
    {
      "id": "692a31df00000000002b635e",
      "text": " 住民会議で[Cartographer]の運用をやっている",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1764372959,
      "updated": 1764372972
    },
    {
      "id": "692a31e900000000002b635f",
      "text": " 政治/公共領域の知り合いが増えすぎた & それが心地よいので、この領域をやっていくのかな〜〜という気持ち[blu3mo.icon]",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1764372970,
      "updated": 1764373409
    },
    {
      "id": "692a33fb00000000002b6364",
      "text": " 　結局人間は周りの人間の関心で意思決定するので[blu3mo.icon]",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1764373557,
      "updated": 1764374528
    },
    {
      "id": "692a744a000000000025507b",
      "text": " 　\t[アロセントリック][sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764389964,
      "updated": 1764389966
    },
    {
      "id": "692af86d000000000041d95a",
      "text": " 　 でも[\" それが心地よい]のは自分の関心によるものに思える[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764423788,
      "updated": 1764423821
    },
    {
      "id": "692a340200000000002b6365",
      "text": " この領域が面白いと思う理由：",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1764373557,
      "updated": 1764373557
    },
    {
      "id": "692a31de00000000002b635d",
      "text": "  [経済合理性の巨大な競争]からは少し距離がある",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764372958,
      "updated": 1764423921
    },
    {
      "id": "692a33eb00000000002b6363",
      "text": "  [現実に存在する本質的な大きな問題]と向き合える",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764373483,
      "updated": 1764423878
    },
    {
      "id": "692a33c400000000002b6361",
      "text": "  [人文と技術の交差点]、[実務と研究の交差点]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764373444,
      "updated": 1764423914
    },
    {
      "id": "692a33a200000000002b6360",
      "text": "",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1764373410,
      "updated": 1764373410
    },
    {
      "id": "692a399a00000000005204af",
      "text": "[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764374939,
      "updated": 1764374940
    },
    {
      "id": "692a399c00000000005204b1",
      "text": "\t[Bitwarden Secrets Manager CLI]を試す",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764374940,
      "updated": 1764376367
    },
    {
      "id": "692a39ae00000000005204b2",
      "text": "\t\tCLIからvaultに接続するアクセストークンはどこで管理すべきか?keychain?",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764374959,
      "updated": 1764375012
    },
    {
      "id": "692a4ea70000000000cc2194",
      "text": "\t\t`security find-generic-password`がTouch IDに対応していない... おしい、あと一歩",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764380328,
      "updated": 1764380380
    },
    {
      "id": "692a8e3500000000000e3e3e",
      "text": "\t\t　CLIでTouch ID?どういうことだ?[bsahd.icon]",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1764396597,
      "updated": 1764396608
    },
    {
      "id": "692a9ca2000000000043731a",
      "text": "\t\t　`.zshrc`に記載している環境変数をSecrets Managerで管理したいが、そもそもSecrets Managerの認証は`BWS_ACCESS_TOKEN`をどこかで指定しないといけない。シェルを起動したときに、この`BWS_ACCESS_TOKEN`をKeychainから読み込めれば少し楽になると考え、`security find-generic-password`でKeychainにアクセスするとパスワード入力しか受け付けてくれない。[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764400291,
      "updated": 1764400628
    },
    {
      "id": "692a9dee00000000000e3e40",
      "text": "\t\t　そもそもシステム認証はパスワードのみなのでは[bsahd.icon]",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1764400622,
      "updated": 1764400640
    },
    {
      "id": "692a9e39000000000043731b",
      "text": "\t\t　[https://1password.com/jp/downloads/command-line] の挙動をなんとかBitwardenでも実現したいという思いから調べていました。[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764400698,
      "updated": 1764400761
    },
    {
      "id": "692a9e3b000000000043731c",
      "text": "\t\t　\t>生体認証を使用して任意のCLIにサインイン",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764400699,
      "updated": 1764400716
    },
    {
      "id": "692a9e4b000000000043731d",
      "text": "    > CLIアクセス認証情報を1Passwordに保存しておけば、認証情報を手動で入力する代わりに、指紋でCLIを認証してサインインできます。",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764400716,
      "updated": 1764400716
    },
    {
      "id": "692a9e8e00000000000e3e41",
      "text": "   PCで...指紋が...登録できる???[bsahd.icon]",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1764400783,
      "updated": 1764400789
    },
    {
      "id": "692a9ea2000000000043731e",
      "text": "   \tmacOSだと[Touch ID]で指紋登録できます([https://support.apple.com/ja-jp/guide/mac-help/mchl16fbf90a/mac MacでTouch IDを使用する]）。Windowsなら[Windows Hello]かな。[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764400802,
      "updated": 1764401009
    },
    {
      "id": "692a9eb700000000000e3e42",
      "text": "   \tWindowsだとそもそも指紋リーダー搭載機種が少ないイメージで、Linuxはドライバーがないことが多いイメージ[bsahd.icon]",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1764400824,
      "updated": 1764400853
    },
    {
      "id": "692a9ed9000000000043731f",
      "text": "   \tなるほど。Linuxは難しそう[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764400858,
      "updated": 1764400874
    },
    {
      "id": "692aa12f00000000000bee95",
      "text": "   \t\t[https://gihyo.jp/admin/serial/01/ubuntu-recipe/0786 第786回　Ubuntuでもあこがれの指紋認証を！ | gihyo.jp]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764401456,
      "updated": 1764401561
    },
    {
      "id": "692aa19800000000000bee96",
      "text": "   \t\t\tUbuntuでもいけるんだ",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764401561,
      "updated": 1764401571
    },
    {
      "id": "692a4f2d0000000000cc2195",
      "text": "\t\thttps://github.com/johnthethird/keymaster が一応動いた",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764380462,
      "updated": 1764380519
    },
    {
      "id": "692a3ac3000000000008530f",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764375235,
      "updated": 1764375235
    },
    {
      "id": "692a3ac30000000000085310",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764375235,
      "updated": 1764375235
    },
    {
      "id": "692a3ac30000000000085311",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764375235,
      "updated": 1764375237
    },
    {
      "id": "692a3ac50000000000085312",
      "text": " 気持ち良い土曜の[朝風呂]。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764375238,
      "updated": 1764375754
    },
    {
      "id": "692a3ad20000000000085313",
      "text": " \tなのに仕事のネタが頭に浮かんで[ガッデムシット]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764375251,
      "updated": 1764375745
    },
    {
      "id": "692a3ade0000000000085314",
      "text": " \t→androidのキーボードの音声で、プライベートの日記に片っ端から書き出して鎮火をはかる。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764375262,
      "updated": 1764375298
    },
    {
      "id": "692a3e87000000000003f348",
      "text": " \t\t[愚痴を吐き出す手段]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764376200,
      "updated": 1764376248
    },
    {
      "id": "692a3b010000000000085315",
      "text": " さて、散歩に行くべ。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764375298,
      "updated": 1764377060
    },
    {
      "id": "692a41e400000000007052dd",
      "text": " 社内でAI活用を進めて、企業文化をぶち壊す妄想",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764377060,
      "updated": 1764382924
    },
    {
      "id": "692a58cd000000000099089b",
      "text": "  企業内部の活動で、ありとあらゆる箇所にAIを差し込んでいく",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764382925,
      "updated": 1764382960
    },
    {
      "id": "692a58f1000000000099089c",
      "text": "  この時に「使ってるユーザ」よりも、平均的な動作をするようにAIを誘導する",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764382960,
      "updated": 1764382997
    },
    {
      "id": "692a5915000000000099089d",
      "text": "   ユーザ(社員)の個性を消す方向性",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764382997,
      "updated": 1764383101
    },
    {
      "id": "692a5921000000000099089e",
      "text": "   企業にとって優秀な社員に見えるような方向性",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383008,
      "updated": 1764383238
    },
    {
      "id": "692a5949000000000099089f",
      "text": "  社内で流通するデータ(テキスト)が、より中央値によっていくことで、データが有名無実化していく",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383049,
      "updated": 1764383114
    },
    {
      "id": "692a598b00000000009908a0",
      "text": "  経営層に届く頃には、存在しない社員の相違のまとまりに変質する",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383115,
      "updated": 1764383143
    },
    {
      "id": "692a59a700000000009908a1",
      "text": "  逆方向もしかり。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383143,
      "updated": 1764383189
    },
    {
      "id": "692a59d500000000009908a2",
      "text": "   経営層からの指示もAIを噛ますことで、より中央値に寄って下に伝わる",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383189,
      "updated": 1764383189
    },
    {
      "id": "692a59d600000000009908a3",
      "text": " ↑を書いてて、これAIなくても現状でもそうじゃん、ってなった。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383190,
      "updated": 1764383213
    },
    {
      "id": "692a5a1a00000000009908a4",
      "text": "  集団規模が大きくなれば、その中でやり取りされるモノは平均化していく。尖った部分は削られる",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383258,
      "updated": 1764383294
    },
    {
      "id": "692a5a8900000000009908a5",
      "text": " 平準化するためのAIって捉えたほうが、企業には向いてるかも。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764383369,
      "updated": 1764383389
    },
    {
      "id": "692aa0310000000000d8c413",
      "text": " [油そば]を試してみたが、自分にはイマイチかな。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764401200,
      "updated": 1764401225
    },
    {
      "id": "692aa04b0000000000d8c414",
      "text": " チェーンもサビサビにしてしまって乗らなくなった[自転車]を買い替えた",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764401226,
      "updated": 1764403137
    },
    {
      "id": "692aa7840000000000d8c416",
      "text": "  [電動自転車]にした",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764403075,
      "updated": 1764403103
    },
    {
      "id": "692aa7a10000000000d8c417",
      "text": "  これで坂道に負けない！",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764403104,
      "updated": 1764403110
    },
    {
      "id": "692a399b00000000005204b0",
      "text": "",
      "userId": "649a24da357c4d001c518c25",
      "created": 1764374939,
      "updated": 1764374939
    },
    {
      "id": "692a4d89000000000080c450",
      "text": "[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764380042,
      "updated": 1764380043
    },
    {
      "id": "692a4d8b000000000080c452",
      "text": "　[2025/11/29#692a21c700000000006b235b]見て[炎上やアンチて複数じゃなくて単一が熱心に火焚べてるやつ多い過ぎる]て認識強また",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764380043,
      "updated": 1764424200
    },
    {
      "id": "692a4e2c000000000080c453",
      "text": "　コーヒー飲めるようになり調子乗って飲みまくりだが全然寝れてるのは処方してもらってる睡眠薬のが摂取してるカフェインより強いからなんかな",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764380205,
      "updated": 1764380264
    },
    {
      "id": "692a4efb0000000000e9df74",
      "text": "　　飲みまくりと言ったが今まで0だったのが2とかになっただから全然雑魚いのかも",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764380411,
      "updated": 1764380450
    },
    {
      "id": "692a4f260000000000e9df75",
      "text": "　　でも、無から有になったんですよ",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764380454,
      "updated": 1764380466
    },
    {
      "id": "692ae37e00000000005405a1",
      "text": "　Xのおすすめに流れてきた本が面白そうだったので図書館のサイトで貸出予約してから、予約待ちが多すぎて永遠に借りれないんじゃないかと思ってた本の予約確保ができてる状態なのに気づいた",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764418430,
      "updated": 1764418538
    },
    {
      "id": "692ae3fb00000000005405a2",
      "text": "　　しかも昨日から借りれる状態だった　不覚⸺",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764418555,
      "updated": 1764418580
    },
    {
      "id": "692a5e690000000000d62208",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764384362,
      "updated": 1764384362
    },
    {
      "id": "692a5e690000000000d62209",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764384362,
      "updated": 1764384362
    },
    {
      "id": "692a5f720000000000d6220b",
      "text": "\tゲムマ後に[ボ哲の紙＋術語スケルトンパズル]を見た方が、欲しかったけど現地で見つけられなかったとXで叫んでおられた",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764384626,
      "updated": 1764561967
    },
    {
      "id": "692a60c00000000000d6220c",
      "text": "\t\t嬉しみ。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764384961,
      "updated": 1764384963
    },
    {
      "id": "692a60c20000000000d6220d",
      "text": "\t\tそして大急ぎで通販を準備した。初めてのBOOTH。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764384963,
      "updated": 1764384980
    },
    {
      "id": "692a60e60000000000d6220e",
      "text": "\t\t[https://kuyodo.booth.pm/items/7702053 ボ哲の紙＋術語スケルトンパズル - KUYODO e-store - BOOTH]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764384999,
      "updated": 1764385008
    },
    {
      "id": "692a60ef0000000000d6220f",
      "text": "  オープンして数時間でお2人お買い上げ。ありがたし。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764385008,
      "updated": 1764385053
    },
    {
      "id": "692a689200000000005125ac",
      "text": "  いいはなし[caki.icon][Hiro Aki.icon][sta.icon][W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764386963,
      "updated": 1764416229
    },
    {
      "id": "692abab40000000000ac7018",
      "text": "  [/icons/thx.icon] [terang.icon*2]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407989,
      "updated": 1764408169
    },
    {
      "id": "692ab8320000000000ac700f",
      "text": " 疲れた話し合いから帰宅",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407346,
      "updated": 1764407362
    },
    {
      "id": "692ab98800000000006af6dd",
      "text": " \t\t🍵[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764407689,
      "updated": 1764407695
    },
    {
      "id": "692abaad0000000000ac7017",
      "text": " \t\t🙇[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407982,
      "updated": 1764407985
    },
    {
      "id": "692ab88c0000000000ac7012",
      "text": " \t詳しいことはあまり書けないが少し疲れた。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407437,
      "updated": 1764407444
    },
    {
      "id": "692ab8420000000000ac7010",
      "text": " \t自分は基本は対話によって他者と相互理解、そしてなんらかの合意を目指す立場を追っているが、不当なこちら個人の財産や権利の侵害に対してははっきりとNOを突きつけねばならない。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407362,
      "updated": 1764407598
    },
    {
      "id": "692ab87d0000000000ac7011",
      "text": " \tしかしその要求者が関連法の最も基本的なところをわかっていない場合、どれだけ自分が不当な要求をこちらに提示しているかを理解していない。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407421,
      "updated": 1764407611
    },
    {
      "id": "692ab8aa0000000000ac7013",
      "text": " \tしんどいのは、それをこちらが少々説明しても、理解しようとしないこと。学ばない態度。むしろこちらが喧嘩を売っているかのように解釈される。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407466,
      "updated": 1764407637
    },
    {
      "id": "692ab8c10000000000ac7014",
      "text": " \t\tむしろレクチャー代を請求したいくらいだっつーに。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407490,
      "updated": 1764407649
    },
    {
      "id": "692ab8d60000000000ac7015",
      "text": " \t\tその割に、情緒的な訴えだけ一丁前にしてくる。昔はなんとかなったのに今の時代は違うんですねだの、自分たちは弱者だの、体の調子が最近悪いだの。そんなこと言い出したら、最近お客さんからの売り上げが減っちゃってとか、仕入れ価格の高騰でとか、しょっちゅう頭痛でしんどいですわとか、なんぼでもこっちも言えるわい。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407510,
      "updated": 1764407919
    },
    {
      "id": "692ab8f30000000000ac7016",
      "text": " \t\tまあ大人だから言葉では、それはお辛いですねと返答しつつ、それとこれとは話は別なのであなた方の要求は飲めません、と返すも、このこちらの返事を相手がどうしても受け容れられないようなのだ。情緒で訴えれば折れるとでも思っとんのかいっつー話だ。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764407539,
      "updated": 1764407802
    },
    {
      "id": "692a4d89000000000080c451",
      "text": "",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764380042,
      "updated": 1764380042
    },
    {
      "id": "692a75890000000000af55b3",
      "text": "[カイト.icon]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1764390282,
      "updated": 1764390284
    },
    {
      "id": "692a758c0000000000af55b4",
      "text": " [上海で日本のアニソンの歌唱強制中断 https://www.47news.jp/13524236.html]",
