  "lines": [
    {
      "id": "6a2e477ff01fcbbc6366d6fe",
      "text": "字面",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417857,
      "updated": 1781417857
    },
    {
      "id": "6a2e47bc0000000000d0b7be",
      "text": "[字面(ジメン)とは？ 意味や使い方 - コトバンク https://kotobank.jp/word/%E5%AD%97%E9%9D%A2-521779]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417916,
      "updated": 1781417919
    },
    {
      "id": "6a2e47810000000000d0b7a7",
      "text": "> じ‐づら【字面】",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417857,
      "updated": 1781417870
    },
    {
      "id": "6a2e478e0000000000d0b7a9",
      "text": "> 〘 名詞 〙",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417870,
      "updated": 1781417870
    },
    {
      "id": "6a2e478e0000000000d0b7aa",
      "text": "> ① 文字の[字くばり]や形状などから受ける、視覚的な感じ。じめん。〔[文明本節用集]（室町中）〕",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417870,
      "updated": 1781417994
    },
    {
      "id": "6a2e478e0000000000d0b7ab",
      "text": "> (初出の実例)「多情乃仏心の字面(ジヅラ)に眺め入りながら」(出典：[『多情仏心』]（1922‐23）〈里見弴〉振仮名)",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417870,
      "updated": 1781417957
    },
    {
      "id": "6a2e478e0000000000d0b7ac",
      "text": "> ② ある文章が示す[表面的な意味]。じめん。",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781417938
    },
    {
      "id": "6a2e478e0000000000d0b7ad",
      "text": "> (初出の実例)「文壇人に対して、『映画界の人々』では語呂も悪いし、字顔(ヅラ)も面白くない」(出典：[苦笑風呂]（1948）〈古川緑波〉映画それからそれ)",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781417951
    },
    {
      "id": "6a2e47a40000000000d0b7bd",
      "text": "> ",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417892,
      "updated": 1781418024
    },
    {
      "id": "6a2e478e0000000000d0b7ae",
      "text": "> じ‐めん【字面】",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781417878
    },
    {
      "id": "6a2e478e0000000000d0b7af",
      "text": "> 〘 名詞 〙",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781417878
    },
    {
      "id": "6a2e478e0000000000d0b7b0",
      "text": "> ① 文字の字くばりや形状などから受ける視覚的な感じ。じづら。",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781417878
    },
    {
      "id": "6a2e478e0000000000d0b7b1",
      "text": "> (初出の実例)「字面 ジメン」(出典：文明本節用集（室町中）)",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781417896
    },
    {
      "id": "6a2e478e0000000000d0b7b2",
      "text": "> ② 文字の表面的な意味。一つ一つの文字の意味だけから合成した、内容、背景などを考えない意味。じづら。",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781417878
    },
    {
      "id": "6a2e478e0000000000d0b7b3",
      "text": "> (初出の実例)「一切万道、成就云。是は、ただ自面(じメン)のごとくか。又[深義]有るか」(出典：[拾玉得花]（1428）)",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417878,
      "updated": 1781418016
    },
    {
      "id": "6a2e478e0000000000d0b7b4",
      "text": "> 出典　精選版 日本国語大辞典",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417870,
      "updated": 1781417870
    },
    {
      "id": "6a2e478e0000000000d0b7a8",
      "text": "",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781417870,
      "updated": 1781417870
    },
    {
      "id": "6a2e48f60000000000d0b7bf",
      "text": "[まだ字面がアウト]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781418231,
      "updated": 1781418231
    },
    {
      "id": "6a2e48f70000000000d0b7c0",
      "text": "[字面がかっこいいバンド名]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781418231,
      "updated": 1781418235
    },
    {
      "id": "6a2e48fb0000000000d0b7c2",
      "text": "[字面が過激]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1781418235,
      "updated": 1781418254
    },
    {
      "id": "6a2e490e0000000000d0b7c3",
