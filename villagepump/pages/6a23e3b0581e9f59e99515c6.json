  "lines": [
    {
      "id": "6a23e3b0581e9f59e99515c6",
      "text": "竜力",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780736946,
      "updated": 1780736946
    },
    {
      "id": "6a23e38e0000000000815ba5",
      "text": " [希哲館]（希哲社）による[万軌]の参考（リファレンス）実装[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780736946,
      "updated": 1780737013
    },
    {
      "id": "6a23e38f0000000000815ba6",
      "text": "  読みは「りゅうりき」",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780736946,
      "updated": 1780737034
    },
    {
      "id": "6a23e3d90000000000815ba7",
      "text": "  [ロシア]や[ウクライナ]の国家的な祖とされる[リューリク]にちなむ",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780737021,
      "updated": 1780737687
    },
    {
      "id": "6a23e3e70000000000815ba8",
      "text": "   20代の頃の私は[ロシア史]に強い関心を抱いていた",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780737035,
      "updated": 1780737777
    },
    {
      "id": "6a23e6be0000000000815baa",
      "text": "    当時は、[ヴァイキング]が創った小さな国が、ロシアという世界最大の国土に広がっていったことにロマンを感じていた",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780737761,
      "updated": 1780738522
    },
    {
      "id": "6a23e7c50000000000815bab",
      "text": "    まさかロシアとウクライナの間でこんな戦争が起こるとは思っていなかったが、こうなるとむしろ運命的なものを感じる",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780738025,
      "updated": 1780738354
    },
    {
      "id": "6a23e8cb0000000000815bad",
      "text": "     技術協力を通じて和平の象徴に出来なくもないかもしれない",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780738286,
      "updated": 1780738495
    },
    {
      "id": "6a23e89d0000000000815bac",
      "text": "",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780738241,
      "updated": 1780738241
    }
  ]
}