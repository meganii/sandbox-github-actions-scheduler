{
  "id": "69f5db2a1e9e852a13a5dea5",
  "title": "一文字連鎖",
  "created": 1777720108,
  "updated": 1777720165,
  "lines": [
    {
      "id": "69f5db2a1e9e852a13a5dea5",
      "text": "一文字連鎖",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba56",
      "text": "from [2026/04/27]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba57",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720127
    },
    {
      "id": "69f5db5400000000003bba72",
      "text": "[hoshihara.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720148,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba74",
      "text": " あー",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba75",
      "text": "  まー[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba76",
      "text": "   いー[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba77",
      "text": "   \tろー[terang.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba78",
      "text": "   \t\tのー[atohs.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba79",
      "text": "   \t\t かー[vlzs.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba7a",
      "text": "   \t\t \tしー[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba7b",
      "text": "\t↑アイコンが並んでカラフルになっておりかわいい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba7c",
      "text": "\t\t↑カラフルと↓眼精疲労の温度差で風邪ひきそう[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba7d",
      "text": "\t[眼精疲労がひどすぎて目が痛くて開けるのがつらい。]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5500000000003bba7e",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720149,
      "updated": 1777720149
    },
    {
      "id": "69f5db5900000000003bba7f",
      "text": "[mtane0412.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720153,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba80",
      "text": " なー",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba81",
      "text": "  がー[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba82",
      "text": "  \tくー[terang.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba83",
      "text": "  \t てー[vlzs.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba84",
      "text": "  \t  みー[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba85",
      "text": "   \t  りー[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba86",
      "text": "   \t   んー[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db6400000000003bba87",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720165,
      "updated": 1777720165
    },
    {
      "id": "69f5db5400000000003bba73",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720148,
      "updated": 1777720148
    },
    {
      "id": "69f5db2b00000000003bba58",
      "text": "[vlzs.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba59",
      "text": " 付け足すときに勇気が必要だった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba5a",
      "text": "  あー(ah)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba5b",
      "text": "  尼(海での仕事)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba5c",
      "text": "  甘い(味覚のひとつ)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba5d",
      "text": "  亜麻色(色の名前)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba5e",
      "text": "  亜麻色の(髪の乙女、を呼び起こす)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba5f",
      "text": "  ここまでがすべて、一文字の追加で新しい意味を作成してるという構図を見つけた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba60",
      "text": "  \tやべ、ぜんぜん気づいてなかったです[atohs.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba61",
      "text": "  \tこの構図は文字数が多くなると難しくて成立させられません (> . <) [vlzs.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba62",
      "text": "  あまいろのか[vlzs.icon] と書きたすときそれは新しくない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba63",
      "text": "  大丈夫、みんなで文字をつなげて遊んでるところだから大丈夫、大丈夫",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba64",
      "text": "  あ、まってこれ、私がこの回答しかできないと言うとき、前回答者に不満を持っていることになるのか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba65",
      "text": "   自分の批判をしてると思ってた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba66",
      "text": "\t\t\t[お茶.icon][餅つけ][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba67",
      "text": "  ナイスムーブにより続いてた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba68",
      "text": "   亜麻色の(髪の乙女を呼び起こす)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba69",
      "text": "   亜麻色の蚊?",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba6a",
      "text": "   亜麻色の菓子",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba6b",
      "text": "  亜麻色の髪の乙女しかないと思って諦めてたのは[vlzs.icon]だった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba6c",
      "text": "  \t模範的な100点を取る必要はない[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba6d",
      "text": "  \t\t亜麻色のかりんとうとか思いついた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba6e",
      "text": "  前の人までの文字と文脈を考慮して次の文字を入れてくの、LLMに似てる[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba6f",
      "text": "  \t[非常に鋭い指摘ですね！][- [Summer498.icon]]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba70",
      "text": "  \t\t時系列モデルの基礎的な考え方を見出している。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    },
    {
      "id": "69f5db2b00000000003bba71",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777720108,
      "updated": 1777720108
    }
  ]
}