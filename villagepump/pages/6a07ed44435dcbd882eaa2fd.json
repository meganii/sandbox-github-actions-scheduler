    },
    {
      "id": "6a2c962e000000000095ffea",
      "text": "この生き物は",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781306927,
      "updated": 1781308152
    },
    {
      "id": "6a2c9756000000000096000a",
      "text": "　血液型：A型またはB型またはAB型またはO型[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307222,
      "updated": 1781308010
    },
    {
      "id": "6a2c981e0000000000960014",
      "text": "　毎日DHMOを身体に取り込んでいる[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307422,
      "updated": 1781308234
    },
    {
      "id": "6a2c9a5f000000000096003f",
      "text": "　体毛が生えている[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307999,
      "updated": 1781307999
    },
    {
      "id": "6a2c9b450000000000960048",
      "text": "　目が二つある[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781308229,
      "updated": 1781308229
    },
    {
      "id": "6a2c9b510000000000960049",
      "text": "　軟体動物ではない[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781308241,
      "updated": 1781308241
    },
    {
      "id": "6a2c97be000000000096000c",
      "text": "　日本語を読み書きする[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307326,
      "updated": 1781307738
    },
    {
      "id": "6a2c9902000000000096001f",
      "text": "　ちくわ大明神[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307650,
      "updated": 1781307650
    },
    {
      "id": "6a2c9998000000000096002f",
      "text": "　指が合計20本あることが指摘されているが、本人は[軟体動物]ではないと主張している",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307800,
      "updated": 1781308193
    },
    {
      "id": "6a2c98470000000000960019",
      "text": "　ISFPまたはISTPまたはINFPまたはINTPまたはISFJまたはISTJまたはINFJまたはINTJまたはESFPまたはESTPまたはENFPまたはENTPまたはESFJまたはESTJまたはENFJまたはENTJとされている[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307463,
      "updated": 1781307632
    },
    {
      "id": "6a2c999b0000000000960031",
      "text": "　眼球の構造がタコに似ていることが指摘されているが、本人は軟体動物であることを否定している",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307803,
      "updated": 1781327140
    },
    {
      "id": "6a2c99b70000000000960033",
      "text": "　高層ビルの20階から落下すると死ぬ可能性が高い[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307831,
      "updated": 1781308032
    },
    {
      "id": "6a2c9ae10000000000960040",
      "text": "　足が生えている[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781308129,
      "updated": 1781308129
    },
    {
      "id": "6a2c98c1000000000096001a",
      "text": "　憂鬱質−胆汁質[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781307584,
      "updated": 1781308220
    },
    {
      "id": "6a2c9b320000000000960047",
      "text": "　二足歩行[. ［要出典］]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781308210,
      "updated": 1781327119
    },
    {
      "id": "6a2a61d80000000000d258cf",
