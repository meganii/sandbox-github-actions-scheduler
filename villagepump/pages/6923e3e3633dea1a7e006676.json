      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777700509,
      "updated": 1780759367
    },
    {
      "id": "69f6ddf10000000000363827",
      "text": "[クオリアさんの耳]を装備した[偽クオリアさん]のすがた",
      "userId": "6923e3b6e09f0be0924872ef",
