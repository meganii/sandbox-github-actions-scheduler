      "id": "69e5f4a5f78cfe03520e0fc9",
      "text": "雑念駆動",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776678058,
      "updated": 1776678058
    },
    {
      "id": "69e5f4aa0000000000b67957",
      "text": "雑念を力に変えて駆動する",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776678058,
      "updated": 1776678093
    },
    {
      "id": "69e5f4ab0000000000b67958",
      "text": "雑念を完全に抑え込むことはできない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776678060,
      "updated": 1776678123
    },
    {
      "id": "69e5f4d20000000000b67959",
      "text": "雑念を現実に支障がないようにコントロールできるようにする",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776678099,
      "updated": 1776678183
    },
    {
      "id": "69e5f4fc0000000000b6795a",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776678140,
      "updated": 1776678140
    },
    {
      "id": "69e68b790000000000fd7806",
      "text": "もしかして",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776716665,
      "updated": 1776716674
    },
    {
      "id": "69e68b790000000000fd7807",
