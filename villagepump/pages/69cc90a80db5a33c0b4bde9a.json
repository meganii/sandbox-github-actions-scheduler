    },
    {
      "id": "69cd00c9000000000073a282",
      "text": "[2026冬アニメ]←2026春アニメ→[2026夏アニメ]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775042761,
      "updated": 1775042774
    },
    {
      "id": "69cc90f60000000000192e2f",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e30",
      "text": "[レプリカだって、恋をする。]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e31",
      "text": "[悲劇の元凶となる最強外道ラスボス女王は民の為に尽くします。Season2]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e32",
      "text": "[クジマ歌えば家ほろろ]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e33",
      "text": "[転生したらスライムだった件 第4期]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e34",
      "text": "[魔法の姉妹ルルットリリィ]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e35",
      "text": "[黒猫と魔女の教室]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e36",
      "text": "[大賢者リドルの時間逆行]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e37",
      "text": "[神の庭付き楠木邸]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e38",
      "text": "[灰原くんの強くて青春ニューゲーム]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e39",
      "text": "[こめかみっ！Girls]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e3a",
      "text": "[彼女、お借りします(第5期)]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e3b",
      "text": "[最強の王様、二度目の人生は何をする？ Season2]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e3c",
      "text": "[女神「異世界転生何になりたいですか」俺「勇者の肋骨で」]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69ccf8c0000000000071a832",
      "text": "\t[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775040704,
      "updated": 1775040705
    },
    {
      "id": "69cc90f60000000000192e3d",
      "text": "[大きい女の子は好きですか？]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e3e",
      "text": "[杖と剣のウィストリア Season 2]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e3f",
      "text": "[クラスで2番目に可愛い女の子と友だちになった]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e40",
      "text": "[逃がした魚は大きかったが釣りあげた魚が大きすぎた件]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e41",
      "text": "[愛してるゲームを終わらせたい]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e42",
      "text": "[ねずみくんのチョッキ]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e43",
      "text": "[スノウボールアース]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e44",
      "text": "[異世界のんびり農家2]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69ccf8cb000000000071a833",
      "text": "\t[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775040716,
      "updated": 1775040716
    },
    {
      "id": "69cc90f60000000000192e45",
      "text": "[ポンコツ風紀委員とスカート丈が不適切なJKの話]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e46",
      "text": "[上伊那ぼたん、酔へる姿は百合の花]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e47",
      "text": "[一畳間まんきつ暮らし！]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
    {
      "id": "69cc90f60000000000192e48",
      "text": "[氷の城壁]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775014135,
      "updated": 1775014135
    },
