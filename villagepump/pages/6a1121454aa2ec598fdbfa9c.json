    {
      "id": "6a11235f00000000002d2e77",
      "text": "[Gradient Google icon redesign rolling out on Android, iOS, & web ［U］ https://9to5google.com/2026/05/22/gradient-google-icon-redesign-web/]",
      "userId": "5c30ba88e98efe0017e5172d",
