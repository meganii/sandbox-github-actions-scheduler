{
  "id": "69b6112dbbe4d588af315f55",
  "title": "ありがたみ",
  "created": 1773539633,
  "updated": 1773540358,
  "lines": [
    {
      "id": "69b6112dbbe4d588af315f55",
      "text": "ありがたみ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539633,
      "updated": 1773539633
    },
    {
      "id": "69b613900000000000527721",
      "text": "[ありがたさ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540241,
      "updated": 1773540241
    },
    {
      "id": "69b613a20000000000527747",
      "text": "[ありがたい]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540259,
      "updated": 1773540259
    },
    {
      "id": "69b613900000000000527722",
      "text": "[ありがとう]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540241,
      "updated": 1773540241
    },
    {
      "id": "69b613a90000000000527749",
      "text": " [（ありがたい）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540266,
      "updated": 1773540266
    },
    {
      "id": "69b613af000000000052774a",
      "text": "\t[助かります]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540272,
      "updated": 1773540272
    },
    {
      "id": "69b613af000000000052774b",
      "text": "\t[- [蟻が十]]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540272,
      "updated": 1773540279
    },
    {
      "id": "69b613be0000000000527761",
      "text": "[ありがたし]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540288,
      "updated": 1773540288
    },
    {
      "id": "69b613be0000000000527762",
      "text": "[ありがてぇ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540288,
      "updated": 1773540288
    },
    {
      "id": "69b613be0000000000527763",
      "text": "\t[切り出しありがてえ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540288,
      "updated": 1773540288
    },
    {
      "id": "69b613c00000000000527764",
      "text": " [てぇてぇ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540289,
      "updated": 1773540358
    },
    {
      "id": "69b613960000000000527732",
      "text": "[ありがたいこと]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773540246,
      "updated": 1773540246
    },
    {
      "id": "69b6113f00000000005276ea",
      "text": "[普段の健康のありがたみ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539647,
      "updated": 1773539647
    },
    {
      "id": "69b6116200000000005276ef",
      "text": "[それがない環境で過ごして初めてありがたみが分かるもの]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539683,
      "updated": 1773539683
    },
    {
      "id": "69b6113000000000005276e6",
      "text": "[リンクのありがたみ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539633,
      "updated": 1773539639
    },
    {
      "id": "69b6113700000000005276e8",
      "text": "[Scrapboxのありがたみ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539641,
      "updated": 1773539646
    },
    {
      "id": "69b612110000000000527703",
      "text": " [どんな表現でもいいので、記述/発話してくれるとありがたい]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539858,
      "updated": 1773539862
    },
    {
      "id": "69b6121b0000000000527708",
      "text": " [ありがた山の寒がらす]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539868,
      "updated": 1773539869
    },
    {
      "id": "69b61224000000000052770c",
      "text": " [必要なときにそこにいてくれたという事実は、ただそれだけのことで、何にも増して、ありがたいものだ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539877,
      "updated": 1773539882
    },
    {
      "id": "69b6114500000000005276ec",
      "text": "[ありがた迷惑]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539654,
      "updated": 1773539660
    },
    {
      "id": "69b6114900000000005276ed",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773539658,
      "updated": 1773539658
    }
  ]
}