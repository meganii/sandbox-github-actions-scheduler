{
  "id": "69e7715b094ae94f7e752180",
  "title": "脳内BGM",
  "created": 1776775517,
  "updated": 1776776974,
  "lines": [
    {
      "id": "69e7715b094ae94f7e752180",
      "text": "脳内BGM",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776775517,
      "updated": 1776775517
    },
    {
      "id": "69e771a000000000004d5ae5",
      "text": " 機器では音楽を再生していないが、頭の中のどこかから音楽を聞いて楽しんでる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776775584,
      "updated": 1776775723
    },
    {
      "id": "69e77279000000000068b850",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776775801,
      "updated": 1776775801
    },
    {
      "id": "69e771af00000000004d5ae6",
      "text": "脳内BGMと似てるものに[イヤーワーム]がある",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776775599,
      "updated": 1776775801
    },
    {
      "id": "69e771f000000000004d5ae9",
      "text": " 聞きたくないのにこびりついて離れなくて苦しんでるようなときはこっち",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776775665,
      "updated": 1776775907
    },
    {
      "id": "69e7734100000000004d5af0",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776001,
      "updated": 1776776001
    },
    {
      "id": "69e7734100000000004d5af1",
      "text": "井戸端で脳内BGMについて話してるページは",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776001,
      "updated": 1776776021
    },
    {
      "id": "69e7735500000000004d5af5",
      "text": " [頭の中で音を想像する]では頭の中で音を鳴らせるかアンケートを取ってる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776021,
      "updated": 1776776929
    },
    {
      "id": "69e7736600000000004d5af7",
      "text": " [落ち着いてるときに頭の中で流れてる曲]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776039,
      "updated": 1776776041
    },
    {
      "id": "69e7736800000000004d5af8",
      "text": " [忙しくなると頭の中で鳴りだす曲]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776041,
      "updated": 1776776041
    },
    {
      "id": "69e7770e000000000072bf75",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776974,
      "updated": 1776776974
    },
    {
      "id": "69e7736000000000004d5af6",
      "text": " ピンチのときに頭の中で鳴り出す曲?",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776033,
      "updated": 1776776974
    },
    {
      "id": "69e776f1000000000072bf74",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1776776946,
      "updated": 1776776946
    }
  ]
}