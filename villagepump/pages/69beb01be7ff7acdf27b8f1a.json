  "lines": [
    {
      "id": "69beb01be7ff7acdf27b8f1a",
      "text": "WebVM",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104629,
      "updated": 1774104629
    },
    {
      "id": "69beb034000000000010c67e",
      "text": "[Webブラウザ]上で[Linux]を動かすツールのこと",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104629,
      "updated": 1774104684
    },
    {
      "id": "69beb072000000000010c680",
      "text": "[WebAssembly]を利用している",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104691,
      "updated": 1774104700
    },
    {
      "id": "69beb07b000000000010c681",
      "text": "",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104700,
      "updated": 1774104700
    },
    {
      "id": "69beb0b7000000000010c688",
      "text": "\thttps://webvm.io/",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104760,
      "updated": 1774104764
    },
    {
      "id": "69beb0b6000000000010c686",
      "text": "\t[leaningtech/webvm: Virtual Machine for the Web https://github.com/leaningtech/webvm]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104759,
      "updated": 1774104770
    },
    {
      "id": "69beb0b6000000000010c687",
      "text": "",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104759,
      "updated": 1774104759
    },
    {
      "id": "69beb07b000000000010c682",
      "text": "技術",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104700,
      "updated": 1774104702
    },
    {
      "id": "69beb07e000000000010c684",
      "text": "\t[CheerpX]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104702,
      "updated": 1774104803
    },
    {
      "id": "69beb113000000000010c68c",
      "text": "\t\t[WebAssembly]上で動作する[x86エミュレーター]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104852,
      "updated": 1774104900
    },
    {
      "id": "69beb0e3000000000010c689",
      "text": "\t[xterm.js]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104804,
      "updated": 1774104814
    },
    {
      "id": "69beb41c000000000010c695",
      "text": "\t\tWebブラウザ上で動作するターミナル",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774105629,
      "updated": 1774105640
    },
    {
      "id": "69beb0ee000000000010c68a",
      "text": "\t[Tailscale]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104814,
      "updated": 1774104818
    },
    {
      "id": "69beb859000000000010c6ad",
      "text": "\t\t[WebVM]上のLinuxを外と通信させる際に利用されているサービス",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774106713,
      "updated": 1774106772
    },
    {
      "id": "69beb899000000000010c6ae",
      "text": "\t\t近年のWebブラウザはセキュリティ的な都合により[TCP/IP]のような低レベルの通信が使えなかったり、[CORS]制約により任意のサーバーに接続できなかったりするので、こういったサービスを経由する必要がある",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774106778,
      "updated": 1774106866
    },
    {
      "id": "69beb0f8000000000010c68b",
      "text": "\t[lwIP]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774104824,
      "updated": 1774104827
    },
