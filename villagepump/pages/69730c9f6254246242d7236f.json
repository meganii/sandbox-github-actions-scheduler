    {
      "id": "69730c9f6254246242d7236f",
      "text": "2026/01/24",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147568,
      "updated": 1769147568
    },
    {
      "id": "69739a3fed60e60000002bb09c",
      "text": "第4週: 日月火水木金[[土]]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769183806,
      "updated": 1769183806
    },
    {
      "id": "69739a3fed60e6000000b02b15",
      "text": "2026年 6.58％経過",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769183806,
      "updated": 1769183806
    },
    {
      "id": "69730cb100000000003c3a16",
      "text": "from [2026/01/23]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147568,
      "updated": 1769147578
    },
    {
      "id": "69730cb200000000003c3a17",
      "text": "[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147568,
      "updated": 1769147580
    },
    {
      "id": "69730cbe00000000003c3a19",
      "text": " 卒論の試験方法と研究背景を最低限書いて25日までに先生に提出するのを最優先にする",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147580,
      "updated": 1769147580
    },
    {
      "id": "69730cbe00000000003c3a1a",
      "text": " この3日間はこれだけをやる。何とかなれ～",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147580,
      "updated": 1769147580
    },
    {
      "id": "69730cbe00000000003c3a1b",
      "text": "  day 2",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147580,
      "updated": 1769147673
    },
    {
      "id": "69730cbd00000000003c3a18",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147579,
      "updated": 1769147579
    },
    {
      "id": "69739a3fed60e600000063d823",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769183806,
      "updated": 1769183806
    },
    {
      "id": "69739a3fed60e600000079857e",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769183806,
      "updated": 1769184077
    },
    {
      "id": "69739b4f00000000007504d5",
      "text": " まだ何か攻撃的な部分が抜けない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769184078,
      "updated": 1769184166
    },
    {
      "id": "69739baa00000000007504d6",
      "text": " 追い込んで疲れてボロが出て、休んでボロを元に反省して、復活後に同じ轍を踏まないようにして、また追い込んで疲れて別のボロが出て、また反省してを繰り返していくか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769184170,
      "updated": 1769184276
    },
    {
      "id": "69739c3a00000000007504d7",
      "text": " \t大量の知的作業をすると疲れてボロが出始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769184314,
      "updated": 1769184335
    },
    {
      "id": "6973d80e000000000043111b",
      "text": " \t\tわかる[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769199633,
      "updated": 1769199634
    },
    {
      "id": "69739a3fed60e6000000941689",
      "text": " 全銘柄の全時刻の価格のデータ量ってどのくらいなんだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769183806,
      "updated": 1769236840
    },
    {
      "id": "6974699a00000000001c220a",
      "text": "  上場銘柄が3'938",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769236891,
      "updated": 1769237479
    },
    {
      "id": "697469b500000000001c220b",
      "text": "  tickや分足は残っていないだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769236918,
      "updated": 1769237162
    },
    {
      "id": "69746aab00000000001c220c",
      "text": "  日足は残っているようだ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237163,
      "updated": 1769237185
    },
    {
      "id": "69746ac700000000001c220d",
      "text": "  年間365の日足が増えていく",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237192,
      "updated": 1769237231
    },
    {
      "id": "69746af700000000001c220e",
      "text": "  10年間4'000個の銘柄を記録し続けると",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237239,
      "updated": 1769237465
    },
    {
      "id": "69746b7300000000001c220f",
      "text": "   14.6M個の日足が生まれる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237364,
      "updated": 1769237461
    },
    {
      "id": "69746bdd00000000001c2210",
      "text": "  1つの日足に1KBも費やさないだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237469,
      "updated": 1769237587
    },
    {
      "id": "69746c5200000000001c2211",
      "text": "   適当に見つけたデータは8個の値が記録されていた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237587,
      "updated": 1769237775
    },
    {
      "id": "69746d0f00000000001c2213",
      "text": "   16Bくらいに押し込めるかしら",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237775,
      "updated": 1769237801
    },
    {
      "id": "69746cfa00000000001c2212",
      "text": "   https://www.jpx.co.jp/markets/statistics-equities/daily/data/202401.pdf",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237754,
      "updated": 1769237757
    },
    {
      "id": "6974693100000000001c2209",
      "text": "  14.6×16=233.6MB",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769236787,
      "updated": 1769243711
    },
    {
      "id": "6974831700000000000f7eee",
      "text": "   でかい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243415,
      "updated": 1769243437
    },
    {
      "id": "6974832c00000000000f7eef",
      "text": "   動画でも30MBくらいだぞ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243437,
      "updated": 1769243437
    },
    {
      "id": "6974833000000000000f7ef0",
      "text": "  60年分あると1.4GBくらい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243441,
      "updated": 1769243633
    },
    {
      "id": "6974834e00000000000f7ef1",
      "text": "   それで収まるんだ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243470,
      "updated": 1769243501
    },
    {
      "id": "6974840f00000000000f7ef2",
      "text": " データ量このくらいなら全銘柄の過去データでトレーニングした時系列予測モデルとか作れるんじゃないか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243665,
      "updated": 1769243788
    },
    {
      "id": "697484dd00000000000f7ef3",
      "text": "  おもろいことやってるレディット民おった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243870,
      "updated": 1769243886
    },
    {
      "id": "697484ee00000000000f7ef4",
      "text": "  [https://www.reddit.com/r/MachineLearning/comments/1hpuerz/r_gpu_trainingbacktesting_is_2x_slower_than_cpu/?tl=ja LightGBMで\\~1GBの金融データセットの場合、GPUトレーニング/バックテストはCPUトレーニング/バックテストの2倍遅い]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243886,
      "updated": 1769243985
    },
    {
      "id": "69746d3000000000001c2214",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769237809,
      "updated": 1769237809
    },
    {
      "id": "69739ce4000000000033a175",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769184484,
      "updated": 1769184487
    },
    {
      "id": "69739ce7000000000033a176",
      "text": "　[ハイコウイクティス]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769184487,
      "updated": 1769239967
    },
    {
      "id": "697433c800000000008c2ac0",
      "text": "　https://x.com/kosuke_agos/status/2014471230498525335",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769223113,
      "updated": 1769223113
    },
    {
      "id": "697433c800000000008c2ac1",
      "text": "　 編み物をすると寿命が伸びる、マジかよ",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769223113,
      "updated": 1769240024
    },
    {
      "id": "69745ea900000000000ae230",
      "text": "　自分のpublic projectのpin-diaryを止めようと思っている",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769234091,
      "updated": 1769239160
    },
    {
      "id": "6974727800000000000ae234",
      "text": "　\t[/nishio/TODO: 日記をprivate化する]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769239160,
      "updated": 1769239198
    },
    {
      "id": "6974729100000000000ae236",
      "text": "　\tが、たまに書きたくなるのではないか、そういう時に手軽に日記ページを作れるべきでないか、と考えている",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769239186,
      "updated": 1769239186
    },
    {
      "id": "6974729000000000000ae235",
      "text": "　\tメニューに追加した",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769239184,
      "updated": 1769241108
    },
    {
      "id": "6973a6ba0000000000076daa",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769187003,
      "updated": 1769187003
    },
    {
      "id": "6973a6ba0000000000076dab",
      "text": "[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769187003,
      "updated": 1769187005
    },
    {
      "id": "6973a6bd0000000000076dad",
      "text": "\tやはり[ニコチンがないと頭が回らない]ので[オーラルたばこVELO]を補充した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769187005,
      "updated": 1769187552
    },
    {
      "id": "6974855900000000000f7ef5",
      "text": "\t ニコチンガムとかどうすか[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769243994,
      "updated": 1769244007
    },
    {
      "id": "6973a6c80000000000076dae",
      "text": "\tSettingsに[引用文中の箇条書きのテキストの折り返しを揃えるUserCSS]を適用した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769187016,
      "updated": 1769187032
    },
    {
      "id": "6973acf3000000000033acb8",
      "text": "\t体質的に、集中するには心を研ぎ澄まして全身を憎悪の刃にするという手法が一番あっている",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769188595,
      "updated": 1769188797
    },
    {
      "id": "6973adcb000000000033acb9",
      "text": "\t\t[アンガーセルフマネジメント]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769188812,
      "updated": 1769188842
    },
    {
      "id": "6974859800000000000f7efa",
      "text": "\t\t[wakaru.icon][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769244056,
      "updated": 1769244056
    },
    {
      "id": "6973a6bb0000000000076dac",
      "text": "\t\t[アドレナリン]を出すのか[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769187004,
      "updated": 1769223144
    },
    {
      "id": "6974858b00000000000f7ef7",
      "text": "\t\t破壊的な歌詞のメタル聴きながらとか、戦記物のアニメとか流しながらだと作業が捗る[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769244043,
      "updated": 1769244118
    },
    {
      "id": "697485e200000000000f7efb",
      "text": "\t\t 呼ばれた時にそのまま殺気が向かないように注意を要する",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769244131,
      "updated": 1769244164
    },
    {
      "id": "69746c380000000000d3fe1d",
      "text": "\t[日本語版グライド入力]を使いたい",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769237560,
      "updated": 1769237604
    },
    {
      "id": "697433e800000000008c2ac2",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769223144,
      "updated": 1769223144
    },
    {
      "id": "6973ff8a0000000000938c3c",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769209738,
      "updated": 1769209738
    },
    {
      "id": "6973ff8b0000000000938c3e",
      "text": "\t[/fab-wiki/20260118週fabnews]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769209738,
      "updated": 1769209739
    },
    {
      "id": "6973ff8c0000000000938c3f",
      "text": "\t\t今週のモノづくり系気になったニュースまとめました！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769209739,
      "updated": 1769209750
    },
    {
      "id": "6974034c0000000000938c40",
      "text": "\t[https://shonenjumpplus.com/episode/17107094913049140701 第4話 羽鳥と古田の非日常茶飯事 - 野々上大二郎 | 少年ジャンプ＋]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769210700,
      "updated": 1769210703
    },
    {
      "id": "697403650000000000938c42",
      "text": "\t\t[羽鳥と古田の非日常茶飯事]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769210724,
      "updated": 1769210725
    },
    {
      "id": "697403500000000000938c41",
      "text": " \t絵も話も好きだな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769210703,
      "updated": 1769210711
    },
    {
      "id": "69742d0e0000000000aff73a",
      "text": " [はたらく細胞展IN東京ソラマチ https://www.webtsc.com/event/hataraku-saibou-tokyo/]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769221391,
      "updated": 1769269577
    },
    {
      "id": "69742d0f0000000000aff73b",
      "text": "  結局来た",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769221393,
      "updated": 1769221395
    },
    {
      "id": "69742d3c0000000000aff73c",
      "text": "  まぁそこまで大きな展示ではない",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769221437,
      "updated": 1769221446
    },
    {
      "id": "69742d470000000000aff73d",
      "text": "  入場料が高い気がするけど立地上しょうがないかな、、",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769221448,
      "updated": 1769221466
    },
    {
      "id": "69743b61000000000042390c",
      "text": "  5歳の娘が楽しんでるのでヨシ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769225057,
      "updated": 1769225066
    },
    {
      "id": "6974787700000000000dc2bc",
      "text": " [https://gyazo.com/4cb58914b78ac701c3107fcd690ed998]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769240697,
      "updated": 1769240717
    },
    {
      "id": "6974788c00000000000dc2bd",
      "text": "  なぜか読む方向が逆と感じる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769240717,
      "updated": 1769240731
    },
    {
      "id": "6974bdcc0000000000f1c960",
      "text": "  \tたし🦀。「川崎」という単語に引っ張られて逆に感じてしまう[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1769258445,
      "updated": 1769258578
    },
    {
      "id": "69741a1700000000004be5e8",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769216535,
      "updated": 1769216536
    },
    {
      "id": "6973ff8a0000000000938c3d",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769209738,
      "updated": 1769216532
    },
    {
      "id": "69741a1000000000004be5e6",
      "text": " [オール・ユー・ニード・イズ・キル]のアニメ版、上映館少ないし枠も少ない",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769216528,
      "updated": 1769216575
    },
    {
      "id": "69741a4300000000004be5e9",
      "text": "  絵柄が？？？だけど、見るだけ見ておきたい",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769216579,
      "updated": 1769216596
    },
    {
      "id": "69744b850000000000fbdbdc",
      "text": " 通院し薬もらって散歩して、映画館来て良き一日。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769229189,
      "updated": 1769229217
    },
    {
      "id": "697468310000000000fbdbdd",
      "text": " 映画 マーシー AI裁判 見てきた。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769236529,
      "updated": 1769236540
    },
    {
      "id": "6974683d0000000000fbdbde",
      "text": "  よかった。最初はAI対人間か？と思ったけどバディモノになっていった。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769236541,
      "updated": 1769236572
    },
    {
      "id": "697468c50000000000fbdbe1",
      "text": "   刑事モノっぽい展開",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769236676,
      "updated": 1769236684
    },
    {
      "id": "697468650000000000fbdbdf",
      "text": "  クレジットにamazonが入ってたし、いわゆるハリウッド映画っぽくはなかった。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769236580,
      "updated": 1769236793
    },
    {
      "id": "6974694500000000005fe6fd",
      "text": "   アメリカドラマを超圧縮した感じ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769236805,
      "updated": 1769236841
    },
    {
      "id": "6974688d0000000000fbdbe0",
      "text": "  AIはもうちょっと無機質でもええんやで、、って気持ちもある。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769236620,
      "updated": 1769236763
    },
    {
      "id": "69746c540000000000baa560",
      "text": "  クリスプラットとレベッカファーガソンのだ。Siloが大好きだったのでみたい[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769237589,
      "updated": 1769237647
    },
    {
      "id": "697422100000000000adc758",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769218579,
      "updated": 1769218579
    },
    {
      "id": "697422100000000000adc759",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769218579,
      "updated": 1769218581
    },
    {
      "id": "697422300000000000adc75b",
      "text": " 韓国でAI基本法",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769218611,
      "updated": 1769275918
    },
    {
      "id": "697422130000000000adc75a",
      "text": "  >[https://x.com/deepone5950/status/2014443034415661288 @deepone5950]: 韓国で[AI規制基本法]が施行。概要は",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769218582,
      "updated": 1769275922
    },
    {
      "id": "697501700000000000ef4504",
      "text": "  >①[AI生成物にウォーターマーク表示を義務化]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275761,
      "updated": 1769275909
    },
    {
      "id": "697501700000000000ef4505",
      "text": "  >②国民の[基本権]に直結する物を「[高影響AI]」に指定、AI利用事前告知やリスク管理義務化",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275761,
      "updated": 1769275932
    },
    {
      "id": "697501700000000000ef4506",
      "text": "  >③外国企業に対し韓国国内の代理人指定を義務化、上記法令対応を執行させる",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275761,
      "updated": 1769275761
    },
    {
      "id": "697501700000000000ef4507",
      "text": "  >④上記に違反した場合最大約300万円の罰金",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275761,
      "updated": 1769275761
    },
    {
      "id": "697501700000000000ef4508",
      "text": "  >日本もやろう",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275761,
      "updated": 1769275761
    },
    {
      "id": "697501700000000000ef4509",
      "text": "  >[https://gyazo.com/02ffd5c07cd17bdf43a4b28fa8e933c5]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275761,
      "updated": 1769275772
    },
    {
      "id": "697501970000000000ef450c",
      "text": "  > \t[@chosunonline https://x.com/chosunonline/status/2014158412389769489]: 韓国できょうから世界初のAI規制施行…業界混乱、[逆差別]への懸念も ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275799,
      "updated": 1769275946
    },
    {
      "id": "697501a50000000000ef450d",
      "text": "  > AI基本法（[人工知能発展と信頼基盤造成などに関する基本法]）が22日から施行される。欧州連合（EU）は2024年に初めてAI法を制定したが、リスクの高いAI規制は2027年12月に先送りしている。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275813,
      "updated": 1769275954
    },
    {
      "id": "697501a70000000000ef450e",
      "text": "  > \t[https://www.chosunonline.com/site/data/html_dir/2026/01/22/2026012280057.html 韓国できょうから世界初のAI規制施行…業界混乱、逆差別への懸念も-Chosun online 朝鮮日報]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275816,
      "updated": 1769275821
    },
    {
      "id": "697501700000000000ef450a",
      "text": "  > ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275761,
      "updated": 1769275826
    },
    {
      "id": "697501d30000000000ef450f",
      "text": "  > 生成AIの規制意外にも",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275859,
      "updated": 1769275862
    },
    {
      "id": "697501d60000000000ef4510",
      "text": "  > [国家AI基本計画]の策定、[国家AI戦略委員会]の設立、AI技術の開発及び産業育成の支援、AI学習用データの生産・収集・管理・流通・活用促進及び品質水準確保の施策、等を含む包括的な法令となっている",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275862,
      "updated": 1769275977
    },
    {
      "id": "697501d60000000000ef4511",
      "text": "  > 韓国国内では「高影響AIの定義が曖昧」「ウォーターマーク表示義務免除の条件が曖昧」「法令順守コストがベンチャーにとって不利」「[海外大企業に対する実効性]確保が出来るのか」と懸念の声もあり",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769275863,
      "updated": 1769287468
    },
    {
      "id": "697501d90000000000ef4512",
      "text": "  > 今後修正が必要な部分があるかもしれない",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275865,
      "updated": 1769275865
    },
    {
      "id": "697501d90000000000ef4513",
      "text": "  > とは言え特に①の生成AIの生成物に対するウォーターマーク義務化は日本でも取り入れるべきだろう",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275865,
      "updated": 1769275867
    },
    {
      "id": "697501db0000000000ef4514",
      "text": "  > 例えば、[ディープフェイク]での[選挙妨害]や或いは戦争勃発へ誘引する方向に使用されたりする事に対する一定の抑止力になる",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275867,
      "updated": 1769276019
    },
    {
      "id": "697501db0000000000ef4515",
      "text": "  > [ウォーターマーク]を外す事自体を犯罪行為として捜査のとっかかりにできるわけだ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275867,
      "updated": 1769276011
    },
    {
      "id": "697501db0000000000ef4516",
      "text": "  > なお米カリフォルニア州の「[AI透明化法]」では、可視的なウォーターマークだけではなくAI生成物であることを示す「不可視的な証明」も生成データに入れ込むことが盛り込まれている",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275868,
      "updated": 1769276030
    },
    {
      "id": "697501f60000000000ef4519",
      "text": "  > \t[https://www.jetro.go.jp/biznews/2025/10/ea97d110406cf2b1.html 米カリフォルニア州、AIの安全性・透明性・プライバシー保護強化への複数の法案を制定(米国) | ビジネス短信 ―ジェトロの海外ニュース - ジェトロ]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275895,
      "updated": 1769275895
    },
    {
      "id": "697501df0000000000ef4517",
      "text": "  > 参考にした上で「ウォーターマークのないAI生成物をアップロードしたユーザーに対しては罰金」といった罰則を盛り込めば、善良なユーザーはウォーターマーク出力機能の無いAI生成ソフト使用を自然に敬遠するようになるかもしれん",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275871,
      "updated": 1769275873
    },
    {
      "id": "697501e00000000000ef4518",
      "text": "  > そこは善意の第三者の免罪も含め慎重に判断が必要だが",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769275873,
      "updated": 1769275873
    },
    {
      "id": "69741a1000000000004be5e7",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1769216528,
      "updated": 1769216528
    },
    {
      "id": "697433080000000000b5c7eb",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769222921,
      "updated": 1769222922
    },
    {
      "id": "697433090000000000b5c7ec",
      "text": "\tたばこ [た箱]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769222922,
      "updated": 1769223049
    },
    {
      "id": "697433280000000000b5c7f0",
      "text": "\t\t2 イラスト",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769222954,
      "updated": 1769222955
    },
    {
      "id": "6974332a0000000000b5c7f1",
      "text": "\t\t\t[https://gyazo.com/1dabb79b057ea2d62da0e217ab974233]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769222955,
      "updated": 1769223008
    },
    {
      "id": "697433090000000000b5c7ed",
      "text": "\t\t [日常]っぽい作画とテーマ[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769222923,
      "updated": 1769224813
    },
    {
      "id": "6974451e0000000000692cd3",
      "text": "\t\t [たばこ]のページアイコンに良さそうだ[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1769227550,
      "updated": 1769227592
    },
    {
      "id": "69743a4d000000000042390b",
      "text": "\t\t1 ascii art出してきた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769224782,
      "updated": 1769224782
    },
    {
      "id": "697433220000000000b5c7ee",
      "text": "\t\t\t[https://gyazo.com/ca01027936b9fcfc52d477bbc4744131]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769222947,
      "updated": 1769222948
    },
    {
      "id": "697433230000000000b5c7ef",
      "text": "\t[チームみらい]のSlackの開発者向けチャンネル、AI開発ノウハウが散らかってて参考になりそう",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769222948,
      "updated": 1769227114
    },
    {
      "id": "6974437000000000001d4e46",
      "text": "\t\tCodeRabbitも初耳",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769227122,
      "updated": 1769227126
    },
    {
      "id": "6974671400000000000ae231",
      "text": "\t\t実際に使っている人と「同じチーム」になれるというのは学習効果が大きいね[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769236246,
      "updated": 1769236267
    },
    {
      "id": "6974672400000000000ae232",
      "text": "\t\t\tSNSだと正直に発信しないインセンティブがある",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769236262,
      "updated": 1769236287
    },
    {
      "id": "6974673c00000000000ae233",
      "text": "\t\t\t\tAIですごい成果が出たように見せかけたり、自分がAIを使いこなしているかのように見せかけたり",
      "userId": "582e63d27c56960011aff09e",
      "created": 1769236287,
      "updated": 1769236307
    },
    {
      "id": "69744a7000000000001d4e48",
      "text": "\tfrom:@人物名 で決め打ちで発言も追う",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769228914,
      "updated": 1769228924
    },
    {
      "id": "6974572a00000000004b7576",
      "text": "\tやっぱ今持ってる仕事次第って感じがする",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769232171,
      "updated": 1769232179
    },
    {
      "id": "6974573200000000004b7577",
      "text": "\t\t急にAI開発ネタが目に入ったりCodexを触ったりする。AI開発の仕事が始まったからだ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769232179,
      "updated": 1769232232
    },
    {
      "id": "6974437600000000001d4e47",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769227127,
      "updated": 1769227127
    },
    {
      "id": "69743acf0000000000529f7f",
      "text": "[カイト.icon]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769224911,
      "updated": 1769224913
    },
    {
      "id": "69743ad10000000000529f80",
      "text": " [如月千早武道館単独公演]、当日",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769224913,
      "updated": 1769224931
    },
    {
      "id": "69743ae30000000000529f81",
      "text": "  開演が17時からということで[連番者]と秋葉原散策",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769224932,
      "updated": 1769224977
    },
    {
      "id": "69743b120000000000529f82",
      "text": "  今回、[センターステージ]構成の[xrライブ]がどういう風に観れるんだろうとソワソワしている",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769224978,
      "updated": 1769226425
    },
    {
      "id": "69743b540000000000529f83",
      "text": "   https://x.com/imas_official/status/2014691350202220798",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769225044,
      "updated": 1769225064
    },
    {
      "id": "69743b650000000000529f85",
      "text": "   [https://gyazo.com/0cdb6c8d8dfeb8bea46be5f332f1c323]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769225064,
      "updated": 1769225078
    },
    {
      "id": "69743b760000000000529f86",
      "text": " [神田たまごけん]のオムライス美味しゅうございました",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769225078,
      "updated": 1769226281
    },
    {
      "id": "6974402700000000004f75b4",
      "text": "  [https://gyazo.com/7d86c865c2112e5c96cfd6e4cd8a9b3f]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769226281,
      "updated": 1769226374
    },
    {
      "id": "697448a40000000000cfc728",
      "text": "  井戸端でごはん画像地味に久々に見た[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769228453,
      "updated": 1769228471
    },
    {
      "id": "6974878a0000000000fde309",
      "text": "  おいしそう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1769244554,
      "updated": 1769244558
    },
    {
      "id": "6974408500000000004f75b5",
      "text": " [日本武道館]着",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769226374,
      "updated": 1769237800
    },
    {
      "id": "69746d280000000000cf16dc",
      "text": "  開場前ということも人が多い",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769237800,
      "updated": 1769237819
    },
    {
      "id": "69746d3c0000000000cf16dd",
      "text": "  [https://gyazo.com/9c6c11aa4d58b68136546a24f09f7a55]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769237821,
      "updated": 1769237845
    },
    {
      "id": "69746d550000000000cf16de",
      "text": "  やっぱり現地で見るとシビれる",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769237845,
      "updated": 1769237932
    },
    {
      "id": "6974ef5c0000000000aa2f44",
      "text": " 終演後、オフ会して勢いで我が家に泊まる人が増えた",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769271133,
      "updated": 1769271170
    },
    {
      "id": "69746c920000000000cf16db",
      "text": "",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769237651,
      "updated": 1769237651
    },
    {
      "id": "697447cb0000000000cfc721",
      "text": "[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769228235,
      "updated": 1769228236
    },
    {
      "id": "697447cc0000000000cfc723",
      "text": "　「明日の晴天」の描き方",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769228237,
      "updated": 1769228243
    },
    {
      "id": "697448180000000000cfc726",
      "text": "　　古くはこれを絵に描くことはできなかったかもしれない",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769228312,
      "updated": 1769228384
    },
    {
      "id": "697447d30000000000cfc724",
      "text": "　　天気予報の画面がそれっぽい像として定着している現代では、例えば天気予報を模した絵が明日の晴天を描いた画像として解釈できるかもしれない",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769228244,
      "updated": 1769228448
    },
    {
      "id": "697447fb0000000000cfc725",
      "text": "　　空の写真から明日の晴天がほぼ100パーの確率で予想できるようになるかもしれない",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769228283,
      "updated": 1769228307
    },
    {
      "id": "6974763a0000000000b5c779",
      "text": "　[workflowyでタブ間のドラッグ&ドロップがサポート]されるようになった←神アプデしかし[vivaldi]非対応",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769240122,
      "updated": 1769276066
    },
    {
      "id": "6974a8060000000000219fab",
      "text": "　[https://gyazo.com/ba9358a0f4b3f26321c9381a95c62fec][https://gyazo.com/7eb246aec930f821db1203c1f3c15dde][https://gyazo.com/da1069bccb97dcde773d15010f44db4d]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769252870,
      "updated": 1769253547
    },
    {
      "id": "6974a8080000000000219fac",
      "text": "　ゴハンじゃしん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769252872,
      "updated": 1769252885
    },
    {
      "id": "6974a9770000000000219fae",
      "text": "\tこのおもちゃカメラの使い方がわからない",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769253239,
      "updated": 1769253711
    },
    {
      "id": "6974a97b0000000000219faf",
      "text": "\t手前がぼやぼやになっている。丁度良く合わせる方法はないのか",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769253244,
      "updated": 1769253285
    },
    {
      "id": "6974a9b00000000000219fb0",
      "text": "\t遠くを撮って概型を見るのがよいのかも",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769253297,
      "updated": 1769253310
    },
    {
      "id": "6974ab510000000000219fb2",
      "text": "\tパンフォーカス/ディープフォーカスという仕組みのピント合わせらしい　知識がなすぎてそう言われてもわからん",
