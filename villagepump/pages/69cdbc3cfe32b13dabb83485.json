    },
    {
      "id": "69cdbc3d00000000002c46e7",
      "text": "from [2026/04/01]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46e8",
      "text": "メガネに[Suica]を仕込む",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090753
    },
    {
      "id": "69cdbc4200000000002c46f6",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090755,
      "updated": 1775090756
    },
    {
      "id": "69cdbc3d00000000002c46e9",
      "text": "\t>[https://x.com/ina_ani/status/2039114673577136305 @ina_ani]: ネタを思いついたらすぐ漫画にできるのは面白いな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46ea",
      "text": " >[https://pbs.twimg.com/media/HExj_OBbYAENzwD.jpg]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46eb",
      "text": " \t体中にsuicaをつけてボクシングでより多く決済したほうが勝ちのボクシングルールを思いついた[mtane0412.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46ec",
      "text": " \t僕はこっちが思いついた[sta.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46ed",
      "text": " \t\t[https://gyazo.com/0738436ba656fbd841bd0f49cf6c622f]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46ee",
      "text": "   気持ち悪い[はるひ.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46ef",
      "text": "   まあstaさんなら平常運転だけど……ええ……[takker.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cde6040000000000c26ecc",
      "text": "   店員ドン引きしすぎて言語失っとるやん[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1775101443,
      "updated": 1775101456
    },
    {
      "id": "69cdbc3d00000000002c46f0",
      "text": " \t歳をとるとバーコード決済ができる可能性😳[terang.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46f1",
      "text": " \t なんかそんなのを昔テレビで見た気がする[inajob.icon][nishio.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46f2",
      "text": " \t  [特ホウ王国]だったかな？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46f3",
      "text": " \t  懐かしい番組名だ[terang.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cdbc3d00000000002c46f4",
      "text": " \t  バイトがバーコードリーダーを持ったまま髪をかきあげたら眉毛を読み込んで「かっぱえびせん」と表示された、というネタを聞いた、事実かどうかは知らない(たぶん盛ってる)[nishio.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775090749,
      "updated": 1775090749
    },
    {
      "id": "69cde6360000000000c26ecd",
      "text": " \t[スマートウォッチ]にSuica入れてる人も毎回手首捻ってて大変そうって思ってる[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1775101493,
      "updated": 1775101528
    },
    {
      "id": "69cde65a0000000000c26ece",
      "text": "\t　[ETC]ゲートみたいに通るだけで決済ってできないのかな[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1775101528,
      "updated": 1775101603
    },
    {
      "id": "69cde6690000000000c26ecf",
      "text": " \t　後ろにビタ付けしてゲート潜る不正が横行しそうだけど",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1775101544,
      "updated": 1775101566
    },
    {
      "id": "69cde88e0000000000c6d17d",
      "text": " \t　[無人コンビニ]がそれじゃなかったっけといううろ覚え[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1775102094,
      "updated": 1775102112
    },
    {
      "id": "69cde8a00000000000c6d17e",
      "text": " \t　\tあらかじめ登録してあれば、商品手にとって外に出るだけで決済完了のやつ",
      "userId": "65e1289acd012200235729c0",
      "created": 1775102112,
      "updated": 1775102136
    },
