    },
    {
      "id": "6946841100000000008f351c",
      "text": "[* [/nrem/Nrem/UserCSS]]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1766229012,
      "updated": 1771239201
    },
    {
      "id": "6980ad930000000000263478",
      "text": "\t`minimal.css`は動作が重すぎて使い物にならない時用",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770040724,
      "updated": 1770040724
    },
    {
      "id": "698b038900000000009cc2a1",
      "text": "[* [/nrem/Nrem/UserScript], [/nrem/Nrem/UserScript: villagepump]]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770718091,
      "updated": 1771239149
    },
    {
      "id": "699e1d0a0000000000f22778",
      "text": " code:disabled",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1771969803,
      "updated": 1771969803
    },
    {
      "id": "698b038300000000009cc29c",
      "text": " code:style.css",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770718085,
      "updated": 1771232060
    },
    {
      "id": "698326520000000000c804e7",
      "text": "  @import url('/api/code/nrem/Nrem%2FUserCSS/minimum.css');",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770202707,
      "updated": 1771240310
    },
    {
      "id": "698b03590000000000402d47",
      "text": " code:script.js",
      "userId": "6780c5dd585ee07f1dc50b2b",
