{
  "id": "69c72e64f6cf6984d3e1d196",
  "title": "infobox日記",
  "created": 1774661228,
  "updated": 1774663030,
  "lines": [
    {
      "id": "69c72e64f6cf6984d3e1d196",
      "text": "infobox日記",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661228,
      "updated": 1774661228
    },
    {
      "id": "69c72e6c0000000000903ac4",
      "text": "infoboxで日記をつける",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661228,
      "updated": 1774661244
    },
    {
      "id": "69c72e6c0000000000903ac5",
      "text": "`YYYY-MM-DD`のページを作って、infoboxを置く",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661229,
      "updated": 1774661470
    },
    {
      "id": "69c730bf000000000014dd2a",
      "text": "`YYYY-MM-DD`のページにアイコンリンク用の画像を用意する",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661823,
      "updated": 1774661852
    },
    {
      "id": "69c731b6000000000014dd2f",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774662070,
      "updated": 1774662070
    },
    {
      "id": "69c72f5e0000000000903aca",
      "text": "infoboxに登録するには、`#YYYY-MM-DD`のページにリンクをつなげる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661470,
      "updated": 1774662117
    },
    {
      "id": "69c72fab0000000000903acb",
      "text": "#YYYY-MM-DD （infoboxに登録される）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661547,
      "updated": 1774662137
    },
    {
      "id": "69c72fac0000000000903acc",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661549,
      "updated": 1774661549
    },
    {
      "id": "69c730e5000000000014dd2b",
      "text": "infobox以外の用途でリンクを使いたい場合は、アイコンリンクを使う",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661862,
      "updated": 1774661951
    },
    {
      "id": "69c73159000000000014dd2e",
      "text": "このリンクはinfoboxから拾われない→[YYYY-MM-DD.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661977,
      "updated": 1774662041
    },
    {
      "id": "69c73140000000000014dd2d",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661952,
      "updated": 1774661952
    },
    {
      "id": "69c73493000000000014dd31",
      "text": "日付形式のアイコンリンクによって、関連ページを増やさないで昨日、明日といった日付のリンクができる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774662804,
      "updated": 1774662905
    },
    {
      "id": "69c73493000000000014dd32",
      "text": "例: [2026-03-11.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774662804,
      "updated": 1774663030
    },
    {
      "id": "69c73493000000000014dd33",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774662804,
      "updated": 1774662804
    },
    {
      "id": "69c72e920000000000903ac6",
      "text": "[https://img.shields.io/badge/%23-infobox日記-black#.png]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661267,
      "updated": 1774661337
    },
    {
      "id": "69c72e930000000000903ac7",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774661268,
      "updated": 1774661268
    }
  ]
}