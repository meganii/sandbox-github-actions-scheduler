{
  "id": "69ccc9b04964a7fe673aa49a",
  "title": "アラウンドと◯代",
  "created": 1775028658,
  "updated": 1775039358,
  "lines": [
    {
      "id": "69ccc9b04964a7fe673aa49a",
      "text": "アラウンドと◯代",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028658,
      "updated": 1775028658
    },
    {
      "id": "69cccaa500000000003bc96d",
      "text": "ティーンエイジャー",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028902,
      "updated": 1775028911
    },
    {
      "id": "69cccaaf00000000003bc96f",
      "text": "\tthirteen (13) ~ nineteen (19)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028911,
      "updated": 1775028960
    },
    {
      "id": "69cccaa600000000003bc96e",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028902,
      "updated": 1775028902
    },
    {
      "id": "69ccc9f400000000003bc967",
      "text": "around x-ty （和製英語）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028724,
      "updated": 1775029029
    },
    {
      "id": "69ccca1600000000003bc969",
      "text": "\tアラサー: around thirty",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028758,
      "updated": 1775028781
    },
    {
      "id": "69ccca2f00000000003bc96a",
      "text": "\tアラフォー: around forty",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028783,
      "updated": 1775028805
    },
    {
      "id": "69ccca4600000000003bc96b",
      "text": "\tアラフィフ: around fifty",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028806,
      "updated": 1775028814
    },
    {
      "id": "69ccca5800000000003bc96c",
      "text": "\tアカカン: around 還暦",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028824,
      "updated": 1775028834
    },
    {
      "id": "69ccc9f400000000003bc968",
      "text": "\t四捨五入 (round off)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028724,
      "updated": 1775029451
    },
    {
      "id": "69ccccaf00000000003bc981",
      "text": "\t\t年齢[$ x]に対して[$ {\\rm around}\\ 10\\lbrack x\\rbrack]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029423,
      "updated": 1775029499
    },
    {
      "id": "69ccccb000000000003bc982",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029424,
      "updated": 1775029424
    },
    {
      "id": "69ccf326000000000071a831",
      "text": "アラミリ (Арами́ль)（ロシア・スヴェルドロフスク州・シセルツキー地区・アラミリ）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775039270,
      "updated": 1775039358
    },
    {
      "id": "69ccf325000000000071a830",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775039269,
      "updated": 1775039269
    },
    {
      "id": "69ccc9b200000000003bc963",
      "text": "◯代",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775028658,
      "updated": 1775029424
    },
    {
      "id": "69cccb3100000000003bc970",
      "text": "\t10代～90代",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029041,
      "updated": 1775029052
    },
    {
      "id": "69cccb3f00000000003bc971",
      "text": "\tあまり聞かない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029055,
      "updated": 1775029061
    },
    {
      "id": "69cccb4700000000003bc973",
      "text": "\t\t0代、100代、110代、120代",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029063,
      "updated": 1775029087
    },
    {
      "id": "69cccb6000000000003bc976",
      "text": "\t\t生存記録なし: 130代以降",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029088,
      "updated": 1775029111
    },
    {
      "id": "69cccbf500000000003bc97e",
      "text": "\t切り捨て",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029237,
      "updated": 1775029358
    },
    {
      "id": "69cccc9800000000003bc980",
      "text": "\t\t年齢[$ x]に対して[$ 10\\lfloor x\\rfloor 代]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029400,
      "updated": 1775029419
    },
    {
      "id": "69cccb7f00000000003bc977",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029120,
      "updated": 1775029165
    },
    {
      "id": "69cccbc500000000003bc979",
      "text": "路",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029188,
      "updated": 1775029193
    },
    {
      "id": "69cccbae00000000003bc978",
      "text": " 三十路",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029166,
      "updated": 1775029194
    },
    {
      "id": "69cccbcc00000000003bc97a",
      "text": " 四十路",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029196,
      "updated": 1775029199
    },
    {
      "id": "69cccbcf00000000003bc97b",
      "text": " 五十路",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029199,
      "updated": 1775029202
    },
    {
      "id": "69cccbd100000000003bc97c",
      "text": " 六十路",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775029202,
      "updated": 1775029203
    },
