      "created": 1773400024,
      "updated": 1773400068
    },
    {
      "id": "69b3efd0000000000037ec79",
      "text": "\t[https://wikisocion.github.io/content/psychological_types.html#id3 倫理型の節（英訳）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773400018,
      "updated": 1773400022
    },
    {
      "id": "69b3efd1000000000037ec7a",
      "text": "\t[https://wikisocion.github.io/content/psychological_types.html#thinking 思考型の節（英訳）]",
