    {
      "id": "6a3ae5a90000000000f1738a",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244778,
      "updated": 1782244778
    },
    {
      "id": "6a3ae5aa0000000000f1738c",
      "text": "\t[「意外と安定する0.5センチくらいのフチ」満員電車で吊り革を掴めなかったときに始まる都市型ボルダリング、もはやその姿は社畜のクリフハンガー - Togetter https://togetter.com/li/2712754]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244778,
      "updated": 1782244779
    },
    {
      "id": "6a3ae5aa0000000000f1738d",
      "text": "\t\tわかる",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244779,
      "updated": 1782244782
    },
    {
      "id": "6a3ae5ad0000000000f1738e",
      "text": "\t\t別に掴まなくても、指を押し付けるだけでもマシ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244782,
      "updated": 1782244795
    },
    {
      "id": "6a3ae5ba0000000000f1738f",
      "text": "\t\t\t体重をかけるのがコツ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244795,
      "updated": 1782244799
    },
    {
      "id": "6a3ae5bf0000000000f17390",
      "text": "\t\t\t当てるだけだと、逆側に引っ張られたときに対抗できない",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244800,
      "updated": 1782244813
    },
    {
      "id": "6a3ae5cc0000000000f17391",
      "text": "\t\t\t結構体力勝負",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244813,
      "updated": 1782244826
    },
    {
      "id": "6a3ae5d20000000000f17392",
      "text": "\t\tあとは潔癖だからつり革掴みたくないってのもあるなぁ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244819,
      "updated": 1782244839
    },
    {
      "id": "6a3ae5e60000000000f17393",
      "text": "\t\t\tつり革の丸いところじゃなくて、その上を掴むことはある",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244839,
      "updated": 1782244859
    },
    {
      "id": "6a3ae6220000000000f17394",
      "text": "\t\t\t[https://gyazo.com/1de4bf98d1bf7a95ef4760c6bb6152b0]([choi-draw]便利だ)",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244899,
      "updated": 1782245148
    },
    {
      "id": "6a3ae6240000000000f17395",
      "text": "\t\t\t最も触られにくいところだと思ってる（さらに上の鉄棒よりも）",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244901,
      "updated": 1782244924
    },
    {
      "id": "6a3ae6450000000000f17396",
      "text": "\t\t\tこれも結構体力、つか握力勝負",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1782244934,
      "updated": 1782244940
    },
