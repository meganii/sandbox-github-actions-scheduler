    },
    {
      "id": "692f02b06eb406000000d27da8",
      "text": "第49週: 日月火[[水]]木金土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764688559,
      "updated": 1764688559
    },
    {
      "id": "692f02b06eb406000000014bb6",
      "text": "2025年 92.33％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764688559,
      "updated": 1764688559
    },
    {
      "id": "692f02b06eb4060000004072fc",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764688559,
      "updated": 1764688559
    },
    {
      "id": "692f02b06eb4060000001e38cb",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764688559,
      "updated": 1764688559
    },
    {
      "id": "692f02b06eb40600000024c49b",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764688559,
      "updated": 1764689215
    },
    {
      "id": "692f0540000000000064c207",
      "text": "\t[#inajob の試しに録音してみた talk128: inajobのいろいろレビューを紹介します]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764689215,
      "updated": 1764689249
    },
    {
      "id": "692f90ad00000000002d8f4b",
      "text": "\t\tいつもと経路の違う内容にしてみた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764724910,
      "updated": 1764724915
    },
    {
      "id": "692f90b200000000002d8f4c",
      "text": "\t\t[inajobのいろいろレビュー]の紹介",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764724915,
      "updated": 1764724924
    },
    {
      "id": "692f7cae0000000000f338e3",
      "text": "\t[https://open.spotify.com/episode/1Cw1QkAPvP7UvTZdKDPpiu]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764719790,
      "updated": 1764719792
    },
    {
      "id": "692f7cb00000000000f338e5",
      "text": "\t\tめちゃ良い",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764719792,
      "updated": 1764719795
    },
    {
      "id": "692f7cf80000000000f338e6",
      "text": "\t\tコンデンサの謎の例えの説明",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764719865,
      "updated": 1764719878
    },
    {
      "id": "692f7fa90000000000f338e7",
      "text": "\t\t[子どもが体験するべき50の危険なこと]的な話",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764720553,
      "updated": 1764720559
    },
    {
      "id": "6930187c0000000000fd3a49",
      "text": "\t[https://inajob.hatenablog.jp/entry/diy-for-daughter-2025 エンジニアパパと5歳の娘で2025年に作ったもの - inajob's blog]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764759676,
      "updated": 1764759679
    },
    {
      "id": "6930187f0000000000fd3a4a",
      "text": " \t書いた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764759679,
      "updated": 1764759681
    },
    {
      "id": "692f89f50000000000ed5527",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764723190,
      "updated": 1764723190
    },
    {
      "id": "692f89f50000000000ed5528",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764723190,
      "updated": 1764723191
    },
    {
      "id": "692f89f70000000000ed5529",
      "text": "\t[ランチミーティング]、ちょっと苦手。",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764723191,
      "updated": 1764771383
    },
    {
      "id": "692f9cac0000000000b862c9",
      "text": "\t渋谷のスクランブル交差点、撮影外国人多し。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764727981,
      "updated": 1764727998
    },
    {
      "id": "692f9cf40000000000b862ca",
      "text": "\tinfoboxを宣伝するバニラ高収入トレーラーが走っていった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764728052,
      "updated": 1764728114
    },
    {
      "id": "692f9d330000000000b862cb",
      "text": "\t コセンスは関係なかった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764728115,
      "updated": 1764728127
    },
    {
      "id": "693017ea0000000000b86886",
      "text": "\tいつも売り切れだった[西友のおはぎ]を嫁が売ってるのを発見して買って帰ってきた",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764759530,
      "updated": 1764771420
    },
    {
      "id": "693018010000000000b86887",
      "text": "\t\t確かにこりゃうまい",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764759554,
      "updated": 1764759560
    },
    {
      "id": "6930180b0000000000b86888",
      "text": "\t\tいつも売り切れというのは訪れる時間帯が夜が多いというのもあるのだろうが、とにかく見たことがなかった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764759564,
      "updated": 1764759588
    },
    {
      "id": "693018240000000000b86889",
      "text": "\t\t西友がトライアル傘下になって以降、このおはぎとたまごサンドは一度食べてみたかった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1764759588,
      "updated": 1764759627
    },
    {
      "id": "6930184b0000000000b8688a",
      "text": "\t\t[たまごサンド]の方は、売り場はあれどいつも空っぽで未だ見かけたことがない",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764759627,
      "updated": 1764771430
    },
    {
      "id": "692f02b06eb40600000039f94b",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764688559,
      "updated": 1764688559
    },
    {
      "id": "692f8ae8000000000072597e",
      "text": "[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764723433,
      "updated": 1764723435
    },
    {
      "id": "692f8aeb0000000000725980",
      "text": " 水道水の件異常無して返答きたけどいや絶対味も臭いもおかしいって",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764723435,
      "updated": 1764723491
    },
    {
      "id": "692f8b2b0000000000725981",
      "text": " 　[W7kA9pX2.icon]がおかしくなってる可能性もあるか…",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764723499,
      "updated": 1764723516
    },
    {
      "id": "692f901000000000001487f2",
      "text": " 　こういうのどうしたらいいんだろうね[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764724753,
      "updated": 1764724767
    },
    {
      "id": "692f96e80000000000d589c0",
      "text": " 　　管理会社は水道局から供給される水自体に問題があるんちゃう？と言い水道局は管理会社に対応してもらってね！と言い、狂います[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764726504,
      "updated": 1764726576
    },
    {
      "id": "692f988600000000002d8f4d",
      "text": " 　　ご近所さんに聞いて証拠を集める必要がありそう[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764726918,
      "updated": 1764726963
    },
    {
      "id": "692f98c000000000002d8f4e",
      "text": " 　　\tマンションの他の部屋で同じ現象が起きているかどうか？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764726976,
      "updated": 1764726989
    },
    {
      "id": "692fa9dc0000000000cbd14f",
      "text": " 　　\t　ご近所付き合いをしていなかったツケが襲いかかってくる…[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764731356,
      "updated": 1764731379
    },
    {
      "id": "692f908000000000002d8f4a",
      "text": " 　これか [2025/11/30#692c43d400000000002ea2da] [inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764724864,
      "updated": 1764724867
    },
    {
      "id": "692f97400000000000d589c1",
      "text": " 　　それです[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764726593,
      "updated": 1764726597
    },
    {
      "id": "692fa0b8000000000039e757",
      "text": " 　管理会社の人に、実際に水を飲みに来てほしいですよね。[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764729017,
      "updated": 1764729039
    },
    {
      "id": "692fa0ec000000000039e758",
      "text": " 　 そのうえで、管理会社から水道局に問い合わせして欲しいって思う",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764729068,
      "updated": 1764729106
    },
    {
      "id": "692faa020000000000cbd150",
      "text": " 　 　本当にそう思う[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764731395,
      "updated": 1764731403
    },
    {
      "id": "692fa274000000000039e75b",
      "text": " 　 GPTさん曰く、[消費生活センター]に相談したら？と。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764729461,
      "updated": 1764730077
    },
    {
      "id": "692f901f00000000001487f3",
      "text": "\t\t\tマンション理事長を体験して管理会社は本当に最低限のことしかしてくれないなと思っている[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764724768,
      "updated": 1764731564
    },
    {
      "id": "692fc0e0000000000083cf0f",
      "text": "\t\t\t　激安単身者向けアパートなのもありあんまり要求するのもなあという気持ちもあります…[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764737248,
      "updated": 1764737304
    },
    {
      "id": "692feaa8000000000078d6ff",
      "text": "\tXの検索タブのおすすめに[inajob.icon]さんのポストがあってオオ！となり、元気が出ました",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764747945,
      "updated": 1764748006
    },
    {
      "id": "692feaf9000000000078d700",
      "text": "\t　https://x.com/ina_ani/status/1996008960038764551　こちらのポスト",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764748026,
      "updated": 1764748051
    },
    {
      "id": "692ff5e1000000000020fda1",
      "text": "\t　謎に反応良いのはこのせいか、ありがたい[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764750818,
      "updated": 1764750834
    },
    {
      "id": "69300c0c0000000000480a51",
      "text": "\t　すごい[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764756495,
      "updated": 1764756496
    },
    {
      "id": "692feb15000000000078d701",
      "text": "　ホームのおすすめと検索のおすすめ結構系統が違うがこれどう決めてるんだろう",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764748053,
      "updated": 1764748115
    },
    {
      "id": "692febf1000000000078d702",
      "text": "　　ホームの方は教育が行き届きすぎたのか犬か犬以外のフワフワいのちしか出てこなくなってしまったので他の話題見たいときに検索のおすすめ見て今これが流行ってる/燃えてるのか〜してる",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764748274,
      "updated": 1764748358
    },
    {
      "id": "692faa9900000000002d8f4f",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1764731546,
      "updated": 1764731546
    },
    {
      "id": "692f902000000000001487f4",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764724768,
      "updated": 1764724770
    },
    {
      "id": "692f902200000000001487f5",
      "text": "　朝イチの会議done",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764724770,
      "updated": 1764724778
    },
    {
      "id": "692ff3400000000000f52f7b",
      "text": "　わざわざ銀座の茅乃舎にだしいなりを買いに行ったのに売り切れてた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764750144,
      "updated": 1764750164
    },
    {
      "id": "692f902a00000000001487f6",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1764724778,
      "updated": 1764724779
    },
    {
      "id": "692fa5c1000000000041f93b",
      "text": "[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1764730307,
      "updated": 1764730307
    },
    {
      "id": "692fa5c2000000000041f93c",
      "text": " [AnthropicがBun買収]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764730307,
      "updated": 1764772100
    },
    {
      "id": "692fb852000000000000c420",
      "text": " n8nのGoogle TasksノードでパラメータがないやつがあったのでPR出した",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1764735059,
      "updated": 1764735080
    },
    {
      "id": "692fb868000000000000c421",
      "text": " 　これでGoogle ChatやGoogle Docsで作成したタスクも見えるようになる",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1764735080,
      "updated": 1764735091
    },
    {
      "id": "692fb8f8000000000000c422",
      "text": " [https://gyazo.com/1458ad2e7ce9997ce613ead65abfbda9]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1764735225,
      "updated": 1764735225
    },
    {
      "id": "692fb8f9000000000000c423",
      "text": "  ヒドイ[Summer498.icon][caki.icon][bsahd.icon][W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1764735225,
      "updated": 1764746122
    },
    {
      "id": "692fd49a00000000005b9262",
      "text": "  記憶では前は機械翻訳で「無効にする」と入力しろと書かれてあるが値はdisableを入れなくてはならなかったのが、修正が入って入れ替わった気がする[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1764742299,
      "updated": 1764742338
    },
    {
      "id": "692fb04600000000003eadb3",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764732998,
      "updated": 1764732998
    },
    {
      "id": "692fb04600000000003eadb4",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764732998,
      "updated": 1764733000
    },
    {
      "id": "692fb04900000000003eadb5",
      "text": " 今日も曇でグレーな気分。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764733001,
      "updated": 1764733014
    },
    {
      "id": "692fc9c50000000000bd6a35",
      "text": " [scrapbox-duplicator]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764739526,
      "updated": 1764739531
    },
    {
      "id": "692fc9de0000000000bd6a36",
      "text": " \tgithub actionは動いてるのに更新されてないっぽい",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764739550,
      "updated": 1764739564
    },
    {
      "id": "692fc9ec0000000000bd6a37",
      "text": " \tScrapboxのSIDが変わったとかかな？仕事終わったら見てみよう。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1764739564,
      "updated": 1764739639
    },
    {
      "id": "692fc2c700000000006a86be",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764737736,
      "updated": 1764737736
    },
    {
      "id": "692fc2c700000000006a86bf",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764737736,
      "updated": 1764737738
    },
    {
      "id": "692fa5f8000000000041f93d",
      "text": " さむい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764730361,
      "updated": 1764737749
    },
    {
      "id": "692fc4b000000000006a86c8",
      "text": " 自国領を攻撃したり、諸外国からの自国領内のイザコザに対して内政干渉カードを切れるるバグ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738225,
      "updated": 1764738316
    },
    {
      "id": "692fc55e00000000006a86cb",
      "text": "  例えば隣国を自国として組み込んだ上で自国領内に攻撃できてしまう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738399,
      "updated": 1764738475
    },
    {
      "id": "692fc50d00000000006a86c9",
      "text": " 自国領に対する軍事攻撃って何かに引っかかったりするんかな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738318,
      "updated": 1764738372
    },
    {
      "id": "692fc54500000000006a86ca",
      "text": "  国境ギリギリの自国領内に攻撃を仕掛けると国境を超えて何らかの嫌がらせができる可能性",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738373,
      "updated": 1764738607
    },
    {
      "id": "692fd7250000000000d2db1d",
      "text": "  ベイルート港大爆発みたいに、爆発物を保管しておくだけで、周囲一帯を吹き飛ばせる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764742950,
      "updated": 1764743021
    },
    {
      "id": "692fd77b0000000000d2db1e",
      "text": "   でもこの方法だと隣国に侵攻する兵站を置いていると思われてしまう。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743036,
      "updated": 1764743075
    },
    {
      "id": "692fc63a00000000006a86cc",
      "text": "  そうじゃなくとも小さな領域の領有権争いをしているとして、そこが自国領だという認識のもとで全面焼き払うみたいな発想も思いつく。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738619,
      "updated": 1764743087
    },
    {
      "id": "692fd7ae0000000000d2db1f",
      "text": "  ロケットの発射実験を国境沿いでやることも考えられる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743087,
      "updated": 1764743118
    },
    {
      "id": "692fd7ce0000000000d2db20",
      "text": "   これは中国がやってる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743119,
      "updated": 1764743128
    },
    {
      "id": "692fd7dc0000000000d2db21",
      "text": "   打ち上げ失敗すると大規模な爆発による被害が隣国にも行く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743132,
      "updated": 1764743174
    },
    {
      "id": "692fc6a600000000006a86cd",
      "text": "  これ植民地主義的発想やな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738726,
      "updated": 1764738753
    },
    {
      "id": "692fc6c200000000006a86ce",
      "text": "   本土以外の自国領に対する非道",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738755,
      "updated": 1764738780
    },
    {
      "id": "692fc6ff00000000006a86cf",
      "text": " 自国領に対する攻撃といえば、中国とミャンマーがエラい事になってる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738816,
      "updated": 1764741890
    },
    {
      "id": "692fc72700000000006a86d0",
      "text": "  🇲🇲ミャンマーの[ロヒンギャ問題]は中々に興味深い言い分をしている。",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1764738856,
      "updated": 1764772412
    },
    {
      "id": "692fc78d00000000006a86d1",
      "text": "  ミャンマー政府はバングラデシュからの不法移民として扱っていて、民族的歴史も何もかも無いみたいな扱い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764738957,
      "updated": 1764739157
    },
    {
      "id": "692fc89c00000000006a86d2",
      "text": "  事態をややこしくしているのが、英領インドは現インド、パキスタン、バングラデシュ、ミャンマーを含む領域で、英領インド時点でのムスリムやベンガル人の移動自体は自国内での移動に過ぎない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739229,
      "updated": 1764739369
    },
    {
      "id": "692fc90500000000006a86d3",
      "text": "   またイギリスか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739334,
      "updated": 1764739341
    },
    {
      "id": "692fc92a00000000006a86d4",
      "text": "  しかもミャンマーは多民族国家だから、下手を打つと分裂する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739371,
      "updated": 1764739421
    },
    {
      "id": "692fc95d00000000006a86d5",
      "text": "   旧ユーゴみたいにパーンと割れてしまう。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739421,
      "updated": 1764739598
    },
    {
      "id": "692fc96c00000000006a86d6",
      "text": "   分裂した方が幸せなんじゃないの？(分離独立主義/国民国家主義)ということも考えられるが、それでもくっつけておきたい事情はあるんだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739436,
      "updated": 1764739627
    },
    {
      "id": "692fca4900000000006a86d8",
      "text": "  🇨🇳中国は辺境に行くとかなり多民族国家",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739657,
      "updated": 1764739763
    },
    {
      "id": "692fcab400000000006a86da",
      "text": "   回族(回教＝イスラム教を信仰する民族)の系統がそれなりにいる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739764,
      "updated": 1764739875
    },
    {
      "id": "692fcb2300000000006a86db",
      "text": "    テュルク系やツングース系の民族、果ては回教に改宗した漢族まで様々",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739875,
      "updated": 1764739951
    },
    {
      "id": "692fcb7000000000006a86dc",
      "text": "   どういうわけか隣国の民族がそこそこ住んでいる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764739953,
      "updated": 1764740049
    },
    {
      "id": "692fcbd200000000006a86dd",
      "text": "    ウズベク族(ウズベキスタン)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740050,
      "updated": 1764740077
    },
    {
      "id": "692fcc1a00000000006a86e0",
      "text": "    カザフ族(カザフスタン)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740123,
      "updated": 1764740134
    },
    {
      "id": "692fcbec00000000006a86de",
      "text": "    キルギス族(キルギス)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740077,
      "updated": 1764740114
    },
    {
      "id": "692fcc1200000000006a86df",
      "text": "    ジン族（京族、越族、ベトナム族）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740114,
      "updated": 1764740168
    },
    {
      "id": "692fcc4800000000006a86e1",
      "text": "    タイ族",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740169,
      "updated": 1764740174
    },
    {
      "id": "692fcc7900000000006a86e2",
      "text": "    タジク族(タジキスタン)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740218,
      "updated": 1764740229
    },
    {
      "id": "692fcc8500000000006a86e3",
      "text": "    朝鮮族(北朝鮮・韓国)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740229,
      "updated": 1764740279
    },
    {
      "id": "692fccb700000000006a86e4",
      "text": "    モンゴル族(モンゴル)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740279,
      "updated": 1764740319
    },
    {
      "id": "692fcef60000000000d2db0f",
      "text": "   国として独立できずに丸呑みされている民族もいる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740855,
      "updated": 1764740885
    },
    {
      "id": "692fcf140000000000d2db10",
      "text": "    ウイグル族",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740885,
      "updated": 1764740890
    },
    {
      "id": "692fcf1a0000000000d2db11",
      "text": "    チベット族",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740890,
      "updated": 1764740895
    },
    {
      "id": "692fcf1f0000000000d2db12",
      "text": "    高山族(台湾原住民)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764740895,
      "updated": 1764741224
    },
    {
      "id": "692fd1d40000000000d2db13",
      "text": "    満州族",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764741591,
      "updated": 1764741594
    },
    {
      "id": "692fd1f40000000000d2db14",
      "text": "   下手に独立を許すと、隣国に組み込まれる可能性があるので独立させられない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764741621,
      "updated": 1764741668
    },
    {
      "id": "692fd2290000000000d2db15",
      "text": "    ウクライナの親ロシア派の分離独立運動からのロシア併合",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764741673,
      "updated": 1764741717
    },
    {
      "id": "692fd2580000000000d2db16",
      "text": "    中国では満州族の独立と日本による傀儡化",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764741721,
      "updated": 1764741762
    },
    {
      "id": "692fd3300000000000d2db18",
      "text": " 独立したがって目立っている民族も居れば、調べないと出てこないようなマニアックな民族もいる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764741937,
      "updated": 1764741978
    },
    {
      "id": "692fd35a0000000000d2db19",
      "text": "  目立つ民族は独立心の強さ、その地域の資源特性、隣国との関係等様々な要素がそうさせていそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764741979,
      "updated": 1764742096
    },
    {
      "id": "692fd8610000000000d2db22",
      "text": " 民族っていう概念は割とよくわからない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743266,
      "updated": 1764743303
    },
    {
      "id": "692fd8880000000000d2db23",
      "text": "  多分人が人を見て似てるとか大きく違うと思うような感覚を統治に利用したものなんだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743304,
      "updated": 1764743395
    },
    {
      "id": "692fd8d70000000000d2db24",
      "text": "  パッと見違う民族もいるが、ほぼ同じような民族もいる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743384,
      "updated": 1764743450
    },
    {
      "id": "692fd91b0000000000d2db25",
      "text": "  言語・文字・風習が民族を分けそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743452,
      "updated": 1764743617
    },
    {
      "id": "692fd9c10000000000d2db26",
      "text": "   生物としての特徴は民族を分けるか？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743618,
      "updated": 1764743638
    },
    {
      "id": "692fd9d60000000000d2db27",
      "text": "   古い時代の考えならそうだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743639,
      "updated": 1764743656
    },
    {
      "id": "692fd9e80000000000d2db28",
      "text": "   実際どうだろう。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743656,
      "updated": 1764743677
    },
    {
      "id": "692fd9fd0000000000d2db29",
      "text": "   例えば、完全に日本人の精神を持つ、(見た目が)アングロサクソン人が大量に住んでいる街が日本にあったとする",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764743678,
      "updated": 1764766769
    },
    {
      "id": "6930338e00000000008c6a85",
      "text": "   \tパッと見は大量の観光客で溢れる街なんだけど、話している言語も日本語で、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764766606,
      "updated": 1764766655
    },
    {
      "id": "693033cd00000000008c6a86",
      "text": "   \t話しかけた時の対応も日本的で",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764766669,
      "updated": 1764766686
    },
    {
      "id": "693033de00000000008c6a87",
      "text": "   \t着ている服も住んでいる家も日本的だとする",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764766686,
      "updated": 1764766757
    },
    {
      "id": "6930342600000000008c6a88",
      "text": "    特異な見た目を保てている時点で、結婚等に関する厳格なルールがあると思われるので、そこで風習の違いを指摘できそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764766758,
      "updated": 1764766853
    },
    {
      "id": "693034a400000000008c6a89",
      "text": "   同化すると遺伝子的にも溶け合いそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764766884,
      "updated": 1764766910
    },
    {
      "id": "693034df00000000008c6a8a",
      "text": " よく考えたら似たような状況の国があるわ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764766943,
      "updated": 1764767418
    },
    {
      "id": "693034ec00000000008c6a8b",
      "text": " \tイスラエルはユダヤ人として集まった国のはずだが、同じユダヤ人内でも区別が発生している",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764766956,
      "updated": 1764767008
    },
    {
      "id": "6930352100000000008c6a8c",
      "text": " \tヨーロッパ系をアシュケナジム、アジア・アフリカ系をセファルディム、オリエント系をミズラヒムという",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764767009,
      "updated": 1764767161
    },
    {
      "id": "693035bf00000000008c6a8d",
      "text": " \t同じ宗教で集まっているけど、言語や習慣がディアスポラ先の民族と同化されて変容している",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764767167,
      "updated": 1764767264
    },
    {
      "id": "693037dc00000000008c6a8e",
      "text": " タイのアユタヤに16世紀（戦国時代）頃に日本人街が形成されたらしい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764767708,
      "updated": 1764767745
    },
    {
      "id": "69303a3100000000008c6a95",
      "text": " \t18世紀くらいまで存続したようだ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764768305,
      "updated": 1764768315
    },
    {
      "id": "6930380100000000008c6a8f",
      "text": " \tしかもタイ人と同化して自然消滅したらしい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764767745,
      "updated": 1764767763
    },
    {
      "id": "6930389c00000000008c6a91",
      "text": " \t日本人街が形成された頃は商業力や単身での武力を持っていて頼りにされると同時に警戒されていたようだ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764767900,
      "updated": 1764767989
    },
    {
      "id": "693038f500000000008c6a92",
      "text": " \t\t単身での武力は傭兵として生かされていた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764767989,
      "updated": 1764768001
    },
    {
      "id": "6930390200000000008c6a93",
      "text": " \t\t謀反を起こす恐れがあるほど集まると王室から焼き討ちされたらしい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764768001,
      "updated": 1764768032
    },
    {
      "id": "6930392d00000000008c6a94",
      "text": " \t\t商業力的にも華僑と同様に警戒されていた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764768044,
      "updated": 1764768063
    },
    {
      "id": "69303c4400000000008c6a96",
      "text": " \t\t月代を沿って髷を結う髪型を現地でもしている日本人、辮髪の華僑、とにかく目立つだろうね",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764768836,
      "updated": 1764769036
    },
    {
      "id": "6930381300000000008c6a90",
      "text": " \tおもろすぎる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1764767763,
      "updated": 1764767767
    },
    {
      "id": "6930139e00000000004d8c58",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758431,
      "updated": 1764758431
    },
    {
      "id": "692fc2d000000000006a86c1",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764737745,
      "updated": 1764758431
    },
    {
      "id": "6930139c00000000004d8c57",
      "text": "\t[【G2R2018】温泉大作戦 / Freezer feat. 妃苺 MV - YouTube https://www.youtube.com/watch?v=-4XQHTuDjNg]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758430,
      "updated": 1764758432
    },
    {
      "id": "6930139f00000000004d8c59",
      "text": "\t\tが好きすぎるんだけど、どうして[くれりゅ？]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758432,
      "updated": 1764758446
    },
    {
      "id": "6930139800000000004d8c56",
      "text": "\t\tくれりゅはともかく、真面目に踊りたいけど、BPM205が速すぎてふーむ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758426,
      "updated": 1764758471
    },
    {
      "id": "693013f900000000004d8c5b",
      "text": "\t\tまあまずは[コミットメント効果]ですね！",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758523,
      "updated": 1764758529
    },
    {
      "id": "693013fe00000000004d8c5c",
      "text": "\t\t\t[https://gyazo.com/88e88e1c179a183e1b3820a98104f0bc]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758527,
      "updated": 1764758528
    },
    {
      "id": "693013ff00000000004d8c5d",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758528,
      "updated": 1764758528
    },
    {
      "id": "693018dc00000000006d6562",
      "text": "[seibe.icon]",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1764759770,
      "updated": 1764759771
    },
    {
      "id": "693018df00000000006d6564",
      "text": "　LLMを使うのに[懐疑主義]大事な感じがある",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1764759774,
      "updated": 1764759883
    },
    {
      "id": "69304676000000000080cf71",
      "text": "　[Building Index]のパーセンテージ表示が出て良い",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1764771444,
      "updated": 1764771456
    },
    {
      "id": "693013ad00000000004d8c5a",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1764758446,
      "updated": 1764758446
    },
