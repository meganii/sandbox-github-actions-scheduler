    },
    {
      "id": "6a00b8600000000000310cc6",
      "text": "from [未解決謎解き]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cc7",
      "text": "2026-04-30下ネタ謎解き",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cc8",
      "text": "[https://gyazo.com/d9fcf0d79d698486530dc47544d779f4 https://x.com/2026musyoku/status/2049413388443242706]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cc9",
      "text": " ?んこ かつ 下ネタでない だと結構絞れそう[caki.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cca",
      "text": "  [~ あんこ、いんこ、えんこ、しんこ…]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310ccb",
      "text": "   そんなことなかった",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310ccc",
      "text": "  ?にすは絞れそう",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310ccd",
      "text": "   [~ テニス、アニス]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cce",
      "text": "\t\tま?こは[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310ccf",
      "text": "\t\t\t[~ まいこ、まきこ？、まさこ？、まちこ？、まなこ、ままこ、まみこ？、まゆこ？]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd0",
      "text": "\t\t\t[~ 人名がありかわからんので一応出したが「まなこ」が怪しいな]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd1",
      "text": "\t\t\t\t[~ あなPPPPPべつの下ネタに抵触します！]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd2",
      "text": "\t\t\t[~ あいす、すんこ、ちがう　あいだ、だんこ、ちがう　　違わないか？「断固」はあり]✅？",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd3",
      "text": "\t\t\t\t[~ あいき、きんこ、もあり　あいち(ダメ)　あいて、てんこ　あいわ？わんこ？]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd4",
      "text": "\t\t\t  わかったかも、[~ ていき]では？[caki.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd5",
      "text": "\t\t\t  \tそれもあり[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd6",
      "text": "\t\t\t  \t回答複数ありそう[caki.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd7",
      "text": "\t\t\t  \t\t今まで出てきた中では[~ 断固下ネタ禁止です]が一番しっくりくるな〜[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
    {
      "id": "6a00b8600000000000310cd8",
      "text": "\t\t\t  \t\t なるほど！気づいてなかった！[caki.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1778432096,
      "updated": 1778432096
    },
