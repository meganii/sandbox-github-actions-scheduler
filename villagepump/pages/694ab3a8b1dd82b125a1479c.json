      "updated": 1766513331
    },
    {
      "id": "694b25b80000000000da5df9",
      "text": " \t[👍][Hiro Aki.icon][koyoshi.icon][sta.icon][W7kA9pX2.icon][はるひ.icon][Mijikko.icon][taktamur.icon][caki.icon][mtane0412.icon][yosider.icon][seibe.icon][カイト.icon][hoshihara.icon][RR.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1766532537,
      "updated": 1766569116
    },
    {
      "id": "694b447e0000000000e8c2b8",
      "text": " \tタイトルの文字が見づらいので白抜きにしておきました[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1766540414,
      "updated": 1766540431
    },
    {
      "id": "694bbd9200000000001fdfe7",
      "text": " \t　感謝[wogikaze.icon]",
      "userId": "64099110a39a5c001c8a016e",
      "created": 1766571435,
      "updated": 1766571435
