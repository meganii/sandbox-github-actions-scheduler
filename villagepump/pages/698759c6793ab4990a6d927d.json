    {
      "id": "698759c6793ab4990a6d927d",
      "text": "2026/02/08",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770478022,
      "updated": 1770478022
    },
    {
      "id": "698759c7ed60e60000007921b5",
      "text": "第7週: [[日]]月火水木金土",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770478023,
      "updated": 1770478023
    },
    {
      "id": "698759c7ed60e600000018e455",
      "text": "2026年 10.68％経過",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770478023,
      "updated": 1770478023
    },
    {
      "id": "698759c7ed60e6000000250cc4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770478023,
      "updated": 1770478023
    },
    {
      "id": "698759c7ed60e60000001742e9",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770478023,
      "updated": 1770478023
    },
    {
      "id": "6987ba8e0000000000f3c9dd",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770502802,
      "updated": 1770502802
    },
    {
      "id": "6987ba8f0000000000f3c9de",
      "text": "\t積雪だけど歯食いしばって散歩して日光浴びてきたなう 07:20:21",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770502802,
      "updated": 1770502823
    },
    {
      "id": "6987baa60000000000f3c9df",
      "text": "\t\t寒すぎ。[手袋してるのに冷たい]とか何事",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770502823,
      "updated": 1770541484
    },
    {
      "id": "6987baae0000000000f3c9e1",
      "text": "\t\tそして服が雪まみれで濡れてダメになる",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770502832,
      "updated": 1770502843
    },
    {
      "id": "6987bab90000000000f3c9e2",
      "text": "\t\t\t2着しかないミニマリストには痛すぎる、3着ほしいな",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770502843,
      "updated": 1770503839
    },
    {
      "id": "698759c7ed60e6000000431b93",
      "text": "\t\t人がいないのは快適",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770478023,
      "updated": 1770503853
    },
    {
      "id": "6987beab0000000000b3c039",
      "text": "\t\t\t人を踏まえた立ち回りにはかなり認知使う → 息切れにつながるくらいだが、今日はいつも息切れする[100段階段]でも息切れしなかったりした",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770503853,
      "updated": 1770541514
    },
    {
      "id": "6989150f000000000056b345",
      "text": "\t[エリトラで飛び出すのムズい問題]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770591505,
      "updated": 1770591515
    },
    {
      "id": "6987e0070000000000fd8dfd",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770512392,
      "updated": 1770591519
    },
    {
      "id": "6987ca3a0000000000764e66",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1770506811,
      "updated": 1770506813
    },
    {
      "id": "6987ca3c0000000000764e68",
      "text": " 雪積もったな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1770506814,
      "updated": 1770506816
    },
    {
      "id": "6987d43c0000000000764e69",
      "text": " [ファミマプリント]で印刷物を売れるらしい。ビジネスチャンスか？",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770509373,
      "updated": 1770512615
    },
    {
      "id": "6987d43f0000000000764e6a",
      "text": "  [ファミマプリントクリエイターズ｜あなたの作品をコンビニで販売 https://creators-fp.family.co.jp/?src=7]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770509376,
      "updated": 1770542151
    },
    {
      "id": "6987d44d0000000000764e6b",
      "text": "  今はアート系が多いが、知的生産方面とも相性が良さそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1770509390,
      "updated": 1770509421
    },
    {
      "id": "6987dfe50000000000fd8dfc",
      "text": "  \t+1。テンプレートとかシート的なやつ色々つくれそう（でもビジュアルのセンスも求められそう[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770512359,
      "updated": 1770512378
    },
    {
      "id": "6987ebe50000000000a1024b",
      "text": "  \t\tチートシート販売したくなるね[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515430,
      "updated": 1770515436
    },
    {
      "id": "6987ebf70000000000a1024c",
      "text": "  \t\t\tぜひいろいろな研究をしている人がマニアックな魚とかプランクトンとかのポスターを作って",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515448,
      "updated": 1770515507
    },
    {
      "id": "6987ca3a0000000000764e67",
      "text": "\t>[https://x.com/ina_ani/status/2020294270700384601 @ina_ani]: 今年こそ雪の観察をやるぞ！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1770506811,
      "updated": 1770512836
    },
    {
      "id": "6987e1c40000000000a8ad67",
      "text": " >**たまたま**うちにデジタル顕微鏡があったのだ！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1770512836,
      "updated": 1770512836
    },
    {
      "id": "6987e1c40000000000a8ad68",
      "text": " >[https://pbs.twimg.com/media/HAmG7bracAEuEfA.jpg]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1770512836,
      "updated": 1770512836
    },
    {
      "id": "6987e1c40000000000a8ad69",
      "text": " \tCOOL[nishio.icon][takker.icon][taktamur.icon][Hiro Aki.icon][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770512836,
      "updated": 1770544081
    },
    {
      "id": "69885bf000000000007801ea",
      "text": " \tたまたまあるのいいな[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770544112,
      "updated": 1770544121
    },
    {
      "id": "6987e1c00000000000a8ad66",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1770512832,
      "updated": 1770512832
    },
    {
      "id": "6987d05500000000002255ae",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770508373,
      "updated": 1770508376
    },
    {
      "id": "6987d05a00000000002255b0",
      "text": " 東京でぼた雪は珍しい",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770508377,
      "updated": 1770508515
    },
    {
      "id": "6987d0dc00000000002255b2",
      "text": "  牡丹雪 ぼた雪 べた雪",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770508507,
      "updated": 1770512347
    },
    {
      "id": "6987df5d00000000002255b7",
      "text": " 今日選挙だ。雪の中行くか。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512220,
      "updated": 1770512357
    },
    {
      "id": "6987df2300000000002255b3",
      "text": " 投票終わり。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512162,
      "updated": 1770512170
    },
    {
      "id": "6987df2c00000000002255b4",
      "text": " 桜並木も雪化粧",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512171,
      "updated": 1770512182
    },
    {
      "id": "6987df3700000000002255b5",
      "text": "  [https://gyazo.com/cba532d55920c9bf7f8d1456bd8817e4]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512182,
      "updated": 1770512193
    },
    {
      "id": "6987df4200000000002255b6",
      "text": " 黒背景での雪の塊をじっくり見たら、小さな白い粒と、綿毛のような細い氷が観察できた。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512193,
      "updated": 1770512759
    },
    {
      "id": "6987e08a00000000002255b9",
      "text": "  [https://gyazo.com/6a5a3a30952eb3a98337e7290f9e9b68]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512521,
      "updated": 1770512554
    },
    {
      "id": "6987e0ab00000000002255ba",
      "text": "  アスファルトにおちた雪はすぐ溶けるけど、葉っぱの上では積もってた。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512554,
      "updated": 1770512603
    },
    {
      "id": "6987e7870000000000fd8e73",
      "text": "  おお[sta.icon][yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770514313,
      "updated": 1770542480
    },
    {
      "id": "6987d05600000000002255af",
      "text": " 雪の街はなかなか良かった。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770508373,
      "updated": 1770512699
    },
    {
      "id": "6987e13c00000000002255bc",
      "text": "  けど寒いから今日はもう引きこもる。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512699,
      "updated": 1770512708
    },
    {
      "id": "6987fb9a00000000002255c2",
      "text": " 外に出たくないのでピザ配達してもらおう",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770519449,
      "updated": 1770519465
    },
    {
      "id": "6987fbab00000000002255c3",
      "text": "  外に出ない贅沢",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770519467,
      "updated": 1770519484
    },
    {
      "id": "6987fc5000000000002255c4",
      "text": "  と思ったら、ピザ屋が臨時休業してた。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770519634,
      "updated": 1770519671
    },
    {
      "id": "6987fc7900000000002255c5",
      "text": "   ですよね〜。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770519672,
      "updated": 1770519679
    },
    {
      "id": "698812b6000000000082e82e",
      "text": "  バイクで出前するの不確定要素多そうだもんな[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770525367,
      "updated": 1770525393
    },
    {
      "id": "698856090000000000d941d4",
      "text": "   稼ぎ時ほど業務効率下がるのつらい[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770542602,
      "updated": 1770542616
    },
    {
      "id": "698812d2000000000082e82f",
      "text": " 寒い時には味噌鍋",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770525395,
      "updated": 1770551291
    },
    {
      "id": "698878000000000000c12aae",
      "text": "  [https://gyazo.com/76542ced4852f648e57cb278133cd540]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770551294,
      "updated": 1770551307
    },
    {
      "id": "6988780d0000000000c12aaf",
      "text": "  煮えろや煮えろ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770551307,
      "updated": 1770551328
    },
    {
      "id": "698879490000000000bfd7f1",
      "text": " 安野さんのいつも？着てる、コードの書かれた黒いTシャツ、何着持ってるんだ。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770551623,
      "updated": 1770551677
    },
    {
      "id": "6988aa550000000000af5773",
      "text": " 　21枚[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770564181,
      "updated": 1770564221
    },
    {
      "id": "6988aa7c0000000000af5774",
      "text": " 　　https://x.com/takahiroanno/status/1926966290889015475?s=46&t=gkSZtjGEtUZPO0JCzBxCBw",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770564221,
      "updated": 1770564224
    },
    {
      "id": "698946ab000000000075b2c9",
      "text": " 　　持ちすぎぃ[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770604203,
      "updated": 1770604211
    },
    {
      "id": "6987e12d00000000002255bb",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1770512684,
      "updated": 1770512684
    },
    {
      "id": "6987d9150000000000ab1629",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1770510616,
      "updated": 1770510617
    },
    {
      "id": "6987d9170000000000ab162a",
      "text": "\t雪ing",
      "userId": "65e1289acd012200235729c0",
      "created": 1770510619,
      "updated": 1770510633
    },
    {
      "id": "6987d9280000000000ab162b",
      "text": "\t\t雪というか氷っぽいから霰かな",
      "userId": "65e1289acd012200235729c0",
      "created": 1770510635,
      "updated": 1770510656
    },
    {
      "id": "6987d9150000000000ab1628",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1770510615,
      "updated": 1770510615
    },
    {
      "id": "6987ddeb0000000000c7a3c0",
      "text": "[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770511851,
      "updated": 1770511853
    },
    {
      "id": "6987dded0000000000c7a3c1",
      "text": " 思ったより雪が積もってる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770511853,
      "updated": 1770511863
    },
    {
      "id": "6987ddf70000000000c7a3c2",
      "text": " 夜になったら凍って滑っていたそう",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770511863,
      "updated": 1770511879
    },
    {
      "id": "6987de1c0000000000c7a3c3",
      "text": " この間買った[撥水加工されたユニクロのダウンじゃない方のジャケット]が役立っている",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770511900,
      "updated": 1770521802
    },
    {
      "id": "6987de3a0000000000c7a3c4",
      "text": "  [パフテック]だ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770511930,
      "updated": 1770511993
    },
    {
      "id": "698844b90000000000f0140d",
      "text": " [https://gyazo.com/a5d39e342094b0c3756f84e6ba92502c]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770538170,
      "updated": 1770538197
    },
    {
      "id": "698844d50000000000f0140e",
      "text": "  雪だ！",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770538197,
      "updated": 1770538210
    },
    {
      "id": "698856520000000000d941d5",
      "text": "  Lのへこみすごく積もりそう[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770542675,
      "updated": 1770542702
    },
    {
      "id": "69888b960000000000be7201",
      "text": " [GALA]聞いてXGにはまってしまった",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770556311,
      "updated": 1770556342
    },
    {
      "id": "69888e4900000000000562e6",
      "text": "  衣装も毎回凝ってて好き",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770557001,
      "updated": 1770557015
    },
    {
      "id": "6987e2dd0000000000833c1f",
      "text": "",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770513118,
      "updated": 1770513118
    },
    {
      "id": "6987e2dd0000000000833c20",
      "text": "[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770513118,
      "updated": 1770513121
    },
    {
      "id": "6987e2e20000000000833c22",
      "text": "　期日前行っておけばよかったと後悔するぐらいには寒いし雪",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770513122,
      "updated": 1770513156
    },
    {
      "id": "69885ec10000000000b57f31",
      "text": "　　雪にメガネやられつつも投票いてきた",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770544834,
      "updated": 1770544857
    },
    {
      "id": "6987e94f00000000005b9138",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1770514768,
      "updated": 1770514768
    },
    {
      "id": "6987e94f00000000005b9139",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1770514768,
      "updated": 1770514770
    },
    {
      "id": "6987e95300000000005b913a",
      "text": " さむむ。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1770514772,
      "updated": 1770514774
    },
    {
      "id": "6987e2df0000000000833c21",
      "text": "",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770513120,
      "updated": 1770513120
    },
    {
      "id": "6987ec700000000000a1024d",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515569,
      "updated": 1770515569
    },
    {
      "id": "6987ec710000000000a1024e",
      "text": "\t>[nishio https://x.com/nishio/status/2020304188929110512] 選挙日当日、東京朝9時の気温は-2度。東京では珍しいレベルの雪じゃない？頭のニット帽に積もった雪が溶けて投票用紙に水が落ちたので焦ったよ。無事投票完了！",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515569,
      "updated": 1770515570
    },
    {
      "id": "6987ec720000000000a1024f",
      "text": " > [https://pbs.twimg.com/media/HAmP8smboAAYvEv?format=jpg&name=900x900#.png] [https://pbs.twimg.com/media/HAmP8sebUAAjkvj?format=jpg&name=small#.png] [https://pbs.twimg.com/media/HAmP8sfaAAAPf6q?format=jpg&name=900x900#.png]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515570,
      "updated": 1770515570
    },
    {
      "id": "6987ec720000000000a10250",
      "text": " まじ寒い",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515570,
      "updated": 1770515574
    },
    {
      "id": "6987ec760000000000a10251",
      "text": " が、北海道の候補が雪まみれになってる動画を見た後なのでこのくらいで泣き言をいうのはあまっちょろいよなという気持ちになる",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515574,
      "updated": 1770515610
    },
    {
      "id": "698807a600000000005c76fa",
      "text": " 祭りの人手が足りないようなので祭りに行ってくるわ(比喩)",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770522534,
      "updated": 1770522552
    },
    {
      "id": "6988097800000000005c7702",
      "text": " 　何もなければゆっくり暖かい家で週記の切り替えでもするつもりだったが、まあそれはそれ",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770523000,
      "updated": 1770523028
    },
    {
      "id": "698807f40000000000580f75",
      "text": " 祭りうらやま[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770522612,
      "updated": 1770522621
    },
    {
      "id": "698807b700000000005c76fb",
      "text": "　　卒論がんばれ👍[nishio.icon][inajob.icon][sta.icon][taktamur.icon][Hiro Aki.icon][caki.icon][W7kA9pX2.icon][mtane0412.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770522552,
      "updated": 1770549083
    },
    {
      "id": "698808230000000000580f77",
      "text": "　　ありがとう[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770522659,
      "updated": 1770522666
    },
    {
      "id": "6988041f0000000000ff9242",
      "text": "　すごい眠い[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770521631,
      "updated": 1770542266
    },
    {
      "id": "69885c0600000000007801eb",
      "text": "　 お疲れさま！[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1770544135,
      "updated": 1770544140
    },
    {
      "id": "69885ea00000000000b57f30",
      "text": "　 [お茶.icon][W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770544801,
      "updated": 1770544809
    },
    {
      "id": "698854ba00000000009ead04",
      "text": "\t神輿にクラフトシールを貼った人がいるせいで糊が残ってしまった問題をゴシゴシして解決してた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770542266,
      "updated": 1770550853
    },
    {
      "id": "698854ba00000000009ead05",
      "text": "\t\tAIの時代に残された仕事！",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770542266,
      "updated": 1770554848
    },
    {
      "id": "698885e00000000000a10255",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770554848,
      "updated": 1770554849
    },
    {
      "id": "6988041f0000000000ff9243",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770521631,
      "updated": 1770521634
    },
    {
      "id": "698804230000000000ff9244",
      "text": " ゆーきやこんこん あられやこんこん",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770521635,
      "updated": 1770521656
    },
    {
      "id": "698804380000000000ff9246",
      "text": " いよいよ明日が卒論発表本番ですよ！",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770521656,
      "updated": 1770521675
    },
    {
      "id": "6988044e0000000000ff9247",
      "text": "  今日試験機のデータを取り出すために大学に向かう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770521679,
      "updated": 1770521733
    },
    {
      "id": "698804870000000000ff9248",
      "text": "  スライドはギリギリ作れるかどうか。スピーカーノートはあきらめる",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770521735,
      "updated": 1770521761
    },
    {
      "id": "698857210000000000d941d6",
      "text": "   スライドをpdfにしてAIにぶち込めば叩き台出してくれそう[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770542882,
      "updated": 1770542906
    },
    {
      "id": "6988610f00000000003a7795",
      "text": "   一応やっておくかー[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770545423,
      "updated": 1770545435
    },
    {
      "id": "69889faa0000000000e9a306",
      "text": "   これだけ雑にやった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770561447,
      "updated": 1770561450
    },
    {
      "id": "698804a20000000000ff9249",
      "text": "  発表に出席できればよしとしよう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770521762,
      "updated": 1770521783
    },
    {
      "id": "69880637000000000077a600",
      "text": "   イイね[taktamur.icon][Hiro Aki.icon][hoshihara.icon][yosider.icon][seibe.icon][W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770522166,
      "updated": 1770544814
    },
    {
      "id": "698829740000000000b83dd6",
      "text": "  最後の追い込みだー[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1770531189,
      "updated": 1770531195
    },
    {
      "id": "698845030000000000f0140f",
      "text": "  [加油.icon][caki.icon][seibe.icon][W7kA9pX2.icon][nomadoor.icon][suto3.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1770538243,
      "updated": 1770560024
    },
    {
      "id": "698808010000000000580f76",
      "text": " 電車が不規則なので、データだけ取ったら帰ろう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770522625,
      "updated": 1770522648
    },
    {
      "id": "6988612300000000003a7796",
      "text": " 結局夜になっちゃった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770545443,
      "updated": 1770545458
    },
    {
      "id": "6988613200000000003a7797",
      "text": "  データの差し替えしかできてない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770545458,
      "updated": 1770545473
    },
    {
      "id": "69889fb30000000000e9a307",
      "text": " ねむい、もうむり",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1770561456,
      "updated": 1770561460
    },
    {
      "id": "6987ec920000000000a10252",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770515603,
      "updated": 1770515603
    },
    {
      "id": "6988224c00000000000a3d22",
      "text": "[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1770529356,
      "updated": 1770529357
    },
    {
      "id": "6988224d00000000000a3d23",
      "text": " 投票行ってきた",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1770529357,
      "updated": 1770529362
    },
    {
      "id": "6988225300000000000a3d24",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1770529363,
      "updated": 1770529363
    },
    {
      "id": "69883c0c0000000000eb9261",
      "text": "[hoshihara.icon]",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1770535948,
      "updated": 1770535950
    },
    {
      "id": "69883c0e0000000000eb9263",
      "text": " 選挙",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1770535950,
      "updated": 1770535953
    },
    {
      "id": "69883c100000000000eb9264",
      "text": " 雪",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1770535953,
      "updated": 1770535953
    },
    {
      "id": "69883c0c0000000000eb9262",
      "text": "",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1770535948,
      "updated": 1770535948
    },
    {
      "id": "698853500000000000d941d1",
      "text": "[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770541905,
      "updated": 1770541906
    },
    {
      "id": "698853520000000000d941d2",
      "text": " ラーメン屋でふと飲んだ水がレモン水なだけでちょっと感動してしまう、ちょろい",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770541907,
      "updated": 1770541973
    },
    {
      "id": "69885c2000000000007801ec",
      "text": "  わりとわかる、こってり系のラーメン屋だとよりうれしい[caki.icon][seibe.icon]",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1770544161,
      "updated": 1770547441
    },
    {
      "id": "69886d6500000000008a6a55",
      "text": " [チームみらい]7~13議席らしい",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770548582,
      "updated": 1770548666
    },
    {
      "id": "69886d7a00000000008a6a56",
      "text": "  すごいな、いつの間にそんなことに",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770548602,
      "updated": 1770548632
    },
    {
      "id": "69886df50000000000902981",
      "text": "  これは何%の信頼区間なんだろう",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770548725,
      "updated": 1770548734
    },
    {
      "id": "698876590000000000a10254",
      "text": "  わからんが6議席当選確実が出てて当初の目標はいきなり達成した感じ[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1770550874,
      "updated": 1770550917
    },
    {
      "id": "6988541b00000000008901b5",
      "text": "  ひとまず大躍進だ[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1770542107,
      "updated": 1770561017
    },
    {
      "id": "69889df900000000001158c0",
      "text": "",
      "userId": "59fb21121207900012774b17",
      "created": 1770561017,
      "updated": 1770561020
    },
    {
      "id": "6988541b00000000008901b6",
      "text": "[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1770542107,
      "updated": 1770542109
    },
    {
      "id": "6988541d00000000008901b7",
      "text": " [ScanSnap S1500の修理]をやった。一応動いた。",
      "userId": "649a24da357c4d001c518c25",
      "created": 1770542109,
      "updated": 1770542132
    },
    {
      "id": "698853530000000000d941d3",
      "text": "",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1770541907,
      "updated": 1770541907
    },
    {
      "id": "69885aea0000000000a7e7bc",
      "text": "[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1770543851,
      "updated": 1770543852
    },
    {
      "id": "69885aec0000000000a7e7be",
      "text": " 投票した",
      "userId": "59fb21121207900012774b17",
      "created": 1770543853,
      "updated": 1770543856
    },
    {
      "id": "69886aa400000000002bf3a8",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770547877,
      "updated": 1770547877
    },
    {
      "id": "69886aa500000000002bf3a9",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770547877,
      "updated": 1770547878
    },
    {
      "id": "69886aa600000000002bf3aa",
      "text": "\t小説家になろうで条件を指定せずに検索をかけて、文字数順にソートするととんでもない文字数の作品が出てくる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770547878,
      "updated": 1770547928
    },
    {
      "id": "69886ada00000000002bf3ab",
      "text": "\t\t10年間かけて 2'000万文字書かれた物がある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770547930,
      "updated": 1770547983
    },
    {
      "id": "6988f060000000000083b866",
      "text": "\t\t\tすご、200万まではあると思ってたが、一桁上がるのか[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1770582114,
      "updated": 1770582129
    },
    {
      "id": "69886b3100000000002bf3ac",
      "text": "\t\thttps://ncode.syosetu.com/n6136dm/",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548018,
      "updated": 1770548021
    },
    {
      "id": "69886b5700000000002bf3af",
      "text": "\t\thttps://ncode.syosetu.com/n3726bt/",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548055,
      "updated": 1770548063
    },
    {
      "id": "69886b8200000000002bf3b1",
      "text": "\t\thttps://ncode.syosetu.com/n5534co/",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548099,
      "updated": 1770548102
    },
    {
      "id": "69886b3700000000002bf3ae",
      "text": "\t\t「継続は力なり」かどうかは微妙",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548023,
      "updated": 1770548248
    },
    {
      "id": "69886ba500000000002bf3b3",
      "text": "\t\t\tこの規模の作品の評価ポイント数に2桁の開きがある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548133,
      "updated": 1770548205
    },
    {
      "id": "69886c1900000000002bf3b4",
      "text": "\t\t\t誰からも評価されなくても継続し続ける人がいる事がわかる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548249,
      "updated": 1770548314
    },
    {
      "id": "69886d9c00000000002bf3b9",
      "text": "\t\t一日何文字書いているのか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548637,
      "updated": 1770548645
    },
    {
      "id": "69886c8a00000000002bf3b5",
      "text": "\t\t[$ \\frac{20'000\\lbrack\\rm k文字\\rbrack}{3'650\\lbrack日\\rbrack}=5.47\\lbrack\\rm k文字/日\\rbrack]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548362,
      "updated": 1770548565
    },
    {
      "id": "69886d7b00000000002bf3b7",
      "text": "\t\t速すぎて怖いよ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548607,
      "updated": 1770548760
    },
    {
      "id": "69886dae00000000002bf3bb",
      "text": "\t\t文庫何冊分なのか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548655,
      "updated": 1770548673
    },
    {
      "id": "69886d9000000000002bf3b8",
      "text": "\t\t[$ \\frac{20'000\\lbrack\\rm k文字\\rbrack}{100\\lbrack\\rm k文字/冊\\rbrack}=200\\lbrack\\rm k文字/日\\rbrack]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548624,
      "updated": 1770548736
    },
    {
      "id": "69886dfb00000000002bf3bd",
      "text": "\t\t10年間で文庫200冊分の文章を書いてる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548736,
      "updated": 1770548752
    },
    {
      "id": "69886e2000000000002bf3be",
      "text": "\t\t\t多すぎて怖いよ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548768,
      "updated": 1770548773
    },
    {
      "id": "69886f6100000000002bf3bf",
      "text": "\t\tRe:ゼロも連載が続いていて1'000万文字ある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770549090,
      "updated": 1770549127
    },
    {
      "id": "69886d3000000000002bf3b6",
      "text": " 日本一長い小説は、『グイン・サーガ』とのこと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770548528,
      "updated": 1770549405
    },
    {
      "id": "6988709500000000002bf3c5",
      "text": " \t栗本薫(著)『グイン・サーガ』早川書房",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770549397,
      "updated": 1770549397
    },
    {
      "id": "698870ae00000000002bf3c6",
      "text": " \t著者生存中に130巻刊行、現在150巻まで刊行中",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770549423,
      "updated": 1770549892
    },
    {
      "id": "6988710800000000002bf3c7",
      "text": " \t多分文庫サイズ（10万文字）で刊行されているだろう。知らんけど。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770549512,
      "updated": 1770549556
    },
    {
      "id": "6988713700000000002bf3c9",
      "text": "  \t無編集でドンドン出されている小説家になろう小説クラスの巻数の長編小説が編集されて刊行されている事実が怖い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770549560,
      "updated": 1770550095
    },
    {
      "id": "698872cb00000000002bf3ca",
      "text": " \t1979年9月から現在刊行中だから、刊行期間は45年",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770549964,
      "updated": 1770550236
    },
    {
      "id": "6988735300000000002bf3cb",
      "text": " \t\tなろう小説は10年だから4.5倍",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770550099,
      "updated": 1770550236
    },
    {
      "id": "6988736f00000000002bf3cc",
      "text": "\t\t構成と編集にそれだけかかるのか、情報処理能力の進化なのかはよくわからない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770550128,
      "updated": 1770550245
    },
    {
      "id": "698873a100000000002bf3cd",
      "text": " \t\t期間が長すぎて執筆環境技術の進化を考慮外にできない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770550178,
      "updated": 1770550252
    },
    {
      "id": "6988707500000000002bf3c0",
      "text": " 校正・校閲とか自動化できたら良いのにな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770549365,
      "updated": 1770550823
    },
    {
      "id": "6988745f00000000002bf3ce",
      "text": " \t執筆速度だけ速くて中身が薄っぺらい小説があるのは勿体ない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770550367,
      "updated": 1770550398
    },
    {
      "id": "698874ad00000000002bf3cf",
      "text": " \t生成AIが登場すると環境が変わる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770550445,
      "updated": 1770550757
    },
    {
      "id": "6988756700000000002bf3d0",
      "text": "  \t生成AIにも劣る内容だけど高速に執筆していた人は、生成AIに任せることで質も上がるし速度も上がる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770550632,
      "updated": 1770550678
    },
    {
      "id": "6988759600000000002bf3d1",
      "text": "  \t遅いけど質の良いタイプの人は埋もれそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1770550679,
      "updated": 1770550728
    },
