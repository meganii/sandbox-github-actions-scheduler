      "updated": 1774748340
    },
    {
      "id": "69c8712d0000000000d67851",
      "text": "table:旧国名",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774743854,
      "updated": 1774743864
    },
    {
      "id": "69c871370000000000d67887",
      "text": " 東北",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774743864,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2da",
      "text": " 青森\t陸奥\t",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748482
    },
    {
      "id": "69c882f1000000000091c2dc",
      "text": " 宮城\t陸前\t（陸奥）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748478
    },
    {
      "id": "69c8834d000000000091c34a",
      "text": " 岩手\t陸中\t（陸奥）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748494,
      "updated": 1774748494
    },
    {
      "id": "69c88306000000000091c344",
      "text": " 秋田\t陸中\t（陸奥）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748424,
      "updated": 1774748479
    },
    {
      "id": "69c88306000000000091c345",
      "text": " 秋田\t羽後\t（出羽）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748424,
      "updated": 1774748479
    },
    {
      "id": "69c88318000000000091c346",
      "text": " 山形\t羽後\t（出羽）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748442,
      "updated": 1774748479
    },
    {
      "id": "69c88319000000000091c347",
      "text": " 山形\t羽前\t",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748442,
      "updated": 1774748451
    },
    {
      "id": "69c88325000000000091c348",
      "text": " 福島\t岩代\t（陸奥）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748455,
      "updated": 1774748473
    },
    {
      "id": "69c88326000000000091c349",
      "text": " 福島\t磐城\t（陸奥）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748455,
      "updated": 1774748474
    },
    {
      "id": "69c882f1000000000091c2dd",
      "text": " 関東",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748455
    },
    {
      "id": "69c88360000000000091c34e",
      "text": " 群馬\t上野",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748513,
      "updated": 1774748513
    },
    {
      "id": "69c882f1000000000091c2e2",
      "text": " 栃木\t下野",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c8835e000000000091c34d",
      "text": " 茨城\t下総\t常陸",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748511,
      "updated": 1774748542
    },
    {
      "id": "69c882f1000000000091c2e5",
      "text": " 千葉\t下総\t上総\t安房",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748545
    },
    {
      "id": "69c88364000000000091c350",
      "text": " 埼玉\t武蔵",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748517,
      "updated": 1774748517
    },
    {
      "id": "69c882f1000000000091c2e6",
      "text": " 東京\t武蔵",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2e7",
      "text": " 神奈川\t武蔵\t相模",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748526
    },
    {
      "id": "69c882f1000000000091c2e8",
      "text": " 中部",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2e9",
      "text": " 新潟\t越後\t佐渡",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2ea",
      "text": " 富山\t越中",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2eb",
      "text": " 石川\t能登\t加賀",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2ec",
      "text": " 福井\t越前\t若狭",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2ed",
      "text": " 山梨\t甲斐",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2ee",
      "text": " 長野\t信濃",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2ef",
      "text": " 岐阜\t美濃\t飛騨",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2f0",
      "text": " 静岡\t駿河\t伊豆\t遠江",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2f1",
      "text": " 愛知\t尾張\t三河",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2f2",
      "text": " 近畿",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2f3",
      "text": " 三重\t紀伊\t伊勢\t伊賀\t志摩",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748630
    },
    {
      "id": "69c883cd000000000091c356",
      "text": " 和歌山\t紀伊",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748623,
      "updated": 1774748623
    },
    {
      "id": "69c882f1000000000091c2f4",
      "text": " 滋賀\t近江",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2f5",
      "text": " 京都\t山城\t丹波\t丹後",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c883a9000000000091c351",
      "text": " 兵庫\t摂津\t丹波\t但馬\t播磨\t淡路",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748587,
      "updated": 1774748612
    },
    {
      "id": "69c882f1000000000091c2f6",
      "text": " 大阪\t摂津\t和泉\t河内",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2f8",
      "text": " 奈良\t大和",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2fa",
      "text": " 中国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2fb",
      "text": " 鳥取\t因幡\t伯耆",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2fc",
      "text": " 島根\t石見\t出雲\t隠岐",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2fd",
      "text": " 岡山\t備前\t備中\t美作",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2fe",
      "text": " 広島\t備後\t安芸",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c2ff",
      "text": " 山口\t周防\t長門",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c300",
      "text": " 四国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c301",
      "text": " 徳島\t阿波",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c302",
      "text": " 香川\t讃岐\t備前",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c303",
      "text": " 愛媛\t伊予",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c304",
      "text": " 高知\t土佐",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c305",
      "text": " 九州",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c306",
      "text": " 福岡\t筑前\t筑後\t豊前",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c307",
      "text": " 佐賀\t肥前",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c308",
      "text": " 長崎\t肥前\t壱岐\t対馬",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c309",
      "text": " 熊本\t肥後",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c30a",
      "text": " 大分\t豊前\t豊後",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c30b",
      "text": " 宮崎\t日向",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c30c",
      "text": " 鹿児島\t薩摩\t大隅",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c30d",
      "text": " 沖縄\t琉球",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c882f1000000000091c30e",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748403,
      "updated": 1774748403
    },
    {
      "id": "69c872370000000000d678bd",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774744120,
      "updated": 1774744120
    },
    {
      "id": "69c882c2000000000091c2d8",
      "text": "https://ja.wikipedia.org/wiki/廃藩置県",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748355,
      "updated": 1774748355
    },
    {
      "id": "69c882c2000000000091c2d9",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774748355,
      "updated": 1774748355
    },
    {
      "id": "69c872380000000000d678be",
      "text": "code:mermaid",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774744122,
      "updated": 1774744220
    },
    {
      "id": "69c872870000000000d678c2",
      "text": " graph LR;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774744201,
      "updated": 1774749657
    },
    {
      "id": "69c88a65000000000091c360",
      "text": "  北海道国---札幌県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750310,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c361",
      "text": "  北海道国---函館県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c362",
      "text": "  北海道国---根室県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c363",
      "text": "  ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c364",
      "text": "  東北地方---青森県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c365",
      "text": "   青森県---陸奥国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c366",
      "text": "   陸前国---陸奥国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c367",
      "text": "  東北地方---宮城県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c368",
      "text": "   宮城県---陸前国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c369",
      "text": "  東北地方---福島県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c36a",
      "text": "   福島県---岩代国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c36b",
      "text": "   岩代国---陸奥国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c36c",
      "text": "   福島県---磐城国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c36d",
      "text": "   磐城国---陸奥国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c36e",
      "text": "  東北地方---岩手県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c36f",
      "text": "   岩手県---陸中国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c370",
      "text": "  東北地方---秋田県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c371",
      "text": "   秋田県---陸中国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c372",
      "text": "   陸中国---陸奥国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c373",
      "text": "   秋田県---羽後国;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
    },
    {
      "id": "69c88a66000000000091c374",
      "text": "  東北地方---山形県;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774750312,
      "updated": 1774750312
