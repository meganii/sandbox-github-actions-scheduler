{
  "id": "69ee292f229491bf393fb228",
  "title": "コバルト四天王",
  "created": 1777215792,
  "updated": 1777663086,
  "lines": [
    {
      "id": "69ee292f229491bf393fb228",
      "text": "コバルト四天王",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777215792
    },
    {
      "id": "69ee292f0000000000106035",
      "text": "from [四天王]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777215792
    },
    {
      "id": "69ee292f0000000000106036",
      "text": "　[集英社コバルト文庫]の看板作家",
      "userId": "5d20a16b6e57f80017fd049e",
      "created": 1777215792,
      "updated": 1777641851
    },
    {
      "id": "69ee292f0000000000106038",
      "text": "　[氷室冴子]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777215801
    },
    {
      "id": "69f4f4fc0000000000095c62",
      "text": "　　経歴",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661180,
      "updated": 1777661204
    },
    {
      "id": "69f4f5140000000000095c63",
      "text": "　　　1977年に「小説ジュニア青春小説新人賞」佳作を受賞してデビュー。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661204,
      "updated": 1777661212
    },
    {
      "id": "69f4f51b0000000000095c64",
      "text": "　　　コバルト文庫の絶対的なエースとして君臨し、コメディから歴史もの、青春小説まで幅広いヒット作を生み出しました。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661212,
      "updated": 1777661218
    },
    {
      "id": "69f4f5210000000000095c65",
      "text": "　　代表作",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661218,
      "updated": 1777661221
    },
    {
      "id": "69f4f5250000000000095c66",
      "text": "　　　『なんて素敵にジャパネスク』シリーズ（平安コメディの金字塔）、『[海がきこえる]』（スタジオジブリでアニメ化）。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661221,
      "updated": 1777661497
    },
    {
      "id": "69ee292f0000000000106039",
      "text": "　[正本ノン]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777215801
    },
    {
      "id": "69f4f6110000000000095c70",
      "text": "　　経歴",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661457,
      "updated": 1777661465
    },
    {
      "id": "69f4f6180000000000095c71",
      "text": "　　　バレーボールを題材にした熱いスポーツものや、等身大の少女の悩みを描いた作品で四天王の一角を担いました。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661465,
      "updated": 1777661474
    },
    {
      "id": "69f4f6220000000000095c72",
      "text": "　　代表作",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661474,
      "updated": 1777661477
    },
    {
      "id": "69f4f6240000000000095c73",
      "text": "　　 『独身（シングル）テイクオフ』シリーズ、『アタックNo.1』（ノベライズ版）など。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661477,
      "updated": 1777661804
    },
    {
      "id": "69ee292f000000000010603a",
      "text": "　[久美沙織]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777215801
    },
    {
      "id": "69f4f5580000000000095c67",
      "text": "　　経歴",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661273,
      "updated": 1777661280
    },
    {
      "id": "69f4f5600000000000095c68",
      "text": "　　　1979年に「第13回小説ジュニア青春小説新人賞」で佳作を受賞しデビュー。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661280,
      "updated": 1777661286
    },
    {
      "id": "69f4f5660000000000095c69",
      "text": "　　　繊細な心理描写や洋風な世界観に定評があり、後にゲームのノベライズなどでも活躍しました。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661286,
      "updated": 1777661307
    },
    {
      "id": "69f4f57a0000000000095c6a",
      "text": "　　代表作",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661307,
      "updated": 1777661310
    },
    {
      "id": "69f4f57d0000000000095c6b",
      "text": "　　　『丘の家のミッキー』シリーズ、『ドラゴンクエスト』関連の小説作品。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661310,
      "updated": 1777661314
    },
    {
      "id": "69ee292f000000000010603b",
      "text": "　[田中雅美]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777215801
    },
    {
      "id": "69ee292f000000000010603c",
      "text": " 　経歴",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777661709
    },
    {
      "id": "69f4f5ad0000000000095c6c",
      "text": " 　　1980年代からコバルト文庫で活躍。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661358,
      "updated": 1777661709
    },
    {
      "id": "69f4f5b60000000000095c6d",
      "text": " 　　ミステリー要素を含む作品や、都会的で洗練された雰囲気の物語で人気を博しました。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661366,
      "updated": 1777661709
    },
    {
      "id": "69f4f5bb0000000000095c6e",
      "text": " 　代表作",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661372,
      "updated": 1777661709
    },
    {
      "id": "69f4f5be0000000000095c6f",
      "text": " 　　『謎いっぱいのアリス』シリーズ、『都会のヴェーラたち』。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661375,
      "updated": 1777661709
    },
    {
      "id": "69ee292f000000000010603d",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777215792,
      "updated": 1777215792
    },
    {
      "id": "69f4f7040000000000095c74",
      "text": "[少女小説]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777661700,
      "updated": 1777661723
    },
    {
      "id": "69f4fc530000000000654140",
      "text": "[本を読む楽しさ]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777663060,
      "updated": 1777663086
    },
    {
      "id": "69f4fc5b0000000000654141",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777663068,
      "updated": 1777663068
    }
  ]
}