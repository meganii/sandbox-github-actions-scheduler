      "created": 1776586110,
      "updated": 1776586118
    },
    {
      "id": "69e490540000000000dbe5dd",
      "text": "   5/31-->6/30 & 7/1;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586837,
      "updated": 1776586837
    },
    {
      "id": "69e48a900000000000dbe5a4",
      "text": "   6/1-->7/1 & 7/2;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776585777,
      "updated": 1776586110
    },
    {
      "id": "69e48d8c0000000000dbe5d2",
      "text": "   7/1-->7/31 & 8/1;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586125,
      "updated": 1776586125
    },
    {
      "id": "69e48d8c0000000000dbe5d3",
      "text": "   7/2-->8/1 & 8/2;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586125,
      "updated": 1776586132
    },
    {
      "id": "69e48d990000000000dbe5d4",
      "text": "   8/1-->8/31 & 9/1;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586137,
      "updated": 1776586137
    },
    {
      "id": "69e48d990000000000dbe5d5",
      "text": "   8/2-->9/1 & 9/2;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586137,
      "updated": 1776586144
    },
    {
      "id": "69e490580000000000dbe5df",
      "text": "   8/31-->9/30 & 10/1;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586840,
      "updated": 1776586840
    },
    {
      "id": "69e48aed0000000000dbe5aa",
      "text": "   9/1-->10/1 & 10/2;",
      "userId": "6436266c7ac3c0001bed60e6",
