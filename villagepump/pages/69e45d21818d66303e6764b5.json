      "id": "69e48d7d0000000000dbe5d0",
      "text": "   5/1-->5/31 & 6/1;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586110,
      "updated": 1776586110
    },
    {
      "id": "69e48d7d0000000000dbe5d1",
      "text": "   5/2-->6/1 & 6/2;",
