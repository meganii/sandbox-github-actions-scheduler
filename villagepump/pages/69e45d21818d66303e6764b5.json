      "created": 1776586150,
      "updated": 1776586150
    },
    {
      "id": "69e48da50000000000dbe5d7",
      "text": "   10/2-->11/1 & 11/2;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586150,
      "updated": 1776586157
    },
    {
      "id": "69e4905b0000000000dbe5e1",
      "text": "   10/31-->11/30 & 12/1;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586844,
      "updated": 1776586844
    },
    {
      "id": "69e48af50000000000dbe5ab",
      "text": "   11/1-->12/1 & 12/2;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776585764,
      "updated": 1776586150
    },
    {
      "id": "69e48b0e0000000000dbe5ad",
      "text": "  1/31からの遷移先が3/1と3/2なのはやっぱり変か",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776585486,
      "updated": 1776586944
    },
    {
      "id": "69e490c50000000000dbe5e2",
      "text": "  加えて、2月d日の遷移先が3月d+1日3月d+2日なのも",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776586949,
      "updated": 1776587001
    },
    {
      "id": "69e491540000000000dbe5e3",
      "text": "  2月だけ28日と29日にするか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587093,
      "updated": 1776587146
    },
    {
      "id": "69e493080000000000dbe5e9",
      "text": "  \tやんわりと押し込む",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587529,
      "updated": 1776587536
    },
    {
      "id": "69e492830000000000dbe5e4",
      "text": "   \t1/28 → 2/27, 2/28",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587396,
      "updated": 1776587538
    },
    {
      "id": "69e492aa0000000000dbe5e5",
      "text": "   \t1/29 → 2/28, 2/29",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587435,
      "updated": 1776587538
    },
    {
      "id": "69e492ba0000000000dbe5e6",
      "text": "   \t1/30 → 2/28, 2/29",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587451,
      "updated": 1776587538
    },
    {
      "id": "69e492ca0000000000dbe5e7",
      "text": "   \t1/31 → 2/28, 2/29",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587467,
      "updated": 1776587538
    },
    {
      "id": "69e492d60000000000dbe5e8",
      "text": "   \t2/1 → 2/29, 3/1",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587479,
      "updated": 1776587538
    },
    {
      "id": "69e493550000000000dbe5ec",
      "text": "   \t1/28, 1/29, 1/30 ← 2/28",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587606,
      "updated": 1776587857
    },
    {
      "id": "69e493640000000000dbe5ed",
      "text": "   \t1/29, 1/30, 1/31 ← 2/29",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587621,
      "updated": 1776587845
    },
    {
      "id": "69e493960000000000dbe5f0",
      "text": "   \t1/31, 2/1 ← 3/1",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587671,
      "updated": 1776587797
    },
    {
      "id": "69e494b10000000000dbe5f2",
      "text": "  細かいことを考えずに最終日だけ「最終日」という枠にすればいい。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587953,
      "updated": 1776588512
    },
    {
      "id": "69e494d70000000000dbe5f3",
      "text": "   考えが一周回ってきた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776587991,
      "updated": 1776588466
    },
    {
      "id": "69e494e80000000000dbe5f4",
      "text": "  code:mermaid",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776588009,
      "updated": 1776588014
    },
