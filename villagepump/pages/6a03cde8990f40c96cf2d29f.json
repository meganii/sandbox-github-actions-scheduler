    {
      "id": "6a03cde90000000000605937",
      "text": "　社内Slackに[timesチャンネル]を作ってみた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778634218,
      "updated": 1778634218
    },
    {
      "id": "6a03cde90000000000605938",
      "text": "　誰か来た途端書けなくなりそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778634218,
      "updated": 1778634218
    },
    {
      "id": "6a03cde90000000000605939",
      "text": "　\t人が増えるほどNGワードや話題が増えてしまって書けなくなる感じある[kidooom.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778634218,
      "updated": 1778634218
    },
    {
      "id": "6a03cde9000000000060593a",
      "text": "　社内井戸端を作りたい人生だった…",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778634218,
      "updated": 1778634218
    },
    {
      "id": "6a03cde9000000000060593b",
      "text": "　timesと井戸端にマルチポストする感じになってしまう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778634218,
      "updated": 1778634218
    },
    {
      "id": "6a03cde9000000000060593c",
      "text": "　 自分もそんな感じ、気にしてない[inajob.icon]",
