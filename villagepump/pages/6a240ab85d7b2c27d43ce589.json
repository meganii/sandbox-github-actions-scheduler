    {
      "id": "6a240ab85d7b2c27d43ce589",
      "text": "憐情",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780746957,
      "updated": 1780746957
    },
    {
      "id": "6a240aa90000000000d1440d",
      "text": " 『[レ・ミゼラブル]』の[希哲館訳語]（邦題案）[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780746957,
      "updated": 1780747173
    },
    {
      "id": "6a240be40000000000d14412",
      "text": "  読みは「れんじょう」",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780747272,
      "updated": 1780747275
    },
    {
      "id": "6a240ab90000000000d1440f",
      "text": "  記憶にある限り唯一の、作品名称に対する希哲館訳語",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780746973,
      "updated": 1780747193
    },
    {
      "id": "6a240b9f0000000000d14410",
      "text": "   単純に必要性に乏しいので",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780747202,
      "updated": 1780747209
    },
    {
      "id": "6a240ba60000000000d14411",
      "text": "  古典的な邦題『ああ無情』を現代的にアレンジ",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780747209,
      "updated": 1780747225
    },
    {
      "id": "6a240c750000000000d14414",
      "text": "   これ以上の邦題はありえないだろう",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780747417,
      "updated": 1780747429
    },
    {
      "id": "6a240aa90000000000d1440e",
      "text": "  死蔵しておくにはもったいなさすぎるが、[希哲館]では使い道が難しいので、どこかの出版社にでも使って欲しい",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780746957,
      "updated": 1780747388
    },
    {
      "id": "6a240bf90000000000d14413",
