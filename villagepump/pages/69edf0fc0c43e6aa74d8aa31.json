{
  "id": "69edf0fc0c43e6aa74d8aa31",
  "title": "儲からない愚痴",
  "created": 1777201405,
  "updated": 1777201405,
  "lines": [
    {
      "id": "69edf0fc0c43e6aa74d8aa31",
      "text": "儲からない愚痴",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f6d",
      "text": "from [2026/04/26]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f6e",
      "text": " [儲からない愚痴]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f6f",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f70",
      "text": " [儲からない愚痴]は有益",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f71",
      "text": " \t本当は儲かっていたとしても儲かると公言するメリットがない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f72",
      "text": " \t儲かっていて儲かっていると公言していたらある意味愚か",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f73",
      "text": "  \tメリットがないことをやっているので",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f74",
      "text": "  儲かっていなくて儲かっていないと言っているなら、ただの事実",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f75",
      "text": "  \t助けてもらえるなら儲けもの",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f76",
      "text": "  \t切羽詰まって助けてほしいなら儲からない愚痴をしている場合じゃないが",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f77",
      "text": "  儲かっていても儲かっていないというパターン",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f78",
      "text": "  \t参入障壁は高いほうがいい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f79",
      "text": "  \t\t部外者には儲からないイメージを持ってもらう方が良い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f7a",
      "text": "  \t助けてもらえるなら儲けもの",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f7b",
      "text": "  \t業界ではなく個人として考えても儲かっているイメージよりも儲からないイメージの方が金銭的に得",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f7c",
      "text": "  \t\t「儲かってるなら奢って下さいよ」はない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f7d",
      "text": "  \t\tむしろ「最近金欠で」ができるかもしれない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f7e",
      "text": "  \t\t分かる人は分かる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f7f",
      "text": "  \t\t\tちゃんとした人は強い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f80",
      "text": "  \t\t\t何で見ているのかわからないけど",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f81",
      "text": "  \t\t\t\t審美眼（総合的判断）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f82",
      "text": "  儲かりすぎた場合隠しようがないかもしれない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f83",
      "text": "  \tそうでもない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f84",
      "text": "  \tそんなに露出・アピールしなくていい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f85",
      "text": "  \tキットカットがCM止めたし",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    },
    {
      "id": "69edf0fc0000000000993f86",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777201405,
      "updated": 1777201405
    }
  ]
}