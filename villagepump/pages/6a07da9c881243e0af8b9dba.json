    {
      "id": "6a07daef0000000000c9c7f0",
      "text": "開発環境を整えてくれるツール",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1778899695,
      "updated": 1778899706
    },
    {
      "id": "6a07daf90000000000c9c7f1",
      "text": "ディレクトリ単位での管理ができる",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1778899706,
      "updated": 1778899787
    },
    {
      "id": "6a07db000000000000c9c7f2",
      "text": " nodeやpythonといった開発環境/実行環境のバージョン管理",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1778899712,
      "updated": 1778899725
    },
    {
      "id": "6a07db0d0000000000c9c7f3",
      "text": " ツール類",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1778899725,
      "updated": 1778899762
    },
    {
      "id": "6a07db230000000000c9c7f5",
