      "updated": 1778899858
    },
    {
      "id": "6a07db920000000000c9c7fc",
      "text": " ディレクトリに入ったら[coscli]が使える、出たら使えなくなる、という事もできる",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1778899858,
      "updated": 1778899876
    },
    {
      "id": "6a07dc090000000000c9c808",
      "text": " \tcode: .mise.toml",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1778899978,
      "updated": 1778899994
    },
    {
      "id": "6a07dc1b0000000000c9c809",
      "text": " \t [tools]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1778899995,
      "updated": 1778900000
    },
    {
      "id": "6a07dc200000000000c9c80a",
      "text": "   \"github:mtane0412/coscli\" = { version = \"latest\", exe = \"cos\" }",
