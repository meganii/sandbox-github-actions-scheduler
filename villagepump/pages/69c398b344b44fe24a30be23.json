  "created": 1774426294,
  "updated": 1774430205,
  "lines": [
    {
      "id": "69c398b344b44fe24a30be23",
      "text": "アラビア語の国名",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426294,
      "updated": 1774426294
    },
    {
      "id": "69c398b500000000001a35f2",
      "text": "長くて法則性のある国名が多いので気になった[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426294,
      "updated": 1774426623
    },
    {
      "id": "69c398ca00000000001a35f4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426315,
      "updated": 1774426315
    },
    {
      "id": "69c39d7400000000001a3831",
      "text": "マレーシア",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427508,
      "updated": 1774427508
    },
    {
      "id": "69c39d7400000000001a3832",
      "text": "\tマレー語: Malaysia",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427508,
      "updated": 1774427508
    },
    {
      "id": "69c39d7400000000001a3833",
      "text": "\tمليسيا",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427508,
      "updated": 1774427508
    },
    {
      "id": "69c39d7600000000001a3838",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427510,
      "updated": 1774427510
    },
    {
      "id": "69c39d7400000000001a3834",
      "text": "リビア国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427508,
      "updated": 1774427510
    },
    {
      "id": "69c39d7400000000001a3835",
      "text": "\tアラビア語: ليبيا",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427508,
      "updated": 1774427508
    },
    {
      "id": "69c39d7400000000001a3836",
      "text": "\tUNGEGN式: Lībiyá",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427508,
      "updated": 1774427508
    },
    {
      "id": "69c39d3100000000001a3822",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427442,
      "updated": 1774428552
    },
    {
      "id": "69c39d3100000000001a3823",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427442,
      "updated": 1774427442
    },
    {
      "id": "69c39d3100000000001a3824",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427442,
      "updated": 1774427442
    },
    {
      "id": "69c39a8d00000000001a36a5",
      "text": "イスラエル国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426765,
      "updated": 1774426765
    },
    {
      "id": "69c39a8d00000000001a36a6",
      "text": "\tアラビア語: دولة اسرائيل (اسرائيل)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426765,
      "updated": 1774426765
    },
    {
      "id": "69c39a8d00000000001a36a7",
      "text": "\tUNGEGN式: Dawlat 'Isrā'īl (Isrāʼīl)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426765,
      "updated": 1774426765
    },
    {
      "id": "69c39a9700000000001a36ba",
      "text": "エリトリア国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426776,
      "updated": 1774426776
    },
    {
      "id": "69c39a9700000000001a36bb",
      "text": "\tアラビア語: دولة إريتريا (إريتريا)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426776,
      "updated": 1774426776
    },
    {
      "id": "69c39a9700000000001a36bc",
      "text": "\tUNGEGN式: Dawlat 'Īrītrīyā ('Īrītrīyā)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426776,
      "updated": 1774426776
    },
    {
      "id": "69c39aa200000000001a36d2",
      "text": "カタール国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426787,
      "updated": 1774426787
    },
    {
      "id": "69c39aa200000000001a36d3",
      "text": "\tアラビア語: دولة قطر (قطر)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426787,
      "updated": 1774426787
    },
    {
      "id": "69c39aa200000000001a36d4",
      "text": "\tUNGEGN式: Dawlat Qaţar (Qaţar)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426787,
      "updated": 1774426787
    },
    {
      "id": "69c39aad00000000001a36ea",
      "text": "クウェート国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426797,
      "updated": 1774426797
    },
    {
      "id": "69c39aad00000000001a36eb",
      "text": "\tアラビア語: دولة الكويت (الكويت)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426797,
      "updated": 1774426797
    },
    {
      "id": "69c39aad00000000001a36ec",
      "text": "\tUNGEGN式: Dawlat al-Kuwayt (al-Kuwayt)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426797,
      "updated": 1774426797
    },
    {
      "id": "69c39ad200000000001a3738",
      "text": "パレスチナ国 (パレスチナ)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426978,
      "updated": 1774426978
    },
    {
      "id": "69c39ad200000000001a3739",
      "text": "\tアラビア語: دولة فلسطين (فلسطين)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426978,
      "updated": 1774426978
    },
    {
      "id": "69c39ad200000000001a373a",
      "text": "\tUNGEGN式: Dawlat Filasṭīn (Filasṭīn)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426978,
      "updated": 1774426978
    },
    {
      "id": "69c39d4600000000001a382b",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427463,
      "updated": 1774427463
    },
    {
      "id": "69c39d4700000000001a382c",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427463,
      "updated": 1774427463
    },
    {
      "id": "69c39d1b00000000001a381f",
      "text": "アフガニスタン・イスラム首長国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427419,
      "updated": 1774427463
    },
    {
      "id": "69c399e300000000001a3636",
      "text": "\tダリー語: امارت اسلامی افغانستان (افغانستان)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3637",
      "text": "\tImārat-i Islāmī-yi Afghānistān",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3638",
      "text": "\tパシュトー語: د افغانستان اسلامي امارت (افغانستان)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3639",
      "text": "\tDə Afġānistān Islāmī Imārat",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a363a",
      "text": "アラブ首長国連邦",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a363b",
      "text": "\tアラビア語: الإمارات العربيّة المتّحدة (إمارات)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a363c",
      "text": "\tUNGEGN式: Al-'Imārāt al-ʻArabīyah al-Muttaḩidah ('Imārāt)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c39d4400000000001a3829",
      "text": "\tアフガニスタン・イスラム首長国の名前から Imarat は首長国を意味するとわかる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427460,
      "updated": 1774429306
    },
    {
      "id": "69c3a47900000000001a3847",
      "text": "\tArabiyah はアラビアなので、 Muttahidah が連邦を意味するのだろう。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429306,
      "updated": 1774429341
    },
    {
      "id": "69c3a44200000000001a3846",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429250,
      "updated": 1774429250
    },
    {
      "id": "69c399e300000000001a365d",
      "text": "コモロ連合",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774427461
    },
    {
      "id": "69c399e300000000001a365e",
      "text": "\tアラビア語: الاتحاد القمر",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a365f",
      "text": "\tجزر القمر (القمر)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3660",
      "text": "\tUNGEGN式: Al-'Ittiḩād al-Qamar",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3661",
      "text": "\tJuzur al-Qamar (Al-Qamar)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c39d5800000000001a382d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427481,
      "updated": 1774427481
    },
    {
      "id": "69c39d5900000000001a382e",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427481,
      "updated": 1774427481
    },
    {
      "id": "69c39cf800000000001a3819",
      "text": "ブルネイ・ダルサラーム国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427384,
      "updated": 1774427481
    },
    {
      "id": "69c39cf800000000001a381a",
      "text": "\tマレー語: نڬارا بروني دارالسلام (بروني دارالسلام)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427384,
      "updated": 1774427384
    },
    {
      "id": "69c39cf800000000001a381b",
      "text": "\tNegara Brunei Darussalam (Brunei Darussalam)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427384,
      "updated": 1774427384
    },
    {
      "id": "69c3a4fd00000000001a3848",
      "text": " > [https://ja.wikipedia.org/wiki/ブルネイ ブルネイ]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429437,
      "updated": 1774429453
    },
    {
      "id": "69c3a50100000000001a3849",
      "text": " > Negara はマレー語で「国」を意味する語。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429442,
      "updated": 1774429459
    },
    {
      "id": "69c3a51200000000001a384a",
      "text": " > Darussalam はアラビア語の dar(u)（家、土地）と (a)s-salam（平和）で「平和な土地」を意味する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429459,
      "updated": 1774429467
    },
    {
      "id": "69c3a51b00000000001a384b",
      "text": " > Bruneiの語源には諸説あり、マレー語の buni（亜麻）や buah nyiur（ココナッツ）から転じたなどとされる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429467,
      "updated": 1774429467
    },
    {
      "id": "69c39d5a00000000001a3830",
      "text": "\t\tということは、ブルネイ平和国か。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427483,
      "updated": 1774429511
    },
    {
      "id": "69c3a57300000000001a384d",
      "text": "\t\tダルサラームからタンザニアの Dar es Salaam を思い出す。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429555,
      "updated": 1774429576
    },
    {
      "id": "69c3a5ca00000000001a384e",
      "text": "\t\tあるいは、アッサラーム・アライクム（السَّلَامُ عَلَيْكُمْ）/as.sa.laː.mu ʕa.laj.kum/ ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429643,
      "updated": 1774429652
    },
    {
      "id": "69c3a53100000000001a384c",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774429490,
      "updated": 1774429490
    },
    {
      "id": "69c3a18e00000000001a383e",
      "text": "オマーン国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774428558,
      "updated": 1774428558
    },
    {
      "id": "69c3a18e00000000001a383f",
      "text": "\tアラビア語: سلطنة عُمان (عمان)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774428558,
      "updated": 1774428558
    },
    {
      "id": "69c3a18e00000000001a3840",
      "text": "\tUNGEGN式: Salţanat ʻUmān (ʻUmān)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774428558,
      "updated": 1774428558
    },
    {
      "id": "69c3a18e00000000001a3841",
      "text": " [https://ja.wikipedia.org/wiki/スルターン スルターン]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774428558,
      "updated": 1774428558
    },
    {
      "id": "69c3a18e00000000001a3842",
      "text": "  > イスラム世界における君主号（君主の称号）のひとつ。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774428558,
      "updated": 1774428558
    },
    {
      "id": "69c3a18e00000000001a3843",
      "text": "  > アラビア語で「力、権力、権威」「権力者、権威者」「王、絶対的君主」などを意味する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774428558,
      "updated": 1774428558
    },
    {
      "id": "69c3a18e00000000001a3844",
      "text": "  これだけだと王との違いがわからない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774428558,
      "updated": 1774428566
    },
    {
      "id": "69c399e300000000001a3662",
      "text": "サウジアラビア王国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774427483
    },
    {
      "id": "69c399e300000000001a3663",
      "text": "\tアラビア語: المملكة العربيّة السّعوديّة (سعودية)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3664",
      "text": "\tUNGEGN式: Al-Mamlakah al-ʻArabīyah as-Suʻūdīyah (As-Suʻūdīyah)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c39ba700000000001a3774",
      "text": "バーレーン王国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427048,
      "updated": 1774427060
    },
    {
      "id": "69c399e300000000001a367d",
      "text": "\tアラビア語: مملكة البحرين (بحرين)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a367e",
      "text": "\tUNGEGN式: Mamlakat al-Baḩrayn (al-Baḩrayn)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c39f2100000000001a3839",
      "text": "\t何故か Al-Mamlakah ではない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427938,
      "updated": 1774428003
    },
    {
      "id": "69c39bb500000000001a3785",
      "text": "モロッコ王国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427062,
      "updated": 1774427351
    },
    {
      "id": "69c399e300000000001a368d",
      "text": "\tアラビア語:  المملكة المغربية (المغرب)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a368e",
      "text": "\tUNGEGN式: Al-Mamlakah al-Maghribīyah (al-Maghribīyah)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a368f",
      "text": "ヨルダン・ハシミテ王国",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3690",
      "text": "\tアラビア語: المملكة الأردنّيّة الهاشميّة (الاردن)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c399e300000000001a3691",
      "text": "\tUNGEGN式: Al-Mamlakah al-'Urdunnīyah al-Hāshimīyah (al-'Urdunn)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774426595,
      "updated": 1774426595
    },
    {
      "id": "69c39c2000000000001a380f",
      "text": " > 公式の英語表記は Hashemite Kingdom of Jordan。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427168,
      "updated": 1774430205
    },
    {
      "id": "69c3a7da00000000001a3851",
      "text": " > 通称 Jordan。Hashemiteがアラビア語のハーシミーヤ、Kingdomがマムラカ、Jordanがウルドゥンニーヤ部分に対応している。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774430170,
      "updated": 1774430175
    },
    {
      "id": "69c3a7df00000000001a3852",
      "text": " > ハーシミーヤは、預言者ムハンマドの曽祖父ハーシムの子孫の家系であるハーシム家にちなむことを表す形容詞「ハーシム家の」。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774430175,
      "updated": 1774430175
    },
    {
      "id": "69c3a7e200000000001a3853",
      "text": " ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774430179,
      "updated": 1774430179
    },
    {
      "id": "69c39be200000000001a3807",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774427106,
      "updated": 1774427106
    },
    {
