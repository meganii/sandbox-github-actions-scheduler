    {
      "id": "69baff3b36d18d20fe994a96",
      "text": "週番号",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862717,
      "updated": 1773862717
    },
    {
      "id": "69baff3d0000000000957bcb",
      "text": "[/takker/週番号]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862717,
      "updated": 1773862738
    },
    {
      "id": "69baff520000000000957bcc",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862738,
      "updated": 1773862738
    },
    {
      "id": "69baff700000000000957bd6",
      "text": "井戸端での週番号はアメリカ式らしい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862769,
      "updated": 1773862881
    },
    {
      "id": "69baff790000000000957bd7",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862778,
      "updated": 1773862778
    },
    {
      "id": "69baff530000000000957bcd",
      "text": "週番号の主な方式と違い",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862740,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bce",
      "text": " アメリカ式（日本で一般的）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bcf",
      "text": "  基準: 1月1日を含む週を第1週とする。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bd0",
      "text": "  開始曜日: 日曜日。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bd1",
      "text": " ISO 8601方式（欧州・ビジネス）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bd2",
      "text": "  基準: 1年の最初の木曜日を含む週（＝1月4日を含む週）を第1週とする。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bd3",
      "text": "  開始曜日: 月曜日。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bd4",
      "text": "  特徴: 12月末の数日間が、翌年の第1週となるケースがある。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    },
    {
      "id": "69baff6d0000000000957bd5",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773862765,
      "updated": 1773862765
    }
  ]
}