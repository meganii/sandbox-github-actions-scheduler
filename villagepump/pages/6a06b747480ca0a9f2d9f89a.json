    },
    {
      "id": "6a10e6a100000000007b7155",
      "text": "[デライト.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1779492514,
      "updated": 1779492515
    },
    {
      "id": "6a10e6a300000000007b7156",
