      "id": "69f7c58c5e7a53be43539d69",
      "text": "2026/03/29―inajob",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50cf8",
      "text": "from [2026/03/29]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50cf9",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845647
    },
    {
      "id": "69f7c58d0000000000e50cfa",
      "text": "[inajob.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50cfb",
      "text": " 花見行った",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50cfc",
      "text": "  子連れの花見は超運動だ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50cfd",
      "text": "  子供つながりでの知り合いの方とたくさん出会えた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50cfe",
      "text": "  体力切れて機嫌悪くなって退場するのをなんとかしたい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50cff",
      "text": "  \t期限が悪くなった時は疲れているのだということを教えるとか[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50d00",
      "text": "  \t\t「あー自分疲れてるんだなー」ってメタ認知できると機嫌の悪さを外面に出さなくても内々に処理しやすくなると思う",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50d01",
      "text": "  \t\t多分それは十分に伝えているので後は熟成を待つのみ・・[inajob.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50d02",
      "text": "  \t\t\tわかっているけど疲れるまで活動してしまうという感じらしい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50d03",
      "text": "  \t\t\t\t大人でもあるよね・・",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
    },
    {
      "id": "69f7c58d0000000000e50d04",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845645,
      "updated": 1777845645
