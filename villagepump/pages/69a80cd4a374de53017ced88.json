    {
      "id": "69a80cd4a374de53017ced88",
      "text": "whakawhānaungatanga",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772621054,
      "updated": 1772621054
    },
    {
      "id": "69a80cfd0000000000181d7e",
      "text": "[What is Whanaungatanga / Whakawhanaungatanga? NZ Māori https://www.twinkl.jp/teaching-wiki/whanaungatanga-whakawhanaungatanga]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772621054,
      "updated": 1772621059
    },
    {
      "id": "69a80d140000000000181d83",
      "text": "> Whanaungatanga is about making and maintaining relationships. These relationships create a sense of belonging, obligation, support, responsibilities and roles.",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772621076,
      "updated": 1772621158
    },
    {
      "id": "69a80d660000000000181d84",
      "text": "> These relationships are not necessarily about whanau or blood relationships and focus on cohesive relationships that result in benefits to the group rather than individuals.",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772621158,
      "updated": 1772621158
    },
