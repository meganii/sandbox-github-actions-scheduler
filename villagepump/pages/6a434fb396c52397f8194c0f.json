    },
    {
      "id": "6a43503e000000000091144d",
      "text": " [https://gyazo.com/fb5ea1ae7a214eef1f2db2a876cd726a]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796348,
      "updated": 1782796348
    },
    {
      "id": "6a4350570000000000911450",
      "text": " 雪が全くない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796372,
      "updated": 1782796375
    },
    {
      "id": "6a43503f000000000091144e",
      "text": "  [https://gyazo.com/04054e54b9cc6a7557fe76f5f2a2af9c]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796348,
      "updated": 1782796376
    },
    {
      "id": "6a43506f0000000000911451",
      "text": " [https://gyazo.com/c49806a0e839f087126963a250907a80]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796396,
      "updated": 1782796396
    },
    {
      "id": "6a43553a000000000091145d",
      "text": " 指導センター前も全く積もっていない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797623,
      "updated": 1782797639
    },
    {
      "id": "6a435538000000000091145b",
      "text": "  [https://gyazo.com/e40dd78090ff5ca8a37da5d62464bf78]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797621,
      "updated": 1782797640
    },
    {
      "id": "6a4350780000000000911455",
      "text": " ザックのベルトが切れてしまった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796406,
      "updated": 1782796413
    },
    {
      "id": "6a4350810000000000911456",
      "text": "  出発前に1/2ほど切れており、嫌な予感はしていた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796414,
      "updated": 1782796426
    },
    {
      "id": "6a4350770000000000911453",
      "text": "  [https://gyazo.com/bb2bb39c315f6414943a693c1724ace4]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796404,
      "updated": 1782796429
    },
    {
      "id": "6a4350a20000000000911459",
      "text": "  　以前加水分解したベルトを直してもらったばかりなのだが……どうしてこうなった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796448,
      "updated": 1782796463
    },
    {
      "id": "6a435505000000000091145a",
      "text": "  　3,4年前から使っているし、寿命なのかもしれん",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797570,
      "updated": 1782797579
    },
    {
      "id": "6a4350910000000000911458",
      "text": "  細引きとカラビナを仲間から借りて、なんとか応急処置できた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796430,
      "updated": 1782796446
    },
    {
      "id": "6a4355700000000000911464",
      "text": " なんかあった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797677,
      "updated": 1782797680
    },
    {
      "id": "6a43556f0000000000911463",
      "text": "  [https://gyazo.com/97b99330f5b87c8506c64e5482eca82e]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797676,
      "updated": 1782797681
    },
    {
      "id": "6a43554f000000000091145e",
      "text": " [一ノ倉沢]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797644,
      "updated": 1782797646
    },
    {
      "id": "6a4355780000000000911465",
      "text": "  雪が大変少ない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797685,
      "updated": 1782797695
    },
    {
      "id": "6a4355b10000000000911466",
      "text": "  [https://gyazo.com/a973fac35fa6c19b87c224726c28c0d1]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797742,
      "updated": 1782797779
    },
    {
      "id": "6a4355cd0000000000911468",
      "text": "  [https://gyazo.com/f624d50cdd65e1e6d143c5c477e15970]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782797770,
      "updated": 1782797770
    },
    {
      "id": "6a434fde000000000091144a",
      "text": " [芝倉沢]で講習場所を選定した",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796251,
      "updated": 1782796265
    },
    {
      "id": "6a434fce0000000000911447",
