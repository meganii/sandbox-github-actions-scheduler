      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796237,
      "updated": 1782796239
    },
    {
      "id": "6a434fed000000000091144b",
      "text": "　雪上講習",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796266,
      "updated": 1782796270
    },
    {
      "id": "6a434fd40000000000911448",
      "text": "2026-05-04",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1782796241,
      "updated": 1782796242
    },
    {
      "id": "6a434ff2000000000091144c",
      "text": "　[芝倉沢]を登って尾根に取り付く",
      "userId": "5ef2bdebb60650001e1280f0",
