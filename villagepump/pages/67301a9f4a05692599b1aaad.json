{
  "id": "67301a9f4a05692599b1aaad",
  "title": "長いページランキング作成スクリプト",
  "created": 1731205794,
  "updated": 1778207887,
  "lines": [
    {
      "id": "67301a9f4a05692599b1aaad",
      "text": "長いページランキング作成スクリプト",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1731205794,
      "updated": 1778066997
    },
    {
      "id": "69fb263500000000006aaa69",
      "text": "",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778066997,
      "updated": 1778066997
    },
    {
      "id": "69fb263500000000006aaa6a",
      "text": "[/scrapboxlab/api/pages/:projectname/search/titles]を使うように書き換えるべきか?",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778066997,
      "updated": 1778067235
    },
    {
      "id": "69fb272200000000006aaa6d",
      "text": "\tもっともこっちは文字数を返さないな〜",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067235,
      "updated": 1778067240
    },
    {
      "id": "69fd34b1000000000062aac3",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201778,
      "updated": 1778201778
    },
    {
      "id": "69fb29fa0000000000051817",
      "text": "% deno run --reload https://scrapbox.io/api/code/villagepump/%E9%95%B7%E3%81%84%E3%83%9A%E3%83%BC%E3%82%B8%E3%83%A9%E3%83%B3%E3%82%AD%E3%83%B3%E3%82%B0%E4%BD%9C%E6%88%90%E3%82%B9%E3%82%AF%E3%83%AA%E3%83%97%E3%83%88/createRank.ts",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067962,
      "updated": 1778067964
    },
    {
      "id": "69fd34b5000000000062aac4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201782,
      "updated": 1778201782
    },
    {
      "id": "69fd34b5000000000062aac5",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201782,
      "updated": 1778201793
    },
    {
      "id": "69fd34c1000000000062aac7",
      "text": " 1. fetch 回数の削減",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201793,
      "updated": 1778207781
    },
    {
      "id": "69fd4c1b00000000002c8b54",
      "text": "  変数 pageLimit を追加。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778207771,
      "updated": 1778207775
    },
    {
      "id": "69fd34c7000000000062aac8",
      "text": "  → 100ページ毎に fetch していたのを可変になるように変更。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201799,
      "updated": 1778207775
    },
    {
      "id": "69fd34df000000000062aac9",
      "text": "  pageLimit を 1000 にして 1000 ページずつ fetch するように変更。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201823,
      "updated": 1778207775
    },
    {
      "id": "69fd350a000000000062aaca",
      "text": "  \tこれにより送信リクエスト数を 1/10 にする。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201867,
      "updated": 1778207775
    },
    {
      "id": "69fd4c1800000000002c8b53",
      "text": " 2. 出力個数の制限解除",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778207768,
      "updated": 1778207802
    },
    {
      "id": "69fd4c3b00000000002c8b55",
      "text": " \t元の処理：記録を吐き出す際に全部 fetch して全部 sort した後で slice している",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778207803,
      "updated": 1778207881
    },
    {
      "id": "69fd4c6100000000002c8b56",
      "text": " \t\tシンプルにデータを捨てているだけで勿体ない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778207842,
      "updated": 1778207887
    },
    {
      "id": "69fd4c6d00000000002c8b57",
      "text": " \t`marked.slice(0, 500)` を `marked` に変更。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778207853,
      "updated": 1778207872
    },
    {
      "id": "69fd34b5000000000062aac6",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201782,
      "updated": 1778201782
    },
    {
      "id": "69fb26a700000000006aaa6c",
      "text": "code:createRank.ts",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067112,
      "updated": 1778067278
    },
    {
      "id": "69fb274c0000000000216251",
      "text": " import Spinner from \"https://deno.land/x/cli_spinners@v0.0.2/mod.ts\";",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216252",
      "text": " interface ScrapboxPagesJson {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216253",
      "text": "   count: number;",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216254",
      "text": "   pages: { title: string; charsCount: number }[];",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216255",
      "text": " }",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fd345b000000000062aac1",
      "text": " const pageLimit = 1000;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778201691,
      "updated": 1778201744
    },
    {
      "id": "69fb274d0000000000216256",
      "text": " const getList = (projectName: string, offset: number) => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216257",
      "text": "   return fetch(",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216258",
      "text": "     \"https://scrapbox.io/api/pages/\" +",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216259",
      "text": "       projectName +",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021625a",
      "text": "       `/?limit=${pageLimit}&skip=` +",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778067278,
      "updated": 1778201730
    },
    {
      "id": "69fb274d000000000021625b",
      "text": "       encodeURIComponent(offset),",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021625c",
      "text": "   ).then((pageRes) => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021625d",
      "text": "     if (pageRes.ok) {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021625e",
      "text": "       return pageRes.json();",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021625f",
      "text": "     } else {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216260",
      "text": "       return { pages: [] };",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216261",
      "text": "     }",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216262",
      "text": "   }).then((pageJson: ScrapboxPagesJson) => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216263",
      "text": "     return pageJson.pages;",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216264",
      "text": "   });",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216265",
      "text": " };",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216266",
      "text": " ",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216267",
      "text": " const allpagelist = (pjname: string) => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216268",
      "text": "   const spinner = Spinner.getInstance();",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216269",
      "text": "   spinner.start(\"Fetching All Page List...\");",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021626a",
      "text": "   const projectName: string = pjname;",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021626b",
      "text": "   const marked: { title: string; charsCount: number }[] = [];",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021626c",
      "text": " ",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021626d",
      "text": "   return fetch(\"https://scrapbox.io/api/pages/\" + projectName).then(",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021626e",
      "text": "     (pageRes) => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021626f",
      "text": "       if (!pageRes.ok) {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216270",
      "text": "         throw Error;",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216271",
      "text": "       }",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216272",
      "text": "       return pageRes.json();",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216273",
      "text": "     },",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216274",
      "text": "   ).then((pageJson: Readonly<ScrapboxPagesJson>) => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216275",
      "text": "     const arrayRange = (start: number, stop: number, step: number) =>",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216276",
      "text": "       Array.from(",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216277",
      "text": "         { length: (stop - start) / step + 1 },",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216278",
      "text": "         (_, index) => start + index * step,",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216279",
      "text": "       );",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021627a",
      "text": "     const getiter = arrayRange(0, pageJson.count, pageLimit);",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778067278,
      "updated": 1778201735
    },
    {
      "id": "69fb274d000000000021627b",
      "text": "     function getitertick():Promise<void>|void {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021627c",
      "text": "       const element = getiter.shift();",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021627d",
      "text": "       if (typeof element == \"undefined\") {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021627e",
      "text": "         return;",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021627f",
      "text": "       }",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216280",
      "text": "       spinner.setText(",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216281",
      "text": "         \"Fetching All Page List...[\" +",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216282",
      "text": "           element.toString().padStart(pageJson.count.toString().length) +",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216283",
      "text": "           \"/\" +",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216284",
      "text": "           pageJson.count +",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216285",
      "text": "           \"]\",",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216286",
      "text": "       );",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216287",
      "text": "       return getList(projectName, element).then((pages) => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216288",
      "text": "         marked.push(...pages);",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216289",
      "text": "         return getitertick();",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021628a",
      "text": "       });",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021628b",
      "text": "     }",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021628c",
      "text": "     return getitertick();",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021628d",
      "text": "   }).then(() => {",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021628e",
      "text": "     spinner.succeed(\"Fetched All Page List\");",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d000000000021628f",
      "text": "     spinner.stop();",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216290",
      "text": "     marked.sort((a, b) => b.charsCount - a.charsCount);",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216291",
      "text": "     let scrapchar = \"\";",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216292",
      "text": "     for (const element2 of marked) {",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778067278,
      "updated": 1778207759
    },
    {
      "id": "69fb274d0000000000216293",
      "text": "       scrapchar += \" [\" + element2.title + \"] (\" + element2.charsCount +",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778072714
    },
    {
      "id": "69fb274d0000000000216294",
      "text": "         \"文字)\\n\";",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216295",
      "text": "     }",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216296",
      "text": "     return scrapchar;",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216297",
      "text": "   });",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216298",
      "text": " };",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778067278,
      "updated": 1778067278
    },
    {
      "id": "69fb274d0000000000216299",
      "text": " ",
      "userId": "686b72ebdffe36b729b4453d",
