    {
      "id": "69becd3a000000000010c6b4",
      "text": "製品",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112059,
      "updated": 1774112061
    },
    {
      "id": "69becd3c000000000010c6b6",
      "text": "\t[WebVM]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112061,
      "updated": 1774112063
    },
    {
      "id": "69becd61000000000010c6b7",
      "text": "\t\tサーバーレスのクライアントで完全に動作する仮想Linux環境",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112098,
      "updated": 1774112128
    },
    {
      "id": "69becd83000000000010c6b8",
      "text": "\t[BrowserPod]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112132,
      "updated": 1774112135
    },
    {
      "id": "69becd88000000000010c6b9",
      "text": "\t\tブラウザ内のフルスタック開発環境",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112137,
      "updated": 1774112254
    },
    {
      "id": "69becdfe000000000010c6ba",
      "text": "\t[Cheerp]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112255,
      "updated": 1774112478
    },
    {
      "id": "69bece28000000000010c6bb",
      "text": "\t\t[WebAssembly]や[JavaScript]に変換するオープンソースのC/C++コンパイラー",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112297,
      "updated": 1774112337
    },
    {
      "id": "69bece50000000000010c6bc",
      "text": "\t[Cheerpj]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112337,
      "updated": 1774112483
    },
    {
      "id": "69bece86000000000010c6bd",
      "text": "\t\tブラウザ向けの[Java Virtual Machine]（[JVM]）とランタイム、背景は[WebAssembly]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112391,
      "updated": 1774112448
    },
    {
      "id": "69bed059000000000010c6c2",
      "text": "\t\t動作サンプルとして[Minecraft] 1.2.5をそのまま動かしたものがある（[Browsercraft]）",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112858,
      "updated": 1774112891
    },
    {
      "id": "69bed073000000000010c6c3",
      "text": "\t\t\thttps://browsercraft.cheerpj.com/",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112884,
      "updated": 1774112893
    },
    {
      "id": "69bed0be000000000010c6c4",
      "text": "\t\t\thttps://github.com/leaningtech/browsercraft/",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112959,
      "updated": 1774112959
    },
    {
      "id": "69becec0000000000010c6bf",
      "text": "\t[CheerpX]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774112449,
      "updated": 1774112454
    },
    {
      "id": "69beceeb000000000010c6c0",
