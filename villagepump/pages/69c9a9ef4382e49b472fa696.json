  "lines": [
    {
      "id": "69c9a9ef4382e49b472fa696",
      "text": "トポロジカル日本地図",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd00",
      "text": "from [2023/10/10]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd01",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774824153
    },
    {
      "id": "69c9aad700000000001dfd10",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774824153,
      "updated": 1774824153
    },
    {
      "id": "69c9a9ee00000000001dfd02",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd03",
      "text": "\t[トポロジカル日本地図]ができた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9aada00000000001dfd11",
      "text": " \t[https://gyazo.com/92c41f693d2c696a45be8372eca9f603]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774824156,
      "updated": 1774824223
    },
    {
      "id": "69c9a9ee00000000001dfd05",
      "text": "\t\tノードが都道府県、エッジが都道府県境を表す",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd06",
      "text": "\t\t\tミスってる箇所があるが、どこなのか分かれば結構凄いと思う",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd07",
      "text": "\t\t[https://gyazo.com/7c81eac979310ef4574a145dbb78ec26]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774824260
    },
    {
      "id": "69c9ab4300000000001dfd13",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774824260,
      "updated": 1774824260
    },
    {
      "id": "69c9a9ee00000000001dfd08",
      "text": "\t\t\t直した",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd09",
      "text": "\tトポロジカル日本地図その2",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd0a",
      "text": "\t\t[https://gyazo.com/e7a5c1c7bc5a38e4bf0bbde868f6db80]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774824285
    },
    {
      "id": "69c9a9ee00000000001dfd0b",
      "text": "\t\t頂点が 3 都府県境と海岸の 2 都府県境、辺が都府県境、面が都府県、丸いのは単島道県",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd0c",
      "text": "\t\t長崎だけ二角形",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd0d",
      "text": "\t\tバネ質点モデルとかでグラフの形を整えたらどうなるんかな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9a9ee00000000001dfd0e",
      "text": "\t\t\tノード間には斥力が働いてほしいから質点と言うよりは電子だけど",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9ab7900000000001dfd15",
      "text": "\t\tこれを書いた当時は知らなかったが、graphviz があったらできる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774824315,
      "updated": 1774824338
    },
    {
      "id": "69c9a9ee00000000001dfd0f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774823920,
      "updated": 1774823920
    },
    {
      "id": "69c9abb100000000001dfd19",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774824370,
      "updated": 1774824370
    },
    {
      "id": "69c9ab9e00000000001dfd18",
      "text": "マーメイドで作るとより抽象的な形になると思う",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774824351,
      "updated": 1774824382
    },
    {
      "id": "69c9ab9300000000001dfd16",
      "text": "code:mermaid",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774824340,
      "updated": 1774848396
    },
    {
