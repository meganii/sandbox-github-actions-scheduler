      "created": 1742354850,
      "updated": 1742354850
    },
    {
      "id": "67da39a15b98c20000d8b151",
      "text": "[赤リンク]は[行き止まり]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1742354850,
      "updated": 1742354861
    },
    {
      "id": "67da39a25b98c20000d8b152",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1742354851,
      "updated": 1742354851
    },
    {
      "id": "69dbd97700000000003834e1",
      "text": "　　code:mermaid",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776015735,
      "updated": 1776015736
    },
    {
      "id": "69dbd97800000000003834e2",
      "text": "   graph LR",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776015736,
      "updated": 1776015736
    },
    {
      "id": "69dbd97800000000003834e3",
      "text": "   Q(起点ページ)<-->B1(ページ)<-->B2(ページ)-->|赤リンク|B3(空ページ)",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776015736,
      "updated": 1776015947
    },
    {
      "id": "69dbd97800000000003834e4",
      "text": "   Q-->C1(ページ)-->C2(ページ)-->|青リンク|C3(空ページ)",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776015736,
      "updated": 1776016306
    },
    {
      "id": "69dbdb1200000000003834f1",
      "text": "   Q-->D1(ページ)-->D2(ページ)-->|青リンク|C3",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016146,
      "updated": 1776016317
    },
    {
      "id": "69dbdab200000000003834ef",
      "text": "   B1<-->C1",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016050,
      "updated": 1776016062
    },
    {
      "id": "69dbdaea00000000003834f0",
      "text": "   B2<-->C2",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016106,
      "updated": 1776016115
    },
    {
      "id": "69dbd97800000000003834e5",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776015736,
      "updated": 1776016467
    },
    {
      "id": "69dbe41c0000000000383503",
      "text": "行き止まりにならないようにページを作り、リンクをはる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776018461,
      "updated": 1776018552
    },
    {
      "id": "69dbdc5400000000003834f3",
      "text": "　　code:mermaid",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016468,
      "updated": 1776016469
    },
    {
      "id": "69dbdc5500000000003834f4",
      "text": "   graph LR",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016469,
      "updated": 1776016469
    },
    {
      "id": "69dbdc5500000000003834f5",
      "text": "   Q(起点ページ)<-->B1(ページ)<-->B2(ページ)-->B3(ページ)",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016469,
      "updated": 1776016517
    },
    {
      "id": "69dbdc5500000000003834f6",
      "text": "   Q-->C1(ページ)-->C2(ページ)-->C3(ページ)",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016469,
      "updated": 1776016488
    },
    {
      "id": "69dbdc5500000000003834f7",
      "text": "   Q-->D1(ページ)-->D2(ページ)-->C3",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016469,
      "updated": 1776016481
    },
    {
      "id": "69dbdc5500000000003834f8",
      "text": "   B1<-->C1",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016469,
      "updated": 1776016469
    },
    {
      "id": "69dbdc5500000000003834f9",
      "text": "   B2<-->C2",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016469,
      "updated": 1776016469
    },
    {
      "id": "69dbdc9300000000003834fb",
      "text": "   B3<-->C3",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016531,
      "updated": 1776016546
    },
    {
      "id": "69dbdc9400000000003834fc",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776016532,
      "updated": 1776016532
    },
    {
      "id": "69dbe4a70000000000383504",
      "text": "ただし、作成したページから、また赤リンクは生えてくるので、どの程度許容できるかという程度問題だろう",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776018599,
      "updated": 1776018715
    },
    {
      "id": "69dbdef900000000009bf53e",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1776017145,
      "updated": 1776017145
    },
    {
      "id": "69dbdefa00000000009bf53f",
      "text": "例外: 他プロジェクトからリンクされている場合",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1776017146,
      "updated": 1776017152
    },
    {
      "id": "69dbdf0100000000009bf541",
      "text": "\tただしページ化しないと表示されない",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1776017153,
      "updated": 1776017173
    },
    {
      "id": "69dbe0aa0000000000383502",
      "text": "\t よくわからないのですが、こういうことですか？[suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776017578,
      "updated": 1776017619
    },
    {
      "id": "69dbe01d00000000003834fd",
      "text": "　　code:mermaid",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776017438,
      "updated": 1776017440
    },
    {
      "id": "69dbe02000000000003834fe",
      "text": "   graph LR",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776017440,
      "updated": 1776017440
    },
    {
      "id": "69dbe02000000000003834ff",
      "text": "   Q(起点ページ)-->B1(空ページ)",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776017440,
      "updated": 1776017474
    },
    {
      "id": "69dbe0410000000000383501",
      "text": "   X(他プロジェクト)-->|external link|B1",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776017474,
      "updated": 1776017733
    },
    {
      "id": "69dbe0200000000000383500",
      "text": "\t\tですです[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1776017440,
      "updated": 1776017966
    },
    {
      "id": "69dbe7ba0000000000383505",
      "text": "\t\t [External Links] はまた別の話になるよ、と理解してよろしいでしょうか？ [suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776019386,
      "updated": 1776019492
    },
