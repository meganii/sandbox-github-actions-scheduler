    {
      "id": "69a8340e0000000000bff228",
      "text": "\t中\t唇\t齒齦\t齦齶\t捲舌\t軟齶\t聲門",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772631055,
      "updated": 1772631357
    },
    {
      "id": "69a8344b0000000000bff229",
      "text": "\t日\t両唇\t歯茎\t硬口蓋\tそり舌\t軟口蓋\t声門",
