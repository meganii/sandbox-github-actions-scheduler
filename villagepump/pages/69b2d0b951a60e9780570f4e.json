      "updated": 1773326809
    },
    {
      "id": "69b2d0c9000000000095d603",
      "text": "[mermaid.js]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773326538,
      "updated": 1773326617
    },
    {
      "id": "69b2d0cd000000000095d605",
      "text": "[井戸端にダークテーマを導入したい#69aed1ce0000000000ac5d23]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773326542,
      "updated": 1773327793
    },
    {
      "id": "69b2d536000000000095d60f",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327791,
      "updated": 1773327791
    },
    {
      "id": "69b2d537000000000095d610",
      "text": "資料",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327791,
      "updated": 1773327791
    },
    {
      "id": "69b2d53d000000000095d612",
      "text": "\thttps://mermaid.js.org/config/theming.html",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327791,
      "updated": 1773327791
    },
    {
      "id": "69b2d538000000000095d611",
      "text": "\t> Dynamic and integrated theme configuration was introduced in Mermaid version 8.7.0.",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327791,
      "updated": 1773327819
    },
    {
      "id": "69b2d5d9000000000095d620",
      "text": "  Available Themes",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327834,
      "updated": 1773327848
    },
    {
      "id": "69b2d5de000000000095d621",
      "text": "  > default - This is the default theme for all diagrams.",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327839,
      "updated": 1773327848
    },
    {
      "id": "69b2d5de000000000095d622",
      "text": "  > neutral - This theme is great for black and white documents that will be printed.",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327839,
      "updated": 1773327848
    },
    {
      "id": "69b2d5de000000000095d623",
      "text": "  > dark - This theme goes well with dark-colored elements or dark-mode.",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327839,
      "updated": 1773327848
    },
    {
      "id": "69b2d5de000000000095d624",
      "text": "  > forest - This theme contains shades of green.",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327839,
      "updated": 1773327848
    },
    {
      "id": "69b2d5de000000000095d625",
      "text": "  > base - This is the only theme that can be modified. Use this theme as the base for customizations.",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327839,
      "updated": 1773327848
    },
    {
      "id": "69b2d547000000000095d619",
      "text": "\t\tcode:mermaid",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327791,
      "updated": 1773327904
    },
    {
      "id": "69b2d54c000000000095d61a",
      "text": "   ---",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327904,
      "updated": 1773327904
    },
    {
      "id": "69b2d612000000000095d62a",
      "text": "   config:",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d62b",
      "text": "     theme: 'base'",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d62c",
      "text": "     themeVariables:",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d62d",
      "text": "       primaryColor: '#BB2528'",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d62e",
      "text": "       primaryTextColor: '#fff'",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d62f",
      "text": "       primaryBorderColor: '#7C0000'",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d630",
      "text": "       lineColor: '#F8B229'",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d631",
      "text": "       secondaryColor: '#006100'",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d632",
      "text": "       tertiaryColor: '#fff'",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d633",
      "text": "   ---",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d634",
      "text": "           graph TD",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d635",
      "text": "             A[Christmas] -->|Get money| B(Go shopping)",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d636",
      "text": "             B --> C{Let me think}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d637",
      "text": "             B --> G[/Another/]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d638",
      "text": "             C ==>|One| D[Laptop]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d639",
      "text": "             C -->|Two| E[iPhone]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d63a",
      "text": "             C -->|Three| F[fa:fa-car Car]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d63b",
      "text": "             subgraph section",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d63c",
      "text": "               C",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d63d",
      "text": "               D",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d63e",
      "text": "               E",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d63f",
      "text": "               F",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d640",
      "text": "               G",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d641",
      "text": "             end",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d612000000000095d642",
      "text": "   ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773327890,
      "updated": 1773327890
    },
    {
      "id": "69b2d545000000000095d618",
