    {
      "id": "69f59f3902c188efa30ceb4c",
      "text": "目玉焼きむずかしい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c6857f",
      "text": "from [2026/04/28]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68580",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704927
    },
    {
      "id": "69f59f3a0000000000c68581",
      "text": "[sta.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68582",
      "text": "\t[目玉焼きむずかしい]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68583",
      "text": "\t[https://gyazo.com/e842b556aa065156edf576dddefa403d]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68584",
      "text": "\t\t目玉の周りに肉が（言い方）[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68585",
      "text": "\t\tもし数回挑戦しても黄身がすぐつぶれてしまうようなら、卵の質がよくない可能性もある[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68586",
      "text": "\t\t\tサイズばらばらたまご？みたいな安いやつなので可能性高そう[sta.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68587",
      "text": "\t\t\tサイズばらばら売りとかあるんだ[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68588",
      "text": "\t\t\t　大きさを揃えてパック詰めで売ってるやつしか知らんかった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68589",
      "text": "\t食えるからいいか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c6858a",
      "text": "\t 食べて美味しければおーるおっけー[taktamur.icon][Hiro Aki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c6858b",
      "text": "\t油と蓋の役割も理解した",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c6858c",
      "text": "\t\t蓋は水蒸気閉じ込めて上面からの加熱をアシストする",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c6858d",
      "text": "\t\t油は「実は凸凹な表面を均一にする」「200℃でも蒸発しない」などで触媒として優秀",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c6858e",
      "text": "\t\t 油自体に美味しさを感じさせる役割もありそう[yosider.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c6858f",
      "text": "\t\t  メカニズムはよくわからんけど",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    },
    {
      "id": "69f59f3a0000000000c68590",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777704764,
      "updated": 1777704764
    }
  ]
}