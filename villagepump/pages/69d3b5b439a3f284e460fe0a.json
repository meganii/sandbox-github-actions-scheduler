  "lines": [
    {
      "id": "69d3b5b439a3f284e460fe0a",
      "text": "●●するための●●がない",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775482294,
      "updated": 1775482294
    },
    {
      "id": "69d3b5b500000000000943a1",
      "text": "[服を買いに行く服がない]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775482294,
      "updated": 1775482295
    },
    {
      "id": "69d3b5b600000000000943a2",
      "text": "[体力を維持する体力がない]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775482295,
      "updated": 1775482295
    },
    {
      "id": "69d3b5b600000000000943a3",
      "text": "[体力をつけるための体力がない]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775482295,
      "updated": 1775482295
    },
    {
      "id": "69d3b5b600000000000943a4",
      "text": "[知識を得るための知識がない]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775482295,
      "updated": 1775482295
    },
    {
      "id": "69d3b5b700000000000943a5",
      "text": "うんこするためのうんこがない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775482296,
      "updated": 1775484259
    },
    {
      "id": "69d3bd650000000000484dbf",
      "text": "\tうんこがなくてもうんこしないといけない状況がどういう状況かわからないけど、一応腸内が空っぽの状態にも関わらずうんこしなくてはいけない状況なら、うんこするためのうんこがないは成立する。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775484262,
      "updated": 1775484382
    },
    {
      "id": "69d3bde50000000000484dc1",
      "text": "\tトイレは今のうちに行っといて下さいねー！の時か",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775484389,
      "updated": 1775484415
    },
