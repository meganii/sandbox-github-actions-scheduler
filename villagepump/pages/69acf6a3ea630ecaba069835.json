  "lines": [
    {
      "id": "69acf6a80000000000cbf286",
      "text": "井戸端に今まで書き込まれていない話題",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772943017,
      "updated": 1772943037
    },
    {
      "id": "69acf6a3ea630ecaba069835",
      "text": "[今まで書き込まれていない話題を書く] #書いてけ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772943017,
      "updated": 1772964896
    },
    {
      "id": "69acf6ad0000000000cbf287",
      "text": "\t[- あるのか？]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772943022,
      "updated": 1772964927
    },
    {
      "id": "69ad4c220000000000343338",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772964899,
      "updated": 1772964899
    },
    {
      "id": "69acf6ce0000000000cbf28e",
      "text": "\t[井戸端でまだ語られてない話題]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772943055,
      "updated": 1772966748
    },
    {
      "id": "69ad62a7000000000039e8c8",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970664,
      "updated": 1772970664
    },
    {
      "id": "69ad62a8000000000039e8c9",
      "text": "[日ユ同祖論][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970664,
      "updated": 1772970683
    },
    {
      "id": "69ad62b1000000000039e8ca",
      "text": "\tうわ青リンクやんけ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970673,
      "updated": 1772970682
    },
    {
      "id": "69ad62bd000000000039e8cb",
      "text": "\t^^; [Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772970686,
      "updated": 1772970723
    },
    {
      "id": "69ad62c8000000000034873c",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772970697,
      "updated": 1772970697
    },
    {
      "id": "69ad62bd000000000039e8cc",
      "text": "[日韓同祖論][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970686,
      "updated": 1772970694
    },
    {
      "id": "69ad62c6000000000039e8cd",
      "text": "\t日本語と韓国語が同じ言語グループにあるという主張が征韓論の頃になされていた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970694,
      "updated": 1772970748
    },
    {
      "id": "69acf6c00000000000cbf28a",
      "text": "\t[ウラル・アルタイ語族]…む[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772943041,
      "updated": 1772970948
    },
    {
      "id": "69ad63a8000000000039e8d6",
      "text": "\t[アルタイ語族]の話がない[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970921,
      "updated": 1772970937
    },
    {
      "id": "69ad63ca000000000034873e",
      "text": "\t知名度のある説ではあるので意外だ…[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772970955,
      "updated": 1772971006
    },
    {
      "id": "69ad637f000000000034873d",
      "text": "  言語学に触れていたら「知名度がある」と認識できるけど一般的には無いよw[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970880,
      "updated": 1772971031
    },
    {
      "id": "69ad63f3000000000039e8d7",
      "text": "\t\tそんな…井戸端には逸般人しかいないはず…[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772970995,
      "updated": 1772971064
    },
    {
      "id": "69ad6429000000000034873f",
      "text": "  \t[あっ、そっかぁ。じゃあ問題ないね！][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772971050,
      "updated": 1772971093
    },
    {
      "id": "69ad643a000000000039e8d8",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772971066,
      "updated": 1772971073
    },
    {
      "id": "69ad6325000000000039e8ce",
      "text": "[ミトコンドリア・イブ]に関する話題[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970790,
      "updated": 1772970809
    },
    {
      "id": "69ad6339000000000039e8d0",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970809,
      "updated": 1772970809
    },
    {
      "id": "69ad633b000000000039e8d1",
      "text": "[Y染色体アダム]に関する話題[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970811,
      "updated": 1772970869
    },
    {
      "id": "69ad6346000000000039e8d2",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970823,
      "updated": 1772970823
    },
    {
      "id": "69ad6347000000000039e8d3",
      "text": "[インフルエンザ株]に関する話題[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970824,
      "updated": 1772970867
    },
    {
      "id": "69ad6364000000000039e8d4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970852,
      "updated": 1772970852
    },
    {
      "id": "69ad6364000000000039e8d5",
      "text": "[ハレム] (イスラム世界関連のやつ)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772970853,
      "updated": 1772970894
    },
    {
      "id": "69ada7c500000000000bb9e1",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988357,
      "updated": 1772988372
    },
    {
      "id": "69ada8d500000000000bb9e5",
      "text": " 既に青でもおかしくないくらいの赤リンクを挙げる遊び[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988629,
      "updated": 1772988692
    },
    {
      "id": "69ada8fb00000000000bb9e6",
      "text": "  [WBC]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988668,
      "updated": 1772988727
    },
    {
      "id": "69ada93900000000000bb9e7",
      "text": "   [WBC日韓戦]あった あっぶっね",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988730,
      "updated": 1772988742
    },
    {
      "id": "69ada94400000000000bb9e8",
      "text": "  [Nubian]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988740,
      "updated": 1772988752
    },
    {
      "id": "69ada95200000000000bb9e9",
      "text": "  [スターフライヤー]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988754,
      "updated": 1772988769
    },
    {
      "id": "69ada96300000000000bb9ea",
      "text": "  ひやひやする",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988771,
      "updated": 1772988859
    },
    {
      "id": "69ada97100000000000bb9eb",
      "text": "  [テロメラーゼ]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988786,
      "updated": 1772988796
    },
    {
      "id": "69adab7f00000000000bb9fa",
      "text": "   テロメア関連用語は豊富っぽいかもと思った",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989312,
      "updated": 1772989336
    },
    {
      "id": "69ada9af00000000000bb9ed",
      "text": "  [エイデン]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988848,
      "updated": 1772988850
    },
    {
      "id": "69ada9b300000000000bb9ee",
      "text": "  [シズル]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988851,
      "updated": 1772988891
    },
    {
      "id": "69ada9ee00000000000bb9ef",
      "text": "  [カウンターカルチャー]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988910,
      "updated": 1772988968
    },
    {
      "id": "69adaa2a00000000000bb9f0",
      "text": "  慎重に考え始めてしまった",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988970,
      "updated": 1772989032
    },
    {
      "id": "69adaa7400000000000bb9f4",
      "text": "   青踏んだら即ゲームオーバーの感じになってきてる",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989044,
      "updated": 1772989071
    },
    {
      "id": "69adaa6800000000000bb9f3",
      "text": "   青でももっともらしい、と自分が思えることってなんだろうなあ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989032,
      "updated": 1772989036
    },
    {
      "id": "69adadd5000000000070a913",
      "text": "    自分が納得するかどうかがレギュになっている",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989910,
      "updated": 1772989932
    },
    {
      "id": "69adab1e00000000000bb9f8",
      "text": "    じぶんの場合は、井戸端を長年見ている者の勘でギリギリを攻めてみることができる",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989214,
      "updated": 1772989373
    },
    {
      "id": "69adadba000000000070a90f",
      "text": "     「泣かないで」はなんとなくギリないと思うが、あるとしたら歌詞か日記のブラケティングで、中身はなく赤リンクで、しかし全文検索したら結構出てきて…というわりと細かい景色を想像する",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989883,
      "updated": 1772990128
    },
    {
      "id": "69adaaa100000000000bb9f5",
      "text": "   うーん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989089,
      "updated": 1772989252
    },
    {
      "id": "69adaa6500000000000bb9f2",
      "text": "  [大西ライオン]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989029,
      "updated": 1772989108
    },
    {
      "id": "69adaab400000000000bb9f6",
      "text": "  [ウンナン極限ネタバトル! ザ・イロモネア 笑わせたら100万円]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989109,
      "updated": 1772989153
    },
    {
      "id": "69adaade00000000000bb9f7",
      "text": "  あー 終わり",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989153,
      "updated": 1772989185
    },
    {
      "id": "69adabdd00000000000bb9fb",
      "text": "   頭の変なところ使った",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772989405,
      "updated": 1772989416
    },
    {
      "id": "69ada80400000000000bb9e4",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1772988420,
      "updated": 1772988531
    },
    {
      "id": "69adaa5d00000000004b6473",
      "text": "",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989021,
      "updated": 1772989021
    },
    {
      "id": "69adaa5d00000000004b6474",
      "text": "[HelloPeople.icon]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989021,
      "updated": 1772989023
    },
    {
      "id": "69adaa0800000000004b646d",
      "text": "[児玉裕一]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772988935,
      "updated": 1772989019
    },
    {
      "id": "69adaa6100000000004b6475",
      "text": "[ほかほかおでんのうた]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989025,
      "updated": 1772989145
    },
    {
      "id": "69adaadb00000000004b6477",
      "text": "[日本橋高架下R計画]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989147,
      "updated": 1772989164
    },
    {
      "id": "69adaa7300000000004b6476",
      "text": "[える]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989043,
      "updated": 1772989210
    },
    {
      "id": "69adab1b00000000004b6478",
      "text": "[ハーモナイザー]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989210,
      "updated": 1772989276
    },
    {
      "id": "69adabb100000000004b647b",
      "text": "[にじたうん]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989361,
      "updated": 1772989367
    },
    {
      "id": "69adabb200000000004b647c",
      "text": "[ボリュメトリックビデオ]",
      "userId": "5f938a902ea5180024085116",
      "created": 1772989362,
      "updated": 1772989401
    },
