  "updated": 1781236297,
  "lines": [
    {
      "id": "6a2b818c05bb8f0b09b9edb8",
      "text": "箱のメタファ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781236111,
      "updated": 1781236111
    },
    {
      "id": "6a2b818e00000000003cd1c4",
      "text": "クラスは箱。オブジェクトも箱。関数も箱。変数も箱。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781236111,
      "updated": 1781236125
    },
    {
      "id": "6a2b819d00000000003cd1c5",
      "text": "プログラミングの世界では、なぜかあらゆる概念が「箱」として例えられる。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781236125,
      "updated": 1781236125
    },
    {
      "id": "6a2b819d00000000003cd1c6",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781236125,
      "updated": 1781236125
    },
    {
      "id": "6a2b819e00000000003cd1c7",
      "text": "[人は城、人は石垣、人は堀、情けは味方、仇は敵なり]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781236126,
      "updated": 1781236153
    },
    {
      "id": "6a2b82470000000000cce9e7",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1781236296,
      "updated": 1781236296
    },
    {
