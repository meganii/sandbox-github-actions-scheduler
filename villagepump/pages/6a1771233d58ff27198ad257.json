{
  "id": "6a1771233d58ff27198ad257",
  "title": "安全旗",
  "created": 1779921317,
  "updated": 1779921380,
  "lines": [
    {
      "id": "6a1771233d58ff27198ad257",
      "text": "安全旗",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921317,
      "updated": 1779921317
    },
    {
      "id": "6a1771a50000000000d1a74e",
      "text": "[労働安全]",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921317,
      "updated": 1779921355
    },
    {
      "id": "6a1771cc0000000000d1a75f",
      "text": "[工事現場]によくはためいている白と緑に十字の旗",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921357,
      "updated": 1779921380
    },
    {
      "id": "6a1771a50000000000d1a74f",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921317,
      "updated": 1779921317
    },
    {
      "id": "6a1771a50000000000d1a750",
      "text": "[https://www.jsce.jp/pro/node/6137 安全旗と安全衛生旗の使い分けで | JSCE.jp for Engineers]",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921317,
      "updated": 1779921318
    },
    {
      "id": "6a1771a50000000000d1a751",
      "text": ">・[安全旗]（白地に緑十字）",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921318,
      "updated": 1779921349
    },
    {
      "id": "6a1771b20000000000d1a753",
      "text": "> 　安全週間のシンボルマークとして、日本で初めて制定。",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    },
    {
      "id": "6a1771b20000000000d1a754",
      "text": "> 　大正８年に提案。昭和２年に国として了承。",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    },
    {
      "id": "6a1771b20000000000d1a755",
      "text": "> ・[労働衛生旗]（緑地に白十字）",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921334
    },
    {
      "id": "6a1771b20000000000d1a756",
      "text": "> 　労働衛生を象徴するものとして、",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    },
    {
      "id": "6a1771b20000000000d1a757",
      "text": "> 　昭和２８年に労働省の公募により制定。",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    },
    {
      "id": "6a1771b20000000000d1a758",
      "text": "> ・[安全衛生旗]（緑地に白十字、その中に緑十字）",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921336
    },
    {
      "id": "6a1771b20000000000d1a759",
      "text": "> 　安全と労働衛生は密接な関係にあるものとして、",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    },
    {
      "id": "6a1771b20000000000d1a75a",
      "text": "> 　昭和４０年に中災防の公募により制定。",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    },
    {
      "id": "6a1771b20000000000d1a75b",
      "text": "> ということで、その旗の成り立ちから勘案すれば",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    },
    {
      "id": "6a1771b20000000000d1a75c",
      "text": "> ・[安全旗]・・・全国安全週間および準備期間（６月１日～７月７日）",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921341
    },
    {
      "id": "6a1771b20000000000d1a75d",
      "text": "> ・[労働衛生旗]・・・全国労働衛生週間および準備期間（９月１日～１０月７日）",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921344
    },
    {
      "id": "6a1771b20000000000d1a75e",
      "text": "> ・[安全衛生旗]・・・上記以外の期間",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921347
    },
    {
      "id": "6a1771b10000000000d1a752",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1779921330,
      "updated": 1779921330
    }
  ]
}