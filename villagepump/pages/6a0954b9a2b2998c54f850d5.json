    {
      "id": "6a0954b9a2b2998c54f850d5",
      "text": "file over app",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996412,
      "updated": 1778996644
    },
    {
      "id": "6a0954cf0000000000a6023d",
      "text": "https://stephango.com/file-over-app",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996431,
      "updated": 1778996431
    },
    {
      "id": "6a0956490000000000a6024c",
      "text": " ファイルは",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996810,
      "updated": 1778997047
    },
    {
      "id": "6a0957260000000000a60256",
      "text": "  アプリのライフスパンを超えて残せる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778997047,
      "updated": 1778997047
    },
    {
      "id": "6a0957270000000000a60257",
      "text": "  アプリより重要",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778997031,
      "updated": 1778997034
    },
    {
      "id": "6a0956f50000000000a60254",
      "text": " ファイルは永続する",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996981,
      "updated": 1778997077
    },
    {
      "id": "6a0957420000000000a60258",
      "text": " デジタルツール(obsidianを含む)はいつかなくなる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778997059,
      "updated": 1778997085
    },
    {
      "id": "6a09575d0000000000a60259",
      "text": " ファイルはデジタルツールの固有のフォーマットでなく、数十年後も数千年後も開けるような形で残すのがいい",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778997085,
      "updated": 1778997086
    },
    {
      "id": "6a0955d20000000000a60248",
      "text": "  プレーンテキストでファイルを保存するのがいい",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996690,
      "updated": 1778996720
    },
    {
      "id": "6a0956b10000000000a60252",
      "text": "  プレーンテキストは1960年にも開けたから、何十年後にも開けそう",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996913,
      "updated": 1778996931
    },
    {
      "id": "6a09569e0000000000a6024f",
      "text": " ファイルはサーバーやクラウドストレージでなく、ローカルに保存するのがいい",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996895,
      "updated": 1778996939
    },
    {
      "id": "6a0956cb0000000000a60253",
      "text": "  インターネット接続やクラウドサービスが使えなくなっても開けるように",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996940,
      "updated": 1778996969
    },
    {
      "id": "6a0954cf0000000000a6023e",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778996431,
      "updated": 1778996431
    },
    {
      "id": "6a09576d0000000000a60271",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778997101,
      "updated": 1778997101
    },
    {
      "id": "6a09576c0000000000a60270",
      "text": "[Obsidianの哲学]の1つ",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1778997100,
      "updated": 1778997100
    }
  ]
}