      "userId": "688c296691686a314f82fb52",
      "created": 1777675838,
      "updated": 1777675848
    },
    {
      "id": "69f52e3d00000000008522df",
      "text": "> 25　聖ガブリエル　19歳/伊勢/同宿",
      "userId": "688c296691686a314f82fb52",
      "created": 1777675838,
      "updated": 1777675844
    },
    {
      "id": "69f52e3d00000000008522e0",
      "text": "> 26　聖パウロ鈴木　49歳/尾張/フランシスコ会修道士",
      "userId": "688c296691686a314f82fb52",
      "created": 1777675838,
      "updated": 1777675843
    },
