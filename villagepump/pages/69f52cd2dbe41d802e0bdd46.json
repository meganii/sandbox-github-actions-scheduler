      "created": 1777675838,
      "updated": 1777675866
    },
    {
      "id": "69f52e3d00000000008522ca",
      "text": "> 15　聖フランシスコ・ブランコ(スペイン)　28歳/スペイン/フランシスコ会司祭",
      "userId": "688c296691686a314f82fb52",
      "created": 1777675838,
      "updated": 1777675864
    },
    {
      "id": "69f52e3d00000000008522cc",
      "text": "> 16　聖フランシスコ・デ・サン・ミゲル　53歳/スペイン/フランシスコ会修道士",
      "userId": "688c296691686a314f82fb52",
      "created": 1777675838,
      "updated": 1777675863
    },
    {
      "id": "69f52e3d00000000008522ce",
