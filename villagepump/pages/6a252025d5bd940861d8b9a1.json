  "lines": [
    {
      "id": "6a252025d5bd940861d8b9a1",
      "text": "ページ作成への抵抗感",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780817963,
      "updated": 1780817963
    },
    {
      "id": "6a2520d50000000000045947",
      "text": " [複数人Projectでやたらとページを作るのには抵抗があ]る人もいる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818134,
      "updated": 1780818151
    },
    {
      "id": "6a2520640000000000045946",
      "text": " [共同プロジェクトで発生する遠慮]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818021,
      "updated": 1780818027
    },
    {
      "id": "6a2521e20000000000045949",
      "text": " 　[遠慮を井戸に捨て]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818403,
      "updated": 1780818409
    },
    {
      "id": "6a25202a0000000000045944",
      "text": " [共同プロジェクトの私物化]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780817963,
      "updated": 1780818007
    },
    {
      "id": "6a252275000000000004594a",
      "text": "  [井戸端を私物にするメリット]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818550,
      "updated": 1780818555
    },
    {
      "id": "6a2522a0000000000004594b",
      "text": "  [井戸端に書き込むメリット]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818593,
      "updated": 1780818653
    },
    {
      "id": "6a2522e0000000000004594e",
      "text": "   [井戸端で他人の情報処理を期待して書く(仮)]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818657,
      "updated": 1780818719
    },
    {
      "id": "6a2522a6000000000004594c",
      "text": "  [井戸端に書き込むデメリット]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818598,
      "updated": 1780818646
    },
    {
      "id": "6a2520470000000000045945",
      "text": "　[グループで使うscrapboxを「成功」させるには]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780817992,
      "updated": 1780818198
    },
    {
      "id": "6a2521150000000000045948",
      "text": "　　>たわいのないことを書いて[ハードル]を下げる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780818198,
