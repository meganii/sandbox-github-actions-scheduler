    {
      "id": "6a5109e9ddcbe59d7764be1f",
      "text": "U2",
      "userId": "6303abe85eed77001d707837",
      "created": 1783695851,
      "updated": 1783695852
    },
    {
      "id": "6a510a7a0000000000140c48",
      "text": "\tアイルランドを代表する世界的に有名なロックバンド",
      "userId": "6303abe85eed77001d707837",
      "created": 1783695995,
      "updated": 1783696017
    },
    {
      "id": "6a510aad0000000000140c4a",
      "text": "\t高校時代に結成したメンバーのまま、2026年に結成50周年を迎えるバンド",
      "userId": "6303abe85eed77001d707837",
      "created": 1783696046,
      "updated": 1783696095
    },
    {
      "id": "6a510ade0000000000140c4e",
      "text": "\tグラミー賞も多数受賞",
      "userId": "6303abe85eed77001d707837",
      "created": 1783696095,
      "updated": 1783696102
    },
    {
      "id": "6a510ae50000000000140c4f",
      "text": "\t2026年中に新作アルバムもリリース予定",
      "userId": "6303abe85eed77001d707837",
      "created": 1783696102,
      "updated": 1783696116
    },
    {
      "id": "6a510b370000000000140c56",
      "text": "\tスティーブ・ジョブズもU2モデルのiPodを出すぐらい好きなバンド",
      "userId": "6303abe85eed77001d707837",
      "created": 1783696185,
      "updated": 1783696209
    },
    {
      "id": "6a5109eb0000000000140c40",
      "text": "",
      "userId": "6303abe85eed77001d707837",
      "created": 1783695852,
      "updated": 1783695920
    },
    {
      "id": "6a510abc0000000000140c4b",
      "text": "日本ではヨーロッパほど知名度がない気がするので、",
      "userId": "6303abe85eed77001d707837",
      "created": 1783696061,
      "updated": 1783696080
    },
    {
      "id": "6a510acf0000000000140c4c",
      "text": "50周年という区切りなのであれこれ書いていくつもり[nejimaki.icon]",
      "userId": "6303abe85eed77001d707837",
      "created": 1783696080,
      "updated": 1783696090
    },
