      "updated": 1781857538
    },
    {
      "id": "6a34fbec00000000001b4d4d",
      "text": "\t議論中での比較",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1781857260,
      "updated": 1781857267
    },
    {
      "id": "6a34fc1900000000001b4d52",
      "text": "\t元の文脈",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1781857306,
      "updated": 1781857315
    },
    {
      "id": "6a34fc2200000000001b4d53",
      "text": "\t\t[「インライン引用記法」のデザインを変更したい#6a2e651f0000000000fec977]",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1781857315,
      "updated": 1781857330
    },
    {
      "id": "6a34fc4400000000001b4d54",
      "text": "\t先行するスクリーンショットが変更前のスタイル、その後のスクリーンショットが変更後のスタイルです",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1781857349,
      "updated": 1781857391
    },
    {
      "id": "6a34fbf200000000001b4d4f",
      "text": "\t\t[https://gyazo.com/54cacc036f51bf23cfaa0d88eb186b78][https://gyazo.com/3c109659eae44ab3c2b8cf040ef9432b]",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1781857267,
      "updated": 1781857268
    },
    {
      "id": "6a34fbec00000000001b4d4e",
      "text": "\t\t[https://gyazo.com/b8114747f574f34bcd915e10dd4017cc][https://gyazo.com/7bbe5c107998dc6a4a2e254cb1dae3c0]",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1781857260,
      "updated": 1781857286
    },
    {
      "id": "6a34fbf500000000001b4d50",
      "text": "\t[https://gyazo.com/081ce04ef01eefb5f247e737e02fb32c][https://gyazo.com/5fa8d521e10c2a9f92f5fb638072b031]",
      "userId": "5ffbd8b8512f4e001cae68fd",
