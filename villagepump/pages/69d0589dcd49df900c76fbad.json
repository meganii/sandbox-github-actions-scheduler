  "lines": [
    {
      "id": "69d0589dcd49df900c76fbad",
      "text": "ローマ数字の一覧",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775261859,
      "updated": 1775261859
    },
    {
      "id": "69d2571f0000000000ef3f27",
      "text": "[ローマ数字]の一覧",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775392543,
      "updated": 1775392546
    },
    {
      "id": "69d058a30000000000c0af9a",
      "text": "体系的に説明するよりも実物を見るほうが分かりやすい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775261859,
      "updated": 1775261884
    },
    {
      "id": "69d058bc0000000000c0af9c",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775261885,
      "updated": 1775261885
    },
    {
      "id": "69d253750000000000ef3f1c",
      "text": "https://ja.wikipedia.org/wiki/ローマ数字",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391606,
      "updated": 1775391606
    },
    {
      "id": "69d256f40000000000ef3f25",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775392500,
      "updated": 1775392500
    },
    {
      "id": "69d252cc0000000000ef3f11",
      "text": "各文字の値",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391437,
      "updated": 1775391444
    },
    {
      "id": "69d252d30000000000ef3f14",
      "text": "\ttable:roman_value",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391444,
      "updated": 1775391456
    },
    {
      "id": "69d252e00000000000ef3f17",
      "text": "\t I\tV\tX\tL\tC\tD\tM",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391456,
      "updated": 1775391483
    },
    {
      "id": "69d252e20000000000ef3f18",
      "text": "\t 1\t5\t10\t50\t100\t500\t1000",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391459,
      "updated": 1775391485
    },
    {
      "id": "69d2534e0000000000ef3f1b",
      "text": " 1 から 3999 の値が表現できる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391567,
      "updated": 1775391567
    },
    {
      "id": "69d252cd0000000000ef3f12",
      "text": " 4000以上の大きな数字",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391437,
      "updated": 1775391603
    },
    {
      "id": "69d253790000000000ef3f1e",
      "text": " 重ね表記",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391610,
      "updated": 1775391648
    },
    {
      "id": "69d2539f0000000000ef3f1f",
      "text": "  1000 を表すのに「M」ではなく「ↀ」または「CIↃ」を用いる場合もある。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391648,
      "updated": 1775391654
    },
    {
      "id": "69d253a50000000000ef3f20",
      "text": "  5000 を「ↁ」または「IↃↃ」、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391654,
      "updated": 1775391833
    },
    {
      "id": "69d254590000000000ef3f22",
      "text": "  10000 を「ↂ」または「CCIↃↃ」で表した例もある。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391833,
      "updated": 1775391833
    },
    {
      "id": "69d253a90000000000ef3f21",
      "text": "  同様にして 50000 は「ↇ」または「IↃↃↃ」、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391657,
      "updated": 1775391838
    },
    {
      "id": "69d2545d0000000000ef3f23",
      "text": "  100000 は「ↈ」または「CCCIↃↃↃ」となる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391838,
      "updated": 1775391838
    },
    {
      "id": "69d2534b0000000000ef3f19",
      "text": "\t例えば、388888 は ↈↈↈↇↂↂↂↁↀↀↀDCCCLXXXVIII になる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775391564,
      "updated": 1775392298
    },
    {
      "id": "69d2562d0000000000ef3f24",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775392302,
      "updated": 1775392302
    },
    {
