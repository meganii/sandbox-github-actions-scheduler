    {
      "id": "69f5ff1956f147cfa7197796",
      "text": "デジタルガーデンは手入れが重要",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729308,
      "updated": 1777729308
    },
    {
      "id": "69f5ff50000000000069e3a7",
      "text": "デジタルガーデンは手入れが重要",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729360,
      "updated": 1777729361
    },
    {
      "id": "69f5ff51000000000069e3a8",
      "text": "デジタル情報を庭の管理の様に手入れ（修正や見直し）をすることで、いつまでも使える情報資産にしましょう",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729361,
      "updated": 1777729361
    },
    {
      "id": "69f5ff51000000000069e3a9",
      "text": "わざわざ他人に見せびらかすというよりは、常に手入れして自己満足するようなもの",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729361,
      "updated": 1777729361
    },
    {
      "id": "69f5ff51000000000069e3aa",
      "text": "[良質なアウトプットを生み出すための土壌]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729361,
      "updated": 1777729653
    },
    {
      "id": "69f79fa80000000000cf67af",
      "text": "[デジタルガーデンは永遠に未完成]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777835944,
      "updated": 1777835949
    },
    {
      "id": "69f5ff51000000000069e3ab",
      "text": "庭の手入れ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729361,
      "updated": 1777729375
    },
    {
      "id": "6a229665000000000050219d",
      "text": "[土づくり]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780651621,
      "updated": 1780651635
    },
    {
      "id": "69f5ff51000000000069e3ac",
      "text": "[メンテナンス]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729361,
      "updated": 1777729371
    },
    {
      "id": "69f5ff51000000000069e3ad",
      "text": "[自動化ツール]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729361,
      "updated": 1777729367
    },
    {
      "id": "69f5ff51000000000069e3ae",
      "text": "[キュレーション]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777729361,
      "updated": 1777729364
    },
