    {
      "id": "69f443170000000000ec98c6",
      "text": "from [2026/04/30]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98c7",
      "text": "[高田馬場]で適当に買った[バインミー]がおいしすぎる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98c8",
      "text": " [バインミー⭐︎サンドイッチ]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98c9",
      "text": "  冗談みたいな店名だ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98ca",
      "text": "  有名店だったのか",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98cb",
      "text": "  中身入りすぎててあごはずれるかと思った",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98cc",
      "text": " おやご近所にいらしている[terang.icon*2]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98cd",
      "text": "  ご近所だ！[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98ce",
      "text": "  この辺りよく通るのでいつか[terang.icon]さんの本屋に立ち寄らせていただきたく思っている",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98cf",
      "text": "  ぜひぜひ✨ オープン時間[google map https://maps.app.goo.gl/xALCHP6cA7BGpRaS9]ご覧くださいませ[terang.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98d0",
      "text": "   感謝！[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
    },
    {
      "id": "69f443170000000000ec98d1",
      "text": " 池袋、早稲田、高田馬場、新大久保あたりは[エスニック料理]のレベルがめっちゃ高い",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777615639,
      "updated": 1777615639
