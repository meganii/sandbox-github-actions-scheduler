{
  "id": "69c3466450d7da17377529ea",
  "title": "日本国旗",
  "created": 1774405245,
  "updated": 1775981396,
  "lines": [
    {
      "id": "69c3466450d7da17377529ea",
      "text": "日本国旗",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774405245,
      "updated": 1774405245
    },
    {
      "id": "69db530c000000000051e7a0",
      "text": "[https://gyazo.com/5c1051f518f9eb9d9a44b00951d29401]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a1",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a2",
      "text": "大日本帝国と日本国の境と国旗の境目が異なる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a3",
      "text": "\t[大日本帝国旗.icon]とこの国旗は同じ。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a5",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a6",
      "text": "[- 日本国旗(1999-)と色が少し異なる]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a7",
      "text": "\t[https://scrapbox.io/files/69c3467b9ea0767ac852d7d3.webp]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981387
    },
    {
      "id": "69db530c000000000051e7a8",
      "text": "\tしらんかった！[はるひ.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7a9",
      "text": "\t[知らなかった]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7aa",
      "text": "\tごめん、嘘かもしれん[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7ab",
      "text": "\t\t嘘でした。ごめん。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7ac",
      "text": "\t\t色規程は厳密になされていない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7ad",
      "text": "\t\t\t「紅色」という明示はある。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7ae",
      "text": "\t\t\tそもそも色を厳密に定めるのは難しい。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7af",
      "text": "\t\t\t\t使用生地、染料、染め方の違いで発色が変わる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    },
    {
      "id": "69db530c000000000051e7b0",
      "text": " 何も違わないのでページを統合。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981396
    },
    {
      "id": "69db530c000000000051e7b1",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775981324,
      "updated": 1775981324
    }
  ]
}