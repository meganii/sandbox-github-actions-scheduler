    {
      "id": "69da1cce0000000000b4579b",
      "text": "        margin-bottom: 6px;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4579c",
      "text": "        display: -webkit-box;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4579d",
      "text": "        -webkit-line-clamp: 2;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4579e",
      "text": "        -webkit-box-orient: vertical;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4579f",
      "text": "        overflow: hidden;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a0",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a1",
      "text": "      #hover-card .hc-desc {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a2",
      "text": "        font-size: 12px;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a3",
      "text": "        line-height: 1.5;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a4",
      "text": "        color: #666;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a5",
      "text": "        display: -webkit-box;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a6",
      "text": "        -webkit-line-clamp: 3;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a7",
      "text": "        -webkit-box-orient: vertical;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a8",
      "text": "        overflow: hidden;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457a9",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457aa",
      "text": "    `;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ab",
      "text": "    document.head.appendChild(style);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ac",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ad",
      "text": "    async function fetchPage(title) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ae",
      "text": "      if (CACHE.has(title)) return CACHE.get(title);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457af",
      "text": "      try {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b0",
      "text": "        const res = await fetch(`/api/pages/${PROJECT}/${encodeURIComponent(title)}`);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b1",
      "text": "        if (!res.ok) return null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b2",
      "text": "        const data = await res.json();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b3",
      "text": "        CACHE.set(title, data);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b4",
      "text": "        return data;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b5",
      "text": "      } catch {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b6",
      "text": "        return null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b7",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b8",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457b9",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ba",
      "text": "    function extractImage(page) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457bb",
      "text": "      if (page.image) return page.image;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457bc",
      "text": "      for (const line of (page.descriptions || [])) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457bd",
      "text": "        const m = line.match(/https?:\\/\\/[^\\s\\]]+\\.(?:png|jpe?g|gif|webp|svg)/i);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457be",
      "text": "        if (m) return m[0];",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457bf",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c0",
      "text": "      for (const l of (page.lines || []).slice(0, 10)) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c1",
      "text": "        const m = l.text?.match(/https?:\\/\\/[^\\s\\]]+\\.(?:png|jpe?g|gif|webp|svg)/i);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c2",
      "text": "        if (m) return m[0];",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c3",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c4",
      "text": "      return null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c5",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c6",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c7",
      "text": "    function show(link, data) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c8",
      "text": "      if (!card) card = createCard();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457c9",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ca",
      "text": "      const imgEl = card.querySelector('.hc-image');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457cb",
      "text": "      const titleEl = card.querySelector('.hc-title');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457cc",
      "text": "      const descEl = card.querySelector('.hc-desc');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457cd",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ce",
      "text": "      titleEl.textContent = data.title || '';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457cf",
      "text": "      descEl.textContent = (data.descriptions || []).join(' ').slice(0, 200);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d0",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d1",
      "text": "      const imgUrl = extractImage(data);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d2",
      "text": "      imgEl.innerHTML = '';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d3",
      "text": "      if (imgUrl) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d4",
      "text": "        imgEl.classList.add('has-img');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d5",
      "text": "        const img = document.createElement('img');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d6",
      "text": "        img.src = imgUrl;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d7",
      "text": "        img.loading = 'lazy';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d8",
      "text": "        imgEl.appendChild(img);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457d9",
      "text": "      } else {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457da",
      "text": "        imgEl.classList.remove('has-img');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457db",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457dc",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457dd",
      "text": "      const rect = link.getBoundingClientRect();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457de",
      "text": "      let top = rect.bottom + 8;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457df",
      "text": "      let left = rect.left;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e0",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e1",
      "text": "      if (left + 270 > window.innerWidth) left = window.innerWidth - 275;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e2",
      "text": "      if (left < 5) left = 5;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e3",
      "text": "      if (top + 280 > window.innerHeight) top = rect.top - 280;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e4",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e5",
      "text": "      card.style.top = top + 'px';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e6",
      "text": "      card.style.left = left + 'px';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e7",
      "text": "      card.classList.add('visible');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e8",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457e9",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ea",
      "text": "    function hide() {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457eb",
      "text": "      if (card) card.classList.remove('visible');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ec",
      "text": "      currentLink = null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ed",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ee",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ef",
      "text": "    function scheduleHide() {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f0",
      "text": "      clearTimeout(hideTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f1",
      "text": "      hideTimer = setTimeout(hide, 250);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f2",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f3",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f4",
      "text": "    // リンクに直接 mouseenter/mouseleave を付与",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f5",
      "text": "    const attachedLinks = new WeakSet();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f6",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f7",
      "text": "    function attachLink(link) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f8",
      "text": "      if (attachedLinks.has(link)) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457f9",
      "text": "      attachedLinks.add(link);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457fa",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457fb",
      "text": "      link.addEventListener('mouseenter', () => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457fc",
      "text": "        clearTimeout(hideTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457fd",
      "text": "        clearTimeout(showTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457fe",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b457ff",
      "text": "        if (link === currentLink && card && card.classList.contains('visible')) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45800",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45801",
      "text": "        currentLink = link;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45802",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45803",
      "text": "        showTimer = setTimeout(async () => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45804",
      "text": "          const title = link.getAttribute('data-page-title');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45805",
      "text": "          if (!title) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45806",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45807",
      "text": "          const data = await fetchPage(title);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45808",
      "text": "          if (!data || currentLink !== link) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45809",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4580a",
      "text": "          show(link, data);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4580b",
      "text": "        }, 300);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4580c",
      "text": "      });",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4580d",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4580e",
      "text": "      link.addEventListener('mouseleave', (e) => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4580f",
      "text": "        clearTimeout(showTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45810",
      "text": "        const related = e.relatedTarget;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45811",
      "text": "        if (card && (card === related || card.contains(related))) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45812",
      "text": "        scheduleHide();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45813",
      "text": "      });",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45814",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45815",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45816",
      "text": "    function scanLinks() {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45817",
      "text": "      document.querySelectorAll('a.page-link').forEach(attachLink);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45818",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45819",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4581a",
      "text": "    scanLinks();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4581b",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4581c",
      "text": "    const observer = new MutationObserver(() => scanLinks());",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4581d",
      "text": "    observer.observe(document.body, { childList: true, subtree: true });",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4581e",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b4581f",
      "text": "    document.addEventListener('scroll', () => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45820",
      "text": "      clearTimeout(showTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45821",
      "text": "      hide();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45822",
      "text": "    }, true);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cce0000000000b45823",
      "text": "  })();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901902,
      "updated": 1775901902
    },
    {
      "id": "69da1cc80000000000b45750",
      "text": "",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901896,
      "updated": 1775901896
    }
  ]
}