{
  "id": "69ca138374f2432d679beffa",
  "title": "2つの読み方がある熟語",
  "created": 1774850950,
  "updated": 1774934951,
  "lines": [
    {
      "id": "69ca138374f2432d679beffa",
      "text": "2つの読み方がある熟語",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774850950,
      "updated": 1774850950
    },
    {
      "id": "69ca13850000000000b769b6",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774850950,
      "updated": 1774850950
    },
    {
      "id": "69ca13850000000000b769b7",
      "text": " 細々（こまごま、ほそぼそ）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774850950,
      "updated": 1774850962
    },
    {
      "id": "69ca13910000000000b769b9",
      "text": " 大分（おおいた、だいぶ）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774850962,
      "updated": 1774850969
    },
    {
      "id": "69ca13980000000000b769ba",
      "text": " 何人（なんにん、なにじん）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774850969,
      "updated": 1774853366
    },
    {
      "id": "69ca24fd00000000006a34a8",
      "text": " 大麻（たいま、おおあさ）",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774855421,
      "updated": 1774855428
    },
    {
      "id": "69ca268b00000000006c2011",
      "text": " 人工（じんこう、にんく）",
      "userId": "65e1289acd012200235729c0",
      "created": 1774855820,
      "updated": 1774855824
    },
    {
      "id": "69ca13860000000000b769b8",
      "text": "　人気（にんき、ひとけ）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774850951,
      "updated": 1774860321
    },
    {
      "id": "69ca389d00000000007e2d05",
      "text": "　牧場（ぼくじょう、まきば）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774860445,
      "updated": 1774860450
    },
    {
      "id": "69ca38a200000000007e2d06",
      "text": "　市場（しじょう、いちば）",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774860450,
      "updated": 1774860458
    },
    {
      "id": "69ca43c00000000000df9edd",
      "text": "　化学（かがく、ばけがく）",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774863296,
      "updated": 1774863302
    },
    {
      "id": "69ca43cc0000000000df9ede",
      "text": "　塩味（えんみ、しおあじ）",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774863308,
      "updated": 1774863353
    },
    {
      "id": "69ca45480000000000df9ee1",
      "text": "　雨水（うすい、あまみず）",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774863689,
      "updated": 1774863694
    },
    {
      "id": "69ca4cc80000000000859c87",
      "text": "　漏斗 (ろうと、じょうご)",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1774865613,
      "updated": 1774865620
    },
    {
      "id": "69ca2d090000000000961bb3",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1774857481,
      "updated": 1774857481
    },
    {
      "id": "69ca446a0000000000df9edf",
      "text": "数字系",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774863466,
      "updated": 1774863468
    },
    {
      "id": "69ca446c0000000000df9ee0",
      "text": "\t一日（いちにち、ついたち、いっぴ）",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774863468,
      "updated": 1774863481
    },
    {
      "id": "69ca3da1000000000086ba9b",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1774861730,
      "updated": 1774861730
    },
    {
      "id": "69ca48b10000000000d5d332",
      "text": "[説明読み]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1774864562,
      "updated": 1774864563
    },
    {
      "id": "69ca48b70000000000d5d334",
      "text": "[慣用読み]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1774864567,
      "updated": 1774864567
    },
    {
