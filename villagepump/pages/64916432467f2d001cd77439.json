    {
      "id": "64916432467f2d001cd77439",
      "text": "ことわざ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1687249971,
      "updated": 1687249971
    },
    {
      "id": "64916433b8bbfc000008ebe8",
      "text": "from [海外のことわざ]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1687249988,
      "updated": 1687249988
    },
    {
      "id": "64916433b8bbfc000008ebea",
      "text": "「ことわざ」の意味がよくわかってない[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1687249971,
      "updated": 1687249997
    },
    {
      "id": "64916433b8bbfc000008ebeb",
      "text": "look for a needle in a haystackをsayingだと思えなかった",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1687249971,
      "updated": 1776583893
    },
    {
      "id": "64916433b8bbfc000008ebec",
      "text": "\t「石橋を叩いて渡る」はことわざだが、別に知恵でも何でも無い気がする、ただ行為を示しているのみ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1687249971,
      "updated": 1687249971
    },
    {
      "id": "64916433b8bbfc000008ebed",
      "text": "\t\t[酒は飲むべし]を思い出した",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1687249971,
      "updated": 1687249971
    },
    {
      "id": "649164e46eb4060000f4f1ec",
      "text": "\t故事成語というのもあるな[inajob.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1687250149,
      "updated": 1776585323
    },
    {
      "id": "64916433b8bbfc000008ebee",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1687249971,
      "updated": 1687249971
    },
    {
      "id": "64916450b8bbfc000008ebef",
      "text": "[諺]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1687250001,
      "updated": 1687250004
    },
    {
      "id": "64916452b8bbfc000008ebf0",
