  "lines": [
    {
      "id": "6a0fafbc3e53ae33757cc5e2",
      "text": "空気でグルメする",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779412927,
      "updated": 1779413281
    },
    {
      "id": "6a0faff800000000003ae63e",
      "text": " 空気が美味しい、空気は美味しい",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779412985,
      "updated": 1779412996
    },
    {
      "id": "6a0fb04f00000000003ae646",
      "text": " 山奥の仙人は霞を食べて生きているのだし空気には栄養がありそう",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779413072,
      "updated": 1779413171
    },
    {
      "id": "6a0fb04900000000003ae645",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779413066,
      "updated": 1779413066
    },
    {
      "id": "6a0fafe500000000003ae63d",
      "text": "from [2026/04/18#69e2a9730000000000b57706]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779412966,
      "updated": 1779412968
    },
    {
      "id": "6a0fafbf00000000003ae638",
      "text": "> 朝の空気が冷たくて美味しかった [vlzs.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779412927,
      "updated": 1779413040
    },
    {
      "id": "6a0fafc000000000003ae63b",
      "text": ">  しばらく散歩はこの時間にしよ",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779412928,
      "updated": 1779413041
    },
    {
      "id": "6a0fafc000000000003ae63c",
      "text": ">  おいしそう[takker.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779412928,
      "updated": 1779413041
    },
    {
      "id": "6a0fafbf00000000003ae639",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779412928,
      "updated": 1779412928
    },
    {
      "id": "6a0fb01500000000003ae63f",
      "text": "from [2026/05/22#6a0fa0cb0000000000311636]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779413013,
      "updated": 1779413029
    },
    {
      "id": "6a0fb01500000000003ae640",
      "text": "> 窓を開けたら今日の空気は柏餅みたいな香りだった [vlzs.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779413013,
      "updated": 1779413062
    },
    {
      "id": "6a0fb03f00000000003ae642",
      "text": ">  むしゃむしゃ",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779413055,
      "updated": 1779413057
    },
    {
      "id": "6a0fb03f00000000003ae643",
      "text": ">  [空気でグルメする]",
      "userId": "63042e42f2ab90001d68385a",
