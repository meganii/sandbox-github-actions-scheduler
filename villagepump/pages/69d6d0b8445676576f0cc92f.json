  "lines": [
    {
      "id": "69d6d0b8445676576f0cc92f",
      "text": "人類の進化",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775685817
    },
    {
      "id": "69d6d0b8000000000044a213",
      "text": "from [文明史]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775685817
    },
    {
      "id": "69d6d0b8000000000044a214",
      "text": "人類の進化",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775685817
    },
    {
      "id": "69d6d0b8000000000044a215",
      "text": "`[hum]`[https://ja.wikipedia.org/wiki/人類の進化 人類の進化]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775685817
    },
    {
      "id": "69d6d1e6000000000044a23c",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775686119,
      "updated": 1775686119
    },
    {
      "id": "69d6d0b8000000000044a216",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686133
    },
    {
      "id": "69d6d0b8000000000044a217",
      "text": "> [https://gyazo.com/df112be8fd5f8ca0eacee7c9fa598837]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686137
    },
    {
      "id": "69d6d0b8000000000044a218",
      "text": "> [https://ja.wikipedia.org/wiki/人類の進化 人類の進化]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686139
    },
    {
      "id": "69d6d1fc000000000044a23d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775686140,
      "updated": 1775686140
    },
    {
      "id": "69d6d0b8000000000044a219",
      "text": "[ヒト]亜族と[チンパンジー]亜族の分岐（猿人の登場）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686140
    },
    {
      "id": "69d6d0b8000000000044a21a",
      "text": "\t約700万年前にヒト亜族とチンパンジー亜族に分岐と推定。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a21b",
      "text": "\tDNA変異時間に基づき推定、800-700万年前の分岐可能性が高いとの論文が発表された。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a21c",
      "text": "\t最初期のものは[サヘラントロプス・チャデンシス]（700-600万年前）。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a21d",
      "text": "\t他のヒト科は赤道の外縁あたりで、[アンテロープ]、[ハイエナ]、[ウマ]、[ゾウ]たちと共に、より乾燥した環境に適応した可能性。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d200000000000044a23e",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775686144,
      "updated": 1775686144
    },
    {
      "id": "69d6d0b8000000000044a21e",
      "text": "[アウストラロピテクス]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686144
    },
    {
      "id": "69d6d0b8000000000044a21f",
      "text": " [アフリカ]で生まれた初期の人類で、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a220",
      "text": " 約400万 - 約200万年前に生存、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a221",
      "text": " 約440万 - 約390万年前、[アウストラロピテクス・アナメンシス]が現れ、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a222",
      "text": " 約390万 - 約300万年前、[アウストラロピテクス・アファレンシス]が現れ、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a223",
      "text": " 約330万 - 約240万年前、[アウストラロピテクス・アフリカヌス]に進化。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a224",
      "text": "  この属から[パラントロプス]と、ホモ（ヒト属）最初の種[ホモ・ハビリス]に進化したと考えられる。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d202000000000044a23f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775686147,
      "updated": 1775686147
    },
    {
      "id": "69d6d0b8000000000044a225",
      "text": "[原人]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686147
    },
    {
      "id": "69d6d0b8000000000044a226",
      "text": "\t[ホモ・ハビリス]：240万から140万年前にかけて生存",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a227",
      "text": "\t\t[https://ja.wikipedia.org/wiki/ホモ・ハビリス ホモ・ハビリス]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a228",
      "text": " [ホモ・ルドルフエンシス]：約190万年から約160万年前（[タンザニア]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a229",
      "text": " [ホモ・ゲオルギクス]：約190万年から約160万年前（[ジョージア]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a22a",
      "text": "\t[ホモ・エルガステル]：180万から125万年前（[インドネシア]・[ジャワ島]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a22b",
      "text": "\t[ホモ・エレクトゥス]：約180万年前から約7万年前（[ジャワ島]、[北京]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a22c",
      "text": " [ホモ・アンテセッサー]：約120万年前から約50万年前（[スペイン]・[イングランド]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a22d",
      "text": " [ホモ・ケプラネンシス]：約80万年前のものと推測（[イタリア半島]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a22e",
      "text": " [ホモ・ハイデルベルゲンシス]：約80万年から約30万年前（[ドイツ]・[ハイデルベルク]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a22f",
      "text": "  [https://ja.wikipedia.org/wiki/ホモ・ハイデルベルゲンシス ホモ・ハイデルベルゲンシス]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a230",
      "text": " [ホモ・フローレシエンシス]：約19万年から約5万年前（[インドネシア]・[フローレス島]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686153
    },
    {
      "id": "69d6d20a000000000044a241",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775686154,
      "updated": 1775686154
    },
    {
      "id": "69d6d0b8000000000044a231",
      "text": "旧人",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686154
    },
    {
      "id": "69d6d0b8000000000044a232",
      "text": " [ホモ・ヘルメイ]：約26万年前 (259±35 ka) （[南アフリカ]・[フロリスバッド]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a233",
      "text": " [ホモ・ローデシエンシス]：約30万年前から約12.5万年前（[南アフリカ]、[東アフリカ]、[北アフリカ]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a234",
      "text": " [ホモ・ネアンデルターレンシス]： 約40万年前から2万数千年前（[ドイツ]・[ネアンデル]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d20c000000000044a242",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775686157,
      "updated": 1775686157
    },
    {
      "id": "69d6d0b8000000000044a235",
      "text": "新人",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686157
    },
    {
      "id": "69d6d0b8000000000044a236",
      "text": " [ホモ・サピエンス・イダルトゥ]：16万年前頃（[エチオピア]）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a237",
      "text": " \t[ネグロイド]の祖先か。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a238",
      "text": " \t[モンゴロイド]と[コーカソイド]は[ネアンデルターレンシス]との混血か。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a239",
      "text": " [ホモ・サピエンス・サピエンス]： 66万年～47万年前～現代",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775686110
    },
    {
      "id": "69d6d0b8000000000044a23a",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775685817,
      "updated": 1775685817
    },
