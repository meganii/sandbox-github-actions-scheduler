    {
      "id": "69cd11dc000000000076105d",
      "text": "ある日、午前中に雪が降り始めた。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047133,
      "updated": 1775047190
    },
    {
      "id": "69cd12150000000000761068",
      "text": "雪はつねに一定のペースで降る。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047190,
      "updated": 1775047190
    },
    {
      "id": "69cd12130000000000761067",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047188,
      "updated": 1775047188
    },
    {
      "id": "69cd11de0000000000761060",
      "text": "除雪車が正午（AM12時）ぴったりに動き出し、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047134,
      "updated": 1775047193
    },
    {
      "id": "69cd12190000000000761069",
      "text": "1時間で2kmの除雪を完了し、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047193,
      "updated": 1775047196
    },
    {
      "id": "69cd121c000000000076106a",
      "text": "さらに1時間で1kmの除雪を完了した。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047196,
      "updated": 1775047196
    },
    {
      "id": "69cd11de0000000000761061",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047134,
      "updated": 1775047134
    },
    {
      "id": "69cd11de0000000000761062",
      "text": "雪はいつ降り始めたか？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047134,
      "updated": 1775047172
    },
    {
      "id": "69cd11ef0000000000761063",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775047151,
      "updated": 1775047151
