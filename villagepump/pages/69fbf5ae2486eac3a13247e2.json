      "updated": 1778120114
    },
    {
      "id": "69fbf5ae00000000007538a6",
      "text": "[seibe.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538a7",
      "text": " [対機説法]はもっと知られても良いのかも",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538a8",
      "text": "  相手によって説き方を変える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538a9",
      "text": "  相手によってアドバイスの仕方を変える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538aa",
      "text": "   理屈で分かる人なら、理屈で",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538ab",
      "text": "   気持ちで分かる人なら、気持ちで",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538ac",
      "text": "   実践で分かる人なら、実践で",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538ad",
      "text": "   その余裕がない人には、まず余裕を",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
      "id": "69fbf5ae00000000007538ae",
      "text": "  私もそんなできとらんかった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778120111,
      "updated": 1778120111
    },
    {
