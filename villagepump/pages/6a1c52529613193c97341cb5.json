      "text": "[nomadoor.icon]",
      "userId": "5f0ae250e8cd56001ee2dacc",
      "created": 1780312395,
      "updated": 1780312396
    },
    {
      "id": "6a1d68f2000000000054aa4c",
      "text": " [二万円かけたモデルが完成]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780312396,
      "updated": 1780672360
    },
    {
