      "created": 1780312102,
      "updated": 1780312102
    },
    {
      "id": "6a1d68260000000000d9f496",
      "text": "[zatsma.icon]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1780312102,
      "updated": 1780312104
    },
    {
      "id": "6a1d68360000000000d9f498",
      "text": " スマホを忘れた1日だった",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1780312118,
      "updated": 1780312129
    },
    {
      "id": "6a1d6f3f0000000000eca2e8",
      "text": "  実質的に[デライトデトックス]となった",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1780313920,
      "updated": 1780314443
    },
    {
      "id": "6a1d3a8b00000000003afd69",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1780300428,
      "updated": 1780300428
    },
    {
