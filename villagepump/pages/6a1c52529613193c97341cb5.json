    },
    {
      "id": "6a1c52536eb406000000bbd54d",
      "text": "[nishio.icon]テッティタトタイテタイトオトイタス！",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780240980,
      "updated": 1780241969
    },
    {
      "id": "6a1c5e0e000000000029b16e",
      "text": "[caki.icon]ログ）シマス！",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780243982,
      "updated": 1780243992
    },
    {
      "id": "6a1cb2ff00000000008e4773",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780265715,
      "updated": 1780265715
    },
    {
      "id": "6a1cb2ff00000000008e4774",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780265715,
      "updated": 1780265716
    },
    {
      "id": "6a1cdb010000000000ceb015",
      "text": "　ストレッチした",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780275956,
      "updated": 1780275959
    },
    {
      "id": "6a1cdb030000000000ceb016",
      "text": "　歩行練習",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780275959,
      "updated": 1780275962
    },
    {
      "id": "6a1cb30000000000008e4775",
      "text": " 英語の課題をあと数十分で片付けるのに、全部LLMに丸投げしないいい方法を思いついてやってみていることを書こうとしたら誰だこれ！？",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780265716,
      "updated": 1780265752
    },
    {
      "id": "6a1cdafc0000000000ceb013",
      "text": " あさごはんたべた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780275951,
      "updated": 1780275954
    },
    {
      "id": "6a1cdaff0000000000ceb014",
      "text": " お風呂入った",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780275954,
      "updated": 1780275965
    },
    {
      "id": "6a1cdb090000000000ceb017",
      "text": " 　まだ[車椅子でお風呂]している",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780275965,
      "updated": 1780275972
    },
    {
      "id": "6a1cdb110000000000ceb018",
      "text": " 　そろそろ[歩行浴]になりそう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780275972,
      "updated": 1780275983
    },
    {
      "id": "6a1cdb1d0000000000ceb019",
      "text": " 　一人で入れるんだけどな……まあいいや",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780275984,
      "updated": 1780275994
    },
    {
      "id": "6a1cdb600000000000ceb01b",
      "text": " 　しかし入浴に1時間もとらんでもいいのに",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780276052,
      "updated": 1780276069
    },
    {
      "id": "6a1cdb520000000000ceb01a",
      "text": " 今日までの課題はなんとかなった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780276038,
      "updated": 1780276044
    },
    {
      "id": "6a1d1fda00000000009b8953",
      "text": "  すばらしい[kana.icon]",
      "userId": "5e9487d750011b001eb536eb",
      "created": 1780293598,
      "updated": 1780293607
    },
    {
      "id": "6a1d3f0d000000000030322c",
      "text": " リハビリした",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780301568,
      "updated": 1780301573
    },
    {
      "id": "6a1d3f12000000000030322d",
      "text": " ひるごはんたべた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780301573,
      "updated": 1780301583
    },
    {
      "id": "6a1d3f17000000000030322e",
      "text": " リハビリした",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780301577,
      "updated": 1780301580
    },
    {
      "id": "6a1d39cc000000000030320b",
      "text": " 今日の英語の講義なんとかなった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780300222,
      "updated": 1780300236
    },
    {
      "id": "6a1d39d9000000000030320c",
      "text": " 　次は明日12:00締切のレポートだ～",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780300236,
      "updated": 1780300245
    },
    {
      "id": "6a1d457100000000008d4a1f",
      "text": " 　わーい[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780303218,
      "updated": 1780303221
    },
    {
      "id": "6a1d46da0000000000ff1b9e",
      "text": " [/motoso/2026-06-01#6a1d21790000000000e7e08f][/motoso/予備試験の出願が書類不備で帰ってきた]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780303564,
      "updated": 1780309190
    },
    {
      "id": "6a1d46d50000000000ff1b9c",
      "text": "  よかった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780303559,
      "updated": 1780303565
    },
    {
      "id": "6a1d5c8e0000000000ebbcda",
      "text": "  [切り出しと行リンクの相性の悪さ]w[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1780309135,
      "updated": 1780309146
    },
    {
      "id": "6a1d54cb00000000009a06a3",
      "text": "  直した～[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780307148,
      "updated": 1780309207
    },
    {
      "id": "6a1d5d2600000000008aca14",
      "text": "  内容怖ェ[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780309286,
      "updated": 1780309316
    },
    {
      "id": "6a1d5cc9000000000060b9da",
      "text": " 今日はもうゆっくりしようと思ったが、明日09:00～10:00がリハビリで、11:00～12:00が研究室のmeetingだから、明日課題に使える時間1時間しかないじゃん！",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780309194,
      "updated": 1780309194
    },
    {
      "id": "6a1d550c00000000009a06a4",
      "text": "  今日中に講義の概要だけでも把握して、サマリーの方向性決めとかないと",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780307213,
      "updated": 1780307233
    },
    {
      "id": "6a1d5ce3000000000060b9db",
      "text": "  とりあえずnotebookLMのクイズを一周解いた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780309221,
      "updated": 1780309261
    },
    {
      "id": "6a1c56300000000000f85e3e",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780241969,
      "updated": 1780241969
    },
    {
      "id": "6a1cc30c000000000088d573",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1780269836,
      "updated": 1780269838
    },
    {
      "id": "6a1cc30d000000000088d574",
      "text": "\tおはようございます",
      "userId": "65e1289acd012200235729c0",
      "created": 1780269838,
      "updated": 1780269845
    },
    {
      "id": "6a1cc315000000000088d575",
      "text": "\t何か書こうと思って来たら[美少女が増殖]していてそれどころではなくなっていた",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780269845,
      "updated": 1780672251
    },
    {
      "id": "6a1cc482000000000088d576",
      "text": " \t[takker.icon]さんのアイコン見て思い出した。お山のニュースを見たんだった",
      "userId": "65e1289acd012200235729c0",
      "created": 1780270211,
      "updated": 1780270243
    },
    {
      "id": "6a1cca63000000000088a791",
      "text": " \t [takker.icon]をみて思い出すの草[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780271702,
      "updated": 1780271708
    },
    {
      "id": "6a1cc49e000000000088d577",
      "text": "\t\t[https://www.yomiuri.co.jp/national/20260531-GYT1T00220/ 富士山の閉山期に年間１万人が登山、通行禁止でも歯止めかからず…読売新聞など推計 : 読売新聞]",
      "userId": "65e1289acd012200235729c0",
      "created": 1780270239,
      "updated": 1780270251
    },
    {
      "id": "6a1cc4ab000000000088d578",
      "text": "  富士山が人気なのは分かるが、入るなと設定されていて入るのはアカン",
      "userId": "65e1289acd012200235729c0",
      "created": 1780270251,
      "updated": 1780270273
    },
    {
      "id": "6a1cc4d0000000000088d579",
      "text": "  加えて外国人はカウントしていないらしいので、もっと多いと見ると本当に人気スポットなんだなと認識",
      "userId": "65e1289acd012200235729c0",
      "created": 1780270289,
      "updated": 1780270324
    },
    {
      "id": "6a1cc5a0000000000088d57a",
      "text": "  富士山の閉山中登山は何の規則に反するのか気になり調べるが、立ち入り禁止一般に適用される軽犯罪なのかな、信じられそうなページがイマイチ出てこない",
      "userId": "65e1289acd012200235729c0",
      "created": 1780270497,
      "updated": 1780270552
    },
    {
      "id": "6a1cc5d8000000000088d57b",
      "text": "  [https://www.nikkansports.com/entertainment/news/202505230000243.html 野口健氏「不法侵入で犯罪となる」富士山閉山期の救助問題 ８合目以上の所有者からめ対策案 - 芸能 : 日刊スポーツ]",
      "userId": "65e1289acd012200235729c0",
      "created": 1780270552,
      "updated": 1780270586
    },
    {
      "id": "6a1cc5f9000000000088d57c",
      "text": "  もっと規制を強くするべきという話は出ているのか",
      "userId": "65e1289acd012200235729c0",
      "created": 1780270586,
      "updated": 1780270624
    },
    {
      "id": "6a1cca49000000000088a78f",
      "text": "  閉山期の12月にしか富士山登ったことない[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780271677,
      "updated": 1780271694
    },
    {
      "id": "6a1cca5a000000000088a790",
      "text": "   捕まっちゃう！",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780271694,
      "updated": 1780271697
    },
    {
      "id": "6a1d088d00000000002f0036",
      "text": "   特別な許可を(ry[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780287630,
      "updated": 1780287645
    },
    {
      "id": "6a1d0e2000000000002ebeb4",
      "text": "   12月の富士山、ということで初日の出を富士山山頂で眺める人たちを連想[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1780289056,
      "updated": 1780289172
    },
    {
      "id": "6a1d0e9300000000002ebeb5",
      "text": "   \t彼らは閉山している登山道を突破した軽犯罪者達で、その実績である初日の出をアピールする姿は結構ダメな姿かもしれない",
      "userId": "65e1289acd012200235729c0",
      "created": 1780289172,
      "updated": 1780289193
    },
    {
      "id": "6a1ceabe000000000088d57e",
      "text": " [サイバーレジリエンス法]を見て思う、今年9/11から報告義務が始まるわけだけど、生成AIが当たり前になりつつある現在、脆弱性発見から24時間以内に報告ってAIからすれば「遅すぎる」とか思われそうだなと",
      "userId": "65e1289acd012200235729c0",
      "created": 1780279999,
      "updated": 1780280092
    },
    {
      "id": "6a1ceb1b000000000088d57f",
      "text": " \tこの規定は2024年に定まったらしいから、生成AIがここまで発展するとは思っていなかっただろうし仕方がない",
      "userId": "65e1289acd012200235729c0",
      "created": 1780280092,
      "updated": 1780280116
    },
    {
      "id": "6a1ceb34000000000088d580",
      "text": " \tこの対応のために生成AI利用が実質必須、人力で対応は無理な規定に改正されたとしたら、生成AIを適切に運用出来ない会社は欧州へ製品が売れないとなりそうだなとふと思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1780280116,
      "updated": 1780280657
    },
    {
      "id": "6a1ceb91000000000088d581",
      "text": " \tサイバーレジリエンス法が適用されるのは後から書き換えが可能な電子機器を搭載している製品となるため、部品製造会社は結構な割合で大丈夫だろうけど、完成品を作って売ってる会社はかなり広い範囲で影響しそう",
      "userId": "65e1289acd012200235729c0",
      "created": 1780280210,
      "updated": 1780280440
    },
    {
      "id": "6a1ced6d00000000002ebea3",
      "text": " \t自分が知らないだけで、他にも広く「人力で管理は遅すぎる」という話がたくさんありそう",
      "userId": "65e1289acd012200235729c0",
      "created": 1780280685,
      "updated": 1780280746
    },
    {
      "id": "6a1d38ed00000000002ebeb6",
      "text": " 油圧機器配置と並行した油圧配管の通し設計マジ辛い",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780300013,
      "updated": 1780672282
    },
    {
      "id": "6a1d38fd00000000002ebeb7",
      "text": " \t頭痛い理由はこれだろうと思われる",
      "userId": "65e1289acd012200235729c0",
      "created": 1780300030,
      "updated": 1780300043
    },
    {
      "id": "6a1d390a00000000002ebeb8",
      "text": " \t半日かけて全長30cmにも満たない配管１本を設計とか作業遅すぎて情けない気分",
      "userId": "65e1289acd012200235729c0",
      "created": 1780300043,
      "updated": 1780300121
    },
    {
      "id": "6a1d395800000000002ebeb9",
      "text": " \tあれこれ考えた結果、ものすごくシンプルな形に収めたのだけど、結論がシンプルな形なだけに達成感あんまり無いのも辛い要因かも",
      "userId": "65e1289acd012200235729c0",
      "created": 1780300121,
      "updated": 1780300156
    },
    {
      "id": "6a1d3c360000000000e40b83",
      "text": " \t機械設計のうち、シンプルな目的を達成させる構造物は、その構造もシンプルな形が良いとされるため、がんばって考え適した構造をこしらえたとしても、シンプルな成果物であるために「なんか簡単そう」と思われ評価されにくいかもとふと思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1780300855,
      "updated": 1780300943
    },
    {
      "id": "6a1d990d0000000000469733",
      "text": " \tコードのリファクタリングとかするとこれ思う[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1780324621,
      "updated": 1780324630
    },
    {
      "id": "6a1d71850000000000f004e1",
      "text": " クルマの運転にサングラスは大事だと実感",
      "userId": "65e1289acd012200235729c0",
      "created": 1780314504,
      "updated": 1780314523
    },
    {
      "id": "6a1d71980000000000f004e2",
      "text": " \t太陽が眩しすぎる",
      "userId": "65e1289acd012200235729c0",
      "created": 1780314523,
      "updated": 1780314529
    },
    {
      "id": "6a1da94e0000000000deb1e5",
      "text": " \t\tムルソー[imo.icon]",
      "userId": "5ad57975d54cd50014068484",
      "created": 1780328784,
      "updated": 1780328786
    },
    {
      "id": "6a1d719f0000000000f004e3",
      "text": " \t作業着着た濃い無精ひげのある坊主頭のおっさんがサングラスしてゴツイ車を運転という、絵面が酷いことになるが知らん",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1780314530,
      "updated": 1780324649
    },
    {
      "id": "6a1ccedc0000000000d65171",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780272861,
      "updated": 1780272861
    },
    {
      "id": "6a1ccedd0000000000d65172",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780272861,
      "updated": 1780272862
    },
    {
      "id": "6a1ccede0000000000d65173",
      "text": "\tいっぴ6月。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780272863,
      "updated": 1780272883
    },
    {
      "id": "6a1d043e0000000000d12f05",
      "text": "\t👀米国フィンテックの[Bolt社]がHRを廃止",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780286527,
      "updated": 1780672303
    },
    {
      "id": "6a1d04410000000000d12f06",
      "text": "\t\t>[https://x.com/Polymarket/status/2057666240093569462 @Polymarket]: JUST IN: Bolt CEO [Ryan Breslow] fired the company’s entire HR team because they were “creating problems that didn’t exist.”",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1780286529,
      "updated": 1780293203
    },
    {
      "id": "6a1d044a0000000000d12f07",
      "text": "\t\t存在しない仕事を作っていた",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780286538,
      "updated": 1780286563
    },
    {
      "id": "6a1d04670000000000d12f08",
      "text": "\t\tリプ欄がずいぶん熱狂しているなあ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780286567,
      "updated": 1780286573
    },
    {
      "id": "6a1d04830000000000d12f09",
      "text": "\t\t[AIに詳細を聞いてファクトチェック https://chatgpt.com/share/6a1cfe7c-732c-8324-ba77-c5594c37f4bb]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780286596,
      "updated": 1780286608
    },
    {
      "id": "6a1d04b90000000000d12f0a",
      "text": "\t\tHRからPeople Operationsへとチーム置き換え",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780286650,
      "updated": 1780286656
    },
    {
      "id": "6a1d35810000000000a9cbbf",
      "text": "\t朝からの頭痛が強まってきた。台風かなあ。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780299138,
      "updated": 1780299160
    },
    {
      "id": "6a1d35550000000000a9cbbe",
      "text": "\t[匝瑳市]を操作してソーサーつくるソーサリー",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1780299094,
      "updated": 1780324663
    },
    {
      "id": "6a1d5ca200000000003e227f",
      "text": "\tさっき散歩してたらビクッってなった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780309155,
      "updated": 1780309175
    },
    {
      "id": "6a1d5cb600000000003e2280",
      "text": "\t\t[https://gyazo.com/0e51c65f38c0bd5f5bf1db3c6bbf985c]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780309175,
      "updated": 1780309179
    },
    {
      "id": "6a1d5d19000000000060b9dc",
      "text": "\t\t……？……！？！？[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780309274,
      "updated": 1780309293
    },
    {
      "id": "6a1d649600000000008c1b59",
      "text": "\t\t謎の靴もある[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780311190,
      "updated": 1780311202
    },
    {
      "id": "6a1d64a200000000008c1b5a",
      "text": "\t\t 濡れちゃって干してるのかな",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780311203,
      "updated": 1780311215
    },
    {
      "id": "6a1d92bd00000000008f5923",
      "text": "\t電子辞書の電池が切れたので替えた",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1780323006,
      "updated": 1780323016
    },
    {
      "id": "6a1cc30b000000000088d572",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1780269835,
      "updated": 1780269835
    },
    {
      "id": "6a1cd6110000000000a3ef39",
      "text": "[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780274706,
      "updated": 1780274706
    },
    {
      "id": "6a1cd6110000000000a3ef3a",
      "text": " これが...私！？",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780274706,
      "updated": 1780274712
    },
    {
      "id": "6a1cf5ad00000000000ab03e",
      "text": " \t[https://gyazo.com/98d069b0338568d2586392d2aacf572a]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780282797,
      "updated": 1780282949
    },
    {
      "id": "6a1cf64500000000000ab040",
      "text": " \tめっちゃ芋臭くていい",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780282950,
      "updated": 1780282969
    },
    {
      "id": "6a1d10c20000000000f9ae99",
      "text": " [井戸端荘: 懸垂バー]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780289731,
      "updated": 1780289742
    },
    {
      "id": "6a1d35510000000000647d9c",
      "text": " LLMに解釈させて解釈違いな物語を作るより普通に個人日記を美少女化して疑似シェアハウスで繰り広げられる物語が見たいのだなと思った",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780299089,
      "updated": 1780299124
    },
    {
      "id": "6a1d358e0000000000647d9e",
      "text": "  井戸端という仮想空間に肉付けするような",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780299151,
      "updated": 1780299161
    },
    {
      "id": "6a1d35e90000000000bc8eb1",
      "text": "  実際の議論をベースに物語化するといいのかもしれない",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780299242,
      "updated": 1780299259
    },
    {
      "id": "6a1d35fb0000000000bc8eb2",
      "text": "   [井戸端荘: トイレットペーパープロブレム]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780299259,
      "updated": 1780299269
    },
    {
      "id": "6a1cf5b100000000000ab03f",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780282802,
      "updated": 1780282802
    },
    {
      "id": "6a1cd6170000000000a3ef3b",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780274712,
      "updated": 1780274712
    },
    {
      "id": "6a1cdb900000000000189d1c",
      "text": "[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780276112,
      "updated": 1780276114
    },
    {
      "id": "6a1cdb920000000000189d1d",
      "text": " トモコレでは今日から夏みたいだ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780276114,
      "updated": 1780276124
    },
    {
      "id": "6a1cdba40000000000189d1f",
      "text": " 誰…⁈私か…",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780276132,
      "updated": 1780276146
    },
    {
      "id": "6a1cfae00000000000dfc293",
      "text": " [いどばタイムきらら]で新しい私が発生していた",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780284129,
      "updated": 1780284172
    },
    {
      "id": "6a1cfaef0000000000dfc294",
      "text": "  [https://gyazo.com/5f0e2d33aafb5fe66ef829c197f4b8ed]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780284144,
      "updated": 1780284150
    },
    {
      "id": "6a1cfafa0000000000dfc296",
      "text": "   ヘアピンつけてあげた",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780284155,
      "updated": 1780284168
    },
    {
      "id": "6a1cfb500000000000dfc298",
      "text": "   [スティィクき]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780284241,
      "updated": 1780284254
    },
    {
      "id": "6a1d3f6c000000000030322f",
      "text": "   [アペラクセントイエロー][takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780301662,
      "updated": 1780301675
    },
    {
      "id": "6a1cfb220000000000dfc297",
      "text": "  これが[日々更新される自己]ってやつか〜",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780284195,
      "updated": 1780301679
    },
    {
      "id": "6a1d15370000000000133e8c",
      "text": " sonnetは賢さの度合いがあんまり高くなくて話しやすくていい",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780290872,
      "updated": 1780290888
    },
    {
      "id": "6a1d452d00000000008d4a1e",
      "text": " ごはんを完全に食べ忘れていた よくない",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780303150,
      "updated": 1780303164
    },
    {
      "id": "6a1d459200000000008d4a20",
      "text": "  フィッシュバーガー的なものが食べたい",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780303250,
      "updated": 1780303259
    },
    {
      "id": "6a1d4cf900000000008d4a22",
      "text": "  待ってモスになんかエビの新作出てる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780305146,
      "updated": 1780305159
    },
    {
      "id": "6a1d9d2700000000001219d7",
      "text": "   調査してきた、ぺろり🍤",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780325672,
      "updated": 1780325693
    },
    {
      "id": "6a1d48180000000000b5e1f4",
      "text": " 森の整備が進む もはや赤くない、緑",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780303896,
      "updated": 1780303910
    },
    {
      "id": "6a1d4a1e0000000000b5e1f7",
      "text": " しまった、opusにやらせるべき作業をsonnetにやらせてしまった",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780304415,
      "updated": 1780304441
    },
    {
      "id": "6a1d4aae0000000000b5e1f8",
      "text": " しまった、月が変わっていた",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780304558,
      "updated": 1780304565
    },
    {
      "id": "6a1d4acb0000000000b5e1f9",
      "text": " しまいすぎ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780304587,
      "updated": 1780304590
    },
    {
      "id": "6a1d99cd0000000000469734",
      "text": "  しまりすぎではないのか[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1780324812,
      "updated": 1780324818
    },
    {
      "id": "6a1d99d70000000000469735",
      "text": "  [しまった]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1780324823,
      "updated": 1780324825
    },
    {
      "id": "6a1d9be30000000000469736",
      "text": "  仕舞うだった",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1780325346,
      "updated": 1780325375
    },
    {
      "id": "6a1d9d1e00000000001219d6",
      "text": "   そうだったのか[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780325662,
      "updated": 1780325665
    },
    {
      "id": "6a1dbebf0000000000685f8b",
      "text": " しまったまた夜更かししてしまった",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780334272,
      "updated": 1780334284
    },
    {
      "id": "6a1dbecc0000000000685f8c",
      "text": "  claudeのリミットが1時に復活するのがいけない",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780334285,
      "updated": 1780334309
    },
    {
      "id": "6a1cf0530000000000fdc504",
      "text": "",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780281428,
      "updated": 1780281428
    },
    {
      "id": "6a1cf0540000000000fdc505",
      "text": "[koyoshi.icon]",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780281428,
      "updated": 1780281430
    },
    {
      "id": "6a1cf0560000000000fdc506",
      "text": " なんかまた面白そうなことが始まってる",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780281431,
      "updated": 1780281444
    },
    {
      "id": "6a1cf06f0000000000fdc507",
      "text": "  [いいぞ、もっとやれ]",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780281456,
      "updated": 1780281465
    },
    {
      "id": "6a1d0a7f000000000088d247",
      "text": " 台風6号の影響が いつ発生するか気にしている",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780288127,
      "updated": 1780288197
    },
    {
      "id": "6a1d0ae1000000000088d248",
      "text": "  鉄道会社の計画運休で出社できなくなるのが困る",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780288225,
      "updated": 1780288304
    },
    {
      "id": "6a1d0b44000000000088d249",
      "text": "  今週の水木は出社したほうが仕事が捗るけど、そのあたりに台風がやってきそう",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780288324,
      "updated": 1780288385
    },
    {
      "id": "6a1d5bbb00000000009bd713",
      "text": " 仕事してないのに疲れた",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1780308923,
      "updated": 1780308937
    },
    {
      "id": "6a1cdb9c0000000000189d1e",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780276124,
      "updated": 1780276125
    },
    {
      "id": "6a1cf35f00000000003007e2",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780282207,
      "updated": 1780282208
    },
    {
      "id": "6a1cf36100000000003007e4",
      "text": " アイコンを衣替え",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780282209,
      "updated": 1780282216
    },
    {
      "id": "6a1cf43400000000003007e5",
      "text": " [いどばタイムきらら]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780282420,
      "updated": 1780283466
    },
    {
      "id": "6a1cf84a00000000003007e6",
      "text": "  [いいぞ、もっとやれ]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780283466,
      "updated": 1780283466
    },
    {
      "id": "6a1d02e20000000000d11abe",
      "text": " 世界的に週休4日ぐらいにならないかなぁ。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780286178,
      "updated": 1780286196
    },
    {
      "id": "6a1d39a70000000000792989",
      "text": " [シェアハウス]やったことないから、事例としてシェアハウス話が見れてちょっと嬉しい",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780300198,
      "updated": 1780300282
    },
    {
      "id": "6a1d39c9000000000079298a",
      "text": "  トイレットペーパーを使い切らずに交換する人が居るのか、、、",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780300238,
      "updated": 1780300249
    },
    {
      "id": "6a1d3d890000000000bc8f10",
      "text": "  これを見てそもそも交換してないのだと気づいた[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780301194,
      "updated": 1780301201
    },
    {
      "id": "6a1d3d910000000000bc8f11",
      "text": "   切れそうなトイペをそのままに新しいトイペを使い始めてその辺に置く",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780301201,
      "updated": 1780301218
    },
    {
      "id": "6a1d543b000000000079298c",
      "text": "    あーなるほど。いろんな人が居るんだな。。[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780307003,
      "updated": 1780307014
    },
    {
      "id": "6a1d5422000000000079298b",
      "text": " [今日も一日頑張ったぞい]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780306978,
      "updated": 1780307248
    },
    {
      "id": "6a1d67b0000000000086a494",
      "text": " [JRE POINTを効率よく貯めるための仕込み]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780311984,
      "updated": 1780315482
    },
    {
      "id": "6a1d755a0000000000b389df",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780315483,
      "updated": 1780315483
    },
    {
      "id": "6a1cf7870000000000fed6fd",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780283272,
      "updated": 1780283274
    },
    {
      "id": "6a1cf7890000000000fed6fe",
      "text": "　[VRChatでかわいい少女になるおじさんの気持ち]が少しわかった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780283274,
      "updated": 1780285401
    },
    {
      "id": "6a1cffee0000000000382b05",
      "text": "　 それ以上いくと戻れなくなるぞい[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780285409,
      "updated": 1780285419
    },
    {
      "id": "6a1cf79e0000000000fed6ff",
      "text": "　かわいいは正義",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780283295,
      "updated": 1780283299
    },
    {
      "id": "6a1cf7a30000000000fed700",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780283299,
      "updated": 1780283299
    },
    {
      "id": "6a1cf8760000000000710752",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283511,
      "updated": 1780283511
    },
    {
      "id": "6a1cf8770000000000710753",
      "text": "\t上の暗号なんだったんだろう・・",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283511,
      "updated": 1780283516
    },
    {
      "id": "6a1cf87c0000000000710754",
      "text": "\t[いどばタイムきらら]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283516,
      "updated": 1780283523
    },
    {
      "id": "6a1cf8840000000000710755",
      "text": "\t\t響きは良いが、「まんが」の部分を「いどば」に変えたのはもう少し良い方法があった感",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283524,
      "updated": 1780283560
    },
    {
      "id": "6a1cff250000000000c99320",
      "text": "\t\t 語感好き[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780285221,
      "updated": 1780285242
    },
    {
      "id": "6a1cf8af0000000000710756",
      "text": "\t\tみんな自分の解釈で[井戸端荘]を書いて欲しい（読みたい）",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283567,
      "updated": 1780283588
    },
    {
      "id": "6a1cf8e50000000000710757",
      "text": "\t自分の名を冠するキャラクターが出てくるだけで、面白さが上がるのは人間のバグっぽいなぁ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283622,
      "updated": 1780283639
    },
    {
      "id": "6a1cf8f70000000000710758",
      "text": "\t\t[差別的いじり]とかにならないように注意が必要",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283640,
      "updated": 1780283658
    },
    {
      "id": "6a1cf91e0000000000710759",
      "text": "\t\t配慮したつもりだけど、嫌だったら言ってね！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283678,
      "updated": 1780283686
    },
    {
      "id": "6a1cf7a30000000000fed701",
      "text": "\t[井戸端荘: ウロボロスのプロンプト]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780283299,
      "updated": 1780301945
    },
    {
      "id": "6a1d59c2000000000017e8ba",
      "text": "\t妻にトイレットペーパーのヒアリングをした",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780308419,
      "updated": 1780308429
    },
    {
      "id": "6a1d5af200000000008aca12",
      "text": "\t\t語感好き[Summer498.icon][mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1780308722,
      "updated": 1780309531
    },
    {
      "id": "6a1d406a0000000000238178",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1780301930,
      "updated": 1780301930
    },
    {
      "id": "6a1cf9a600000000007ad4ea",
      "text": "[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1780283814,
      "updated": 1780283815
    },
    {
      "id": "6a1cf9a900000000007ad4ec",
      "text": " [https://morioka.keizai.biz/headline/3195/ 盛岡で「ハラケイ入門」再び　100回忌に合わせ、内容アップデート - 盛岡経済新聞]",
      "userId": "688c296691686a314f82fb52",
      "created": 1780283818,
      "updated": 1780283818
    },
    {
      "id": "6a1cf9ab00000000007ad4ed",
      "text": " \t>入り口にはマスクを着けた原敬のパネルも。「スペイン風邪」にかかったことから注意を呼び掛け",
      "userId": "688c296691686a314f82fb52",
      "created": 1780283819,
      "updated": 1780283826
    },
    {
      "id": "6a1cf9c400000000007ad4ee",
      "text": " \t>2020.11.24",
      "userId": "688c296691686a314f82fb52",
      "created": 1780283844,
      "updated": 1780283845
    },
    {
      "id": "6a1cf9c500000000007ad4ef",
      "text": " \t「私も…」と感染症対策を呼びかけさせられる[原敬](のパネル)、なんかジワジワくる",
      "userId": "688c296691686a314f82fb52",
      "created": 1780283845,
      "updated": 1780283888
    },
    {
      "id": "6a1cf9a600000000007ad4eb",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1780283814,
      "updated": 1780283814
    },
    {
      "id": "6a1cf9e10000000000d8ba11",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780283874,
      "updated": 1780283880
    },
    {
      "id": "6a1cf9e90000000000d8ba13",
      "text": " [研究ネタの雑談]をするためだけに呼ばれた",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780283881,
      "updated": 1780672336
    },
    {
      "id": "6a1d08f400000000002f0037",
      "text": "  オモロい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780287733,
      "updated": 1780287734
    },
    {
      "id": "6a1cfa5b0000000000d8ba14",
      "text": "  インスピレーションに飢えてるか、そういう話が通じる人に飢えてるんかな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780283996,
      "updated": 1780284036
    },
    {
      "id": "6a1d48920000000000b5e1f5",
      "text": "   若者たちに種を植えてるのかも[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1780304018,
      "updated": 1780304037
    },
    {
      "id": "6a1cfb9c0000000000d8ba16",
      "text": "  不可思議な状況に居る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780284317,
      "updated": 1780304041
    },
    {
      "id": "6a1cfe300000000000c9931c",
      "text": " 話が通じる人に飢えるって言うのはありそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780284976,
      "updated": 1780285002
    },
    {
      "id": "6a1cfe4a0000000000c9931d",
      "text": "  授業にも研究室にも自分の話を理解してくれてなさそうな人しか居ないと相当キツそう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780285003,
      "updated": 1780285121
    },
    {
      "id": "6a1cfec20000000000c9931e",
      "text": "  今そうなのかは知らんけど",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780285123,
      "updated": 1780302961
    },
    {
      "id": "6a1d4471000000000054d3a9",
      "text": " 何あの荒らし報告……怖すぎるんだけど",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780302962,
      "updated": 1780303013
    },
    {
      "id": "6a1d44a6000000000054d3aa",
      "text": "  何が怖いって、プロジェクト自体を特定ユーザには見られないようにブロックかけつつやってること",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780303015,
      "updated": 1780303186
    },
    {
      "id": "6a1d48b2000000000054d3ad",
      "text": " \tそこまでのレベルで恨まれてるか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780304051,
      "updated": 1780304569
    },
    {
      "id": "6a1d59b100000000008aca11",
      "text": " [takker.icon]に迷惑をかけていて申し訳ない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780308401,
      "updated": 1780308430
    },
    {
      "id": "6a1d853d0000000000b7b48d",
      "text": " なんで 3D モデルを虹色で表示するんだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780319549,
      "updated": 1780319571
    },
    {
      "id": "6a1d85a80000000000b7b48f",
      "text": " \t何かの論文でも虹色の3Dモデルを見た",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780319657,
      "updated": 1780319672
    },
    {
      "id": "6a1d85540000000000b7b48e",
      "text": " \t凹凸が分かりやすいから？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780319572,
      "updated": 1780319648
    },
    {
      "id": "6a1dd26e00000000004044d7",
      "text": " \t法線の表現でよく使われる[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1780339311,
      "updated": 1780339329
    },
    {
      "id": "6a1cf9e10000000000d8ba12",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1780283874,
      "updated": 1780283874
    },
    {
      "id": "6a1d3a8b00000000003afd68",
      "text": "[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1780300428,
      "updated": 1780300429
    },
    {
      "id": "6a1d3a8c00000000003afd6a",
      "text": " 今日は6ポモドーロでつかれた",
      "userId": "5a61856392ee03001413cde3",
      "created": 1780300429,
      "updated": 1780300434
    },
    {
