      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778068290,
      "updated": 1778068301
    },
    {
      "id": "69fb2b4d0000000000e9a92d",
      "text": "[デライト.icon]",
      "userId": "686b72ebdffe36b729b4453d",
      "created": 1778068301,
      "updated": 1778068313
    },
    {
      "id": "69fb2b530000000000e9a92f",
