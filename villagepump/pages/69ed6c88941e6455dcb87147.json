    {
      "id": "69ed6c88941e6455dcb87147",
      "text": "モーニング",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777167501,
      "updated": 1777167501
    },
    {
      "id": "69ed6ca600000000001c537e",
      "text": "喫茶店やカフェなどで、午前中にコーヒーとセットで提供される食品類のこと",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777167526,
      "updated": 1777167558
    },
    {
      "id": "69ed6c8d00000000001c537c",
      "text": "[モーニングコート]を意味することもある？",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777167501,
      "updated": 1777167525
    },
    {
      "id": "69ed6c8d00000000001c537d",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1777167501,
      "updated": 1777167501
    },
    {
      "id": "69ed792f0000000000c5bdd8",
      "text": "すき家の朝定食もモーニングと言える？",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777170736,
      "updated": 1777170743
    },
    {
      "id": "69ed792e0000000000c5bdd6",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777170735,
      "updated": 1777170735
    },
    {
      "id": "69ed79360000000000c5bdd9",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777170743,
      "updated": 1777170743
    },
    {
      "id": "69ed79190000000000c5bdd3",
      "text": "朝型マン[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777170714,
      "updated": 1777170801
    },
    {
      "id": "69ed794e0000000000c5bdda",
      "text": "\tモーニングは昼ご飯扱い。8:30とか10:00とか",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777170768,
      "updated": 1777170799
    },
    {
      "id": "69ed79510000000000c5bddb",
      "text": "\t普通に昼飯食いに行ったらまだモーニングの時間帯だったりする",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1777170771,
      "updated": 1777170783
    },
