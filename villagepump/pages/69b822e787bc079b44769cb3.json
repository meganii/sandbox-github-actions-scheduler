      "userId": "6970e90c94fe766b6a026352",
      "created": 1773675240,
      "updated": 1773675240
    },
    {
      "id": "69c276bc0000000000f0660c",
      "text": "[https://gyazo.com/09989bae5e30672fb05d09e1872db3b9]",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352060,
      "updated": 1774369835
    },
    {
      "id": "69b823160000000000940247",
      "text": "2026/03/25 アイコン更新 ",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1773675285,
      "updated": 1774369846
    },
    {
      "id": "69c279bd0000000000f06620",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352830,
      "updated": 1774352830
    },
    {
      "id": "69b822e80000000000940238",
      "text": "[* 獏] あるいは [* baku3]",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1773675240,
      "updated": 1774352259
    },
    {
      "id": "69c2778c0000000000f06619",
      "text": "慢性的な虚無感、カフェイン中毒、学生、そんな感じの人",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352269,
      "updated": 1774370108
    },
    {
      "id": "69c27aa20000000000f06621",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353058,
      "updated": 1774353058
    },
    {
      "id": "69c27ab60000000000f06622",
      "text": "興味関心、意欲、趣味etc",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353078,
      "updated": 1774353101
    },
    {
      "id": "69c27acc0000000000f06624",
      "text": "・物事へ興味関心が低い状態にある。恒常的に好きなもの、関心があるものがない。",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353101,
      "updated": 1774353101
    },
    {
      "id": "69c27acc0000000000f06625",
      "text": "・物理の基礎づけの議論内の論理や思想の読解と理解、再構築に意欲的に取り組むことも希にある。",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353101,
      "updated": 1774353101
    },
    {
      "id": "69c27acc0000000000f06626",
      "text": "・思考の言語化、音楽、読書が（毒ともなるが薬ともなる点を踏まえて）一番 趣味 に近い。",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353101,
      "updated": 1774353101
    },
    {
      "id": "69c27acc0000000000f06627",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353101,
      "updated": 1774353101
    },
    {
      "id": "69c27acc0000000000f06628",
      "text": "特性：心の奴隷",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353101,
      "updated": 1774353486
    },
    {
      "id": "69c27acc0000000000f06629",
      "text": "好き：雨の音、夜景、猫、常夜灯",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353101,
      "updated": 1774353101
    },
    {
      "id": "69c27ab60000000000f06623",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353078,
      "updated": 1774353078
    },
    {
      "id": "69b825200000000000940253",
      "text": "参加プロジェクト",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1773675808,
      "updated": 1774352470
    },
    {
      "id": "69c278550000000000f0661b",
      "text": " [/arpla]",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352470,
      "updated": 1774352510
    },
    {
      "id": "69c278e40000000000f0661d",
      "text": "  メインで活動しているプロジェクト",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352613,
      "updated": 1774353295
    },
    {
      "id": "69c2791a0000000000f0661f",
      "text": "  Discordの方のアープラの様子を記録していたりする。",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352667,
      "updated": 1774370026
    },
    {
      "id": "69c27ba10000000000f0662e",
      "text": "  このプロジェクトの記事を見ていたなかで、井戸端の存在を知って参加した。",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774353314,
      "updated": 1774353537
    },
    {
      "id": "69c278590000000000f0661c",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352473,
      "updated": 1778405245
    },
    {
      "id": "69b825370000000000940256",
      "text": "よろしくお願いします。",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1773675831,
      "updated": 1773675880
    },
    {
      "id": "69b825d500000000006b9b18",
      "text": "\t歓迎[Summer498.icon][yosider.icon][はるひ.icon][suto3.icon][meganii.icon][atohs.icon][hoagecko.icon][Hiro Aki.icon][sta.icon][caki.icon][koyoshi.icon][Mijikko.icon][Nrem.icon][nomadoor.icon][基素.icon][nishio.icon][vlzs.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1773675990,
      "updated": 1774403904
    },
    {
      "id": "69c276dd0000000000f06610",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1774352093,
      "updated": 1774354063
    },
    {
      "id": "6a004e97000000000022d349",
      "text": "[/icons/hr.icon]",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778405015,
      "updated": 1778405100
    },
    {
      "id": "6a004e25000000000022d2f3",
      "text": " code:style.css",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404901,
      "updated": 1778405213
    },
    {
      "id": "6a004e61000000000022d31b",
      "text": "  .page-list > .grid li.pin {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404961,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d31c",
      "text": "    \theight: 32px;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d31d",
      "text": "    \twidth: 100%;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d31e",
      "text": "    \tmargin-bottom: 5px;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d31f",
      "text": "    }",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d320",
      "text": "    @media (hover: none) {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d321",
      "text": "    \t/* ピン留めするカードの数が偶数である限りは秩序が保たれる脆弱なCSS */",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d322",
      "text": "    \t.page-list ul.grid {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d323",
      "text": "   \t\tgrid-template-columns: repeat(6, 1Fr);",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d324",
      "text": "   \t}",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d325",
      "text": "   \t.page-list > .grid li.pin {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d326",
      "text": "   \t\tgrid-column: 2 span;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d327",
      "text": "   \t}",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d328",
      "text": "   \t.page-list > .grid li:not(.pin):nth-child(odd) {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d329",
      "text": "   \t\tgrid-column: 1 / 4;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d32a",
      "text": "   \t}",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d32b",
      "text": "   \t.page-list > .grid li:not(.pin):nth-child(even) {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d32c",
      "text": "   \t\tgrid-column: 4 / 7;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d32d",
      "text": "   \t}",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d32e",
      "text": "   }",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d32f",
      "text": "    .page-list > .grid li.page-list-item.pin a {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d330",
      "text": "    \tbackground-color: var(--card-bg);",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d331",
      "text": "    \tborder-radius: 7px;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d332",
      "text": "    \tmargin: none;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d333",
      "text": "    \tbox-shadow: none;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d334",
      "text": "    }",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d335",
      "text": "    .page-list > .grid li.page-list-item a .header.pinned {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d336",
      "text": "    \tborder-top:none;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d337",
      "text": "    \tpadding: 6px 5px;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d338",
      "text": "    }",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d339",
      "text": "    .page-list > .grid li.page-list-item.pin a .title {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d33a",
      "text": "    \tfont-size: 12px;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d33b",
      "text": "    \tcolor: var(--card-title-color);",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d33c",
      "text": "    \tmax-height: 20px;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d33d",
      "text": "    \ttext-align: center;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d33e",
      "text": "    }",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d33f",
      "text": "    .page-list > .grid li.page-list-item.pin a .content :is(.description,.icon) {display: none;}",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e62000000000022d340",
      "text": "    .page-list > .grid li.page-list-item a .pin {background: none;}",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404962,
      "updated": 1778404962
    },
    {
      "id": "6a004e73000000000022d341",
      "text": "    ",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404979,
      "updated": 1778404979
    },
    {
      "id": "6a004e75000000000022d343",
      "text": "",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404982,
      "updated": 1778404982
    },
    {
      "id": "6a004e73000000000022d342",
      "text": " code:style.css",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778404979,
      "updated": 1778405004
    },
    {
      "id": "6a004e8c000000000022d344",
      "text": "  /* ピン留めされてるカードの段を分ける */",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778405004,
      "updated": 1778405005
    },
    {
      "id": "6a004e8d000000000022d345",
      "text": "   .page-list-item.pin + .page-list-item:not(.pin) {",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778405005,
      "updated": 1778405005
    },
    {
      "id": "6a004e8d000000000022d346",
      "text": "     \tgrid-column-start: 1;",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778405005,
      "updated": 1778405005
    },
    {
      "id": "6a004e8d000000000022d347",
      "text": "   }",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1778405005,
      "updated": 1778405005
    },
