      "updated": 1776670778
    },
    {
      "id": "69e5d8390000000000393ff7",
      "text": "\tドナルド・トランプ大統領 \t2017年1月20日 ～ 2021年1月20日",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1776670778,
      "updated": 1776671678
    },
    {
      "id": "69e5dbaa0000000000394006",
      "text": "\tジョー・バイデン大統領 　\t2021年1月20日 ～ 2025年1月20日",
