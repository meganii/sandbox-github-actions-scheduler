      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1757377487,
      "updated": 1757377488
    },
    {
      "id": "68bf73cf0000000000f9ea27",
      "text": "\t[情報源は何か？]",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1757377488,
      "updated": 1776848326
    },
    {
      "id": "68bf741a0000000000f9ea2b",
      "text": "\t[おっせん]という概念を考えていた",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1757377563,
      "updated": 1757381339
    },
    {
      "id": "68bf82d60000000000e7abea",
