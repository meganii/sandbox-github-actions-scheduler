  "lines": [
    {
      "id": "6a0b169c3b421d8f98cfe9a9",
      "text": "KEY 原則",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779111582,
      "updated": 1779111582
    },
    {
      "id": "6a0b168500000000002e903c",
      "text": " Keep Enough for You（十分を保て）原則[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779111582,
      "updated": 1779111622
    },
    {
      "id": "6a0b16bc00000000002e903f",
      "text": "  KISS 原則にかけて昔作った開発原則",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779111637,
      "updated": 1779111665
    },
    {
      "id": "6a0b173100000000002e9043",
      "text": "  「足るを知る」の技術版",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779111754,
      "updated": 1779111765
    },
    {
      "id": "6a0b1bb00000000000323f5b",
      "text": "  言い換えるなら「自分にとって本当に必要なことかどうか考え抜け」原則",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779112905,
      "updated": 1779114456
    },
    {
      "id": "6a0b1ceb0000000000323f5d",
      "text": "   必要十分・単純性を保つというところは KISS や [YAGNI] と同じだが、「何に対して」の部分で若干ニュアンスが変わってくる",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779113220,
      "updated": 1779114531
    },
    {
      "id": "6a0b1dfc0000000000323f5e",
      "text": "   それが時として、常識に反する大胆な割り切りにつながる",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779113493,
      "updated": 1779113549
    },
    {
      "id": "6a0b200f0000000000323f5f",
      "text": "   必要そうに思えることも、考えようによっては意外と必要じゃないということがある",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779114024,
      "updated": 1779114344
    },
    {
      "id": "6a0b21130000000000323f60",
      "text": "   自己中心的設計原則とも言えるかもしれない",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779114284,
      "updated": 1779114285
    },
    {
      "id": "6a0b170a00000000002e9041",
      "text": "  その名の通り[デライト]開発含めて開発プロジェクト全般で割と鍵になっている",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779111715,
      "updated": 1779111942
    },
    {
      "id": "6a0b179e00000000002e9044",
      "text": "  [造語]としても綺麗なのでお気に入り",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779111863,
      "updated": 1779111877
    },
    {
      "id": "6a0b1c8b0000000000323f5c",
      "text": "   Keep Enough for Yourself ではないのは単に語呂の問題",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779113124,
      "updated": 1779113138
    },
    {
      "id": "6a0b16be00000000002e9040",
      "text": "",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779111639,
      "updated": 1779111639
    }
  ]
}