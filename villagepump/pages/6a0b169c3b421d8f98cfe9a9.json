    },
    {
      "id": "6a10eaaf0000000000bc5155",
      "text": "[デライト.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1779493551,
      "updated": 1779493552
    },
    {
      "id": "6a10eab00000000000bc5156",
