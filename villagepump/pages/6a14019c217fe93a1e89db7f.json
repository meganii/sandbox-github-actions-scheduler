      "created": 1779696029,
      "updated": 1779696029
    },
    {
      "id": "6a14019d00000000009f8050",
      "text": "ライバルにエックスサーバー関連の企業が運営するシンレンタルサーバーがある",
      "userId": "688c296691686a314f82fb52",
      "created": 1779696029,
