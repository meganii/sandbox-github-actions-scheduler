    {
      "id": "69eb3bce00000000009b8da6",
      "text": "[作曲]の技法の一つ",
      "userId": "688c296691686a314f82fb52",
      "created": 1777023951,
      "updated": 1777023971
    },
    {
      "id": "69eb3be300000000009b8da9",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1777023972,
      "updated": 1777023972
    },
    {
      "id": "69eb3be500000000009b8daa",
      "text": "キャラクターないし実在する人物の[台詞]の[イントネーション]を元に[作曲]すること",
      "userId": "688c296691686a314f82fb52",
      "created": 1777023973,
      "updated": 1777024111
    },
    {
      "id": "69eb3c6f00000000009b8db5",
      "text": "",
