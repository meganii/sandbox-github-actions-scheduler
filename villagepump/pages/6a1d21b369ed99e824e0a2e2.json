  "lines": [
    {
      "id": "6a1d21b369ed99e824e0a2e2",
      "text": "ホモ・ファーベル",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294120,
      "updated": 1780294120
    },
    {
      "id": "6a1d21e7000000000023e869",
      "text": "ラテン語の造語で、「工作人」と訳す。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294120,
      "updated": 1780294121
    },
    {
      "id": "6a1d21e8000000000023e86a",
      "text": "[ホモ・サピエンス]との対比で、人間を他の動物から区別する本質的規定を、道具を作り、使用する点に求める人間観を要約している。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294121,
      "updated": 1780294157
    },
    {
      "id": "6a1d220c000000000023e86b",
      "text": "Homo faber",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294157,
      "updated": 1780294217
    },
    {
      "id": "6a1d2242000000000023e86f",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294211,
      "updated": 1780294211
    },
    {
      "id": "6a1d220f000000000023e86c",
      "text": "[アンリ・ベルクソン]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294160,
      "updated": 1780294181
    },
    {
      "id": "6a1d2224000000000023e86d",
      "text": "[ハンナ・アーレント]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294181,
      "updated": 1780294271
    },
    {
      "id": "6a1d227b000000000023e870",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294267,
      "updated": 1780294267
    },
    {
      "id": "6a1d2280000000000023e871",
      "text": "マックス・シェーラー",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780294272,
      "updated": 1780294328
    },
    {
      "id": "6a1d22b3000000000023e872",
      "text": "[ベンジャミン・フランクリン]",
