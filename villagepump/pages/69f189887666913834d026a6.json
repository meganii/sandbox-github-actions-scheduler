    {
      "id": "69f189887666913834d026a6",
      "text": "マンダロリアン・アンド・グローグー",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437066,
      "updated": 1777437066
    },
    {
      "id": "69f189b70000000000aef6fc",
      "text": "[https://youtu.be/0li7YeiemC8]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437112,
      "updated": 1777437119
    },
    {
      "id": "69f189b80000000000aef6fd",
      "text": "[2026/05/22]公開の映画",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437112,
      "updated": 1777437155
    },
    {
      "id": "69f189f30000000000aef6fe",
      "text": ">”[スター・ウォーズ]”最新作が映画館に帰ってくる！",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437171,
      "updated": 1777437194
    },
    {
      "id": "69f189f40000000000aef700",
      "text": ">  帝国が崩壊し、銀河は無法地帯と化していた。",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437173
    },
    {
      "id": "69f189f40000000000aef701",
      "text": ">  孤高の賞金稼ぎ“[マンダロリアン]”。そしてフォースの力を秘めた[グローグー]。",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437206
    },
    {
      "id": "69f189f40000000000aef702",
      "text": ">  長く果てしない旅を続ける中で、固い絆に結ばれた二人を待ち受ける、壮大な冒険と驚くべき運命とは？",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437173
    },
    {
      "id": "69f189f40000000000aef704",
      "text": ">  『スター・ウォーズ／マンダロリアン・アンド・グローグー』5月22日（金）日米同時公開！",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437173
    },
    {
      "id": "69f189f40000000000aef705",
      "text": ">  https://starwars.disney.co.jp/movie/m...",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437173
    },
    {
      "id": "69f189f40000000000aef707",
      "text": ">  ■キャスト：ペドロ・パスカル（マンダロリアン／ディン・ジャリン）、シガーニー・ウィーバー",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437173
    },
    {
      "id": "69f189f40000000000aef708",
      "text": ">  ■監督：ジョン・ファヴロー",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437173
    },
    {
      "id": "69f189f40000000000aef709",
      "text": ">  ■制作総指揮：デイヴ・フィローニ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777437173,
      "updated": 1777437173
    },
    {
      "id": "69f18b7300000000002b37e8",
      "text": "\tシガニーウィーバー出るの⁉️[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777437556,
      "updated": 1777437556
    },
    {
      "id": "69f18b7400000000002b37e9",
      "text": "\tめちゃ楽しみ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777437556,
      "updated": 1777437558
    },
    {
      "id": "69f18e050000000000aef714",
      "text": "\t たのしみ[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777438213,
      "updated": 1777438216
    },
