    },
    {
      "id": "69a237ce0000000000180e14",
      "text": "\t\t評価S",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e15",
      "text": "\tSo5",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e16",
      "text": "\t\t[回避性パーソナリティ障害]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391171
    },
    {
      "id": "69a237ce0000000000180e17",
      "text": "\t\t強迫性パーソナリティ障害",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e18",
      "text": "\tSx5",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e19",
      "text": "\t　D型愛着",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e1a",
      "text": "\t\t統合失調型パーソナリティ障害",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e1b",
      "text": "\t\t二分法・動的",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e1c",
      "text": "\t\t偏執的",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e1d",
      "text": "\t\t[フリードリヒ・ニーチェ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391096
    },
    {
      "id": "69a237ce0000000000180e1e",
      "text": "\t\t___F (4F)",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772255052
    },
    {
      "id": "69a237ce0000000000180e1f",
      "text": "\t\t[ELVF]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772394923
    },
    {
      "id": "69a237ce0000000000180e20",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e21",
      "text": "E6\t",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e22",
      "text": "\t[内向的感情型]（[劣等機能]としての外向的思考）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391684
    },
    {
      "id": "69a237ce0000000000180e23",
      "text": "\t[内向的思考型]（[劣等機能]としての外向的感情）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391683
    },
    {
      "id": "69a237ce0000000000180e24",
      "text": "\t[パーソナリティ障害・B群]と密接に関係する",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391657
    },
    {
      "id": "69a237ce0000000000180e25",
      "text": "\t自らが無批判に[内在化]した外界の価値観の受け売りを暗黙の前提としたうえで、その判断基準に反発する己の動機を他者に投影する（[外在化]、[スプリッティング]）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391179
    },
    {
      "id": "69a237ce0000000000180e26",
      "text": "\t\t[客観主義（レーニン二分法）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e27",
      "text": "\t\tメタな文脈理解と批判的思考の形成が最も遅れる傾向",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e28",
      "text": "\t\t\t「反発」と「批判的思考」の区別がつかない",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a48c8d0000000000b0fd1f",
      "text": " \t[根本的な帰属の誤り]という名の錯誤を犯すことが多い。",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391565,
      "updated": 1772391572
    },
    {
      "id": "69a237ce0000000000180e2a",
      "text": "\t\t特定個人への人身攻撃多し",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e2b",
      "text": "\t全体的に個体識別能力が乏しい",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e2c",
      "text": "\t　内向性、[静的（レーニン二分法）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e2d",
      "text": "\t不安型愛着",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e2e",
      "text": "\t偏執的",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e2f",
      "text": "\t同質性の高い者同士で惹かれ合う傾向が強い。他者を「内と外」に分け、積極的に[エコーチェンバー]を形成する",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a48c7a0000000000b0fd06",
      "text": "\t思い込みの強さと社会不安が目立つ受動的攻撃的な人物に多い",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391547,
      "updated": 1772391548
    },
    {
      "id": "69a237ce0000000000180e30",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772255063
    },
    {
      "id": "69a237ce0000000000180e31",
      "text": "\tSp6\t",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a48b340000000000b0fcd0",
      "text": "\t\t不安型愛着",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391220,
      "updated": 1772391220
    },
    {
      "id": "69a237ce0000000000180e37",
      "text": "\t\t[境界性パーソナリティ障害]（現代型）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e38",
      "text": "\t\tシゾイドパーソナリティー障害",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e39",
      "text": "\t\t[ストーカー防止法違反]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e3a",
      "text": "\t\t内向型（ユング二分法）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e3b",
      "text": "\t\t_FV_ (2F3V)",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e3c",
      "text": "\t\t__EV (3E4V)",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a48b3f0000000000b0fce5",
      "text": "\t\t良くも悪くも個人的である",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391232,
      "updated": 1772391232
    },
    {
      "id": "69a48b3f0000000000b0fce6",
      "text": "\t\tSp 6w7-9-3はSp9に似て[的外れ応答]の傾向がある",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391232,
      "updated": 1772391232
    },
    {
      "id": "69a48c340000000000b0fcf1",
      "text": "\t\t\t自己正当化の詭弁と被害者感情が前面に出る。しかしこの者の場合は事実関係に依らない",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391477,
      "updated": 1772391734
    },
    {
      "id": "69a48b3f0000000000b0fce7",
      "text": "\t\t特に[客観主義（レーニン二分法）]の場合：",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391232,
      "updated": 1772394889
    },
    {
      "id": "69a4997e0000000000d9d540",
      "text": "\t\t\t自身と同じ階層とみなすものとの結託",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772394879,
      "updated": 1772394879
    },
    {
      "id": "69a48b3f0000000000b0fce8",
      "text": "\t\t\t僻み・妬みの強さと関係する",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391232,
      "updated": 1772391232
    },
    {
      "id": "69a48a2e0000000000b0fcc5",
      "text": "\t\t自身をSo4と誤認する傾向",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772390959,
      "updated": 1772390973
    },
    {
      "id": "69a48a530000000000b0fcc6",
      "text": "\t\t[フョードル・ドストエフスキー]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772390996,
      "updated": 1772391091
    },
    {
      "id": "69a237ce0000000000180e3d",
      "text": "\tSo6\t立場へのとらわれ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a48c030000000000b0fce9",
      "text": "\t\t立場に囚われていて保身と根回しの手管に秀でている",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391428,
      "updated": 1772391531
    },
    {
      "id": "69a48cb80000000000b0fd32",
      "text": "\t\tその多くは対話能力が乏しい",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391609,
      "updated": 1772391629
    },
    {
      "id": "69a237ce0000000000180e3e",
      "text": "\t\t[自己愛性パーソナリティ障害]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e3f",
      "text": "\t\t[権威主義的パーソナリティ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e40",
      "text": "\t\t合理型（ユング二分法）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e41",
      "text": "\t\t客観主義（レーニン二分法）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e42",
      "text": "\t\t_LV_",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e43",
      "text": "\t\t_FV_",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772394946
    },
    {
      "id": "69a499c10000000000d9d541",
      "text": "\t\t[LFVE]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772394946,
      "updated": 1772394946
    },
    {
      "id": "69a237ce0000000000180e44",
      "text": "\t\t己自身の動因や行動特性をSp1と誤認する傾向",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e45",
      "text": "\tSx6",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e46",
      "text": "\t\t[自己愛性パーソナリティ障害]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772390948
    },
    {
      "id": "69a237ce0000000000180e47",
      "text": "\t\t[妄想性パーソナリティ障害]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e48",
      "text": "\t\t[反抗挑戦性障害]、[反社会性パーソナリティ障害]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772390955
    },
    {
      "id": "69a237ce0000000000180e49",
      "text": "\t\t不法侵入",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e4a",
      "text": "\t\t侮辱罪",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e4b",
      "text": "\t\t[権威主義的パーソナリティ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391389
    },
    {
      "id": "69a48cad0000000000b0fd2b",
      "text": "\t\t対話能力が乏しい",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391598,
      "updated": 1772391598
    },
    {
      "id": "69a237ce0000000000180e4c",
      "text": "\t\t[ルサンチマン]が強い",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e4d",
      "text": "\t\t[陰謀論]的世界観",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772391376
    },
    {
      "id": "69a237ce0000000000180e4e",
      "text": "\t\tしばしば妄執的で苛烈",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e4f",
      "text": "\t\t_FV_",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e50",
      "text": "\t\tF_V_",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e51",
      "text": "\t\t[内向的合理型（ユング二分法）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772390938
    },
    {
      "id": "69a237ce0000000000180e52",
      "text": "\t\t感覚優位型（ユング二分法）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e53",
      "text": "\t\t[静的（レーニン二分法）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772390932
    },
    {
      "id": "69a237ce0000000000180e54",
      "text": "\t\t自我F",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e55",
      "text": "\t\t[客観主義（レーニン二分法）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772390941
    },
    {
      "id": "69a48a720000000000b0fcc7",
      "text": "\t\t[ヨシフ・スターリン]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391027,
      "updated": 1772391043
    },
    {
      "id": "69a48a770000000000b0fcc8",
      "text": "\t\t[暇空茜]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772391032,
      "updated": 1772391032
    },
    {
      "id": "69a277660000000000fd4bb7",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772255080,
      "updated": 1772255081
    },
    {
      "id": "69a237ce0000000000180e56",
      "text": "E7",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e57",
      "text": "\t外向的感覚型",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e58",
      "text": "\t外向的直観型",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e59",
      "text": "\tSp7",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e5a",
      "text": "\t\t[回避性パーソナリティ障害]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e5b",
      "text": "\tSo7",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772238801
    },
    {
      "id": "69a237ce0000000000180e5c",
      "text": "\t\t[エコーチェンバー]に弱い",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772238801,
      "updated": 1772390922
    },
    {
      "id": "69a237ce0000000000180e5d",
      "text": "\tSx7",
