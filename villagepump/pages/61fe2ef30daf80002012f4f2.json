      "created": 1783324385,
      "updated": 1783324387
    },
    {
      "id": "6a4b5ec70000000000ecd522",
      "text": "オプション：",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783324360,
      "updated": 1783324369
    },
    {
      "id": "6a423dda0000000000402c19",
      "text": " `[>/ quote]` – インライン引用記法A（従来からの斜体スタイル）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782726107,
      "updated": 1783326812
    },
    {
      "id": "6a4b5eb80000000000ecd521",
      "text": " 　テキスト[>/ インライン引用記法]テキスト",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783324345,
      "updated": 1783324769
    },
    {
      "id": "6a4531eb0000000000625fb4",
      "text": " 　Text [>/ Inline quotation] text",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782919661,
      "updated": 1783324769
    },
    {
      "id": "6a423e740000000000402c1e",
      "text": " `[>_ quote]` – インライン引用記法B（下線スタイル）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782726261,
      "updated": 1783326815
    },
    {
      "id": "6a4b5f400000000000ecd524",
      "text": " 　テキスト[>_ インライン引用記法]テキスト ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783324481,
      "updated": 1783324769
    },
    {
      "id": "6a4531e40000000000625fb3",
      "text": " 　Text [>_ Inline quotation] text ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782919653,
      "updated": 1783324769
    },
    {
      "id": "6a423dae0000000000402c14",
      "text": " `[>' quote]` – インライン引用記法C（両端引用符のスタイル）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782726063,
      "updated": 1783326850
    },
    {
      "id": "6a4b5f4a0000000000ecd525",
      "text": " 　テキスト[>' インライン引用記法]テキスト",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783324491,
      "updated": 1783324769
    },
    {
      "id": "6a4532040000000000625fb7",
      "text": "  Text [>' Inline quotation] text ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782919686,
      "updated": 1783324769
    },
    {
      "id": "6a423e6d0000000000402c1d",
      "text": " `[>+ quote]` – インライン引用記法D（領域を架線で区切るスタイル）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782726254,
      "updated": 1783326822
    },
    {
      "id": "6a4b5f580000000000ecd526",
      "text": "  テキスト[>+ インライン引用記法]テキスト",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783324504,
      "updated": 1783324769
    },
    {
      "id": "6a4532060000000000625fb8",
      "text": "  Text [>+ Inline quotation] text ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782919687,
      "updated": 1783324769
    },
    {
      "id": "6a406685000000000033251f",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
