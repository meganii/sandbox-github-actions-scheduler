      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782650389,
      "updated": 1782671858
    },
    {
      "id": "6a4169ec0000000000e157b0",
      "text": "  .deco-\\>.deco-\\+[class^=\"deco-\\> deco-\\+\"] {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782671853,
      "updated": 1782673016
    },
    {
      "id": "6a4064200000000000b9a03d",
      "text": "  \t.line & {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782604833,
      "updated": 1782604833
    },
