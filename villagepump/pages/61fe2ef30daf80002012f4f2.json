      "created": 1782646191,
      "updated": 1782646198
    },
    {
      "id": "6a4105b600000000003500ea",
      "text": "  .deco-\\>.deco-\\'[class^=\"deco-\\> deco-\\'\"] {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646198,
      "updated": 1782672011
    },
    {
      "id": "6a4105b800000000003500eb",
      "text": "  \t.line & {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500ec",
      "text": "  \t\tvertical-align: baseline;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500ed",
      "text": "  \t\tbox-sizing: content-box; /* padding: 5.5px 4px 1px 2px; */",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500ee",
      "text": "  \t\tpadding: 5px 2px 5px 2px;",
