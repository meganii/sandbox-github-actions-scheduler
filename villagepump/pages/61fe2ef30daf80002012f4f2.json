    },
    {
      "id": "61fe2ef57838e3000051f6b2",
      "text": "[[下線型のborder案/[インライン引用記法（下線スタイル）]]]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1644048117,
      "updated": 1783139293
    },
    {
      "id": "6a416a580000000000e157b1",
      "text": "[>_ quote]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782671961,
      "updated": 1782671971
    },
    {
      "id": "6a2d2a790000000000f55271",
      "text": "from [/customize/インライン引用記法 (下線スタイル)]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781344889,
      "updated": 1782650185
    },
    {
      "id": "6a311e710000000000760ac3",
      "text": "　経緯については次のページを参照のこと",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781603955,
      "updated": 1782650569
    },
    {
      "id": "6a3a5ee30000000000f4178c",
      "text": "　　[インライン引用記法のデザイン変更案 - 2026/6/19]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782210277,
      "updated": 1782650185
    },
    {
      "id": "6a3a5ece0000000000f41788",
      "text": "　　[「インライン引用記法」のデザインを変更したい]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782210256,
      "updated": 1782650185
    },
    {
      "id": "6a44f44000000000000602ab",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782903873,
      "updated": 1782903874
    },
    {
      "id": "6a4b62c00000000000ecd531",
      "text": "2026-07-06 文字装飾記法とスタイルの対応関係を変更した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325381,
      "updated": 1783325660
    },
    {
      "id": "6a4b64240000000000d65505",
      "text": "　`[\" text]`(デフォルト) – [\" 変更なし]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325732,
      "updated": 1783326459
    },
    {
      "id": "6a4b66540000000000d6550a",
      "text": "　　引用テキストの左側に、上付きの開始引用符アイコンを配置するスタイル",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783326292,
      "updated": 1783326292
    },
    {
      "id": "6a4b65c50000000000d65508",
      "text": "　　[「インライン引用記法」のデザインを変更したい]を経て修正・改善されたスタイル",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783326149,
      "updated": 1783326342
    },
    {
      "id": "6a4b63b60000000000d65502",
      "text": "　`[>_ text]`(06-28 に追加された記法) – [>_ スタイルの一部を変更]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325622,
      "updated": 1783326438
    },
    {
      "id": "6a4b665f0000000000d6550c",
      "text": "　　引用テキストの左側に、下付きの閉じ引用符アイコンを配置するスタイル",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783326311,
      "updated": 1783326311
    },
    {
      "id": "6a4b665e0000000000d6550b",
      "text": "　　原案に忠実",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783326302,
      "updated": 1783326507
    },
    {
      "id": "6a48948700000000007ba7a0",
      "text": "2026-07-04 border の配色と幅の微調整",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783141511,
      "updated": 1783141551
    },
    {
      "id": "6a44f44100000000000602ac",
      "text": "2026-07-01 フォント指定などの変数の値を初期案のものに変更",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782903875,
      "updated": 1782903912
    },
    {
      "id": "6a4894bf00000000007ba7a1",
      "text": "　smallerのfont-weightの微調整が反映された表示にするため、[Google Fonts]の「[Inter]」と「[Noto Sans JP]」の[ウェブフォント]`@import`文を追加",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783141568,
      "updated": 1783141801
    },
    {
      "id": "6a411034000000000011ed9e",
      "text": "2026-06-28 新記法のみ有効化[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782648885,
      "updated": 1782650562
    },
    {
      "id": "6a410ce4000000000011ed97",
      "text": "2026-06-28 新記法追加`[>_ quote]`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782648036,
      "updated": 1783325336
    },
    {
      "id": "6a4b621f0000000000ecd530",
      "text": "　これに伴い、次の記法の書式との衝突対策を施した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325216,
      "updated": 1783325323
    },
    {
      "id": "6a41106c000000000011eda0",
      "text": "　　[ユーザーフラッグ記法] `>`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782648941,
      "updated": 1783325211
    },
    {
      "id": "6a41153a00000000001cd537",
      "text": "　　[下線記法] `_`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782650171,
      "updated": 1783325213
    },
    {
      "id": "6a3a58490000000000d4383a",
      "text": "2026-06-23 引用符アイコンの`font-size-adjust: unset;`の指定漏れを修正",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782208587,
      "updated": 1782650185
    },
    {
      "id": "6a376dea0000000000f8f03e",
      "text": "2026-06-21 引用符アイコンを`content: \"\\f10d\";`に戻した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782017515,
      "updated": 1782650185
    },
    {
      "id": "6a341de800000000005f0fa6",
      "text": "2026-06-19 引用符アイコンを`content: \"\\f10e\";`に変更",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781800425,
      "updated": 1782650185
    },
    {
      "id": "6a33fc4000000000003ba08a",
      "text": "2026-06-19 [BIZ UDゴシック]に変更",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781791808,
      "updated": 1782650185
    },
    {
      "id": "6a33f6fc000000000077421f",
      "text": "2026-06-19 未使用の`font`関連指定をコメントアウト",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781790460,
      "updated": 1782650185
    },
    {
      "id": "6a311e280000000000760ac2",
      "text": "2026-06-16 `font-weight:` 指定を無効化（コメントアウト）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781603882,
      "updated": 1782650185
    },
    {
      "id": "6a3003b10000000000e916d7",
      "text": "2026-06-15 `line-height: calc(1em / 0.7);`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781531570,
      "updated": 1782650185
    },
    {
      "id": "6a2e806900000000002e45af",
      "text": "2026-06-14 `vertical-align: super;\tline-height: calc(1em / 0.94 * 0.7);`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1781432426,
      "updated": 1782650185
    },
    {
      "id": "6a2d2ab50000000000f5528f",
      "text": "2026-06-13 [Nrem.icon]",
