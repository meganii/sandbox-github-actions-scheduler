      "created": 1782646189,
      "updated": 1782646189
    },
    {
      "id": "6a4105e60000000000350108",
      "text": "両端を引用符で囲む案",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646247,
      "updated": 1783327429
    },
    {
      "id": "6a4115c500000000001cd53a",
      "text": "[>' quote]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782650310,
      "updated": 1782672025
    },
    {
      "id": "6a4105e40000000000350107",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646245,
      "updated": 1782646245
    },
    {
      "id": "6a4105f70000000000350109",
      "text": "　[2026-06-28] 記法`[\"' quote]`[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646264,
      "updated": 1782650587
    },
    {
      "id": "6a4114f000000000001cd536",
      "text": "　　cf. [中央揃え記法] `'`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782650097,
      "updated": 1782673359
    },
    {
      "id": "6a4105ae00000000003500e9",
      "text": " code:style.css",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646191,
      "updated": 1782646198
    },
    {
      "id": "6a4105b600000000003500ea",
      "text": "  /* .deco-\\\", */",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646198,
      "updated": 1782810755
    },
    {
      "id": "6a4230720000000000d30d3d",
      "text": "  .deco-\\>.deco-\\'[class^=\"deco-\\> deco-\\'\"] {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782722675,
      "updated": 1782722675
    },
    {
      "id": "6a4105b800000000003500eb",
      "text": "  \t.line & {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500ec",
      "text": "  \t\t--inline-quote-border-width: 1px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1783326997
    },
    {
      "id": "6a4384450000000000fc180c",
      "text": "  \t\tvertical-align: baseline;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782809671,
      "updated": 1782809671
    },
    {
      "id": "6a4105b800000000003500ed",
      "text": "  \t\tbox-sizing: content-box; /* padding: 5.5px 4px 1px 2px; */",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500ee",
      "text": "  \t\tpadding: 5.5px 2px 3.5px 2px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1783324847
    },
    {
      "id": "6a4105b800000000003500ef",
      "text": "  \t\tborder-bottom: solid var(--inline-quote-border-width, var(--quote-border-width, 1px)) var(--quote-border-color, #a0a0a0);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782841136
    },
    {
      "id": "6a4105b800000000003500f0",
      "text": "   \t\tbackground-color: var(--quote-bg-color, rgba(0, 0, 0, 0.05));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500f1",
      "text": "  \t\tcolor: var(--quote-text-color, var(--page-text-color, inherit));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500f2",
      "text": "  \t\tfont-size: .9em;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782802725
    },
    {
      "id": "6a4105b800000000003500f3",
      "text": "   \t\tfont-weight: var(--inline-quote-font-weight, unset);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1783326927
    },
    {
      "id": "6a4b68b80000000000d6550d",
      "text": "   \t\tfont-family: var(--inline-quote-font-family, var(--page-font-family, \"\")), var(--icons, \"Font Awesome 5 Free\", \"Font Awesome 5 Brand\", \"AppIcons\"), sans-serif;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783326904,
      "updated": 1783326904
    },
    {
      "id": "6a4105b800000000003500f5",
      "text": "   \t\t/* font-feature-settings: var(--inline-quote-font-feature-settings, var(--quote-font-feature-settings)); */",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b800000000003500f6",
      "text": "   \t\t/* font-size-adjust: var(--inline-quote-font-size-adjust); */",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782647730
    },
    {
      "id": "6a4105b800000000003500f7",
      "text": "  \t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1783325052
    },
    {
      "id": "6a4105b800000000003500fb",
      "text": "  \t.line &::before,",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1783325023
    },
    {
      "id": "6a4b61490000000000ecd52b",
      "text": "  \t.line &::after {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325002,
      "updated": 1783327274
    },
    {
      "id": "6a4b61370000000000ecd52a",
      "text": "  \t\tfont-size: .4em;\tline-height: calc(1em / 0.4);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783324983,
      "updated": 1783324987
    },
    {
      "id": "6a4105b800000000003500ff",
      "text": "  \t\tfont-family: var(--icons, \"Font Awesome 5 Free\", \"Font Awesome 5 Brand\", AppIcons); font-weight: 700; font-style: normal;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1783324977
    },
    {
      "id": "6a4105b80000000000350100",
      "text": "  \t\tfont-size-adjust: unset;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b80000000000350101",
      "text": "  \t\tcolor: var(--quote-border-color, #a0a0a0);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4b6a0e0000000000d65515",
      "text": "  \t\ttext-decoration: none;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783327246,
      "updated": 1783327246
    },
    {
      "id": "6a4105b80000000000350102",
      "text": "  \t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4b61820000000000ecd52c",
      "text": "  \t.line &::before {\tcontent: \"\\f10d\"; vertical-align: super; margin-right: 2px;\t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325059,
      "updated": 1783325059
    },
    {
      "id": "6a4b61820000000000ecd52d",
      "text": "  \t.line &::after {\tcontent: \"\\f10e\"; vertical-align: super; margin-left: 2px;\t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325059,
      "updated": 1783325059
    },
    {
      "id": "6a4b61820000000000ecd52e",
      "text": "  \t",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783325059,
      "updated": 1783325059
    },
    {
      "id": "6a4105b80000000000350103",
      "text": "  \t.line.cursor-line &::before {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b80000000000350104",
      "text": "  \t\tdisplay: none;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b80000000000350105",
      "text": "  \t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105b80000000000350106",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646201,
      "updated": 1782646201
    },
    {
      "id": "6a4105ac00000000003500e8",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782646189,
      "updated": 1782646189
    },
    {
