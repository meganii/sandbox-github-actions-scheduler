    {
      "id": "69b0116dd9c5734add05b3b8",
      "text": "#inajob の試しに録音してみた talk140: 3つのLEDで数字を表す・2月の悪魔・3Dプリンタでキーホルダー製作",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146480,
      "updated": 1773146480
    },
    {
      "id": "69b016070000000000db4255",
      "text": "[https://open.spotify.com/episode/3UCBuQbel3pL7R1gblSMm6]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147656,
      "updated": 1773147661
    },
    {
      "id": "69b016080000000000db4256",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147656,
      "updated": 1773147656
    },
    {
      "id": "69b0116f0000000000db421b",
      "text": "準備中",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146480,
      "updated": 1773147656
    },
    {
      "id": "69b015610000000000db4250",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147490,
      "updated": 1773147490
    },
    {
      "id": "69b015610000000000db4251",
      "text": "\t[Google Formsで感想を送る https://docs.google.com/forms/d/1fC9gUB6PC3uJidZAJ8pgD1qLiMdvIgZOenrTwcOqpnw/]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147490,
      "updated": 1773147490
    },
    {
      "id": "69b015610000000000db4252",
      "text": " [Discordサーバー「inajob川」に参加する https://discord.gg/vHu4CXuMPq]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147490,
      "updated": 1773147490
    },
    {
      "id": "69b015610000000000db4253",
      "text": " \t[参加する前に様子を見る https://inajob.github.io/inajob-river-peeker/]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147490,
      "updated": 1773147490
    },
    {
      "id": "69b015610000000000db4254",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147490,
      "updated": 1773147490
    },
    {
      "id": "69b011730000000000db421d",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146484,
      "updated": 1773146484
    },
    {
      "id": "69b0117a0000000000db421f",
      "text": "\t健康",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146491,
      "updated": 1773146492
    },
    {
      "id": "69b011800000000000db4220",
      "text": "\t\t前回録音の日の夜から5歳の娘が発熱",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146497,
      "updated": 1773146506
    },
    {
      "id": "69b0118b0000000000db4221",
      "text": "\t\t\tインフルエンザ陰性",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146508,
      "updated": 1773146511
    },
    {
      "id": "69b011960000000000db4222",
      "text": "\t\t自分も喉に違和感",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146518,
      "updated": 1773146525
    },
    {
      "id": "69b0119d0000000000db4223",
      "text": "\t\t\t娘の看病で昼夜逆転みたいになった日があったのも原因の一つか？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146526,
      "updated": 1773146537
    },
    {
      "id": "69b011a90000000000db4224",
      "text": "\t\t\t花粉症と区別がつかない",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146538,
      "updated": 1773146542
    },
    {
      "id": "69b011b20000000000db4225",
      "text": "\t\t看護休暇を取得",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146547,
      "updated": 1773146552
    },
    {
      "id": "69b011d80000000000db4226",
      "text": "\t\t\t今年度は5日の看護休暇がまだ余っているので、娘も健康になってきたなと思う",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146584,
      "updated": 1773146605
    },
    {
      "id": "69b011fa0000000000db4227",
      "text": "\t\t\t「仕事を休まない」ではない、ランダムに仕事を休んでも問題ないような仕事の進め方をする方が良いよねということを自覚し始める",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146619,
      "updated": 1773146640
    },
    {
      "id": "69b0122f0000000000db4228",
      "text": "\t\t\t\t遠くを見るような仕事の方が相性が良い",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146672,
      "updated": 1773146689
    },
    {
      "id": "69b012420000000000db4229",
      "text": "\t\t\t\t\tキャリアを積んだ人がこういう仕事をしがちなのはこういう感じなのかーという気づき",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146690,
      "updated": 1773146714
    },
    {
      "id": "69b0125e0000000000db422a",
      "text": "\t\t\t\t\t\t仕事の価値が高いというのもあるが、都合がつきやすいというのもありそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146719,
      "updated": 1773146734
    },
    {
      "id": "69b0128e0000000000db422b",
      "text": "\t新しいサーキュレーターのインジケーター面白い",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146768,
      "updated": 1773146788
    },
    {
      "id": "69b012a40000000000db422d",
      "text": "\t\tタイマーの時間を示すための3つのLED",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146789,
      "updated": 1773146798
    },
    {
      "id": "69b012b90000000000db422f",
      "text": "\t\t\t1時間・2時間・4時間",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146809,
      "updated": 1773146815
    },
    {
      "id": "69b012c00000000000db4230",
      "text": "\t\t\tバイナリ！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146817,
      "updated": 1773146818
    },
    {
      "id": "69b012ad0000000000db422e",
      "text": "\t\t風量を示すための3つのLED",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146798,
      "updated": 1773146808
    },
    {
      "id": "69b012c30000000000db4231",
      "text": "\t\t\t1・2・3",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146819,
      "updated": 1773146827
    },
    {
      "id": "69b012cc0000000000db4232",
      "text": "\t\t\t1~6までを表現している・・バイナリじゃない！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146828,
      "updated": 1773146841
    },
    {
      "id": "69b012dc0000000000db4233",
      "text": "\t\t\t1, 2, 3, 1+3, 2+3, 1+2+3",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146845,
      "updated": 1773146863
    },
    {
      "id": "69b013180000000000db4234",
      "text": "\t2月の悪魔",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146904,
      "updated": 1773146906
    },
    {
      "id": "69b0131a0000000000db4235",
      "text": "\t\t過去日記によると2月に気持ちが落ち込みがちのようだ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146907,
      "updated": 1773146918
    },
    {
      "id": "69b013250000000000db4236",
      "text": "\t\t\tモヤモヤする・ふわふわする",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146918,
      "updated": 1773146922
    },
    {
      "id": "69b0132b0000000000db4237",
      "text": "\t\t\t寒い、太陽の光にあまり当たらない？",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146924,
      "updated": 1773146938
    },
    {
      "id": "69b013430000000000db4238",
      "text": "\t\t\t新しいことを始めたこともあった([inajob川]をはじめたのがこの辺）",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146948,
      "updated": 1773146985
    },
    {
      "id": "69b013680000000000db4239",
      "text": "\t\t3月は別の不調がくる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146985,
      "updated": 1773146993
    },
    {
      "id": "69b013700000000000db423a",
      "text": "\t\t\t花粉症",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146993,
      "updated": 1773146995
    },
    {
      "id": "69b013730000000000db423b",
      "text": "\t\t\t自律神経の乱れ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146995,
      "updated": 1773147004
    },
    {
      "id": "69b013830000000000db423c",
      "text": "\t最近の3Dプリンタを使った遊び",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147012,
      "updated": 1773147023
    },
    {
      "id": "69b0138e0000000000db423d",
      "text": "\t\t5歳の娘にキーホルダーを作ってあげる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147023,
      "updated": 1773147035
    },
    {
      "id": "69b0139f0000000000db423e",
      "text": "\t\t\t[nano-banana]にデザインをしてもらったり・・",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147040,
      "updated": 1773147055
    },
    {
      "id": "69b013b10000000000db423f",
      "text": "\t\t\t娘も喜ぶし、自分も3Dプリンタを触れて、良い活動だと思う",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147057,
      "updated": 1773147079
    },
    {
      "id": "69b013c80000000000db4240",
      "text": "\t\tフィジェトを作る",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147081,
      "updated": 1773147096
    },
    {
      "id": "69b013d70000000000db4241",
      "text": "\t\t\t[XY Size Compensation]というのを設定すると、我が家の3Dプリンタでいい感じの寸法になることが分かった",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147096,
      "updated": 1773147140
    },
    {
      "id": "69b014080000000000db4243",
      "text": "\t\t\tヒンジやトグルスイッチ、回すとカチカチ鳴るつまみなどを作っている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147144,
      "updated": 1773147163
    },
    {
      "id": "69b0141f0000000000db4244",
      "text": "\t\t\t娘のおもちゃ箱に入れてもらっている",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147167,
      "updated": 1773147182
    },
    {
      "id": "69b0147e0000000000db4245",
      "text": "\t\t\t機構が丸見えのものが多いので、自然と学べてよいと思う",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147262,
      "updated": 1773147274
    },
    {
      "id": "69b014990000000000db4246",
      "text": "\tユニクロ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147290,
      "updated": 1773147292
    },
    {
      "id": "69b0149e0000000000db4247",
      "text": "\t\t[ストレッチイージーアンクルパンツ]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147294,
      "updated": 1773147302
    },
    {
      "id": "69b014b30000000000db4249",
      "text": "\t\t\t[#inajob の試しに録音してみた talk125: ストレッチイージーアンクルパンツ・習い事論・5歳の娘専用のゲーム・素敵な83歳の友人]で試しに買ったものが良かったので追加",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147316,
      "updated": 1773147332
    },
    {
      "id": "69b014b20000000000db4248",
      "text": "\t\t[エアリズムコットンクルーネックTシャツ]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147314,
      "updated": 1773147314
    },
    {
      "id": "69b014c40000000000db424a",
      "text": "\t\t\tシャツ的なもの",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147333,
      "updated": 1773147339
    },
    {
      "id": "69b014ca0000000000db424b",
      "text": "\t\t\t夏も着ることが出来る、冬は重ね着",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147339,
      "updated": 1773147356
    },
    {
      "id": "69b014df0000000000db424c",
      "text": "\t\t季節によらず着ることが出来る物を選びがち",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147360,
      "updated": 1773147372
    },
    {
      "id": "69b015040000000000db424d",
      "text": "\t締め",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147397,
      "updated": 1773147401
    },
    {
      "id": "69b015090000000000db424e",
      "text": "\t\t旅行周りがひと段落して、やっと何でもない内容を話した",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147402,
      "updated": 1773147417
    },
    {
      "id": "69b015180000000000db424f",
      "text": "\t\t今は4月末の旅行を計画中・・",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773147417,
      "updated": 1773147427
    },
    {
      "id": "69b011730000000000db421e",
      "text": "\t前回: [#inajob の試しに録音してみた talk139: LLMを使った時にで？となる現象・近所の行きつけの店があることの良さ・UIAPduino]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1773146484,
      "updated": 1773146490
    },
    {
      "id": "69b011700000000000db421c",
