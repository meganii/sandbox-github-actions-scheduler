    },
    {
      "id": "6a3e4a59000000000046a64a",
      "text": "2026-06-26 疑似背景が[BG]へのリンクになるように",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467161,
      "updated": 1782467247
    },
    {
      "id": "6a3e4aaa000000000046a64b",
      "text": "[2026-06-26] `:has()`を使用しない実装に変更した",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467241,
      "updated": 1782467255
    },
    {
      "id": "6987466f0000000000504a21",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770473072,
      "updated": 1770473072
    },
    {
      "id": "6987431a0000000000c3c501",
      "text": "\tcode:style.css",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c502",
      "text": "  body {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c503",
      "text": "  \t--virtual-page-margin-top: calc(var(--calculated-paragraph-line-height, 24px) * 3);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c504",
      "text": "  \t--page-padding-top: 42px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c505",
      "text": "  \t--page-padding-left: 49px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c506",
      "text": "  \t--page-padding-bottom: 42px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c507",
      "text": "  \t--page-width: calc(100% + var(--page-padding-left, 49px) * 2);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c508",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c509",
      "text": "  @media(max-width: 767px) {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c50a",
      "text": "  \tbody {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c50b",
      "text": "  \t\t--page-padding-top: 28px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c50c",
      "text": "  \t\t--page-padding-left: 21px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c50d",
      "text": "  \t\t--page-padding-bottom: 42px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c50e",
      "text": "  \t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c50f",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c510",
      "text": "  @media(min-width: 768px)and (max-width: 991px) {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c511",
      "text": "  \tbody {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c512",
      "text": "  \t\t--page-padding-top: 42px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c513",
      "text": "  \t\t--page-padding-left: 42px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c514",
      "text": "  \t\t--page-padding-bottom: 35px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c515",
      "text": "  \t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c516",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6a3e4633000000000033c4c4",
      "text": "  ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782466099,
      "updated": 1782466099
    },
    {
      "id": "6a3e462f000000000033c4a6",
      "text": "  .line:not(.cursor-line) a.icon[href$=\"/bg\"]:not(.indent *) {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782466095,
      "updated": 1782466095
    },
    {
      "id": "6a3e462f000000000033c4a7",
      "text": "  \t& > img.icon[title=\"bg\"] {\tdisplay: none;\t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782466095,
      "updated": 1782500609
    },
    {
      "id": "6a3e49d0000000000046a644",
      "text": "  \t",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467024,
      "updated": 1782467024
    },
    {
      "id": "6a3e49ca000000000046a632",
      "text": "  \tdisplay: inline-block;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a633",
      "text": "  \tbox-sizing: content-box;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a634",
      "text": "  \tmargin-top: calc(var(--page-padding-bottom) + 4px);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a635",
      "text": "  \theight: var(--virtual-page-margin-top);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a636",
      "text": "  \tmargin-bottom: calc(var(--page-border-top-width, 0px) + var(--page-padding-top, 7px));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a637",
      "text": "  \twidth: 100%;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a638",
      "text": "  \tfont-size: 0.1px; line-height: 0.1px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a639",
      "text": "  \t",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a63a",
      "text": "  \t&::after {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a63b",
      "text": "  \t\tcontent: \"\";",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a63c",
      "text": "  \t\tdisplay: block;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a63d",
      "text": "  \t\tposition: absolute;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a63e",
      "text": "  \t\theight: calc(var(--virtual-page-margin-top) + var(--page-border-top-width, 0px));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a63f",
      "text": "  \t\ttop: calc(var(--page-border-top-width, 0px) + var(--page-padding-bottom));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a640",
      "text": "  \t\twidth: var(--page-width, 100%);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a641",
      "text": "  \t\tleft: calc(-1 * var(--page-padding-left, 49px));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a642",
      "text": "  \t\tborder-top: 4px solid hsl(0 0 0 / 0.16);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6a3e49ca000000000046a643",
      "text": "  \t\tborder-bottom: var(--page-border-top, none);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782467018,
      "updated": 1782467018
    },
    {
      "id": "6987431a0000000000c3c530",
      "text": "  \t\tbackground: ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c531",
      "text": "  \t\t\tradial-gradient(circle, transparent 20%, var(--B) 20%, var(--B) 80%, transparent 80%, transparent), ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c532",
      "text": "  \t\t\tradial-gradient(circle, transparent 20%, var(--B) 20%, var(--B) 80%, transparent 80%, transparent) 50px 50px, ",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c533",
      "text": "  \t\t\tlinear-gradient(var(--A) 8px, transparent 8px) 0 -4px, linear-gradient(90deg, var(--A) 8px, transparent 8px) -4px 0;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c534",
      "text": "  \t\tbackground-color: var(--B, var(--body-bg));",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c535",
      "text": "  \t\tbackground-size: 100px 100px, 100px 100px, 50px 50px, 50px 50px;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c536",
      "text": "  \t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c537",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c538",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c539",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    },
    {
      "id": "6987431a0000000000c3c53a",
      "text": "#UserCSS",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1770472219,
      "updated": 1770472219
    }
  ]
