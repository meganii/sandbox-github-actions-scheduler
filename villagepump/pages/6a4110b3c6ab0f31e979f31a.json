  "lines": [
    {
      "id": "6a4110b70000000000017f35",
      "text": "下線記法",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649015,
      "updated": 1782674075
    },
    {
      "id": "6a4112430000000000017f60",
      "text": "[UserCSS.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649411,
      "updated": 1782649418
    },
    {
      "id": "6a4110b70000000000017f36",
      "text": "from [/nrem-configs/下線（波線・赤）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649015,
      "updated": 1782649411
    },
    {
      "id": "6a4110d30000000000017f3b",
      "text": "Cosenseの下線記法は（なぜか）HTML側に直接スタイリングされているので、それを打ち消す記述をいれる",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649043,
      "updated": 1782649048
    },
    {
      "id": "6a4110ba0000000000017f37",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649021,
      "updated": 1782649021
    },
    {
      "id": "6a41724300000000003f4369",
      "text": "[_ underline]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782673988,
      "updated": 1782673999
    },
    {
      "id": "6a4110bf0000000000017f38",
      "text": " code:style.css",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649024,
      "updated": 1782674171
    },
    {
      "id": "6a4172fa00000000006bcadd",
      "text": " \t.line span:not(.char-index):not([class])[style=\"text-decoration: underline;\"] {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782674171,
      "updated": 1782674171
    },
    {
      "id": "6a4172fa00000000006bcade",
      "text": " \t\ttext-decoration: none !important;",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782674171,
      "updated": 1782674171
    },
    {
      "id": "6a4172fa00000000006bcadf",
      "text": " \t}",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782674171,
      "updated": 1782674171
    },
    {
      "id": "6a4111140000000000017f4e",
      "text": "  .line .deco-\\_ {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649109,
      "updated": 1782649109
    },
    {
      "id": "6a4111140000000000017f4f",
      "text": "  \ttext-decoration: 1.5px underline solid var(--page-text-color, #444);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649109,
      "updated": 1782725204
    },
    {
      "id": "6a4111140000000000017f50",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649109,
      "updated": 1782649109
    },
    {
      "id": "6a4110bf0000000000017f39",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649024,
      "updated": 1782649024
    },
    {
      "id": "6a4112c40000000000017f65",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649541,
      "updated": 1782649541
    },
    {
      "id": "6a4111b70000000000017f5b",
      "text": "[_~ 波線・赤]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649271,
      "updated": 1782649302
    },
    {
      "id": "6a4111b30000000000017f5a",
      "text": "from [/nrem-configs/下線（波線・赤）]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649267,
      "updated": 1782649268
    },
    {
      "id": "6a41149f00000000001cd535",
      "text": "cf. [曇りガラス記法] `~`",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782650016,
      "updated": 1782650034
    },
    {
      "id": "6a4111250000000000017f52",
      "text": " code:style.css",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649126,
      "updated": 1782649529
    },
    {
      "id": "6a4111250000000000017f56",
      "text": "  .line .deco-\\_.deco-\\~[class*=\"deco-\\_ deco-\\~\"] {",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649126,
      "updated": 1782649286
    },
    {
      "id": "6a4111250000000000017f57",
      "text": "  \ttext-decoration: 1.5px underline wavy light-dark(crimson, lightcoral);",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649126,
      "updated": 1782649254
    },
    {
      "id": "6a4111250000000000017f58",
      "text": "  }",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1782649126,
      "updated": 1782649126
    },
    {
      "id": "6a4111260000000000017f59",
