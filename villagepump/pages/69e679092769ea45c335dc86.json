    },
    {
      "id": "69e679110000000000b693e5",
      "text": "[suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776711954,
      "updated": 1776711966
    },
    {
      "id": "69e679200000000000b693e8",
      "text": "あなたが「やめて」と言ったのなら、私はやめます",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776711969,
      "updated": 1776712036
    },
    {
      "id": "69e679640000000000b693eb",
      "text": "だから、私が「やめて」と言ったら、あなたもやめてください",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776712037,
      "updated": 1776712233
    },
    {
      "id": "69e679200000000000b693e9",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776711969,
      "updated": 1776711969
    },
    {
      "id": "69e679c10000000000b693ec",
      "text": "これは、[共通認識]にできるだろうか",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776712130,
      "updated": 1776712215
    },
    {
      "id": "69e67a170000000000b693ed",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776712216,
      "updated": 1776712216
    },
    {
      "id": "69e67a170000000000b693ee",
      "text": "私が「やめて」と言っても、あなたがやめないのなら",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776712216,
      "updated": 1776712343
    },
    {
      "id": "69e67a720000000000b693ef",
      "text": "あなたが「やめて」と言っても、わたしはやめません",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776712307,
      "updated": 1776712393
    },
    {
      "id": "69e679200000000000b693ea",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776711969,
      "updated": 1776711969
    },
    {
      "id": "69e67aca0000000000b693f0",
      "text": "たぶん、これはあかんやつ（うまく言えないけど）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776712395,
      "updated": 1776712488
