{
  "id": "6a53002a66f0adea5f6506a5",
  "title": "手を動かす",
  "created": 1783824437,
  "updated": 1783825733,
  "lines": [
    {
      "id": "6a53002a66f0adea5f6506a5",
      "text": "手を動かす",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824437,
      "updated": 1783824437
    },
    {
      "id": "6a5301130000000000a77056",
      "text": "[着手ベース]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824660,
      "updated": 1783824668
    },
    {
      "id": "6a53011b0000000000a77057",
      "text": "[着手]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824669,
      "updated": 1783824674
    },
    {
      "id": "6a5300340000000000a77044",
      "text": "[手を動か]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824437,
      "updated": 1783825678
    },
    {
      "id": "6a5300bb0000000000a7704f",
      "text": " [簡単であることの証明として実際に手を動かす]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824573,
      "updated": 1783824579
    },
    {
      "id": "6a53051a0000000000f9bfc2",
      "text": " [自ら手を動かしたほうが強い]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783825692,
      "updated": 1783825708
    },
    {
      "id": "6a5300c30000000000a77050",
      "text": " [頭を動かす]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824581,
      "updated": 1783824594
    },
    {
      "id": "6a5300d20000000000a77051",
      "text": " [心を動かす]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824596,
      "updated": 1783824602
    },
    {
      "id": "6a5300da0000000000a77052",
      "text": " [手を動かす前に一呼吸置く方法]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824604,
      "updated": 1783824611
    },
    {
      "id": "6a5300e20000000000a77053",
      "text": " [簡単であることの証明として実際に手を動かす]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824612,
      "updated": 1783824620
    },
    {
      "id": "6a5300ec0000000000a77054",
      "text": " [「便利で楽しいほうが良い」と思いつつ毎日を何気なく過ごすのではなく、日常に隠れているヒントを見つけて手を動かす行動]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824621,
      "updated": 1783824628
    },
    {
      "id": "6a5300830000000000a7704b",
      "text": " [着手こそが進捗]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824516,
      "updated": 1783824819
    },
    {
      "id": "6a53008b0000000000a7704c",
      "text": "　[着手する日時を決め]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824525,
      "updated": 1783824530
    },
    {
      "id": "6a5300920000000000a7704d",
      "text": "　[着手は進捗の第一歩]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824532,
      "updated": 1783824536
    },
    {
      "id": "6a53009a0000000000a7704e",
      "text": "　[着手は習慣化の前提]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824539,
      "updated": 1783824547
    },
    {
      "id": "6a53053a0000000000f9bfc4",
      "text": "[手がとまる]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783825723,
      "updated": 1783825724
    },
    {
      "id": "6a5300770000000000a7704a",
      "text": " [着手できない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824505,
      "updated": 1783825733
    },
    {
      "id": "6a53003d0000000000a77046",
      "text": "　[何も手が付かな]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824447,
      "updated": 1783824506
    },
    {
      "id": "6a5300720000000000a77048",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824499,
      "updated": 1783824499
    },
    {
      "id": "6a53003c0000000000a77045",
      "text": "表記揺れが多すぎる（[長いリンクを刻むページ]）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783824445,
      "updated": 1783824767
    }
  ]
}