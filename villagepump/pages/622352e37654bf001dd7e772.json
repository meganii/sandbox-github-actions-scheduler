  "lines": [
    {
      "id": "622352e37654bf001dd7e772",
      "text": "コミュニティの一生",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482164,
      "updated": 1646482164
    },
    {
      "id": "622352f35e90c00000fb0dbd",
      "text": "https://dic.nicovideo.jp/a/コミュニティの一生",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482164,
      "updated": 1646482164
    },
    {
      "id": "622352f45e90c00000fb0dbe",
      "text": ">【[コミュニティ]の一生】",
      "userId": "62c8e96f1f5ebf001d71fa08",
      "created": 1646482164,
      "updated": 1674940213
    },
    {
      "id": "622353095e90c00000fb0dc0",
      "text": "> ",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dc1",
      "text": "> [面白い人]が面白いことをする",
      "userId": "62c8e96f1f5ebf001d71fa08",
      "created": 1646482185,
      "updated": 1674940217
    },
    {
      "id": "622353095e90c00000fb0dc2",
      "text": "> ↓",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dc3",
      "text": "> 面白いから[凡人]が集まってくる",
      "userId": "62c8e96f1f5ebf001d71fa08",
      "created": 1646482185,
      "updated": 1674940221
    },
    {
      "id": "622353095e90c00000fb0dc4",
      "text": "> ↓",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dc5",
      "text": "> 住み着いた凡人が居場所を守るために主張し始める",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dc6",
      "text": "> ↓",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dc7",
      "text": "> 面白い人が見切りをつけて居なくなる",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dc8",
      "text": "> ↓",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dc9",
      "text": "> 残った凡人が面白くないことをする",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dca",
      "text": "> ↓",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622353095e90c00000fb0dcb",
      "text": "> 面白くないので皆居なくなる",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482185,
      "updated": 1646482185
    },
    {
      "id": "622354435e90c00000fb0ddf",
      "text": "",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1646482500,
      "updated": 1646482510
    },
    {
      "id": "6223544b5e90c00000fb0de0",
      "text": "　面白い人とは？",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1646482508,
      "updated": 1646484044
    },
    {
      "id": "62235a4ce5172d0000f6cbe1",
      "text": "　　自発的にいろいろ活動してくれる人",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1646484044,
      "updated": 1646484059
    },
    {
      "id": "62235a7fe5172d0000f6cbe3",
      "text": "　　　対価のためではなく、活動自体を楽しいと感じている",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1646484095,
      "updated": 1646484124
    },
    {
      "id": "62235a5be5172d0000f6cbe2",
      "text": "　　面白い話題や視点を提供してくれる人",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1646484059,
      "updated": 1646484070
    },
    {
      "id": "62235a48e5172d0000f6cbe0",
      "text": "",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1646484040,
      "updated": 1646484040
    },
