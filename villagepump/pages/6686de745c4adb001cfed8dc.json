    {
      "id": "6686de745c4adb001cfed8dc",
      "text": "2024/07/05",
      "userId": "59fb21121207900012774b17",
      "created": 1720114814,
      "updated": 1720114814
    },
    {
      "id": "66871bd71280f000000035c345",
      "text": "第27週: 日月火水木[[金]]土",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720130520,
      "updated": 1720130520
    },
    {
      "id": "66871bd71280f0000000b57c08",
      "text": "2024年 51.09％経過",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720130520,
      "updated": 1720130520
    },
    {
      "id": "6686de7e774b1700003333dd",
      "text": "",
      "userId": "59fb21121207900012774b17",
      "created": 1720114814,
      "updated": 1720114814
    },
    {
      "id": "6686de7e774b1700003333df",
      "text": "[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1720114814,
      "updated": 1720114823
    },
    {
      "id": "6686de87774b1700003333e1",
      "text": " 急にたくさんのサイバー犯罪が目に入るようになった",
      "userId": "59fb21121207900012774b17",
      "created": 1720114823,
      "updated": 1720114833
    },
    {
      "id": "6687d109774b1700006f1e72",
      "text": "　 [イセトーのランサムウェア感染で個人情報流出]",
      "userId": "59fb21121207900012774b17",
      "created": 1720176905,
      "updated": 1720176945
    },
    {
      "id": "6686df95774b1700003333e9",
      "text": "  [https://www.itmedia.co.jp/news/amp/2407/04/news170.html 京都府警のセキュリティ支援サイトが不正アクセス被害か 「大失態で重く受け止め」 - ITmedia NEWS]",
      "userId": "59fb21121207900012774b17",
      "created": 1720115094,
      "updated": 1720176944
    },
    {
      "id": "6686df27774b1700003333e8",
      "text": "   こっちは京都府警",
      "userId": "59fb21121207900012774b17",
      "created": 1720114983,
      "updated": 1720115224
    },
    {
      "id": "6686f8cc774b170000268ac7",
      "text": "   いつの間にかITmediaのURL展開ができるようになってる。UTF-8になった？",
      "userId": "59fb21121207900012774b17",
      "created": 1720121548,
      "updated": 1720121566
    },
    {
      "id": "668744451280f000004a946f",
      "text": "    `<meta charset=\"utf-8\">`が含まれていました[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720140870,
      "updated": 1720140881
    },
    {
      "id": "668795286eb40600008306e9",
      "text": "    貼り付けのときストレスだったので、まぁ良かった（こっちが治ったか、という気持ちもあるが）[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1720161577,
      "updated": 1720161592
    },
    {
      "id": "6687a57e774b170000b927f1",
      "text": "    https://www.itmedia.co.jp/news/articles/2407/04/news126.html はダメなので/ampだけ？[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1720165759,
      "updated": 1720165774
    },
    {
      "id": "6687a7d01280f00000bfd96c",
      "text": "     `<meta http-equiv=\"content-type\" content=\"text/html;charset=shift_jis\">`が入ってました[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720166354,
      "updated": 1720166360
    },
    {
      "id": "6687a7d71280f00000bfd96d",
      "text": "     ちゃんと指定するようになってえらい()",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720166360,
      "updated": 1720166368
    },
    {
      "id": "6686de94774b1700003333e2",
      "text": " セキュリティ関連銘柄買おうかな",
      "userId": "59fb21121207900012774b17",
      "created": 1720114836,
      "updated": 1720114843
    },
    {
      "id": "6686de86774b1700003333e0",
      "text": "",
      "userId": "59fb21121207900012774b17",
      "created": 1720114823,
      "updated": 1720114823
    },
    {
      "id": "668716f6b759d700002f2407",
      "text": "[yuyuko.icon]",
      "userId": "5b10baafcc4e900014b759d7",
      "created": 1720129270,
      "updated": 1720129273
    },
    {
      "id": "6687b04fb759d700007329c5",
      "text": " [** 疲れた]",
      "userId": "5b10baafcc4e900014b759d7",
      "created": 1720168528,
      "updated": 1720168536
    },
    {
      "id": "6687b6d35729c00000c8265c",
      "text": " \t🍵[Hiro Aki.icon][sume.icon][RR.icon][cak.icon][つばくろ.icon][基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1720170196,
      "updated": 1720184966
    },
    {
      "id": "6688e1d0b759d7000042cb4f",
      "text": " \t 大感謝🥲[yuyuko.icon]",
      "userId": "5b10baafcc4e900014b759d7",
      "created": 1720246736,
      "updated": 1720246759
    },
    {
      "id": "6687f611e5172d0000a5d7c7",
      "text": " \tわかる〜…[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1720186386,
      "updated": 1720186396
    },
    {
      "id": "6688e1e9b759d7000042cb50",
      "text": " \t お疲れさまです🍵[yuyuko.icon]",
      "userId": "5b10baafcc4e900014b759d7",
      "created": 1720246762,
      "updated": 1720246769
    },
    {
      "id": "668716f8b759d700002f2408",
      "text": "",
      "userId": "59fb21121207900012774b17",
      "created": 1720184963,
      "updated": 1720184963
    },
    {
      "id": "66871e5bbe12ad000066c57b",
      "text": "[sume.icon][元気です.icon]",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720131163,
      "updated": 1720131173
    },
    {
      "id": "66871e5bbe12ad000066c57c",
      "text": "　攻撃多いけれどどの状況でも粛々と対応するしかなくて...",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720131163,
      "updated": 1720138332
    },
    {
      "id": "668739d4be12ad000065caef",
      "text": "　　有事の際に外部支援が遅れるので、もし無いなら棚卸しリストからですな",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720138197,
      "updated": 1720138497
    },
    {
      "id": "66873a7dbe12ad000065caf1",
      "text": "　　把握できてくるとどのくらいの怖さなのか実態が見えてきますので",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720138365,
      "updated": 1720138504
    },
    {
      "id": "66873a27be12ad000065caf0",
      "text": "　　地に足つけてまいりましょう",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720138279,
      "updated": 1720138396
    },
    {
      "id": "66873acdbe12ad000065caf2",
      "text": "　　訓練は本番のように本番は訓練のようにでございますよ",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720138445,
      "updated": 1720138511
    },
    {
      "id": "668739a4be12ad000065caee",
      "text": "　暑すぎて登山組の体調を心配している",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720138148,
      "updated": 1720138157
    },
    {
      "id": "66872ad400645a000051fb4f",
      "text": "",
      "userId": "657c19a3646988002500645a",
      "created": 1720134356,
      "updated": 1720134356
    },
    {
      "id": "66872acb00645a000051fb4c",
      "text": "[Hyou.icon]",
      "userId": "657c19a3646988002500645a",
      "created": 1720134348,
      "updated": 1720134354
    },
    {
      "id": "66872ad400645a000051fb50",
      "text": "　サイバー攻撃多すぎの[サイバーサンダーサイダー]",
      "userId": "657c19a3646988002500645a",
      "created": 1720134357,
      "updated": 1720134649
    },
    {
      "id": "6687592b00645a000051fb57",
      "text": "　[https://gyazo.com/b49228586fad571c290dd9646b287958]",
      "userId": "657c19a3646988002500645a",
      "created": 1720146220,
      "updated": 1720146220
    },
    {
      "id": "6687592d00645a000051fb58",
      "text": "　　なぜ、すべての身体が見えないのにもかかわらず、貴方はこれが猫だとわかるのか。",
      "userId": "661b6e882a96e9002371b3c2",
      "created": 1720146221,
      "updated": 1720167209
    },
    {
      "id": "6687ab2371b3c20000583d22",
      "text": " 　　頭部を身体に含めるとすれば、[\" すべての身体が見えない]にはならない[bsahd.icon]",
      "userId": "661b6e882a96e9002371b3c2",
      "created": 1720167202,
      "updated": 1720167220
    },
    {
      "id": "6687b63100645a0000744a8b",
      "text": " 　　たしカニ、言い方間違えてるわこの人[Hyou.icon]",
      "userId": "657c19a3646988002500645a",
      "created": 1720170034,
      "updated": 1720170222
    },
    {
      "id": "6687b6f500645a0000744a8c",
      "text": " 　　　なんて言えばよかったかな。",
      "userId": "657c19a3646988002500645a",
      "created": 1720170230,
      "updated": 1720170273
    },
    {
      "id": "6687b72100645a0000744a8d",
      "text": " 　　　全身が見えなくともあなたが猫だとわかる理由は〜〜",
      "userId": "657c19a3646988002500645a",
      "created": 1720170273,
      "updated": 1720170459
    },
    {
      "id": "6687c44ded60e60000d093c4",
      "text": " 　　　全ての体が見えるわけではないのに〜[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1720173645,
      "updated": 1720173673
    },
    {
      "id": "6687595e00645a000051fb59",
      "text": "　　過去の知識があるからです。",
      "userId": "657c19a3646988002500645a",
      "created": 1720146271,
      "updated": 1720146279
    },
    {
      "id": "668761aa00645a000051fb5b",
      "text": "　ポッゲンドルフとポゲンドルフどっちですか。",
      "userId": "657c19a3646988002500645a",
      "created": 1720148395,
      "updated": 1720148409
    },
    {
      "id": "66877c6000645a0000744a87",
      "text": "　読書をしていると、一言一句記憶しなくてはと強迫観念にかられて、呼吸が浅くなる。",
      "userId": "657c19a3646988002500645a",
      "created": 1720155232,
      "updated": 1720155259
    },
    {
      "id": "6687a68800645a0000744a88",
      "text": "　あぶねぇストレスで耳が聞こえなくなるとこだった",
      "userId": "657c19a3646988002500645a",
      "created": 1720166024,
      "updated": 1720166034
    },
    {
      "id": "6687a69700645a0000744a89",
      "text": "　　自らストレスを増幅させてしまう。これだからヒューマンは",
      "userId": "657c19a3646988002500645a",
      "created": 1720166040,
      "updated": 1720166065
    },
    {
      "id": "66872acb00645a000051fb4d",
      "text": "",
      "userId": "657c19a3646988002500645a",
      "created": 1720134348,
      "updated": 1720134348
    },
    {
      "id": "66872acc00645a000051fb4e",
      "text": "[RR.icon]",
      "userId": "61e1959b21ba53001f538895",
      "created": 1720134349,
      "updated": 1720134637
    },
    {
      "id": "6687d79a5388950000d322c0",
      "text": "　吸収できてない、まずいぞ〜という焦り",
      "userId": "61e1959b21ba53001f538895",
      "created": 1720178587,
      "updated": 1720178624
    },
    {
      "id": "6687d7e55388950000d322c1",
      "text": "　一周回って(？)全部どうでもいいや楽しいことしよ〜になっちゃう",
      "userId": "61e1959b21ba53001f538895",
      "created": 1720178661,
      "updated": 1720178697
    },
    {
      "id": "6687d80a5388950000d322c2",
      "text": "　　たぶん疲れて誘惑に抗う力がなくなっているだけ、どうでもよくはない",
      "userId": "61e1959b21ba53001f538895",
      "created": 1720178699,
      "updated": 1720178745
    },
    {
      "id": "66872be85388950000880889",
      "text": "",
      "userId": "61e1959b21ba53001f538895",
      "created": 1720134633,
      "updated": 1720134633
    },
    {
      "id": "668736035729c00000b9926a",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137220,
      "updated": 1720137221
    },
    {
      "id": "668736055729c00000b9926b",
      "text": "\tサイバー攻撃怖い",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137222,
      "updated": 1720137238
    },
    {
      "id": "668736165729c00000b9926d",
      "text": "\t[https://www.npa.go.jp/publications/statistics/cybersecurity/ サイバー空間をめぐる脅威の情勢等｜警察庁Webサイト]",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137238,
      "updated": 1720137242
    },
    {
      "id": "668736195729c00000b9926e",
      "text": " \tランサムウェアについて警察が被害状況を公表してた。令和5年上半期の資料から抜粋",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137242,
      "updated": 1720140135
    },
    {
      "id": "668736b35729c00000b99271",
      "text": " \t[https://gyazo.com/8574f21b72fae980075ae034e9f7abd1]",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137396,
      "updated": 1720137398
    },
    {
      "id": "6687370c5729c00000b99273",
      "text": " \t>ランサムウェアの[感染経路]について質問したところ、49件の有効な回答があり、このうち、[ＶＰＮ機器]からの侵入が35件で71％、[リモートデスクトップ]からの侵入が５件で10％を占め、[テレワーク]等に利用される機器等のぜい弱性や強度の弱い認証情報等を利用して侵入したと考えられるものが82％と大半を占めた。",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137484,
      "updated": 1720137524
    },
    {
      "id": "6687399d5729c00000b99277",
      "text": " \t\tやっぱりテレワークかという感想",
      "userId": "65e1289acd012200235729c0",
      "created": 1720138141,
      "updated": 1720138158
    },
    {
      "id": "668738a05729c00000b99274",
      "text": " \t読んで少し意外だったこと",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137888,
      "updated": 1720137954
    },
    {
      "id": "668738e15729c00000b99275",
      "text": " \t\t[二重恐喝]（[ダブルエクストーション]）の手口は100%に近いのではなく、103件のうち65件の78%",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137954,
      "updated": 1720138092
    },
    {
      "id": "668738e55729c00000b99276",
      "text": " \t\t暗号化せずにデータの窃盗だけして対価を要求する、[ノーウェアランサム]というものが出てきた（6件）こと",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137957,
      "updated": 1720138099
    },
    {
      "id": "668775f25729c00000bb5f5b",
      "text": " [ノートパソコン]廃棄のために分解して2.5インチのSSD取り出して物理的に読込できないよう破壊してきたけど、やはり脆い",
      "userId": "65e1289acd012200235729c0",
      "created": 1720153586,
      "updated": 1720153842
    },
    {
      "id": "668776625729c00000bb5f5c",
      "text": " \t破壊方法は[ポンチ]を当て[トンカチ]で叩くだけで、強めに叩いたら貫通した",
      "userId": "65e1289acd012200235729c0",
      "created": 1720153698,
      "updated": 1720153756
    },
    {
      "id": "66877c1f5729c00000bb5f5d",
      "text": " 作業場所近くの温度計見たら、13時なのに38度でやばい",
      "userId": "65e1289acd012200235729c0",
      "created": 1720155168,
      "updated": 1720155224
    },
    {
      "id": "6687ab4371b3c20000583d23",
      "text": " \tエアコンつけろ[bsahd.icon]",
      "userId": "661b6e882a96e9002371b3c2",
      "created": 1720167235,
      "updated": 1720167239
    },
    {
      "id": "6687b70f5729c00000c8265d",
      "text": " \t\tボール盤とか旋盤とかフライス盤とか砥石とかあり開け放たれた場所なので、エアコンは設定されていない。[スポットクーラー]があるからなんとかなってる",
      "userId": "65e1289acd012200235729c0",
      "created": 1720170257,
      "updated": 1720170346
    },
    {
      "id": "6687b8be71b3c20000d46133",
      "text": " \t\t\tmajika[bsahd.icon]",
      "userId": "661b6e882a96e9002371b3c2",
      "created": 1720170686,
      "updated": 1720170688
    },
    {
      "id": "668736b65729c00000b99272",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1720137398,
      "updated": 1720137398
    },
    {
      "id": "668743ef1280f000004a946b",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720140784,
      "updated": 1720140786
    },
    {
      "id": "668743f11280f000004a946d",
      "text": " 正午に街全体に運動中止しなさい令が出てしまったが、正午にお出かけ予定を入れてしまった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720140786,
      "updated": 1720140823
    },
    {
      "id": "668744171280f000004a946e",
      "text": "  夕方にすべきだったか",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720140823,
      "updated": 1720140830
    },
    {
      "id": "69f5960b0000000000b0306e",
      "text": " ✂ [受容体の再取り込みを阻害するとか、明らかに脳神経に作用してくるやつでやばそう]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777702412,
      "updated": 1777702434
    },
    {
      "id": "6687a9781280f00000d969e2",
      "text": " ニコニコがダウンしてアニメ見る時間が激減している",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720166778,
      "updated": 1720166792
    },
    {
      "id": "6687a9871280f00000d969e3",
      "text": "  アニメ見てる余裕は本来ないので、いいことなのかもしれないが……",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720166793,
      "updated": 1720166821
    },
    {
      "id": "6687a9a61280f00000d969e4",
      "text": "  文化的な生活に支障を来している",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720166824,
      "updated": 1720166833
    },
    {
      "id": "6687b78d5729c00000c8265e",
      "text": "  同じくアニメ含む動画視聴時間が激減した[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1720170383,
      "updated": 1720170441
    },
    {
      "id": "6687b7955729c00000c8265f",
      "text": "  \tアニメ見る時間を[エルデンリング]に費やした結果、DLCを早くも終わらせてしまい次どうするか",
      "userId": "65e1289acd012200235729c0",
      "created": 1720170391,
      "updated": 1720170414
    },
    {
      "id": "6687da791280f000002ae63f",
      "text": "  \t[井戸端マイクラ部][takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720179324,
      "updated": 1720179355
    },
    {
      "id": "6687da591280f000002ae63e",
      "text": " ファミマで[新種のチュロッキー]を見つけた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720179293,
      "updated": 1720219189
    },
    {
      "id": "6688d1c8be12ad0000f49aba",
      "text": " 　ううう食べたい！サクサク食感のミニチュロッキー5個入かな[sume.icon]",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720242632,
      "updated": 1720242662
    },
    {
      "id": "668743f01280f000004a946c",
      "text": "  それです[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720140784,
      "updated": 1720568514
    },
    {
      "id": "668dcac11280f00000170ffb",
      "text": "   サクサクとあるとおり、ほかのチュロッキーと比べて柔らかめ",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720568514,
      "updated": 1720568534
    },
    {
      "id": "668dcad51280f00000170ffc",
      "text": "   [セブンのチュロッキー]と食べ比べしてみるとおもしろそう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720568534,
      "updated": 1720568576
    },
    {
      "id": "668dcab61280f00000170ff9",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720568504,
      "updated": 1720568504
    },
    {
      "id": "668dcab71280f00000170ffa",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1720568504,
      "updated": 1720568504
    },
    {
      "id": "668745f2f0f07d00009fd58f",
      "text": "[koyoshi.icon]",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720141299,
      "updated": 1720141300
    },
    {
      "id": "668745f5f0f07d00009fd590",
      "text": "\t[二日酔い]という訳ではないけれど、頭が回ってないです",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720141301,
      "updated": 1720141347
    },
    {
      "id": "66877551f0f07d000048eadd",
      "text": "\t\tダメだ！今日は仕事にならない！",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720153426,
      "updated": 1720153442
    },
    {
      "id": "66874820f0f07d00009fd593",
      "text": "\tマスコミは時として類似性の高いニュースを優先して流すことがあるから、「ニュースに数多く取りあげられている＝その事象が多い」ではないことに注意",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720141856,
      "updated": 1720141967
    },
    {
      "id": "6687c4d3ed60e60000d093c5",
      "text": "\t 世間の関心が高まってるから流すんよね[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1720173779,
      "updated": 1720173820
    },
    {
      "id": "6687af4cf0f07d000010b172",
      "text": "\tあつい～[- [扇風機.icon]][扇風機.icon]",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720168268,
      "updated": 1720170819
    },
    {
      "id": "6687eaf3f0f07d0000083bd8",
      "text": "\t一日中、脳みそから変な物質が出てるみたいで仕事にならなかった。",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720183540,
      "updated": 1720183547
    },
    {
      "id": "6687eafaf0f07d0000083bd9",
      "text": "  新手の二日酔いか？",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720183547,
      "updated": 1720183547
    },
    {
      "id": "6687eafaf0f07d0000083bda",
      "text": "  それとも暑さのせいか？",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720183547,
      "updated": 1720183547
    },
    {
      "id": "6687eafaf0f07d0000083bdb",
      "text": "  実は今もスッキリしない",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720183547,
      "updated": 1720183547
    },
    {
      "id": "6688d1e9be12ad0000f49abb",
      "text": "  🍵[sume.icon]",
      "userId": "6011af6ec190410022be12ad",
      "created": 1720242665,
      "updated": 1720242668
    },
    {
      "id": "66874612f0f07d00009fd591",
      "text": "",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1720141331,
      "updated": 1720141332
    },
