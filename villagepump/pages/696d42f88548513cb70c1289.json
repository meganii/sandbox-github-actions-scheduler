      "userId": "62919f6444e78d001d73e522",
      "created": 1768808675,
      "updated": 1768808706
    },
    {
      "id": "696de1010000000000b51da1",
      "text": " \t[JSDocでよくね？]・[JSDoc + .d.tsでよくね？]は8割撤回！",
      "userId": "62919f6444e78d001d73e522",
