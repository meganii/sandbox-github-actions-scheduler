    },
    {
      "id": "6a54d4f900000000005481a5",
      "text": "[Nrem.icon]#2026-07-13",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783944442,
      "updated": 1783944479
    },
    {
      "id": "6a54d51200000000005481a9",
      "text": "　今日も体調が悪い",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783944468,
      "updated": 1783944552
    },
    {
      "id": "6a54d56700000000005481ab",
      "text": "　　機嫌も悪い",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783944552,
      "updated": 1783944885
    },
    {
      "id": "6a54d6b100000000005481ad",
      "text": "　人の子育て日記を読むことが自分の子供時代を思い出すための記憶の取っ掛かりとなっているらしい",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783944882,
      "updated": 1783945022
    },
    {
      "id": "6a54d6e700000000005481ae",
      "text": "　　「思い出」がない。何も覚えていない",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783944937,
      "updated": 1783944969
    },
    {
      "id": "6a54d76d00000000005481b1",
      "text": "　　自発的に思い出すことができない",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783945070,
      "updated": 1783945070
    },
    {
      "id": "6a54d79b00000000005481b2",
      "text": "　　既に自分の心が失われて久しい",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783945116,
      "updated": 1783945309
    },
    {
      "id": "6a54d4ff00000000005481a6",
      "text": "　#nowplaying",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1783944448,
      "updated": 1783945399
    },
    {
      "id": "6a54d8b500000000005481b4",
