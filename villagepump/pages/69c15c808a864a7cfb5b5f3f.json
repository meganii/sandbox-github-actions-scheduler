    {
      "id": "69c15c817838e30000004f8450",
      "text": "[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774279809,
      "updated": 1774283682
    },
    {
      "id": "69c16ba400000000003eb024",
      "text": "　スマホ用の楽器UIを検討したい",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774283683,
      "updated": 1774283695
    },
    {
      "id": "69c16bef00000000003eb02c",
      "text": "　　7音階だけだったら3本指だけで表現できるな",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774283758,
      "updated": 1774283814
    },
    {
      "id": "69c16baf00000000003eb025",
      "text": "　　　ドレミﾌｧソラシ",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774283695,
      "updated": 1774283814
    },
    {
      "id": "69c16c2a00000000003eb02d",
      "text": "　　　001, 010, 011, 100, 101, 110, 111",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774283817,
      "updated": 1774283834
    },
    {
      "id": "69c16d1b00000000003eb031",
      "text": "　　　右手で7音階、左手でオクターブや半音シフトすればちょうど良さそう",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774284059,
      "updated": 1774284100
    },
    {
      "id": "69c16c5100000000003eb02e",
      "text": "　　まあ世の中には同じこと考えて既に実行してる人がいるんですが",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774283856,
      "updated": 1774284012
    },
    {
      "id": "69c16ced00000000003eb02f",
      "text": "　　　https://greenfunding.jp/kibidango/projects/8859",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774284012,
      "updated": 1774284013
    },
    {
      "id": "69c16cee00000000003eb030",
      "text": "   [笛型のUSBデバイス]で強弱つけれるようにしたのかなり賢い",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774284013,
      "updated": 1774284044
    },
    {
      "id": "69c16d5800000000003eb032",
      "text": "  何でこんなこと考えてるかって",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774284119,
      "updated": 1774284126
    },
    {
      "id": "69c16d5e00000000003eb033",
      "text": "  　スマホで簡単に作曲できるようになればいいなって",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774284126,
      "updated": 1774284147
    },
    {
      "id": "69c16d9400000000003eb034",
      "text": "  　[ピアノロール]系UI、わかりやすいけど触りづらい",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1774284179,
      "updated": 1774284197
    },
