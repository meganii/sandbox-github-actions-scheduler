    {
      "id": "6a379cbf000000000061af8c",
      "text": "長らくご無沙汰しております",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1782029504,
      "updated": 1782029505
    },
    {
      "id": "6a379cc0000000000061af8d",
      "text": "しばらくぶりのご連絡となり、恐縮でございます",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1782029505,
      "updated": 1782029517
    },
    {
      "id": "6a379ccd000000000061af8e",
      "text": "長らくご連絡できず、失礼いたしました",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1782029517,
      "updated": 1782029567
    },
    {
      "id": "6a379cfe000000000061af8f",
      "text": "ご無沙汰しており、誠に申し訳ございません",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1782029567,
      "updated": 1782029583
    },
    {
      "id": "6a379d0e000000000061af90",
      "text": "不義理をお許しください",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1782029583,
      "updated": 1782029597
    },
    {
      "id": "6a379d1d000000000061af91",
      "text": "[お久しぶりです]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1782029597,
      "updated": 1782029623
