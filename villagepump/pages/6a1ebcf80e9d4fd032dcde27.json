  "lines": [
    {
      "id": "6a1ebcf80e9d4fd032dcde27",
      "text": "地球再開発",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780399355,
      "updated": 1780399355
    },
    {
      "id": "6a1ebcda000000000033d844",
      "text": " [宇宙開発]の観点から[希哲館事業]が目指していること[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780399355,
      "updated": 1780399384
    },
    {
      "id": "6a1ebcf7000000000033d846",
      "text": "  [相通化技術]を見よ",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780399384,
      "updated": 1780399391
    },
    {
      "id": "6a1ebd06000000000033d847",
      "text": "  これは「[逆コペルニクス的転回]」だ！",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780399399,
      "updated": 1780399414
    },
    {
      "id": "6a1ec12b000000000033d850",
      "text": "  簡単に言うと、[人類]がこの調子で[宇宙]に飛び出したところで地球でやっているのと同じような宇宙間紛争を起こすだけなので、ちゃんと地球文明を完成させてから宇宙いこ？という考え",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780400460,
      "updated": 1780400521
    },
    {
      "id": "6a1ebcdb000000000033d845",
      "text": "  ここまで来たら[イーロン・マスク]も目じゃないね！",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780399356,
      "updated": 1780400555
    },
    {
      "id": "6a1ec1b8000000000033d852",
      "text": "   [SNS]よりも[KNS]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780400601,
      "updated": 1780400614
    },
    {
      "id": "6a1ec1d1000000000033d854",
      "text": "   [AI]より[IA]（[知能増幅]）",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780400626,
      "updated": 1780400646
    },
    {
      "id": "6a1ec1c0000000000033d853",
      "text": "   新しい自動車よりも[万軌]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780400609,
      "updated": 1780400625
    },
    {
      "id": "6a1ec17c000000000033d851",
      "text": "   地球外宇宙開発より地球再開発",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780400541,
      "updated": 1780400715
    },
    {
      "id": "6a1ec1e7000000000033d855",
      "text": "   我々は構想力で勝つ",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780400649,
      "updated": 1780400776
    },
    {
      "id": "6a1ec260000000000033d856",
