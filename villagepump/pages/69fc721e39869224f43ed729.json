{
  "id": "69fc721e39869224f43ed729",
  "title": "黄金の20年代",
  "created": 1778152000,
  "updated": 1778268170,
  "lines": [
    {
      "id": "69fc721e39869224f43ed729",
      "text": "黄金の20年代",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152000,
      "updated": 1778152000
    },
    {
      "id": "69fe37fb0000000000db544a",
      "text": "1920年代のこと",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778268156,
      "updated": 1778268170
    },
    {
      "id": "69fc723f0000000000ce9e89",
      "text": "[Golden Twenties]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152000,
      "updated": 1778152001
    },
    {
      "id": "69fe2d690000000000d65699",
      "text": " アメリカ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778265450,
      "updated": 1778265456
    },
    {
      "id": "69fe2d700000000000d6569a",
      "text": " 　[Roaring Twenties]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778265456,
      "updated": 1778265555
    },
    {
      "id": "69fe2dca0000000000d6569b",
      "text": " 　 [狂騒の20年代]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778265555,
      "updated": 1778265555
    },
    {
      "id": "69fc72410000000000ce9e8a",
      "text": "　ドイツ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778263921
    },
    {
      "id": "69fe27540000000000d6568a",
      "text": "　　goldene zwanziger Jahre（ゴルデネ・ツワンツィガー・ヤーレ）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778263893,
      "updated": 1778263913
    },
    {
      "id": "69fe28250000000000d6568e",
      "text": "　　　黄金の20年代",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264102,
      "updated": 1778264103
    },
    {
      "id": "69fc72410000000000ce9e8b",
      "text": "　　ハイパーインフレ後の経済回復期",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778264491
    },
    {
      "id": "69fc72410000000000ce9e8c",
      "text": "　　自由な雰囲気の中で、モダニズム文化が急速に発展した",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778264512
    },
    {
      "id": "69fc72410000000000ce9e8d",
      "text": "  [ヴァイマル文化]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fc72db0000000000ce9e93",
      "text": "  [バウハウス]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152156,
      "updated": 1778152166
    },
    {
      "id": "69fe27e50000000000d6568c",
      "text": "  ベルリン",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264038,
      "updated": 1778264046
    },
    {
      "id": "69fe29a20000000000d65692",
      "text": "   ベルリンを中心に前衛的な芸術、文学、音楽、演劇が花開いた",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264483,
      "updated": 1778264519
    },
    {
      "id": "69fe29c80000000000d65693",
      "text": "   [前衛芸術]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264520,
      "updated": 1778264543
    },
    {
      "id": "69fc72410000000000ce9e8e",
      "text": " フランス",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fe27c70000000000d6568b",
      "text": " 　les années folles（レザネ・フォール）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264008,
      "updated": 1778264034
    },
    {
      "id": "69fe284b0000000000d6568f",
      "text": " 　　狂気の年々",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264140,
      "updated": 1778264144
    },
    {
      "id": "69fc72410000000000ce9e8f",
      "text": "　 [アールデコ]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fe280b0000000000d6568d",
      "text": "　 パリ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264075,
      "updated": 1778264079
    },
    {
      "id": "69fe28df0000000000d65690",
      "text": "　 　[ロシア革命]によって亡命してきたロシア人",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264288,
      "updated": 1778264297
    },
    {
      "id": "69fe292c0000000000d65691",
      "text": "　 　[禁酒法]から逃れてきたアメリカ人",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264364,
      "updated": 1778264392
    },
    {
      "id": "69fc72410000000000ce9e90",
      "text": "　日本",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778264722
    },
    {
      "id": "69fe2a930000000000d65695",
      "text": "　　[大正デモクラシー]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264723,
      "updated": 1778264743
    },
    {
      "id": "69fe2ab30000000000d65696",
      "text": "　　[関東大震災]（1923年）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778264755,
      "updated": 1778265048
    },
    {
      "id": "69fe2d240000000000d65697",
      "text": "　　[阪神間モダニズム]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778265380,
      "updated": 1778265389
    },
    {
      "id": "69fe2a8c0000000000d65694",
