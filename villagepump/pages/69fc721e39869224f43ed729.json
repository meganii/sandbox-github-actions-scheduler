    {
      "id": "69fc721e39869224f43ed729",
      "text": "黄金の20年代",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152000,
      "updated": 1778152000
    },
    {
      "id": "69fc723f0000000000ce9e89",
      "text": "[Golden Twenties]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152000,
      "updated": 1778152001
    },
    {
      "id": "69fc72410000000000ce9e8a",
      "text": "　ドイツ（Goldene Zwanziger）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fc72410000000000ce9e8b",
      "text": "　　ハイパーインフレ後の経済回復期を指し、ベルリンを中心に前衛的な芸術、文学、音楽、演劇が花開きました。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fc72410000000000ce9e8c",
      "text": "　　自由な雰囲気の中で、モダニズム文化が急速に発展しました。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fc72410000000000ce9e8d",
      "text": "  [ヴァイマル文化]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fc72db0000000000ce9e93",
      "text": "  [バウハウス]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152156,
      "updated": 1778152166
    },
    {
      "id": "69fc72410000000000ce9e8e",
      "text": " フランス",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1778152001,
      "updated": 1778152001
    },
    {
      "id": "69fc72410000000000ce9e8f",
      "text": "　 [アールデコ]",
      "userId": "5b5e7121417cf700145b98c2",
