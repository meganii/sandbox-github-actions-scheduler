    },
    {
      "id": "69e6f90c00000000006149eb",
      "text": "アツアツ霧",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1776744716,
      "updated": 1776744811
    },
    {
      "id": "69e6f96b00000000006149ef",
      "text": "\t井戸端村で時折おきる奇妙な気象現象",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1776744811,
      "updated": 1776744846
    },
    {
      "id": "69e6f98d00000000006149f0",
      "text": "\tアツアツと錯覚するような霧が発生する",
      "userId": "5ffbd8b8512f4e001cae68fd",
