{
  "id": "69f13d43496d28a2065cb997",
  "title": "昭和天皇",
  "created": 1777417540,
  "updated": 1777417609,
  "lines": [
    {
      "id": "69f13d43496d28a2065cb997",
      "text": "昭和天皇",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417540
    },
    {
      "id": "69f13d440000000000264707",
      "text": "from [2026/04/29]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417540
    },
    {
      "id": "69f13d4f0000000000264719",
      "text": " 昭和の日か。今年は昭和101年[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417551,
      "updated": 1777417552
    },
    {
      "id": "69f13d490000000000264718",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417544,
      "updated": 1777417544
    },
    {
      "id": "69f13d44000000000026470a",
      "text": "昭和天皇の誕生は1901年（明治34年）の4月29日",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417547
    },
    {
      "id": "69f13d44000000000026470b",
      "text": "大正10年から大正の最後（15年）まで摂政、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417568
    },
    {
      "id": "69f13d44000000000026470c",
      "text": "在位は1926年（大正15年・昭和元年）12月25日―1989年（昭和64年）1月7日",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417547
    },
    {
      "id": "69f13d44000000000026470d",
      "text": "大日本帝国憲法下の「統治権の総攬者」としての天皇と日本国憲法下の「象徴天皇」の両方を経験、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417547
    },
    {
      "id": "69f13d66000000000026471a",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417573,
      "updated": 1777417573
    },
    {
      "id": "69f13d44000000000026470e",
      "text": "激動の時代",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417587
    },
    {
      "id": "69f13d44000000000026470f",
      "text": "\t1904年（明治37年）―1905年（明治38年）に日露戦争",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417602
    },
    {
      "id": "69f13d440000000000264710",
      "text": "\t1914年（大正3年）―1918年（大正7年）に第一次世界大戦",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417602
    },
    {
      "id": "69f13d440000000000264711",
      "text": "\t1923年（大正12年）に関東大震災",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417603
    },
    {
      "id": "69f13d440000000000264712",
      "text": "\t1929年（昭和4年）に昭和恐慌",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417603
    },
    {
      "id": "69f13d440000000000264713",
      "text": "\t1931年（昭和6年）に満州事変",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417606
    },
    {
      "id": "69f13d440000000000264714",
      "text": "\t1937年から（昭和12年）支那事変→日中戦争→第二次世界大戦",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417607
    },
    {
      "id": "69f13d440000000000264715",
      "text": "\t1941年から（昭和16年）太平洋戦争→第二次世界大戦",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417608
    },
    {
      "id": "69f13d440000000000264716",
      "text": "\t1945年（昭和20年）終戦",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417609
    },
    {
      "id": "69f13d440000000000264717",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777417540,
      "updated": 1777417540
    }
  ]
}