  "lines": [
    {
      "id": "6a210e2e5c80ce21fe701455",
      "text": "チャンク化",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780551218,
      "updated": 1780551218
    },
    {
      "id": "6a210e3200000000002e906d",
      "text": "[チャンク]（chunk）、チャンキング（chunking）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780551218,
      "updated": 1780562916
    },
    {
      "id": "6a213b59000000000027749a",
      "text": "https://ja.wikipedia.org/wiki/チャンキング",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780562777,
      "updated": 1780562779
    },
    {
      "id": "6a210e3300000000002e906e",
      "text": ">心理学では、情報の断片を類似性など何らかの原理に基づいてより大きな情報の断片の中に統合する過程。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780551219,
      "updated": 1780551245
    },
    {
      "id": "6a210e4e00000000002e9070",
      "text": "> 認知心理学では、容量の小さい作業記憶で扱えるように、知識を構造化し圧縮すること。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780551245,
      "updated": 1780551245
    },
    {
      "id": "6a210e4e00000000002e9071",
      "text": "> 記憶術では、記憶すべき対象を分割したりグループ化したりして記憶の負担を軽減するテクニック。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780551245,
      "updated": 1780551245
    },
    {
      "id": "6a210e4e00000000002e9072",
      "text": "> 自然言語処理では、言語データをより小さな構成要素に分割したり、より大きな構成要素にまとめたりする処理",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780551245,
      "updated": 1780551245
    },
    {
      "id": "6a210e4e00000000002e9073",
      "text": "> ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780551245,
      "updated": 1780551245
    },
    {
      "id": "6a210e3800000000002e906f",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1780551224,
      "updated": 1780551224
    },
    {
      "id": "6a213ba0000000000027749b",
      "text": "チャンクアップ（chunk up）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780562848,
      "updated": 1780562860
    },
    {
      "id": "6a213bac000000000027749c",
      "text": "チャンクダウン（chunk down）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1780562860,
      "updated": 1780562860
    }
  ]
}