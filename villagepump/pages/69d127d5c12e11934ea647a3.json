  "lines": [
    {
      "id": "69d127d5c12e11934ea647a3",
      "text": "2026/04/05",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775314901,
      "updated": 1775314901
    },
    {
      "id": "69d127d56eb406000000fd445c",
      "text": "第15週: [[日]]月火水木金土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775314901,
      "updated": 1775314901
    },
    {
      "id": "69d127d56eb40600000093bf26",
      "text": "2026年 26.03％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775314901,
      "updated": 1775314901
    },
    {
      "id": "69d127d56eb4060000001db23e",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775314901,
      "updated": 1775314901
    },
    {
      "id": "69d127d56eb40600000008603d",
      "text": "[Mijikko.icon] [2026-04-04~06 Mijikko]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1775314901,
      "updated": 1775319213
    },
    {
      "id": "69d127d56eb406000000f9e296",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775314901,
      "updated": 1775314901
    },
    {
      "id": "69d1399f0000000000a8d77f",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775319455,
      "updated": 1775319457
    },
    {
      "id": "69d903fa00000000002d0bf2",
      "text": "\t[謎解き2026-04-04]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775830013,
      "updated": 1775830111
    },
    {
      "id": "69d9045c00000000002d0bf3",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775830111,
      "updated": 1775830111
    },
    {
      "id": "69d14be00000000000cf4f2b",
      "text": "[はるひ.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775324129,
      "updated": 1775830111
    },
    {
      "id": "69d14be10000000000cf4f2c",
      "text": "\t遂にギルティ炭酸飲んだ 感無量",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775324129,
      "updated": 1775326096
    },
    {
      "id": "69d1536d0000000000e5ae1e",
      "text": "\t>[https://x.com/MAMAAAAU/status/2040378980499632270?s=20 @MAMAAAAU]: セックスしないと出られない部屋にひとりで入れられてもう３０年になります",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775326062,
      "updated": 1775374569
    },
    {
      "id": "69d210e80000000000693841",
      "text": "  こういう話大好きだ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775374569,
      "updated": 1775374573
    },
    {
      "id": "69d210ec0000000000693842",
      "text": "  (セク部屋は存在自体が気持ち悪いのでNG)",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775374573,
      "updated": 1775374666
    },
    {
      "id": "69d211280000000000693843",
      "text": "  (大量虐殺はNG) だと間違えて覚えていた　正しくは[(虐殺行為はNO)]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775374633,
      "updated": 1775374672
    },
    {
      "id": "69d26fce00000000007fe0c1",
      "text": "  \t同じ勘違いしてた[imo.icon]",
      "userId": "5ad57975d54cd50014068484",
      "created": 1775398863,
      "updated": 1775398928
    },
    {
      "id": "69d2275100000000002852eb",
      "text": "  判定モジュール内部では生成AIが動いており、AIの采配次第なので、知的生産者の僕は定義を変えて納得させることで対応できる[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775380307,
      "updated": 1775380341
    },
    {
      "id": "69d1c6b90000000000a76ccc",
      "text": "\t間取り決めるがむずい！",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775355577,
      "updated": 1775355646
    },
    {
      "id": "69d1c6c00000000000a76ccd",
      "text": "\t ソファに座ってテレビが見る これがやりたいが、必要でないだけに、まずベッドとデスク等の位置を決めてしまったので、コンセントもおさまりのよいところもなくなってる",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775355585,
      "updated": 1775355672
    },
    {
      "id": "69d1fa9d00000000007daf73",
      "text": "\t[Huel]の初回割引コードあります",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775368863,
      "updated": 1775369145
    },
    {
      "id": "69d20e950000000000693840",
      "text": "\t寒い",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775373974,
      "updated": 1775373976
    },
    {
      "id": "69d26dbe0000000000b0b958",
      "text": "\t井戸端でテキストエリアの中にカーソル持ってくと色薄くなるの、引っ越しでバグったのかCSS変えた？影響なのか",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775398334,
      "updated": 1775398377
    },
    {
      "id": "69d26e390000000000b0b959",
      "text": "\t小さいパックの牛乳をランチのために鞄に入れようとおもたが、保冷剤一緒のほうがいいかな？",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775398458,
      "updated": 1775398476
    },
    {
      "id": "69d26e4c0000000000b0b95a",
      "text": "\t\t世のベイビーママは哺乳瓶持ち歩く時保冷しているんだろうか",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775398476,
      "updated": 1775398500
    },
    {
      "id": "69d26e900000000000b0b95b",
      "text": " \t\tそういうことではないらしい",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775398544,
      "updated": 1775398548
    },
    {
      "id": "69d139a80000000000a8d782",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775319465,
      "updated": 1775319465
    },
    {
      "id": "69d1979500000000002e1de5",
      "text": "[nyarla.icon]",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343509,
      "updated": 1775343511
    },
    {
      "id": "69d1979800000000002e1de7",
      "text": " 眠い",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343512,
      "updated": 1775343536
    },
    {
      "id": "69d197b000000000002e1de9",
      "text": " Cloudflare Workers を解約してみたけど、どうなるんだろうな",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343537,
      "updated": 1775343581
    },
    {
      "id": "69d197de00000000002e1dea",
      "text": "  前に契約したときは CPU 時間の問題だったのだけど、今は処理が変わってる",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343582,
      "updated": 1775343638
    },
    {
      "id": "69d1981800000000002e1deb",
      "text": "   このため問題が出るかどうかは不明",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343640,
      "updated": 1775343660
    },
    {
      "id": "69d1982d00000000002e1dec",
      "text": "   あと 5 USD のサービスが 900円前後になるのは普通に厳しい",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343661,
      "updated": 1775343752
    },
    {
      "id": "69d1986a00000000002e1ded",
      "text": "    円安はもうちょっとなんとかならんか",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343723,
      "updated": 1775343754
    },
    {
      "id": "69d1cbe00000000000d51f2e",
      "text": " 久しぶりにタスクリストの棚卸しをやっていた",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775356897,
      "updated": 1775356912
    },
    {
      "id": "69d1cbf10000000000d51f30",
      "text": "\t\t数時間ほどやっていたので結構つかれた〜",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775356913,
      "updated": 1775356926
    },
    {
      "id": "69d24d920000000000d1bfce",
      "text": "\t[最近のソフトウェアエンジニアは生成AIの話しかしてないように見えるが大丈夫か？]",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775390099,
      "updated": 1775391883
    },
    {
      "id": "69d2540d0000000000d1bff9",
      "text": "\t\t↑なんか呪いというか呪詛みたいな文章が産まれてしまった",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775391758,
      "updated": 1775392484
    },
    {
      "id": "69d2542b0000000000d1bffa",
      "text": "\t\t\t切り出した方がいいか",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775391787,
      "updated": 1775392486
    },
    {
      "id": "69d2548100000000009a7b1b",
      "text": "\t\t\t\t切り出した",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775391874,
      "updated": 1775392491
    },
    {
      "id": "69d256ec00000000009a7b25",
      "text": "\t\t[nyarla.icon]は生成AI技術自体には反対しない人間だけど、生成AIを「使わせる」人間にはなんとなくの反発心がある",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775392492,
      "updated": 1775392527
    },
    {
      "id": "69d2572700000000009a7b28",
      "text": "\t\t\t結局、生成AIを使って口数減らしをしたいだけでしょ、っていう",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775392551,
      "updated": 1775392574
    },
    {
      "id": "69d2573f00000000009a7b29",
      "text": "\t\t\t\t現状アメリカとかそういうのが起きてる訳で、なに考えてるんだ、と思ってます",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775392575,
      "updated": 1775392594
    },
    {
      "id": "69d1a1db00000000001f5657",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775346139,
      "updated": 1775346139
    },
    {
      "id": "69d1a1db00000000001f5658",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775346139,
      "updated": 1775346141
    },
    {
      "id": "69d1a1df00000000001f5659",
      "text": " カードもらったので日曜でも研究室入れる",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775346142,
      "updated": 1775346176
    },
    {
      "id": "69d1a20100000000001f565a",
      "text": " 家からdisplayを持って行く",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775346176,
      "updated": 1775346200
    },
    {
      "id": "69d1a21b00000000001f565b",
      "text": " 明日から授業",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775346202,
      "updated": 1775346212
    },
    {
      "id": "69d1a22500000000001f565c",
      "text": "  どっかの学科の多様体の授業に出てみる",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775346212,
      "updated": 1775346244
    },
    {
      "id": "69d1a24500000000001f565d",
      "text": "  ついていけるかな",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775346245,
      "updated": 1775346252
    },
    {
      "id": "69d1c24f0000000000c218d3",
      "text": " display変えた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354448,
      "updated": 1775354454
    },
    {
      "id": "69d1c2560000000000c218d4",
      "text": "  左右縦、中央横",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354454,
      "updated": 1775354462
    },
    {
      "id": "69d1c25d0000000000c218d5",
      "text": "  後日もう一台持ってきて、3台とも縦にしてみるつもり",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354462,
      "updated": 1775354473
    },
    {
      "id": "69d1c2680000000000c218d6",
      "text": " なんだかんだで今まで2画面までしか使ったことないから、あまり慣れない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354473,
      "updated": 1775354493
    },
    {
      "id": "69d1c27d0000000000c218d7",
      "text": " 　まあそのうちいい感じの使い方がわかるようになるか",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354493,
      "updated": 1775354508
    },
    {
      "id": "69d1c28b0000000000c218d8",
      "text": " 　不要なら減らせばいいし",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354508,
      "updated": 1775354511
    },
    {
      "id": "69d1c2d90000000000ec0bbb",
      "text": " それよりPC台がほしい",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354589,
      "updated": 1775354590
    },
    {
      "id": "69d1c2de0000000000ec0bbc",
      "text": " 　首が痛くなっちゃう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354590,
      "updated": 1775354603
    },
    {
      "id": "69d1c2eb0000000000ec0bbe",
      "text": " 　3Dプリンターで作るか",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354603,
      "updated": 1775354607
    },
    {
      "id": "69d1c2ee0000000000ec0bbf",
      "text": " 　 [BambuLab X1 Carbon Combo]と[Bambu Lab H2D]の2台構成なのやばすぎ",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775354607,
      "updated": 1775354641
    },
    {
      "id": "69d26ddc0000000000f0a02f",
      "text": " まだ講習会の確認終えられてない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775398363,
      "updated": 1775398396
    },
    {
      "id": "69d26dfd0000000000f0a030",
      "text": " 無茶苦茶動いてる。まだ身体が動いているのが不思議",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775398396,
      "updated": 1775398425
    },
    {
      "id": "69d26e190000000000f0a031",
      "text": "  そろそろ倒れてもおかしくない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775398425,
      "updated": 1775398437
    },
    {
      "id": "69d26e260000000000f0a032",
      "text": " 明日5時くらいに起きないと1限間に合わない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775398437,
      "updated": 1775398465
    },
    {
      "id": "69d26e410000000000f0a033",
      "text": "  なんで数学科3年の必修授業なんかとろうとしたのか",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775398465,
      "updated": 1775398503
    },
    {
      "id": "69d26e680000000000f0a034",
      "text": "  しかもキャンパス違うし",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775398503,
      "updated": 1775398515
    },
    {
      "id": "69d26e7b0000000000f0a035",
      "text": "  完全に好奇心だけで履修組んでる",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1775398522,
      "updated": 1775398539
    },
    {
      "id": "69d270b4000000000077d954",
      "text": " また頑張りすぎていないか心配[yosider.icon][caki.icon][Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1775399092,
      "updated": 1775431916
    },
    {
      "id": "69d2713d000000000077d955",
      "text": "  単位取得に体力を使うより、研究を優先したほうがいいのではなかろうか…",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775399229,
      "updated": 1775400210
    },
    {
      "id": "69d2746400000000006615e0",
      "text": "  🍵🍘[caki.icon][yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775400037,
      "updated": 1775400201
    },
    {
      "id": "69d281df00000000002bcd9a",
      "text": "  指導教官に相談してみたら[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775403488,
      "updated": 1775403499
    },
    {
      "id": "69d281f500000000002bcd9b",
      "text": "  \t大学院の単位ってそんなに大事じゃないと思う",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775403510,
      "updated": 1775403536
    },
    {
      "id": "69d1979500000000002e1de6",
      "text": "",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1775343509,
      "updated": 1775343509
    },
    {
      "id": "69d1ae2c0000000000a6de94",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775349292,
      "updated": 1775349294
    },
    {
      "id": "69d1ae2e0000000000a6de95",
      "text": "　寝て起きた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775349294,
      "updated": 1775349297
    },
    {
      "id": "69d3047400000000004f5116",
      "text": "\t[U理論とAIコーディング]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775436916,
      "updated": 1775436924
    },
    {
      "id": "69d3047b00000000004f5117",
      "text": "　日本橋周遊謎解きをしてきました",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775436923,
      "updated": 1775436923
    },
    {
      "id": "69d278ca00000000004f510c",
      "text": "　\t[https://gyazo.com/5f6b3426c59613e76a6d6fc67bf4a222][https://gyazo.com/0b675afa1dee98d266d2768633a264d3]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775401164,
      "updated": 1775401177
    },
    {
      "id": "69d278db00000000004f510f",
      "text": "\t時間が余ったのでナゾスタンドに来ました",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775401181,
      "updated": 1775401192
    },
    {
      "id": "69d278e600000000004f5110",
      "text": "\t\t[https://gyazo.com/6ff311b21a821060cc91e0366c0e0c4c]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775401193,
      "updated": 1775401202
    },
    {
      "id": "69d1afa86eb406000000c3ba50",
      "text": "　謎解きがひと段落してぼんやりしていた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775349673,
      "updated": 1775401181
    },
    {
      "id": "69d26be40000000000baec44",
      "text": "\t\t[https://gyazo.com/3cf1d16913b0312b1ab008ca4a10fb7e][https://gyazo.com/77376442cce50cbb530f391a22cd49f8]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775397860,
      "updated": 1775401220
    },
    {
      "id": "69d2790200000000004f5113",
      "text": "\tすごいボリュームだった",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775401220,
      "updated": 1775401246
    },
    {
      "id": "69d2791c00000000004f5114",
      "text": "\tルール的にクリア画像をクリアしたタイミングでSNSに投稿するのはOKなんだけど、その結果として勘のいい人は[~ プレイヤーが全部終わったと思って帰宅した後にさらに別の謎解きが始まっていること]に気づくかもしれないな",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775401246,
      "updated": 1775401469
    },
    {
      "id": "69d279fa00000000004f5115",
      "text": "\t\tまあそれはそう",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775401469,
      "updated": 1775401482
    },
    {
      "id": "69d278fb00000000004f5112",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775401214,
      "updated": 1775401214
    },
    {
      "id": "69d26be40000000000baec45",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775397860,
      "updated": 1775397860
    },
    {
      "id": "69d1c1a60000000000caad32",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775354279,
      "updated": 1775354279
    },
    {
      "id": "69d3048e00000000004f5118",
      "text": "\t[U理論とAIコーディング]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775436942,
      "updated": 1775436957
    },
    {
      "id": "69d3049c00000000004f5119",
      "text": "\t[suto3.icon]さんのアイコンがなんか毎回変わってる？は気のせいじゃなかった",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775436957,
      "updated": 1775436957
    },
    {
      "id": "69d1d9410000000000f28c4f",
      "text": "\t\tそんなことできるのか",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775360322,
      "updated": 1775360324
    },
    {
      "id": "69d1d96f000000000034ebd2",
      "text": "\t\thttps://svg-hosting.vercel.app/api/svg?url=https://scrapbox.io/api/code/suto3/す/su.svg",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775360369,
      "updated": 1775360374
    },
    {
      "id": "69d1e5fe00000000004328c0",
      "text": "\t\t　やってみたらできたの[suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775363583,
      "updated": 1775363606
    },
    {
      "id": "69d1e61c00000000004328c1",
      "text": "\t\t　 ちなみに、30分（1800秒）周期でループしてます",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775363613,
      "updated": 1775363665
    },
    {
      "id": "69d21a41000000000072ba56",
      "text": "\t\t　  [30分タイマー.icon] ←これの色が変わるところを使っています",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775376961,
      "updated": 1775377055
    },
    {
      "id": "69d1e6ae000000000058e604",
      "text": "\t\t　 たまに色が変わるイメージなのはそういうことだったのか[Summer498.icon][yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775363758,
      "updated": 1775368474
    },
    {
      "id": "69d211400000000000b53216",
      "text": "\t\t　 　顔色が悪い時があるのかと思った[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775374656,
      "updated": 1775374672
    },
    {
      "id": "69d1d9340000000000f28c4e",
      "text": "\t\t最近見ないけど[biwa.icon]のアイコンの変化が大きいから分かりやすい[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775360310,
      "updated": 1775360788
    },
    {
      "id": "69d1daf500000000009ebdde",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775360757,
      "updated": 1775360757
    },
    {
      "id": "69d1c7330000000000faf850",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775355702,
      "updated": 1775355703
    },
    {
      "id": "69d1c7370000000000faf851",
      "text": " 春い",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775355704,
      "updated": 1775355709
    },
    {
      "id": "69d1cac5000000000058db7a",
      "text": " \t[脳内BGM]で2曲が行ったり来たり: [\" こういう夢ならもう一度逢いたい]↔︎[\" 夢ならばどれほどよかったでしょう] ",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1775356614,
      "updated": 1775358453
    },
    {
      "id": "69d1c7620000000000faf852",
      "text": " [U理論]懐かしい",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775355747,
      "updated": 1775437666
    },
    {
      "id": "69d1c77a0000000000faf853",
      "text": "  中土井さん元気かな",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775355771,
      "updated": 1775355780
    },
    {
      "id": "69d307b600000000002c66a4",
      "text": "  \t[中土井僚][nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775437750,
      "updated": 1775437754
    },
    {
      "id": "69d1ce8e0000000000138758",
      "text": " [suto3.icon]さんのアイコンがたまに[うすチュウ]ぽくなってて面白い",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775357583,
      "updated": 1775357603
    },
    {
      "id": "69d1d9210000000000f28c4d",
      "text": " \t美味しそうな色になっていることが多い[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775360291,
      "updated": 1775360306
    },
    {
      "id": "69d211a50000000000b53217",
      "text": " \tうすチュウ見てから[ふつうチュウ]見ると、脂ギッシュテカテカマッチョマンみたいな印象がある(いいすぎ)[nishio.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775374758,
      "updated": 1775383215
    },
    {
      "id": "69d1d8970000000000da714e",
      "text": " [誤読の自由]って[筒井康隆]が言い出しっぺなのか",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775360152,
      "updated": 1775360181
    },
    {
      "id": "69d1e34a00000000006c7c8f",
      "text": " 京王線特急に乗っていたら[飛田給]に臨時停車。たくさん人が降りてった。今日何かあるのかな？",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775362891,
      "updated": 1775386560
    },
    {
      "id": "69d222050000000000b7c436",
      "text": " 知らない神社にて。入口の鳥居横にアルコール置いてあったので消毒した。そのすぐ先で、手水でも手と口をすすいだ。完全に清まった。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775378950,
      "updated": 1775381340
    },
    {
      "id": "69d232d10000000000f6c936",
      "text": "  順番逆のほうが科学的には清まりそう[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775383249,
      "updated": 1775383261
    },
    {
      "id": "69d23ee300000000008fb013",
      "text": " 賑やかだ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775386340,
      "updated": 1775386342
    },
    {
      "id": "69d23ee600000000008fb014",
      "text": " \t[https://gyazo.com/1e4ae4cf11d8f24f4f280c8bf764f8f2]https://www.huffingtonpost.jp/entry/story_jp_69cf6593e4b0d214cc710ad0",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775386342,
      "updated": 1775389507
    },
    {
      "id": "69d24b420000000000a6524e",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775389507,
      "updated": 1775389507
    },
    {
      "id": "69d1c83a00000000002a3ee0",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775355963,
      "updated": 1775355964
    },
    {
      "id": "69d1c83c00000000002a3ee1",
      "text": "[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775355964,
      "updated": 1775355966
    },
    {
      "id": "69d1c85600000000002a3ee3",
      "text": " [【画像】NASAライブ配信に映っていたセーラームーンの猫「アルテミス」そっくりのぬいぐるみ | ハフポスト 画像枠 https://www.huffingtonpost.jp/entry/story_jp_69cf6593e4b0d214cc710ad0]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775355991,
      "updated": 1775368553
    },
    {
      "id": "69d1c83e00000000002a3ee2",
      "text": "  アルテミス2の管制室に[アルテミス]のぬいおいてあるのかわいい",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775355967,
      "updated": 1775368588
    },
    {
      "id": "69d20437000000000069a4bb",
      "text": " AIとの生活、常に何をしたいかを問われてる感じがする",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775371319,
      "updated": 1775371338
    },
    {
      "id": "69d204e8000000000069a4bc",
      "text": " 令和3年の備蓄米を昨年7月に精米したやつが出てきたので食べている",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775371496,
      "updated": 1775371520
    },
    {
      "id": "69d204ff000000000069a4bd",
      "text": "  ややパサだが特になんの問題もない",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775371520,
      "updated": 1775371535
    },
    {
      "id": "69d215140000000000cd57d7",
      "text": " ぽこポケ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775375636,
      "updated": 1775375640
    },
    {
      "id": "69d215180000000000cd57d8",
      "text": "  [出会って5秒で友達になる力]、人間もほしい",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775375640,
      "updated": 1775397599
    },
    {
      "id": "69d261820000000000ccb148",
      "text": " BTS、以前からメンバーの仲がいい理由を問われると喧嘩した時にみんなで集まってわかりあうまで話す、みたいに言っていて、最近のインタビューでそれ聞いて井戸端の姿勢に似てるよなと思った",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775395202,
      "updated": 1775395284
    },
    {
      "id": "69d1c1a60000000000caad31",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1775354279,
      "updated": 1775354279
    },
    {
      "id": "69d1cce70000000000201cb3",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775357160,
      "updated": 1775357161
    },
    {
      "id": "69d1cce90000000000201cb5",
      "text": "\t借金1200兆円って聞くとヤバそうに見えるけど、年収12年分って思うと「そういう人いそう」と思える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775357161,
      "updated": 1775357220
    },
    {
      "id": "69d1cd540000000000201cb6",
      "text": "\t\t日本が借金を返済するとどこに向かうのか？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775357268,
      "updated": 1775357283
    },
    {
      "id": "69d1cd630000000000201cb7",
      "text": "\t\t国債を買った人",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775357283,
      "updated": 1775357289
    },
    {
      "id": "69d1cdd30000000000201cb9",
      "text": "\t\t\t富裕層",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775357396,
      "updated": 1775357398
    },
    {
      "id": "69d1cddb0000000000201cba",
      "text": "\t戦争の時に国債を発行しまくって資金を回収した後に敗戦後に踏み倒して紙屑になった話があったような",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775357404,
      "updated": 1775368141
    },
    {
      "id": "69d1f7cc00000000005c124d",
      "text": "\t\t千億円くらいの国債が発行されたとか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775368141,
      "updated": 1775368156
    },
    {
      "id": "69d25e0d000000000083f91d",
      "text": "\t世界は星の巡りで動いている",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775394318,
      "updated": 1775394326
    },
    {
      "id": "69d25e16000000000083f91e",
      "text": "\t\tと言うと胡散臭い占星術師みたいだが、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775394327,
      "updated": 1775394377
    },
    {
      "id": "69d25e48000000000083f920",
      "text": "\t\tカレンダーを制定するために天体観測が必須",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775394377,
      "updated": 1775394377
    },
    {
      "id": "69d25e49000000000083f921",
      "text": "\t\t季節に合わせて動かないと非効率（という言葉ではヌルい地獄）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775394378,
      "updated": 1775394480
    },
    {
      "id": "69d1cce70000000000201cb4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775357160,
      "updated": 1775357160
    },
    {
      "id": "69d1fab30000000000b83d7f",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1775368885,
      "updated": 1775368886
    },
    {
      "id": "69d1fab50000000000b83d80",
      "text": "\t買ってきた焼豚、[バーナー]で[炙る]だけで１ランク上にクラスチェンジしたかのような旨さになって驚き",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1775368887,
      "updated": 1775374764
    },
    {
      "id": "69d1fb0e0000000000b83d81",
      "text": "\t\tやはり火は大事か",
      "userId": "65e1289acd012200235729c0",
      "created": 1775368976,
      "updated": 1775368982
    },
    {
      "id": "69d26afe0000000000baec41",
      "text": "\t\t　いいなぁ、バーナー買おうかなぁ[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775397631,
      "updated": 1775397640
    },
    {
      "id": "69d26b080000000000baec42",
      "text": "\t\t　　一時期の[火遊び]は[デイキャンプ]に行ってガチの[焚き火]をしたら満たされて最近やってない",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775397640,
      "updated": 1775397704
    },
    {
      "id": "69d26f240000000000b0b95c",
      "text": "\t\t　　さっき[nishio.icon]さんの焚き火のこと考えてたw[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775398692,
      "updated": 1775398703
    },
    {
      "id": "69d2707d00000000007fe0c7",
      "text": "\t\t　炙りとかいう万能エンチャント[imo.icon]",
      "userId": "5ad57975d54cd50014068484",
      "created": 1775399038,
      "updated": 1775399053
    },
    {
      "id": "69d1fb140000000000b83d82",
      "text": "\t\t特に青い炎部分を当てるようにして一気に表面だけ薄く焦がすと、くどいと思える脂が旨味に変換された感じがする",
      "userId": "65e1289acd012200235729c0",
      "created": 1775368982,
      "updated": 1775369028
    },
    {
      "id": "69d1fb4f0000000000b83d83",
      "text": "\t\tそのうち試したいのは寿司、おにぎり、チーズ",
      "userId": "65e1289acd012200235729c0",
      "created": 1775369041,
      "updated": 1775369058
    },
    {
      "id": "69d250760000000000647891",
      "text": "\t今日知ったもの[国際情勢ビューア]",
      "userId": "65e1289acd012200235729c0",
      "created": 1775390838,
      "updated": 1775390845
    },
    {
      "id": "69d1fab30000000000b83d7e",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1775368885,
      "updated": 1775368885
    },
    {
      "id": "69d2182800000000003dae5b",
      "text": "[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1775376424,
      "updated": 1775376429
    },
    {
      "id": "69d2182d00000000003dae5d",
      "text": "　[ファクトチェック]のそれみたいに、宗教メディアの宗派が何かをアイコン等で知らせてくれる拡張機能が欲しい",
      "userId": "688c296691686a314f82fb52",
      "created": 1775376429,
      "updated": 1775377000
    },
    {
      "id": "69d218b400000000003dae5e",
      "text": "　\t一々どの宗派か調べるのは面倒",
      "userId": "688c296691686a314f82fb52",
      "created": 1775376564,
      "updated": 1775376607
    },
    {
      "id": "69d2182b00000000003dae5c",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1775376428,
      "updated": 1775376428
    },
    {
      "id": "69d220910000000000462b5a",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775378578,
      "updated": 1775378580
    },
    {
      "id": "69d220930000000000462b5d",
      "text": " レシートプリンタで算数ドリルをつくる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775378580,
      "updated": 1775378593
    },
    {
      "id": "69d220a10000000000462b5e",
      "text": "  5歳の娘は楽しんで計算してくれた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775378594,
      "updated": 1775378604
    },
    {
      "id": "69d220ac0000000000462b5f",
      "text": "  反応を見ながら難易度を調整できるのがよい",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775378605,
      "updated": 1775378616
    },
    {
      "id": "69d220910000000000462b5b",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1775378578,
      "updated": 1775378578
    },
    {
      "id": "69d2230a0000000000608021",
      "text": "[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379209,
      "updated": 1775379211
    },
    {
      "id": "69d2230c0000000000608023",
      "text": " 獣道楽しみでワクワクしてる",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379211,
      "updated": 1775379217
    },
    {
      "id": "69d223110000000000608024",
      "text": "  vsときどのときのウメハラの取り組み方がすごい好き",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379217,
      "updated": 1775379229
    },
    {
      "id": "69d2231d0000000000608025",
      "text": "   最終的な直対は2週間前と合意していたので、この2週間が勝負だと考えていた",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379229,
      "updated": 1775379247
    },
    {
      "id": "69d223680000000000608029",
      "text": "   当時のときど豪鬼は言うまでもなく最強豪鬼",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379303,
      "updated": 1775379324
    },
    {
      "id": "69d2232f0000000000608026",
      "text": "   この2週間前までに大谷(富山の若手)を育成して完成させる",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379247,
      "updated": 1775379290
    },
    {
      "id": "69d2235b0000000000608028",
      "text": "    完成した大谷豪鬼と2週間みっちり詰めていく",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379291,
      "updated": 1775379355
    },
    {
      "id": "69d2239b000000000060802a",
      "text": "  セルゲームで初めて師匠になった悟空が悟飯を育成する中で自身も大きく成長した感じに似ている",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379355,
      "updated": 1775379383
    },
    {
      "id": "69d250cf0000000000e8a8df",
      "text": " 教科書を裁断して登大遊のけしからん書籍高品質化に通した",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775390927,
      "updated": 1775390990
    },
    {
      "id": "69d250f00000000000e8a8e1",
      "text": "  今まで[Book2Scrapbox]でScrapbox書籍化していた",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775390960,
      "updated": 1775390963
    },
    {
      "id": "69d251920000000000e8a8e3",
      "text": "  Windows前提なのが大変",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775391122,
      "updated": 1775391126
    },
    {
      "id": "69d2510f0000000000e8a8e2",
      "text": "  ここからなんかオリジナルの勉強しやすい何かを作ってみる",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775390991,
      "updated": 1775391000
    },
    {
      "id": "69d25d3d0000000000e8a8e4",
      "text": " 猫のお尻から[線虫]っぽいのが出てた",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775394109,
      "updated": 1775395171
    },
    {
      "id": "69d25d470000000000e8a8e5",
      "text": " \t取ろうと思ったら引っ込んだので[鬼のようにスパンキング]したら外に出てきたので捕獲",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1775394119,
      "updated": 1775395166
    },
    {
      "id": "69d25d610000000000e8a8e6",
      "text": " \t明日動物病院へ",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775394144,
      "updated": 1775394147
    },
    {
      "id": "69d26b650000000000baec43",
      "text": " \t猫にも[サナダ虫]みたいなやつがいるのか[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1775397734,
      "updated": 1775397754
    },
    {
      "id": "69d250db0000000000e8a8e0",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775390939,
      "updated": 1775390939
    },
    {
      "id": "69d233b200000000005c777b",
      "text": "[baku3.icon]",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1775383473,
      "updated": 1775383502
    },
    {
      "id": "69d233cf00000000005c777c",
      "text": " 今年度受講する講義が決った。",
      "userId": "6970e90c94fe766b6a026352",
      "created": 1775383503,
      "updated": 1775383543
    },
    {
      "id": "69d2230a0000000000608022",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1775379209,
      "updated": 1775379209
    },
    {
      "id": "69d23d400000000000196b38",
      "text": "[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1775385920,
      "updated": 1775385920
    },
    {
      "id": "69d23d400000000000196b39",
      "text": " 電力会社の使う資材のかたちを覚えているとジオゲッサーに使えるという話",
      "userId": "59fb21121207900012774b17",
      "created": 1775385920,
      "updated": 1775385964
    },
    {
      "id": "69d23d490000000000196b3a",
      "text": "  [https://youtube.com/shorts/BP-KSuvG9lY?si=crG69S9J_OVa44KU]",
      "userId": "59fb21121207900012774b17",
      "created": 1775385929,
      "updated": 1775385930
    },
