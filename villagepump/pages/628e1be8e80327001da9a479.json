    },
    {
      "id": "69d9339d000000000066775e",
      "text": "2022年配信",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775842205,
      "updated": 1775842213
    },
    {
      "id": "628e1c00b8bbfc00007028a6",
      "text": "「[電脳コイル]」[磯光雄]監督による[Netflixオリジナルアニメ]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1653480449,
      "updated": 1775842153
    },
    {
      "id": "628e1d18b8bbfc00007028ad",
      "text": "\t[宇宙]と[AI]をテーマにしている",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1653480729,
      "updated": 1653480740
    },
    {
      "id": "628e1cf6b8bbfc00007028ac",
      "text": "\t22年の配信に伴い、前後半がそれぞれ1月2月に劇場公開もされた",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1653480695,
      "updated": 1653480695
    },
    {
      "id": "628e1c69b8bbfc00007028a8",
      "text": "\t全6話",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1653480554,
      "updated": 1653480674
    },
    {
      "id": "628e1ce1b8bbfc00007028aa",
      "text": "\t\t製作者的にはもっと尺が欲しかったらしい",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1653480674,
      "updated": 1653480676
    },
    {
      "id": "69d9337b0000000000667755",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775842171,
      "updated": 1775842178
    },
    {
      "id": "69d933820000000000667757",
      "text": "宇宙ステーションあんしん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775842178,
      "updated": 1775842184
    },
    {
      "id": "628e1c00b8bbfc00007028a5",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1653480449,
      "updated": 1653480449
    },
    {
      "id": "658f60eb6eb40600005780ea",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1703895275,
      "updated": 1703895275
    },
    {
      "id": "658f60ec6eb40600005780eb",
      "text": "\t[未来描写]がとても面白い",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1703895276,
      "updated": 1703895279
    },
    {
      "id": "658f60ec6eb40600005780ec",
      "text": "\t 手に投影する端末",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1703895276,
      "updated": 1703895279
    },
    {
      "id": "658f60ec6eb40600005780ed",
      "text": "\t 3Dプリンタのゴツいやつ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1703895276,
      "updated": 1703895279
    },
    {
      "id": "658f60ec6eb40600005780ee",
      "text": "\t 物理的なAIアシスタント",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1703895276,
      "updated": 1703895279
    },
    {
      "id": "658f60ec6eb40600005780ef",
      "text": "\t AIにリミットをつける話",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1703895276,
      "updated": 1703895279
    },
    {
      "id": "658f60f46eb40600005780f0",
      "text": "\t技術の話とオカルトの話が混ざっている感じは、[電脳コイル]とリンクする",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1703895284,
      "updated": 1703895301
    },
    {
      "id": "69d933950000000000667758",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1775842197,
      "updated": 1775842197
    },
    {
      "id": "69d997460000000000b92598",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1775867718,
      "updated": 1775867720
    },
    {
      "id": "69d997490000000000b9259a",
      "text": " 電脳コイルの人と聞いて俄然興味が出てきた",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1775867721,
      "updated": 1775867734
    },
    {
      "id": "69da56c100000000001d2a8a",
      "text": "  一気見しちゃった。面白い！",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1775916736,
      "updated": 1775916751
    },
    {
      "id": "69d9b4300000000000481687",
      "text": " 自分もそれフックで見ました[terang.icon*2]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775875120,
      "updated": 1775875124
    },
