  "lines": [
    {
      "id": "69f051f884e7466a2db73457",
      "text": "ピーター・シンガー",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357853,
      "updated": 1777357853
    },
    {
      "id": "69f0541d0000000000da1d32",
      "text": "Peter Singer",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357853,
      "updated": 1777357854
    },
    {
      "id": "69f0541d0000000000da1d33",
      "text": "1946–",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357854,
      "updated": 1777357854
    },
    {
      "id": "69f0541d0000000000da1d34",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357854,
      "updated": 1777357854
    },
    {
      "id": "69f0541d0000000000da1d35",
      "text": "オーストラリアの[現代功利主義]者。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357854,
      "updated": 1777357854
    },
    {
      "id": "69f0541d0000000000da1d36",
      "text": "[功利計算]対象を広げ、特に[生命倫理]の分野で活躍。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357854,
      "updated": 1777357954
    },
    {
      "id": "69f0541d0000000000da1d37",
      "text": "彼の観点は、グローバル正義、animal rights、[気候変動]問題、[南北問題]といった言説の、思想的根拠として広く活用されている。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357854,
      "updated": 1777357854
    },
    {
      "id": "69f054230000000000da1d38",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357860,
      "updated": 1777357860
    },
    {
      "id": "69f054230000000000da1d39",
      "text": "[シンガー]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357860,
      "updated": 1777357863
    },
    {
      "id": "69f0542e0000000000da1d3c",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357870,
      "updated": 1777357870
    },
    {
      "id": "69f054280000000000da1d3b",
      "text": "もしかして",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357864,
      "updated": 1777357870
    },
    {
      "id": "69f0544f0000000000da1d3e",
      "text": "[バーチャルシンガー]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357903,
      "updated": 1777357904
    },
    {
      "id": "69f0542f0000000000da1d3d",
      "text": "[シンガーソングライター]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357871,
      "updated": 1777357902
    },
    {
      "id": "69f054240000000000da1d3a",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777357860,
      "updated": 1777357860
    }
  ]
}