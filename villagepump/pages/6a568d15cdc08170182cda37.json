    },
    {
      "id": "6a56aa096eb4060000002a034c",
      "text": "第29週: 日月火[[水]]木金土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1784064521,
      "updated": 1784064521
    },
    {
      "id": "6a56aa096eb406000000cf3d8c",
      "text": "2026年 53.70％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1784064521,
      "updated": 1784064521
    },
    {
      "id": "6a568d1a0000000000c0181c",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1784057115,
      "updated": 1784057115
    },
    {
      "id": "6a568d1f0000000000c0181d",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1784057119,
      "updated": 1784057122
    },
    {
      "id": "6a568d230000000000c0181f",
      "text": " フランス スペイン戦！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1784057124,
      "updated": 1784057132
    },
    {
      "id": "6a56a1240000000000daf958",
      "text": "",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1784062302,
      "updated": 1784062302
    },
    {
      "id": "6a56a1240000000000daf959",
      "text": "[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1784062302,
      "updated": 1784062305
    },
    {
      "id": "6a56a1270000000000daf95a",
      "text": " 今日も素晴らしい朝",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1784062305,
      "updated": 1784062309
    },
    {
      "id": "6a56b64800000000003d70f1",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067657,
      "updated": 1784067657
    },
    {
      "id": "6a56b64800000000003d70f2",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067657,
      "updated": 1784067659
    },
    {
      "id": "6a56b64b00000000003d70f3",
      "text": " [/motoso/2026-07-14#6a5552930000000000754486]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067659,
      "updated": 1784067662
    },
    {
      "id": "6a56b65200000000003d70f5",
      "text": "  おうえん",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067669,
      "updated": 1784067670
    },
    {
      "id": "6a56b65500000000003d70f6",
      "text": " [考えるより考えさせた方が早い]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067670,
      "updated": 1784067700
    },
    {
      "id": "6a56b67e00000000003d70f7",
      "text": "  [/motoso/2026-07-14#6a5631d600000000008b4a03]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067710,
      "updated": 1784067712
    },
    {
      "id": "6a56b68000000000003d70f8",
      "text": "  すでにこれになっている",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067713,
      "updated": 1784067728
    },
    {
      "id": "6a56b69000000000003d70f9",
      "text": "  自力で修士号とった人や自己研鑽より仕事のOutputが求められている人ならともかく、まだ修士の経験すら積んでいない人がLLMに計画丸投げするのはまずいと思う",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067729,
      "updated": 1784067885
    },
    {
      "id": "6a56b72c00000000003d70fa",
      "text": "   [自分の成長の機会をどぶに捨て]ている",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784067885,
      "updated": 1784067887
    },
    {
      "id": "6a5705cc000000000052b3b4",
      "text": "   +1 [custard.icon]",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784088012,
      "updated": 1784088021
    },
    {
      "id": "6a57006d000000000097ef91",
      "text": "   LLMにタスクを委譲するかは, 学習機会の損失と時間のトレードオフで考えていた[custard.icon]",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784086637,
      "updated": 1784086690
    },
    {
      "id": "6a5700a6000000000097ef92",
      "text": "    まだまとまっていない... > [/main-custard/AIエージェントにタスクをどう委譲し, ワークフローを改革するか]",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784086695,
      "updated": 1784086887
    },
    {
      "id": "6a570158000000000097ef98",
      "text": "    段階的に委譲するのが良いと思っている",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784086873,
      "updated": 1784087738
    },
    {
      "id": "6a5704b700000000000c1028",
      "text": "    　伸ばしたいなら注力して, そうでないなら投げる",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087736,
      "updated": 1784087737
    },
    {
      "id": "6a5700be000000000097ef94",
      "text": "    関連して, 意思決定の有無も大事だと思う",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784086718,
      "updated": 1784087528
    },
    {
      "id": "6a570126000000000097ef96",
      "text": "     前に少し書いた > [/main-custard/研究ワークフローを確立する]",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784086829,
      "updated": 1784087735
    },
    {
      "id": "6a5701be000000000097ef9a",
      "text": "     ここは粒度や特性にもよりそう. 細かすぎる判断は委譲できそう",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784086974,
      "updated": 1784087524
    },
    {
      "id": "6a57020e000000000097ef9b",
      "text": "     　時間が経つにつれて, より粒度を粗くできる...?",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087055,
      "updated": 1784087549
    },
    {
      "id": "6a570213000000000097ef9c",
      "text": "      半導体のチップ設計をAIエージェントに委譲した研究があって, 2013年頃の性能を出せたという話があった",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087059,
      "updated": 1784087789
    },
    {
      "id": "6a56d684000000000065e606",
      "text": " 英語のプレゼン練習",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784075908,
      "updated": 1784075917
    },
    {
      "id": "6a56d68d000000000065e607",
      "text": " 　ようやくlaptopを見ずに1回だけ通しでしゃべれた",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784075917,
      "updated": 1784075937
    },
    {
      "id": "6a56d6a1000000000065e608",
      "text": "  画面を見ないとだいぶ話すのがゆっくりになる",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784075937,
      "updated": 1784075952
    },
    {
      "id": "6a56d6b0000000000065e609",
      "text": "  　11minが15.5minになった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784075952,
      "updated": 1784075964
    },
    {
      "id": "6a56d6bc000000000065e60a",
      "text": "  ようやくプレゼンの流れが理解できたのか、不要な文章をその場で削って話せるようになった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784075964,
      "updated": 1784076003
    },
    {
      "id": "6a56dd9f00000000007c45bc",
      "text": "  もう一度練習した",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784077727,
      "updated": 1784077730
    },
    {
      "id": "6a56dda200000000007c45bd",
      "text": "   13.5min",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784077730,
      "updated": 1784077732
    },
    {
      "id": "6a56dda400000000007c45be",
      "text": "   これだけやれば大丈夫だろう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784077732,
      "updated": 1784077741
    },
    {
      "id": "6a56ddad00000000007c45bf",
      "text": "   あとは直前にもう一回やって、他の時間は質問対策しよう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784077741,
      "updated": 1784077755
    },
    {
      "id": "6a56ddba00000000007c45c1",
      "text": "   　質問対策に時間を割けれるとは思わなかった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784077755,
      "updated": 1784077764
    },
    {
      "id": "6a5778410000000000e0c252",
      "text": "  めっちゃ練習しててすごい[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1784117311,
      "updated": 1784117331
    },
    {
      "id": "6a577ff50000000000feb91e",
      "text": "  プレゼン終わった[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784119284,
      "updated": 1784119293
    },
    {
      "id": "6a577fff0000000000feb91f",
      "text": "  　質問対策結局できず、質問来たけど全然まともに答えられなかった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784119293,
      "updated": 1784119310
    },
    {
      "id": "6a57800f0000000000feb920",
      "text": "  　他の人と比べてspeakingが非常にゆっくり",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784119310,
      "updated": 1784119319
    },
    {
      "id": "6a5813e9000000000094c533",
      "text": "  　[サムズアップ.icon][Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784157162,
      "updated": 1784157168
    },
    {
      "id": "6a5780220000000000feb921",
      "text": "  これで英語の授業終わりかと思ったが、来週締切のfinal reportが出てしまった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784119329,
      "updated": 1784119347
    },
    {
      "id": "6a5780340000000000feb922",
      "text": "  　まだまだ終わらないドン！()",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784119347,
      "updated": 1784119352
    },
    {
      "id": "6a568d210000000000c0181e",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1784057122,
      "updated": 1784057122
    },
    {
      "id": "6a56bab10000000000a3ba40",
      "text": "",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784068797,
      "updated": 1784068797
    },
    {
      "id": "6a56bab10000000000a3ba41",
      "text": "[紺野春馬.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784068797,
      "updated": 1784068801
    },
    {
      "id": "6a56bab70000000000a3ba44",
      "text": "ぬるい",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784068801,
      "updated": 1784068801
    },
    {
      "id": "6a56bab80000000000a3ba45",
      "text": " ChatGPT（チャッピー）よ夏の暑さも分け合おう手持ちファンから出るぬるい風",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784068801,
      "updated": 1784068801
    },
    {
      "id": "6a56bab80000000000a3ba46",
      "text": " オマエラは熱暴走を知らないか脳を焦がして吐き出すコトバ",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784068801,
      "updated": 1784068801
    },
    {
      "id": "6a56bab80000000000a3ba47",
      "text": "",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784068801,
      "updated": 1784068801
    },
    {
      "id": "6a56bab80000000000a3ba48",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784068801,
      "updated": 1784071105
    },
    {
      "id": "6a56c3c10000000000946817",
      "text": "\tおはようございます",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071106,
      "updated": 1784071110
    },
    {
      "id": "6a56c3c70000000000946818",
      "text": "\tラジオにて、お米に関する政策転換のお話してた",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071111,
      "updated": 1784071147
    },
    {
      "id": "6a56c3ea0000000000946819",
      "text": "\t\t[https://www.yomiuri.co.jp/economy/20260708-GYT1T00322/ コメなど「需要に応じた生産」法定化、改正食糧法成立…石破前首相の増産路線を事実上修正 : 読売新聞]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071147,
      "updated": 1784071230
    },
    {
      "id": "6a56c43d000000000094681a",
      "text": "  いつも通り政府批判な雰囲気で、[令和の米騒動]は誤った判断だったといった論調だった",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071230,
      "updated": 1784071289
    },
    {
      "id": "6a56c468000000000094681b",
      "text": "  \t令和の米騒動、赤リンクだったのか",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071273,
      "updated": 1784071284
    },
    {
      "id": "6a56c4bb000000000094681d",
      "text": "  需要に応じた生産、とはつまり減らすことも出来るのではないか、やはり減反政策が終わっていないのではないか、それでは再びコメ不足が発生するではないか、といった感じのことも言ってた",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071355,
      "updated": 1784071494
    },
    {
      "id": "6a56c473000000000094681c",
      "text": " \t需給予測のうち、足りなくなる可能性を想定した生産にするべきだ、とかも言ってたが、これに関しては予測より豊作で余った場合どうするんだと、ひたすら足りないと言っている人は余る状況を考えているのかなと疑問に思えた",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071284,
      "updated": 1784071442
    },
    {
      "id": "6a56c512000000000094681e",
      "text": " \t\t余ったら余ったで、無駄な生産をさせた政府方針が悪い、となるだけか",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071442,
      "updated": 1784071464
    },
    {
      "id": "6a56c558000000000094681f",
      "text": " \t人類は未だに現実の物理現象を、ごく一部であっても完全掌握できていないわけで、どうしても誤差、ばらつきが発生するわけで、誤差を考慮しない設計は大体破綻した設計",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071512,
      "updated": 1784071643
    },
    {
      "id": "6a56c5ae0000000000946820",
      "text": " \t\tつまりは公差をきっちり考えようね（機械設計の作図作業中な発想",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071599,
      "updated": 1784071630
    },
    {
      "id": "6a56c6f20000000000946821",
      "text": " \t\t知らないだけでごく一部であれば完全掌握しているのかも、と[ちゃっぴー.icon]に聞いてみると、理論分野であればそこそこ完全掌握していて、工学分野だと確かに掌握している領域はまだ無いといった話になった",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071922,
      "updated": 1784071972
    },
    {
      "id": "6a56c7210000000000946822",
      "text": " \t\t理論計算の分野であれば、重力と電磁気学の分野、そこから派生して半導体とかレーザーとかはほぼ掌握出来ている、理論計算による予測と実測の差が、人間におけるスケール感では誤差無しとのこと",
      "userId": "65e1289acd012200235729c0",
      "created": 1784071972,
      "updated": 1784072081
    },
    {
      "id": "6a56c8400000000000946823",
      "text": " ラジオにて、[ポップコーン用トウモロコシ]の紹介してた",
      "userId": "65e1289acd012200235729c0",
      "created": 1784072257,
      "updated": 1784072324
    },
    {
      "id": "6a56c8500000000000946824",
      "text": " \t北海道の農園の紹介が主だったけど、そっちの名称は忘れた",
      "userId": "65e1289acd012200235729c0",
      "created": 1784072273,
      "updated": 1784072286
    },
    {
      "id": "6a56c85e0000000000946825",
      "text": " \t[ポップコーン]用って何だ、と軽く調べる",
      "userId": "65e1289acd012200235729c0",
      "created": 1784072286,
      "updated": 1784072309
    },
    {
      "id": "6a56c8740000000000946826",
      "text": " \t\t[https://snabi.jp/facility/22988/blog_articles/668647 ポップコーンのコーンって、普通のコーンとちょっと違う？そのヒミツをわかりやすく解説！スキルアップ のブログ | LITALICO仕事ナビ]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784072309,
      "updated": 1784072316
    },
    {
      "id": "6a56c87c0000000000946827",
      "text": "   >ポップコーン用のトウモロコシは「[爆裂種]（ばくれつしゅ）」と呼ばれる特別な品種だということです。",
      "userId": "65e1289acd012200235729c0",
      "created": 1784072316,
      "updated": 1784072367
    },
    {
      "id": "6a56c8b10000000000946828",
      "text": "  カッコいい種類名だった",
      "userId": "65e1289acd012200235729c0",
      "created": 1784072370,
      "updated": 1784072383
    },
    {
      "id": "6a56d6470000000000946829",
      "text": " 説明のためにちょっとだけ外に出たが暑すぎる",
      "userId": "65e1289acd012200235729c0",
      "created": 1784075848,
      "updated": 1784075863
    },
    {
      "id": "6a56d662000000000094682a",
      "text": " \tこの急激な気温上昇にも関わらず、今年からは[熱中症による事故は労働災害]として扱うんだっけ",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1784075874,
      "updated": 1784117571
    },
    {
      "id": "6a56d6c4000000000094682c",
      "text": " \t\t労災として扱うのは昔からか、最近変わったのは事業所各所で熱中症対策として十分な活動を行っているかどうか、の話か",
      "userId": "65e1289acd012200235729c0",
      "created": 1784075973,
      "updated": 1784076109
    },
    {
      "id": "6a56d7b9000000000094682d",
      "text": " \t\t労災としての熱中症が発生すると、きちんと対策が出来ていたのか確認が入るとか大変だ",
      "userId": "65e1289acd012200235729c0",
      "created": 1784076217,
      "updated": 1784076251
    },
    {
      "id": "6a56d67c000000000094682b",
      "text": " \t難易度高い[ゼロ災]になりそう",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784075901,
      "updated": 1784076299
    },
    {
      "id": "6a56e615000000000094682f",
      "text": " 本日の[Windowsスポットライト]の壁紙",
      "userId": "65e1289acd012200235729c0",
      "created": 1784079894,
      "updated": 1784079923
    },
    {
      "id": "6a56e6260000000000946830",
      "text": " \t[https://gyazo.com/cccbc10e6f3f52cee00981d34c839099]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784079911,
      "updated": 1784079914
    },
    {
      "id": "6a56e6360000000000946832",
      "text": " \t[アンコールワット]かな？と思ったら当たってた",
      "userId": "65e1289acd012200235729c0",
      "created": 1784079926,
      "updated": 1784079951
    },
    {
      "id": "6a56e64f0000000000946833",
      "text": " \t青空の写真が多い気がするが、夕日でも良い感じだ",
      "userId": "65e1289acd012200235729c0",
      "created": 1784079951,
      "updated": 1784079975
    },
    {
      "id": "6a573d290000000000ee35ae",
      "text": " 作図しようとすると違和感を見つけ、どうなっているのか確認すると微妙な誤りというか、余裕の無い箇所を見つけ修正",
      "userId": "65e1289acd012200235729c0",
      "created": 1784102186,
      "updated": 1784102216
    },
    {
      "id": "6a573d470000000000ee35af",
      "text": " \t修正するとなると隣の部品にも影響するため、となりのも変更、さらに隣との影響を吸収するために微調整",
      "userId": "65e1289acd012200235729c0",
      "created": 1784102216,
      "updated": 1784102245
    },
    {
      "id": "6a573d640000000000ee35b0",
      "text": " \t作業が終盤になるほど修正に手間がかかるを実感",
      "userId": "65e1289acd012200235729c0",
      "created": 1784102245,
      "updated": 1784102266
    },
    {
      "id": "6a56e6290000000000946831",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1784079914,
      "updated": 1784079914
    },
    {
      "id": "6a56bab10000000000a3ba42",
      "text": "",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784068797,
      "updated": 1784068797
    },
    {
      "id": "6a56c40b00000000005f358b",
      "text": "[nyarla.icon]",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071180,
      "updated": 1784071182
    },
    {
      "id": "6a56c40e00000000005f358c",
      "text": " おはようございます",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071182,
      "updated": 1784071192
    },
    {
      "id": "6a56c41800000000005f358d",
      "text": " ここのところ井戸端には顔を出してなかった",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071192,
      "updated": 1784071217
    },
    {
      "id": "6a56c43100000000005f358e",
      "text": "  微妙にメンタル不調で余裕がなかったので出てこなかった",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071218,
      "updated": 1784071269
    },
    {
      "id": "6a56c46500000000005f358f",
      "text": " 自分の Cosense で pin-diary っぽいのを始めた",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071270,
      "updated": 1784071310
    },
    {
      "id": "6a56c48e00000000005f3590",
      "text": "  ページ作成などは安易なスクリプト手書きでなんとかした",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071310,
      "updated": 1784071356
    },
    {
      "id": "6a56c5c800000000005f3591",
      "text": "  温かみのある[運用でカバー]",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071624,
      "updated": 1784071647
    },
    {
      "id": "6a56c6ab0000000000245e36",
      "text": " [ふと見ると投資信託下がってる]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784071851,
      "updated": 1784118623
    },
    {
      "id": "6a56c6bd0000000000245e37",
      "text": "  これって[中東情勢]なのかなー",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784071869,
      "updated": 1784121560
    },
    {
      "id": "6a56c6e30000000000245e38",
      "text": "   少なくとも金の投信が下がってるのは中東情勢の影響がある（と思っている）",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071907,
      "updated": 1784071970
    },
    {
      "id": "6a56c7230000000000245e39",
      "text": "   株式の方はちょっと分からない",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784071971,
      "updated": 1784072012
    },
    {
      "id": "6a5779800000000000e0c256",
      "text": "  [57577.icon][yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1784117630,
      "updated": 1784117638
    },
    {
      "id": "6a56f2e500000000005f65a4",
      "text": " TypeScript で型プログラミングっぽいことをしている",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784083173,
      "updated": 1784083191
    },
    {
      "id": "6a56f2f800000000005f65a5",
      "text": " \tｶﾀｶﾀｶﾀｶﾀ",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784083195,
      "updated": 1784083201
    },
    {
      "id": "6a572dd30000000000c363a1",
      "text": " [POPOPO]、9月でサ終か",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784098259,
      "updated": 1784098299
    },
    {
      "id": "6a572e070000000000c363a3",
      "text": "  結局興味が持てなくてアカウントは作らなかった",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784098311,
      "updated": 1784098367
    },
    {
      "id": "6a577d530000000000986257",
      "text": "   [基素.icon]さんがはまっていたので気になってた[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784118610,
      "updated": 1784118627
    },
    {
      "id": "6a572e87000000000066e13d",
      "text": "  サ終するの、早くない？",
      "userId": "5ffbd8b8512f4e001cae68fd",
      "created": 1784098439,
      "updated": 1784098457
    },
    {
      "id": "6a56d21d000000000045504d",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784074781,
      "updated": 1784074781
    },
    {
      "id": "6a56bab20000000000a3ba43",
      "text": "[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784068797,
      "updated": 1784074781
    },
    {
      "id": "6a56d214000000000045504b",
      "text": " 最近はAIの言うことを理解することに多くのコストをかけている",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784074773,
      "updated": 1784074803
    },
    {
      "id": "6a56d232000000000045504e",
      "text": "  [理解するためにcosenseをこね]ている",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784074803,
      "updated": 1784078183
    },
    {
      "id": "6a56df6f000000000024f8d1",
      "text": "  理解より終わらせることを優先するときは[grasp]/[karwi]でゴリ押しするけど、自分が理解したいときはcosense使うみたいな使い分けがよさそう[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784078191,
      "updated": 1784078236
    },
    {
      "id": "6a56ecd400000000004ff9e1",
      "text": "   そうかも[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784081621,
      "updated": 1784081625
    },
    {
      "id": "6a56ecd900000000004ff9e2",
      "text": "    fableさんが賢すぎて自分が理解できないんだと思っていたけど、自分が長期間使うつもりのシステムの基盤部分を設計してるからごり押しじゃなくて理解して口出したいみたいな気持ちがあるからこうなってるのか",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784081625,
      "updated": 1784081693
    },
    {
      "id": "6a5779d40000000000e0c257",
      "text": "  わかりやすく教えて、ではだめなのだろうか[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1784117715,
      "updated": 1784117739
    },
    {
      "id": "6a57839200000000004ee0a9",
      "text": "   何が問題かわかったかも[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784120210,
      "updated": 1784120224
    },
    {
      "id": "6a57839e00000000004ee0aa",
      "text": "    考えてる対象のプロジェクトに対して、全体像を把握して話すことが大事だが、細部について話しているとき相手が全体像をコンテクストとして持っているかよくわからないまま話している",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784120224,
      "updated": 1784120280
    },
    {
      "id": "6a57862a0000000000fce4bc",
      "text": "    　[前提の共有]や文脈の誤読の問題は難しい[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784120876,
      "updated": 1784121074
    },
    {
      "id": "6a5783d800000000004ee0ab",
      "text": "    私がわすれちゃって欠けていることもあり、claudeが読み込んでなくて欠けているときもある",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784120280,
      "updated": 1784120298
    },
    {
      "id": "6a5783ea00000000004ee0ac",
      "text": "    このため、全体像といま話してる細部の話がかみあってないとき私が気付かなくちゃいけなくなっている",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784120298,
      "updated": 1784120330
    },
    {
      "id": "6a57840a00000000004ee0ad",
      "text": "    それでScrapboxで全体を見つめながら話している",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784120330,
      "updated": 1784120347
    },
    {
      "id": "6a57841b00000000004ee0ae",
      "text": "     たぶんこれ自体はいいことだが、claudeにコンテクストが足りてるかわからないで話してるのはよくないこと",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784120347,
      "updated": 1784120405
    },
    {
      "id": "6a57845400000000004ee0af",
      "text": "      なので今書いたこれをclaudeに見せてどうすればいいか聞いてくる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784120405,
      "updated": 1784120418
    },
    {
      "id": "6a570caa00000000004467a8",
      "text": " アイスキャンディー作れるやつほしいな",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784089771,
      "updated": 1784089783
    },
    {
      "id": "6a5710730000000000ee35a8",
      "text": " \tとりあえずの試しで紙コップ使ってみては[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784090740,
      "updated": 1784090756
    },
    {
      "id": "6a5710850000000000ee35a9",
      "text": " \t\t紙コップだと面倒くさい、と分かれば専用の[アイスキャンディーメーカー]を買う、紙コップで十分ならそれで、そもそもアイスキャンディーはなんか違うとなったら別のやつを探す流れ",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1784090757,
      "updated": 1784117753
    },
    {
      "id": "6a5711160000000000ee35aa",
      "text": " \t\tテキトーに調べたら材料作ってる会社がレシピ出してた",
      "userId": "65e1289acd012200235729c0",
      "created": 1784090902,
      "updated": 1784090916
    },
    {
      "id": "6a5711240000000000ee35ab",
      "text": " \t\t\t[https://www.morinaga.co.jp/recipe/detail/1225 固くならない♪野菜生活アイスキャンディ | 天使のお菓子レシピ | 森永製菓株式会社]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784090916,
      "updated": 1784090920
    },
    {
      "id": "6a5719a500000000005c6ddd",
      "text": " \t\t\tゼラチンで作るの確かに良さそう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784093094,
      "updated": 1784093107
    },
    {
      "id": "6a5711280000000000ee35ac",
      "text": "   最近はレシピを求めてぐぐると各種調味料とかのメーカーが出しているサイトが上位に来る気がする",
      "userId": "65e1289acd012200235729c0",
      "created": 1784090920,
      "updated": 1784090999
    },
    {
      "id": "6a5711450000000000ee35ad",
      "text": "   レシピ投稿サイトは衰退しました、のかな",
      "userId": "65e1289acd012200235729c0",
      "created": 1784090949,
      "updated": 1784090961
    },
    {
      "id": "6a5719b600000000005c6dde",
      "text": "   それもそうだ、とりあえず製氷皿で作って[シャービック]みたいにしよう[caki.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1784093111,
      "updated": 1784117777
    },
    {
      "id": "6a56da67000000000018ebc2",
      "text": " 9月にくそでか連休あるという気づき",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784076903,
      "updated": 1784093316
    },
    {
      "id": "6a574b650000000000f70204",
      "text": " 永谷園のモコモコ再販するらしい、アガる",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784105830,
      "updated": 1784105860
    },
    {
      "id": "6a5788410000000000219c35",
      "text": " [異国の異国料理]を見るのが割に好きだ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784121410,
      "updated": 1784121460
    },
    {
      "id": "6a5788680000000000219c37",
      "text": "  ドイツのベトナム料理とか",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784121448,
      "updated": 1784121455
    },
    {
      "id": "6a5788550000000000219c36",
      "text": "  異国ナイズドされた異国料理",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784121429,
      "updated": 1784121437
    },
    {
      "id": "6a5814db000000000094c534",
      "text": "  世界のお米のお話を紹介している動画で知った、アメリカ南部にある伝統料理を連想[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784157404,
      "updated": 1784157435
    },
    {
      "id": "6a5814fb000000000094c535",
      "text": "  \t伝統、と言いつつもルーツはアフリカ西部の米料理",
      "userId": "65e1289acd012200235729c0",
      "created": 1784157435,
      "updated": 1784157447
    },
    {
      "id": "6a581506000000000094c536",
      "text": "  \tアメリカには世界各地からいろんな人が合流したけど、アメリカ南部においてはアフリカ西部からナイジェリアとかあの辺の地域から奴隷としてアメリカに輸出された人たちが多くいたようで、なおかつ気候が似ている部分があるからか、アフリカで食べられていた料理をアメリカ南部でも一部再現",
      "userId": "65e1289acd012200235729c0",
      "created": 1784157447,
      "updated": 1784157532
    },
    {
      "id": "6a58155b000000000094c537",
      "text": "  \tなので、大体のルーツはアフリカ西部だけど他にも様々な文化が合流して生まれたアメリカ南部の伝統料理は異国ナイズされた異国料理、だけどアメリカ南部料理としか表現しようがない独自発展だったかそういう話",
      "userId": "65e1289acd012200235729c0",
      "created": 1784157532,
      "updated": 1784157585
    },
    {
      "id": "6a571a6f00000000005c6ddf",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784093296,
      "updated": 1784093296
    },
    {
      "id": "6a56da68000000000018ebc3",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1784076903,
      "updated": 1784076905
    },
    {
      "id": "6a56da6a000000000018ebc4",
      "text": " いきなり夏バテ感",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1784076905,
      "updated": 1784076916
    },
    {
      "id": "6a56da76000000000018ebc5",
      "text": " 昼の暑さよりも、夜の暑さがこたえる",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1784076917,
      "updated": 1784076976
    },
    {
      "id": "6a56da89000000000018ebc6",
      "text": "  軽くクーラー入れてるけど、それだと今度は喉に来る",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1784076936,
      "updated": 1784076966
    },
    {
      "id": "6a56e416000000000094682e",
      "text": "  クーラーと加湿器を併用するか、クーラーのOFFタイマーを入れて調整するか、寝るまで部屋を冷やして寝る時に切りONタイマーを利用して調整するか、少し外気を取り込んで湿気を入れつつクーラーを回して調整するか、マスクを装着して寝ることで口腔を保護するか、と思ったがどれもなんかイマイチな結果になりそうで良い案が思いつかぬ[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1784079382,
      "updated": 1784079487
    },
    {
      "id": "6a56dacd000000000018ebc7",
      "text": " 自宅サーバが突然死しがちだったけど、CPUのバグを踏んでた疑惑",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1784077003,
      "updated": 1784077104
    },
    {
      "id": "6a56daeb000000000018ebc8",
      "text": "  [/taktamur/NixOSのC-stateバグ対応]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1784077034,
      "updated": 1784077090
    },
    {
      "id": "6a56db3600000000004ac9ea",
      "text": "  これで収まってくれたらいいなぁ。。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1784077109,
      "updated": 1784077118
    },
    {
      "id": "6a56d215000000000045504c",
      "text": "",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784074773,
      "updated": 1784074773
    },
    {
      "id": "6a56ea920000000000e15241",
      "text": "[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1784081043,
      "updated": 1784081043
    },
    {
      "id": "6a56ea930000000000e15242",
      "text": " [ミートたけし]のYoutubeをつい見てしまう",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1784081043,
      "updated": 1784081700
    },
    {
      "id": "6a56ea9c0000000000e15243",
      "text": "  何かの分野で一流の人の発信なんやかんやで面白い",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1784081053,
      "updated": 1784081073
    },
    {
      "id": "6a5795210000000000bf1219",
      "text": " Stravaから流れなくなったなーと思ったらAPIもサブスクが必要になったっぽい",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1784124705,
      "updated": 1784124720
    },
    {
      "id": "6a5796e10000000000bf121a",
      "text": "  AI時代で負荷激増しているらしい",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1784125153,
      "updated": 1784125158
    },
    {
      "id": "6a5796e60000000000bf121b",
      "text": "  AIの恩恵をめちゃくちゃ受けつつ、PCは高くなるし無料で提供できてたものがどんどん有料になっていって果たしてどこに向かうのか",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1784125158,
      "updated": 1784125195
    },
    {
      "id": "6a57970b0000000000bf121c",
      "text": "  \t昔はAPIってどこもだいたい無料で使えてた時代があるんじゃよ...ってなるのかな",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1784125195,
      "updated": 1784125215
    },
    {
      "id": "6a56f0d9000000000025f699",
      "text": "",
      "userId": "6528da1be2d3b3001bc66f08",
      "created": 1784082650,
      "updated": 1784082650
    },
    {
      "id": "6a56f0d9000000000025f69a",
      "text": "[k47de.icon]",
      "userId": "6528da1be2d3b3001bc66f08",
      "created": 1784082650,
      "updated": 1784082652
    },
    {
      "id": "6a56f0dc000000000025f69b",
      "text": " 外あっちぃよ",
      "userId": "6528da1be2d3b3001bc66f08",
      "created": 1784082652,
      "updated": 1784082660
    },
    {
      "id": "6a56f0e3000000000025f69c",
      "text": "  溶けちゃうよ",
      "userId": "6528da1be2d3b3001bc66f08",
      "created": 1784082660,
      "updated": 1784082665
    },
    {
      "id": "6a56fadf0000000000808030",
      "text": "  ゲル化剤で固めて流れ出ないようにしよう[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784085215,
      "updated": 1784085241
    },
    {
      "id": "6a56f0ea000000000025f69d",
      "text": "",
      "userId": "6528da1be2d3b3001bc66f08",
      "created": 1784082667,
      "updated": 1784082669
    },
    {
      "id": "6a5701210000000000f47f22",
      "text": "[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086818,
      "updated": 1784086820
    },
    {
      "id": "6a5701250000000000f47f24",
      "text": " [結城浩]という流行歌手・[楠木繁夫]の変名がある",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086821,
      "updated": 1784086875
    },
    {
      "id": "6a57015c0000000000f47f25",
      "text": " \tどこかで既視感、と思ってググったら",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086876,
      "updated": 1784086890
    },
    {
      "id": "6a57016a0000000000f47f26",
      "text": "\t \t[https://www.hyuki.com/ 結城浩 / Hiroshi Yuki]",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086890,
      "updated": 1784086892
    },
    {
      "id": "6a57016d0000000000f47f27",
      "text": "\t \t👻アイコンのITエンジニアのあの人が出てきた",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086893,
      "updated": 1784086952
    },
    {
      "id": "6a5701c80000000000ebb1cf",
      "text": "\t \t\tというか[scrapboxユーザー]なのね",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086985,
      "updated": 1784086998
    },
    {
      "id": "6a5701880000000000f47f28",
      "text": "\t流行歌界隈の芸名、実名・芸名ともに現代にもダブりがち",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086920,
      "updated": 1784086946
    },
    {
      "id": "6a5701220000000000f47f23",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1784086818,
      "updated": 1784086818
    },
    {
      "id": "6a5704f8000000000052b3ae",
      "text": "[custard.icon]",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087800,
      "updated": 1784087801
    },
    {
      "id": "6a5704f9000000000052b3b0",
      "text": "　[Fable]をまだ使ってない. 何で試すのがいいのかな",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087801,
      "updated": 1784087856
    },
    {
      "id": "6a570531000000000052b3b2",
      "text": "　　研究計画の草案を激詰してもらうとか? まだ構想段階で新規性とかないし, 特に権限問題もないし",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087857,
      "updated": 1784087931
    },
    {
      "id": "6a570581000000000052b3b3",
      "text": "　　 どの辺が甘いか指摘してもらうか. 先に[Claude Sonnet]でやろう",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087938,
      "updated": 1784087987
    },
    {
      "id": "6a5704f8000000000052b3af",
      "text": " Cosenseの非公開プロジェクトがしっちゃかめっちゃか. 整理が必要",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784087800,
      "updated": 1784088325
    },
    {
      "id": "6a57070400000000006f9cc6",
      "text": " 　mainの方も必要. 時間を作りたい. 研究計画立てたらやる",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784088325,
      "updated": 1784088348
    },
    {
      "id": "6a57071400000000006f9cc7",
      "text": " 　今学期に少し触れた[コンピュータアーキテクチャ]や[最適輸送]などの話は, 元々は全て非公開の方に入れていた. しかし, 研究ネタは別に書くし, 誰かの不利益になったり, 他者を攻撃する発言もないし, むしろ積極的にページを切れないことによるデメリットが非公開によるメリットを上回ったので, 結果的に公開にした. 同じ流れがほとんどの話で言える",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784088340,
      "updated": 1784088942
    },
    {
      "id": "6a57086000000000006f9cc9",
      "text": " 　日誌は[自由な思考]と出力を維持するために非公開領域に書く. [誰にも憚らず書ける]状態が良い. 最初はそうやって自由に出力して, その後に時間を取って整理し, 公開領域に戻す工程を経るのが, 今の所良さそうだと感じている",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784088674,
      "updated": 1784088945
    },
    {
      "id": "6a5708c300000000006f9cca",
      "text": " 　ようやくCosenseの運用が固まってきた感がある. 書きっぱなしのページがいくつもあり, 時間が経過して頭の中で整理されているであろうそれらも更新できればなお良い. フローとしてどこかにまとめようかな",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784088773,
      "updated": 1784088843
    },
    {
      "id": "6a57097a00000000006f9ccb",
      "text": " 　 対象は非公開にメモ > 整理して公開という一連の作業と, 思考の整理",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784088959,
      "updated": 1784089019
    },
    {
      "id": "6a5706ea00000000006f9cc5",
      "text": "",
      "userId": "656449c617c172001c8d1e46",
      "created": 1784088299,
      "updated": 1784088299
    },
    {
      "id": "6a5741b4000000000032d777",
      "text": "[zatsma.icon]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1784103350,
      "updated": 1784103353
    },
    {
      "id": "6a5741b8000000000032d779",
      "text": " POPOPO終わるの早いよ！",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1784103353,
      "updated": 1784103362
    },
    {
      "id": "6a5741d6000000000032d77a",
      "text": "  資本がありそうなSNSが終わるの悲しい",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1784103384,
      "updated": 1784103396
    },
    {
      "id": "6a574207000000000032d77c",
      "text": "  アバターを使った手軽な通話・配信体験自体は良かったと思う",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1784103432,
      "updated": 1784103449
    },
    {
      "id": "6a5741f0000000000032d77b",
      "text": "   後釜が出てくるかなあ",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1784103409,
      "updated": 1784103450
    },
    {
      "id": "6a5741b4000000000032d778",
      "text": "",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1784103350,
      "updated": 1784103350
    },
    {
      "id": "6a574487000000000080ff96",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1784104072,
      "updated": 1784104072
    },
    {
      "id": "6a574488000000000080ff97",
      "text": "\tPOPOPOよりは[setlog]の方がニーズがあるのかなぁ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1784104072,
      "updated": 1784104165
    },
    {
      "id": "6a574491000000000080ff98",
      "text": "\t\t音声や配信自体に可能性はあると思っているが、どこを攻めるかが難しい。たとえば喋る友達がおらず、知らない人との会話をする勇気もない陰キャでも使える塩梅の開拓……",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1784104081,
      "updated": 1784104233
    },
    {
      "id": "6a574487000000000080ff95",
      "text": "\tGMOもリモート撤廃か",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1784104071,
      "updated": 1784104279
    },
    {
      "id": "6a574557000000000080ff9b",
      "text": "\t\t本当なんで撤廃したがるんだろうな",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1784104279,
      "updated": 1784104283
    },
    {
      "id": "6a57455b000000000080ff9c",
      "text": "\t\tやはりリストラのためなのだろうか",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1784104283,
      "updated": 1784104301
    },
    {
      "id": "6a5744ad000000000080ff99",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1784104109,
      "updated": 1784104109
    },
    {
      "id": "6a5765f500000000007819ae",
      "text": "[atohs.icon]",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784112629,
      "updated": 1784112650
    },
    {
      "id": "6a57660a00000000007819af",
      "text": "\t[キス釣り]、数はあんまり出なかったけど、割とサイズが出て良かった",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784112650,
      "updated": 1784128133
    },
    {
      "id": "6a57661c00000000007819b0",
      "text": "\t\tとりあえず内蔵を出してえらい",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784112669,
      "updated": 1784120750
    },
    {
      "id": "6a5785ae00000000007819b1",
      "text": "\t今回は大分の方で釣りをして、県南の方だったので、延岡まで行ってスーパー戦闘みたいなところにいってランチバイキング食べた",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784120751,
      "updated": 1784120792
    },
    {
      "id": "6a5785d800000000007819b3",
      "text": "\t高千穂の天岩戸神社にも行った",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784120792,
      "updated": 1784120804
    },
    {
      "id": "6a5785e300000000007819b4",
      "text": "\t締めに古着屋にも行った",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784120804,
      "updated": 1784120810
    },
    {
      "id": "6a5785ea00000000007819b5",
      "text": "\t充実した1日であった",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784120810,
      "updated": 1784120813
    },
    {
      "id": "6a5785ed00000000007819b6",
      "text": "\tなんにも仕事らしい活動が進んでいない",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784120813,
      "updated": 1784120822
    },
    {
      "id": "6a5785f600000000007819b7",
      "text": "\tお酒飲みながらちょっと進めちゃお",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784120822,
      "updated": 1784120826
    },
    {
      "id": "6a5785fa00000000007819b8",
      "text": "\t久しぶりにBUSKER買った",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784120827,
      "updated": 1784120835
    },
    {
      "id": "6a5765f300000000007819ad",
      "text": "",
      "userId": "5a61856392ee03001413cde3",
      "created": 1784112627,
      "updated": 1784112627
    },
    {
      "id": "6a5778f30000000000e0c253",
      "text": "[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1784117489,
      "updated": 1784117490
    },
    {
      "id": "6a5778f50000000000e0c254",
      "text": " [ゴリ重タスク]しかないので[一周回って心が暇]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1784117491,
      "updated": 1784118637
    },
    {
      "id": "6a5783480000000000bdd238",
      "text": "",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784120136,
      "updated": 1784120136
    },
    {
      "id": "6a5783480000000000bdd239",
      "text": "[meganii.icon]",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784120136,
      "updated": 1784120138
    },
    {
      "id": "6a57834a0000000000bdd23b",
      "text": "　[Backlog]におけるプロジェクトは、結構細かい単位で分けてよいのだろうか",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784120138,
      "updated": 1784120170
    },
    {
      "id": "6a57836a0000000000bdd23c",
      "text": "　　意外とプロジェクトを跨いだ管理も想定されていそうなので、分けてみるのも良さそう",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784120170,
      "updated": 1784120234
    },
    {
      "id": "6a5783480000000000bdd23a",
      "text": "",
      "userId": "649a24da357c4d001c518c25",
      "created": 1784120136,
      "updated": 1784120136
    },
    {
      "id": "6a5787c60000000000fce4be",
      "text": "[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784121288,
      "updated": 1784121291
    },
    {
      "id": "6a5787ca0000000000fce4bf",
      "text": "　Streamに[\" とりあえず内蔵を出してえらい][. [2026/07/15#6a57661c00000000007819b0]]の前後の行が表示されていなかったので一瞬誰か切腹したのかと思ったが、流石にそんな猟奇的な事件は起きていなかったらしい",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784121293,
      "updated": 1784121422
    },
    {
      "id": "6a579e6a0000000000b7d748",
      "text": "",
      "userId": "6303abe85eed77001d707837",
      "created": 1784127083,
      "updated": 1784127083
    },
    {
      "id": "6a579e6a0000000000b7d749",
      "text": "[nejimaki.icon]",
      "userId": "6303abe85eed77001d707837",
      "created": 1784127083,
      "updated": 1784127084
    },
    {
      "id": "6a579e6c0000000000b7d74a",
      "text": "\t音楽ニュースレターを配信しました",
      "userId": "6303abe85eed77001d707837",
      "created": 1784127085,
      "updated": 1784127096
    },
    {
      "id": "6a579e770000000000b7d74c",
      "text": "\t\t[https://otonokabe.substack.com/p/vol10 音の壁レターvol.10]",
      "userId": "6303abe85eed77001d707837",
      "created": 1784127096,
      "updated": 1784127136
    },
    {
      "id": "6a57a0390000000000e0fa2c",
      "text": "\t北陸新幹線延線、桂川案になってまあよかった、最悪は免れたという感じ",
      "userId": "6303abe85eed77001d707837",
      "created": 1784127547,
      "updated": 1784127587
    },
    {
      "id": "6a57f862000000000098800e",
      "text": "",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150114,
      "updated": 1784150115
    },
    {
      "id": "6a57f863000000000098800f",
      "text": "[h45te.icon]",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150115,
      "updated": 1784150127
    },
    {
      "id": "6a57f86f0000000000988010",
      "text": " 1.44MBゲームコンテストの詳細が来たらしい",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150128,
      "updated": 1784150150
    },
    {
      "id": "6a57f8860000000000988011",
      "text": "  https://2pgarcade.com/contest-144mb.html",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150150,
      "updated": 1784150153
    },
    {
      "id": "6a57f8890000000000988012",
      "text": "  試しにRust+macroquadで遊んでたやつのバイナリサイズを見たら1.60MBだった",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150153,
      "updated": 1784150558
    },
    {
      "id": "6a57f8c90000000000988013",
      "text": "   preludeからインポートしてるのが原因？コンパイルにどこまで最適化されるか、使い慣れていなくて全くわからない",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150217,
      "updated": 1784150585
    },
    {
      "id": "6a57f90c0000000000988014",
      "text": "   それでもかなり大変な数値であることは間違いなさそう",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150285,
      "updated": 1784150307
    },
    {
      "id": "6a57fa4000000000004e05d1",
      "text": "    ちょっと良質な音声とか画像入れたらあっという間に蒸発する",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150592,
      "updated": 1784150614
    },
    {
      "id": "6a57f92d0000000000988016",
      "text": "  勉強ついでにエントリーしたい",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150317,
      "updated": 1784150325
    },
    {
      "id": "6a57f9240000000000988015",
      "text": " この前作った謎解きを上げてみる",
      "userId": "69e54ae539ab55540cb29eba",
      "created": 1784150308,
      "updated": 1784150344
    },
    {
      "id": "6a57f9490000000000988017",
