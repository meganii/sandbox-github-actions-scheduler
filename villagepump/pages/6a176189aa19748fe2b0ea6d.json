      "created": 1779923653,
      "updated": 1779923770
    },
    {
      "id": "6a177b59000000000029a5c6",
      "text": "  \t\t[ジスルフィド結合]を形成している。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1779923801,
      "updated": 1779923802
    },
    {
      "id": "6a177aec000000000029a5c3",
      "text": "   \t2つの[硫黄原子]のうちもう一方は隠れて見えない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1779923692,
      "updated": 1779923801
    },
    {
      "id": "6a1777c9000000000029a58e",
