  "lines": [
    {
      "id": "6a241e11839de82c7c3b69bf",
      "text": "オープンヒューマン",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780751892,
      "updated": 1780751892
    },
    {
      "id": "6a241df100000000005550be",
      "text": " 公開人間[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780751893,
      "updated": 1780751897
    },
    {
      "id": "6a241df100000000005550bf",
      "text": "  どんな名前で、どんな顔で、どこに住み、何をしていて、何を考えているのか、各種認証情報など生活の便宜上最低限隠しておく必要がある情報以外は[デライト]のような技術で全て公開された次世代人間",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780751893,
      "updated": 1780752442
    },
    {
      "id": "6a241e7200000000005550c2",
      "text": "  [ホモ・フィロソフィクス]の基本的な姿になるかもしれない",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780752022,
      "updated": 1780752056
    },
    {
      "id": "6a241eb700000000005550c3",
      "text": "   私はその最初の実践者となる",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780752090,
      "updated": 1780752105
    },
    {
      "id": "6a241ec600000000005550c4",
      "text": "  リアル[トゥルーマン・ショー]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1780752105,
      "updated": 1780752153
    },
    {
      "id": "6a241e0800000000005550c1",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1780751916,
      "updated": 1780754880
    },
    {
      "id": "6a2429bf0000000000d12b9d",
      "text": "オープンヒューマンになりたい[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1780754880,
      "updated": 1780754886
    },
    {
      "id": "6a2429c00000000000d12b9e",
      "text": "OH",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1780754881,
      "updated": 1780754898
    },
