  "lines": [
    {
      "id": "6a41d8d2599bf3883d77c03d",
      "text": "KNEST",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700244,
      "updated": 1782700244
    },
    {
      "id": "6a41d8a4000000000099951d",
      "text": " [デライト]の[API]体系[hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700244,
      "updated": 1782700335
    },
    {
      "id": "6a41d8ab000000000099951f",
      "text": "  knower easy state transfer（知機簡易状態転送）、nest（巣、入れ子）にかけてネストと読む",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700251,
      "updated": 1782701419
    },
    {
      "id": "6a41d8cf0000000000999521",
      "text": "  厳密には、HTTPを利用した[知機]の通信規約という概念",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700288,
      "updated": 1782700364
    },
    {
      "id": "6a41db180000000000999524",
      "text": "   デライトAPIはその実装と位置付けている",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700873,
      "updated": 1782700886
    },
    {
      "id": "6a41d8a4000000000099951e",
      "text": "  [REST API] を知機開発に最適化したもの",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700245,
      "updated": 1782700446
    },
    {
      "id": "6a41da190000000000999523",
      "text": "   [ステートレス]ではなく「ステータブルAPI」として設計されている",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700618,
      "updated": 1782700642
    },
    {
      "id": "6a41dc7b0000000000999527",
      "text": "    ステートフルAPIの中にRESTのノウハウを取り入れるというイメージで「入れ子」",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782701227,
      "updated": 1782701539
    },
    {
      "id": "6a41d9410000000000999522",
      "text": "  デライト開発が本格的に始まる2019年に構想が出来始めた",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782700402,
      "updated": 1782700988
    },
    {
      "id": "6a41dddb0000000000999528",
      "text": "  割とがっつり[Cμ]実装を書いている",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782701579,
      "updated": 1782701587
    },
    {
      "id": "6a41f3170000000000741010",
      "text": "   [https://dlt.kitetu.com/KNo.F85E/0758-B818.webp?20260629132312]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1782707016,
      "updated": 1782707016
    },
