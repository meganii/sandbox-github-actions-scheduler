      "created": 1775138126,
      "updated": 1775138126
    },
    {
      "id": "69ce77350000000000175ccf",
      "text": " subgraph 名詞句",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775138613,
      "updated": 1775138675
    },
    {
      "id": "69ce77480000000000175cd2",
      "text": " n-->suf",
