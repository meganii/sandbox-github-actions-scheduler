    {
      "id": "69ce74760000000000175cba",
      "text": "[活用と付属語]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775137911,
      "updated": 1775161903
    },
    {
      "id": "69ced2110000000000840914",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775161874,
      "updated": 1775161874
    },
    {
      "id": "69ced2500000000000840915",
      "text": " code:mermaid",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775161937,
      "updated": 1775175911
    },
    {
      "id": "69ced2560000000000840917",
      "text": "  graph LR;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775161943,
      "updated": 1775175911
    },
    {
      "id": "69cf0066000000000084096f",
      "text": "  K5V(K5V<br>kak); G5V(G5V<br> kag); S5V(S5V<br> kes); T5V(T5V<br> kat); N5V(N5V<br> sin); P5V(P5V<br> kap); B5V(B5V<br> tob); M5V(M5V<br> kam); R5V(R5V<br> kar);",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775173734,
      "updated": 1775175911
    },
    {
      "id": "69cf02fb0000000000840979",
      "text": "  ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775174395,
      "updated": 1775175911
    },
    {
      "id": "69cf02fe000000000084097a",
      "text": "  K5V-->K5Vi(BS i)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775174398,
      "updated": 1775175911
    },
    {
      "id": "69cf034d000000000084097d",
      "text": "  G5V-->G5Vi(BS i)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775174477,
      "updated": 1775175911
    },
    {
      "id": "69cf04060000000000840980",
      "text": "  S5V-->S5Vi(i)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775174662,
      "updated": 1775175911
    },
    {
      "id": "69cf040a0000000000840981",
      "text": "  T5V & P5V & R5V-->P5Vi(t)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775175701,
      "updated": 1775175911
    },
    {
      "id": "69cf040c0000000000840983",
      "text": "  N5V-->N5Vi(n)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775174668,
      "updated": 1775175911
    },
    {
      "id": "69cf040d0000000000840984",
      "text": "  B5V & M5V-->B5Vi(m)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775174669,
      "updated": 1775175911
    },
    {
      "id": "69cf040e0000000000840985",
      "text": "  K5Vi & S5Vi & P5Vi-->teta( )-->te & ta;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775174671,
      "updated": 1775175911
    },
    {
      "id": "69cf08b10000000000840996",
      "text": "  G5Vi & N5Vi & B5Vi-->deda( )-->de & da;",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775175858,
      "updated": 1775175911
    },
    {
      "id": "69cf08c0000000000084099b",
      "text": "  K5V & S5V & T5V & P5V & R5V & G5V & N5V & B5V & M5V-->5V( );",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775175872,
      "updated": 1775175911
    },
    {
      "id": "69cf061b000000000084098f",
      "text": "  5V-->5VMi(a) & 5VS(u) & 5VRT(u) & 5VK(e) & 5VMe(e)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775175195,
      "updated": 1775175911
    },
    {
      "id": "69cf08da000000000084099c",
      "text": " 五段活用だけでこのゴチャゴチャ感",
      "userId": "6436266c7ac3c0001bed60e6",
