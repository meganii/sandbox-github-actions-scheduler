  "lines": [
    {
      "id": "69efc3401c7653143ecf01d0",
      "text": "times-suto3-2026-04-28",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777320769,
      "updated": 1777320769
    },
    {
      "id": "69eff37e00000000006779c6",
      "text": "[https://raw.githubusercontent.com/twitter/twemoji/ad3d3d669bb3697946577247ebb15818f09c6c91/assets/svg/1f9ca.svg]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777333119,
      "updated": 1777333120
    },
    {
      "id": "69efc5fa0000000000e49e84",
      "text": "冷却中なので刺激しないでください",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777321467,
      "updated": 1777333150
    },
    {
      "id": "69efc5fc0000000000e49e85",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777321468,
      "updated": 1777321468
    },
    {
      "id": "69f05be20000000000816832",
      "text": "[幕末の三舟]なあ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777359842,
      "updated": 1777359861
    },
    {
      "id": "69f05bfb0000000000816834",
      "text": "　個人的には「名前に船がつく3人」くらいの情報で、丁度いいと思うの",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777359867,
      "updated": 1777360053
    },
    {
      "id": "69f05c6d0000000000816835",
      "text": "　知っている人には、「はいはい、いつもの3人ですね」くらい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777359981,
      "updated": 1777360087
    },
    {
      "id": "69f05ce00000000000816836",
      "text": "　興味がない人はスルーしてもらってかまわない、それくらいのノリ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777360097,
      "updated": 1777360389
    },
    {
      "id": "69f05e0500000000003385f7",
      "text": "　ところがそうはいかんらしい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777360390,
      "updated": 1777360545
    },
    {
      "id": "69f05be40000000000816833",
      "text": "[山岡鉄舟]なあ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777359845,
      "updated": 1777360764
    },
    {
      "id": "69f05f7600000000003385f8",
      "text": "　個人的には三舟の中で一番好きなキャラ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777360758,
      "updated": 1777360840
    },
    {
      "id": "69f05f7d00000000003385f9",
      "text": "　名前くらい知っている人は多いと思うんだけどなあ…",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777360766,
      "updated": 1777360979
    },
    {
      "id": "69f0600b00000000003385fb",
      "text": "　　「るろうに剣心」の元ネタのひとりと言われている",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777360907,
      "updated": 1777360968
    },
    {
      "id": "69f0606200000000003385fc",
      "text": "　　幕末を無刀で通した刀の達人",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777360995,
      "updated": 1777361065
    },
    {
      "id": "69f060bf00000000003385fd",
      "text": "　掘り下げたいんだけど、また大量のスタッブを消費しそうなんだよ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361087,
      "updated": 1777361152
    },
    {
      "id": "69f062ca0000000000816837",
      "text": "[徳川四天王]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361610,
      "updated": 1777361620
    },
    {
      "id": "69f062cc0000000000816838",
      "text": " 実はあれ以上書くことがない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361613,
      "updated": 1777361648
    },
    {
      "id": "69f062d70000000000816839",
      "text": "　四天王のひとりひとりを掘り下げていけば大変おもしろい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361624,
      "updated": 1777361711
    },
    {
      "id": "69f062f1000000000081683a",
      "text": "　家康の周辺（めんどくさい三河武士）あたりのコンテンツがそろえばとてもおもしろくなりそう",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361650,
      "updated": 1777361837
    },
    {
      "id": "69f063ad000000000081683c",
      "text": "　しかし時間がない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361838,
      "updated": 1777361856
    },
    {
      "id": "69f06330000000000081683b",
      "text": "[織田四天王]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361712,
      "updated": 1777361890
    },
    {
      "id": "69f06407000000000081683e",
      "text": " 有名すぎる四天王",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361928,
      "updated": 1777361946
    },
    {
      "id": "69f063d4000000000081683d",
      "text": " 実はあれ以上書くことがない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361876,
      "updated": 1777361979
    },
    {
      "id": "69f0645b0000000000816840",
      "text": " あれ以上書くとなると膨大な時間が",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777362012,
      "updated": 1777362031
    },
    {
      "id": "69f0643c000000000081683f",
      "text": "[頼光四天王]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777361981,
      "updated": 1777363719
    },
    {
      "id": "69f06aff00000000007a4be1",
      "text": " 実は個人的にはあまり詳しくない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777363711,
      "updated": 1777363766
    },
    {
      "id": "69f06b0900000000007a4be2",
      "text": "　ゲームや創作で人気なんで、詳しい人はいそうだしそういう人に直してもらいたい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777363721,
      "updated": 1777364449
    },
    {
      "id": "69f06de100000000007a4be4",
      "text": "　どちらかというと、[四天王]のページをすっきりさせたかった",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777364450,
      "updated": 1777364521
    },
    {
      "id": "69f06b3700000000007a4be3",
      "text": "　四天王のページは追記しやすくなったということ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777363768,
      "updated": 1777365267
    },
    {
      "id": "69f070e500000000007a4be5",
      "text": "[御三家]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777365221,
      "updated": 1777367101
    },
    {
      "id": "69f078390000000000816847",
      "text": " いっぱいあるので分けたほうがいいと思った",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777367097,
      "updated": 1777367187
    },
    {
      "id": "69f0786f0000000000816848",
      "text": "[三人娘]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777367152,
      "updated": 1777377466
    },
    {
      "id": "69f0a0b6000000000076ee7e",
      "text": " いっぱいあるので分けたほうがいいと思った",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377462,
      "updated": 1777377473
    },
    {
      "id": "69f0a0c3000000000076ee7f",
      "text": "[三大巨匠]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377475,
      "updated": 1777377585
    },
    {
      "id": "69f0a0c3000000000076ee80",
      "text": " これはこれ以上書くことがない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377475,
      "updated": 1777377621
    },
    {
      "id": "69f0a15600000000004ef7b2",
      "text": " どうしよう",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377623,
      "updated": 1777377630
    },
    {
      "id": "69f0a1e500000000004ef7b3",
      "text": "[ルネサンスの三大巨匠]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377765,
      "updated": 1777377807
    },
    {
      "id": "69f0a1fb00000000004ef7b7",
      "text": " これはこれ以上書くことがない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377787,
      "updated": 1777377794
    },
    {
      "id": "69f0a1e600000000004ef7b5",
      "text": "[近代日本画の三大巨匠]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377766,
      "updated": 1777378921
    },
    {
      "id": "69f0a1e600000000004ef7b6",
      "text": " これはこれ以上書くことがない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1777377766,
      "updated": 1777377798
    },
    {
