  "lines": [
    {
      "id": "69d9c5b6d00b150fedb8e97e",
      "text": "2026/04/11 (copy)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d34e",
      "text": "第15週: 日月火水木金[[土]]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d34f",
      "text": "2026年 27.67％経過",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d357",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5c60000000000c7d397",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879623,
      "updated": 1775879626
    },
    {
      "id": "69d9c5ca0000000000c7d399",
      "text": " リンクテストをしてみる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879627,
      "updated": 1775879698
    },
    {
      "id": "69d9c85a0000000000c7d3ac",
      "text": "  [2026/04/11 に関連する日]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775880283,
      "updated": 1775880290
    },
    {
      "id": "69d9c8c50000000000c7d3ad",
      "text": "  2hop化するにはリンク方向が逆",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775880390,
      "updated": 1775880410
    },
    {
      "id": "69d9c8e80000000000c7d3ae",
      "text": "   再現がめんどくさい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775880424,
      "updated": 1775880439
    },
    {
      "id": "69d9c8f90000000000c7d3af",
      "text": "   再現する必要もないか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775880442,
      "updated": 1775880462
    },
    {
      "id": "69d9c5c70000000000c7d398",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879623,
      "updated": 1775879623
    },
    {
      "id": "69d9c5b90000000000c7d358",
      "text": "[inajob.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d359",
      "text": " [アルテミス計画]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d35a",
      "text": "  地球に帰ってくる日",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d35b",
      "text": "  無事帰ってこれたようだ、5歳の娘とライブで見た",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d35c",
      "text": "   one by one が聞き取れてた(英語のレッスンでよく聞く言い回し)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d35d",
      "text": " ランドセル注文した！",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d35e",
      "text": "  多少高くても5歳の娘が欲しいものにしたほうが面倒が少ないなという気持ち",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d35f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d360",
      "text": "[Hiro Aki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d361",
      "text": "\t[Grind Survivors]のPS5版、トロフィーコンプした",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d362",
      "text": "\t\t頭空っぽでぼーっとしながらプレイ出来るゲームやりたくなったので、何かないかなとPSstore眺めてて見かけ購入",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d363",
      "text": "\t\t難易度設定って難しいよなぁ、という感想が出てくるゲームだった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d364",
      "text": "\t\t決して悪いゲームじゃないが、絶妙にしっくり来ない感じ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d365",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d366",
      "text": "[taktamur.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d367",
      "text": " 喫茶店でまったり",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d368",
      "text": "  朝食セット美味い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d369",
      "text": " 今日は朝から日差しが暑い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d36a",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d36b",
      "text": "[terang.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d36c",
      "text": "\t27℃予報",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d36d",
      "text": "\t 300K！[who3.icon][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d36e",
      "text": "\t  アイコンつけ忘れ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d36f",
      "text": "\t  no problem [who4.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d370",
      "text": "\t彼が（英米系でなくて）[大陸哲学]やってる自認からってのもあんのかも。まあいいか。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d371",
      "text": "\tパブリックな場である以上、他者の[現れ]は歓迎したい。その一方、儀礼としての修辞には、孤独（solitude, アーレント）を邪魔されない武装（あるいは防御）の側面があるのかもしれない。[. inspired by [本日の教訓 2026-04-10 suto3#69d958100000000000c5013c]&[本日の教訓 2026-04-10 suto3#69d9b7790000000000d233a5]]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d372",
      "text": "\t[コーチェラ]始まってるっ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d373",
      "text": " \tきづかんかった！配信みないと！[はるひ.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d374",
      "text": " \tfakemink見逃した！",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d375",
      "text": " \tSexyyRedは見よう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d376",
      "text": " \t yがならんでて好き[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d377",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d378",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d379",
      "text": " 問題 (plobrem)",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d37a",
      "text": "  「このような問題があるんですよ！」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d37b",
      "text": "  「何が問題なんです？」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d37c",
      "text": "  「だから、これが起こっているんですよ！」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d37d",
      "text": "  「それが起こっているのは分かりますが、それの何が問題なんです？」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d37e",
      "text": "  「それが起こると困るじゃないですか！」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d37f",
      "text": "  「あなた以外の誰が困ってるんですか？」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d380",
      "text": " 温度計を見ながら過ごす日々がやってくるかもしれない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d381",
      "text": "  一昨日、昨日、今日とで気温が違いすぎて勘ではわからない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d382",
      "text": " xyy 染色体ってあったっけ xxy はあったと思うが",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d383",
      "text": "  何の話だ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d384",
      "text": " 今日は忙しいから何かの知識を集めて stream の流速を上げれない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d385",
      "text": " 日記下のリンク一覧の上の方に日付リンクが来て嫌",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d386",
      "text": "  今日の話題の中でリンクされたワードのリンクは見たい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d387",
      "text": "  日記の日付リンクを[2 hop link]か被リンクにするのはどうだろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d388",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d389",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d38a",
      "text": "[nishio.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d38b",
      "text": "　起床時、室温が29.6度だった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d38c",
      "text": "　　熱中症の危険がある……",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d38d",
      "text": "　　　なお暑めだと知ってたので半袖の夏用パジャマを着て下半身は羽布団に入れてた、まあまあうまくいった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d38e",
      "text": "　　最低気温14度、最高気温26度",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d38f",
      "text": "　　うーん、温度高めでエアコンをつけ続けた方がいいのかな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d390",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d391",
      "text": "[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d392",
      "text": " 安全靴を買うついでに、久々に理科大に行く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d393",
      "text": "  課題終わってないのでそこそこで切り上げたい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879615
    },
    {
      "id": "69d9c5b90000000000c7d395",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879615,
      "updated": 1775879726
    },
    {
      "id": "69d9c62f0000000000c7d39a",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775879728,
      "updated": 1775879728
    }
  ]
}