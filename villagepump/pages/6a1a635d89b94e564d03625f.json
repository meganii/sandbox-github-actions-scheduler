    },
    {
      "id": "6a1a6a2300000000006a69d9",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116004,
      "updated": 1780116004
    },
    {
      "id": "6a1a6a4900000000006a69da",
      "text": "↓ -1",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116041,
      "updated": 1780116041
    },
    {
      "id": "6a1a6a4900000000006a69db",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116041,
      "updated": 1780116041
    },
    {
      "id": "6a1a6a4900000000006a69dc",
      "text": "[$ \\ln (\\ln(1+x))]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116042,
      "updated": 1780116047
    },
    {
      "id": "6a1a6a4d00000000006a69dd",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116045,
      "updated": 1780116045
    },
    {
      "id": "6a1a6a5000000000006a69de",
      "text": "↓ exp",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116048,
      "updated": 1780116084
    },
    {
      "id": "6a1a6a7400000000006a69e9",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116085,
      "updated": 1780116085
    },
    {
      "id": "6a1a6a7200000000006a69e8",
      "text": "[$ \\ln(1+x)]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116083,
      "updated": 1780116093
    },
    {
      "id": "6a1a6a7800000000006a69ea",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116088,
      "updated": 1780116088
    },
    {
      "id": "6a1a6a8000000000006a69eb",
      "text": "↓ exp",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116097,
      "updated": 1780116097
    },
    {
      "id": "6a1a6a8500000000006a69ee",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116102,
      "updated": 1780116102
    },
    {
      "id": "6a1a6a8100000000006a69ec",
      "text": "[$ 1+x]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116097,
      "updated": 1780116106
    },
    {
      "id": "6a1a6a8400000000006a69ed",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116100,
      "updated": 1780116100
    },
    {
      "id": "6a1a6a8a00000000006a69ef",
      "text": "できた！[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116107,
      "updated": 1780116109
    },
    {
      "id": "6a1a6a8d00000000006a69f1",
      "text": "\t面白い",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116109,
      "updated": 1780116113
    },
    {
      "id": "6a1a6a9000000000006a69f2",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116113,
      "updated": 1780116113
    },
    {
      "id": "6a1a700900000000003c8d37",
      "text": "[Fourier変換]と[畳み込み]の組み合わせ[$ \\mathcal F(f)*\\mathcal F(g)=\\sqrt{2\\pi}\\mathcal F(fg)]の証明に似てる[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780117507,
      "updated": 1780117520
    },
    {
      "id": "6a1a701700000000003c8d38",
      "text": " 函数と逆函数とを、符号を反転させて組み合わせる点が",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1780117521,
      "updated": 1780117550
    },
    {
      "id": "6a1a6a8c00000000006a69f0",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780116108,
      "updated": 1780116108
    },
    {
      "id": "6a1ad15e0000000000bb26eb",
      "text": "図解",
      "userId": "582e63d27c56960011aff09e",
      "created": 1780142430,
      "updated": 1780142432
    },
