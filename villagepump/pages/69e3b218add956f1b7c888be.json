      "updated": 1776529947
    },
    {
      "id": "69e3b26e000000000076fbfd",
      "text": "未解決の[Cosense謎解き]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1776530029,
      "updated": 1776601551
    },
    {
      "id": "69e4c99f0000000000c0356c",
      "text": "",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1776601502,
      "updated": 1776601502
    },
    {
      "id": "69ecaa230000000000be757f",
      "text": "[https://gyazo.com/d9fcf0d79d698486530dc47544d779f4 https://x.com/2026musyoku/status/2049413388443242706]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777117732,
      "updated": 1777477447
    },
    {
      "id": "69f41e480000000000930e84",
      "text": " ?んこ かつ 下ネタでない だと結構絞れそう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777606216,
      "updated": 1777606242
    },
    {
      "id": "69f41e620000000000930e85",
      "text": "  [~ あんこ、いんこ、えんこ、しんこ…]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777606242,
      "updated": 1777606272
    },
    {
      "id": "69f41e810000000000930e86",
      "text": "   そんなことなかった",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777606273,
      "updated": 1777606282
    },
    {
      "id": "69f41eb60000000000930e87",
      "text": "  ?にすは絞れそう",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777606330,
      "updated": 1777606356
    },
    {
      "id": "69f41ebd0000000000930e88",
      "text": "   [~ テニス、アニス]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777606333,
      "updated": 1777606355
    },
    {
      "id": "69f2273c0000000000d784cc",
      "text": "\t\tま?こは[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777477436,
      "updated": 1777606607
    },
    {
      "id": "69f41fce0000000000dacc70",
      "text": "\t\t\t[~ まいこ、まきこ？、まさこ？、まちこ？、まなこ、ままこ、まみこ？、まゆこ？]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777606607,
      "updated": 1777606676
    },
    {
      "id": "69f420140000000000dacc71",
      "text": "\t\t\t[~ 人名がありかわからんので一応出したが「まなこ」が怪しいな]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777606677,
      "updated": 1777606692
    },
    {
      "id": "69f4206b0000000000dacc72",
      "text": "\t\t\t\t[~ あなPPPPPべつの下ネタに抵触します！]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777606763,
      "updated": 1777606786
    },
    {
      "id": "69f420820000000000dacc73",
      "text": "\t\t\t[~ あいす、すんこ、ちがう　あいだ、だんこ、ちがう　　違わないか？「断固」はあり]✅？",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777606787,
      "updated": 1777606828
    },
    {
      "id": "69f420c80000000000dacc75",
      "text": "\t\t\t\t[~ あいき、きんこ、もあり　あいち(ダメ)　あいて、てんこ　あいわ？わんこ？]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777606857,
      "updated": 1777607017
    },
    {
      "id": "69f420a20000000000dacc74",
      "text": "\t\t\t  わかったかも、[~ ていき]では？[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777606818,
      "updated": 1777607053
    },
    {
      "id": "69f421a00000000000dacc76",
      "text": "\t\t\t  \tそれもあり[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777607073,
      "updated": 1777607077
    },
    {
      "id": "69f421ab0000000000930e89",
      "text": "\t\t\t  \t回答複数ありそう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777607083,
      "updated": 1777607089
    },
    {
      "id": "69f421b60000000000dacc78",
      "text": "\t\t\t  \t\t今まで出てきた中では[~ 断固下ネタ禁止です]が一番しっくりくるな〜[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777607094,
      "updated": 1777607123
    },
    {
      "id": "69f421e10000000000930e8a",
      "text": "\t\t\t  \t\t なるほど！気づいてなかった！[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777607138,
      "updated": 1777607147
    },
    {
      "id": "69f421a60000000000dacc77",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777607078,
      "updated": 1777607079
    },
    {
      "id": "69ecaac5000000000044a2d9",
      "text": ">[Cheetah_math https://x.com/Cheetah_math/status/1948654463633555928] #ちーたー謎",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777117894,
      "updated": 1777117894
    },
    {
      "id": "69ecaac5000000000044a2da",
      "text": "> [https://pbs.twimg.com/media/GwsCGxTbgAI3A5D?format=jpg&name=medium#.png]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777117894,
      "updated": 1777117894
    },
    {
      "id": "69ecaac5000000000044a2db",
      "text": "\t特定できるか？[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777117894,
      "updated": 1777117895
    },
    {
      "id": "69ecaf940000000000a6048d",
      "text": "\t [~ 答え側を先に思いついて逆算で解けた][caki.icon][yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1777119125,
      "updated": 1777132479
    },
    {
      "id": "69ece3bf0000000000d49878",
      "text": "\t かなりわからなかったけど、[~ 下の問題文の枠の文字数からピンときて逆算できた][yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1777132479,
      "updated": 1777132612
    },
    {
      "id": "69eceb8e0000000000ee930e",
      "text": "\t これがわからないでいる[terang.icon][nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777134479,
      "updated": 1777606541
    },
    {
      "id": "69f41e1e0000000000930e82",
      "text": "\t  [~ 四字熟語]になっている[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777606175,
      "updated": 1777606192
    },
    {
      "id": "69f41fa50000000000dacc6f",
      "text": "\t  \t[~ カタカナかと思ってた][nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777606565,
      "updated": 1777606572
    },
    {
      "id": "69f421f00000000000dacc79",
      "text": "\t  \t\t　[~ 無理難題？罵詈雑言？ 同じ文字の繰り返しにならないな〜〜]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777607152,
      "updated": 1777607174
    },
    {
      "id": "69f4222d0000000000930e8b",
      "text": "\t  \t[~ 下のスラッシュで区切られているところに四字熟語のよみがあてはまるようになっている][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777607214,
      "updated": 1777607390
    },
    {
      "id": "69f424090000000000dba282",
      "text": "\t  理解にいたった！ヒント[/icons/感謝.icon][terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777607689,
      "updated": 1777607718
    },
    {
      "id": "69ecf33e0000000000e833a0",
      "text": "　　　あー[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777136446,
      "updated": 1777626744
    },
    {
      "id": "69f46e7c00000000001d51b5",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777626748,
      "updated": 1777626749
    },
    {
      "id": "69ecac21000000000044a2e3",
      "text": ">[Cheetah_math https://x.com/Cheetah_math/status/2001200695395950912] #ちーたー謎 （再掲）",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777118242,
      "updated": 1777118242
    },
    {
      "id": "69ecac21000000000044a2e4",
      "text": "> [https://pbs.twimg.com/media/G8WRvzpa4AAG3Qd?format=jpg&name=medium#.png]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777118242,
      "updated": 1777118242
    },
    {
      "id": "69ecac21000000000044a2e5",
      "text": "\tぜんぜんわからん[nishio.icon][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777118242,
      "updated": 1777119186
    },
    {
      "id": "69ecc6d2000000000056e93c",
      "text": "\tあー[~ 漢字]かー！[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777125075,
      "updated": 1777125081
    },
    {
      "id": "69f41e360000000000930e83",
      "text": "\t まだわからん[caki.icon][nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1777606199,
      "updated": 1777606584
    },
    {
      "id": "69f424b40000000000dba283",
      "text": "\t [~ 英語にも]する[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777607860,
      "updated": 1777607865
    },
    {
      "id": "69f475e0000000000055c7d8",
      "text": "\t  [~ 家はhome?だとすると左はmo??hで右はe?eになるな][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777628753,
      "updated": 1777628757
    },
    {
      "id": "69f4763b000000000055c7d9",
      "text": "\t   あー！わかった、おもしろ",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777628757,
      "updated": 1777628757
    },
    {
      "id": "69f479c7000000000022d00c",
      "text": "\t   [~ 🪀]✨[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1777629639,
      "updated": 1777629656
    },
    {
      "id": "69f4b84800000000006e6ce9",
      "text": "\t   なるほど！おもしろ[yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1777645641,
      "updated": 1777645649
    },
    {
      "id": "69f4b86800000000006e6cea",
      "text": "\t    そしてむずすぎる",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1777645673,
      "updated": 1777645708
    },
    {
      "id": "69f4b89400000000006e6ceb",
      "text": "\t    [~ ？=問い=toy]ってこと？そんなのありなのか",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1777645716,
      "updated": 1777645768
    },
