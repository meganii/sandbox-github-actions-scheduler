    },
    {
      "id": "666b0a375b98c20000073c70",
      "text": "[ハイパーテキスト]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1718291000,
      "updated": 1718291001
    },
    {
      "id": "666b0a385b98c20000073c71",
      "text": "[ハイパーリンク]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1718291001,
      "updated": 1718291001
    },
    {
      "id": "666b0a385b98c20000073c72",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1718291001,
      "updated": 1718291001
    },
    {
      "id": "69f9a40f000000000024bae3",
      "text": "[https://ja.wikipedia.org/wiki/テッド・ネルソン テッド・ネルソン]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968143,
      "updated": 1777968158
    },
    {
      "id": "69f9a408000000000024bade",
      "text": "アメリカ合衆国の社会学者であり思想家であり情報技術のパイオニア。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968137,
      "updated": 1777968170
    },
    {
      "id": "69f9a429000000000024bae4",
      "text": " 1963年に「ハイパーテキスト」と「ハイパーメディア」という用語を生み出し1965年に発表。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968170,
      "updated": 1777968182
    },
    {
      "id": "69f9a435000000000024bae5",
      "text": " 他に生み出された用語：",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968182,
      "updated": 1777968211
    },
    {
      "id": "69f9a449000000000024bae8",
      "text": "  [トランスクルージョン]、Virtuality (電子書籍システムの概念構造)、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968202,
      "updated": 1777968246
    },
    {
      "id": "69f9a444000000000024bae6",
      "text": "  Intertwingularity (知識の相互関連性)、",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968197,
      "updated": 1777968241
    },
    {
      "id": "69f9a448000000000024bae7",
      "text": "  テレディルドニクス",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968200,
      "updated": 1777968242
    },
    {
      "id": "69f9a408000000000024badf",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968137,
      "updated": 1777968137
    },
    {
      "id": "69f9a483000000000024bae9",
      "text": "1960年に[ザナドゥ]計画を立ち上げ、コンピュータネットワーク上に単純なユーザインタフェースを構築することを目標とした。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968260,
      "updated": 1777968331
    },
    {
      "id": "69f9a48f000000000024baed",
      "text": "1974年『コンピュータ・リブ／夢の機械』",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968271,
      "updated": 1777968302
    },
    {
      "id": "69f9a4a9000000000024baee",
      "text": "1981年『リテラリーマシン』",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968297,
      "updated": 1777968311
    },
    {
      "id": "69f9a4b4000000000024baef",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968309,
      "updated": 1777968309
    },
