    },
    {
      "id": "6a00145f000000000050587a",
      "text": "[https://ja.wikipedia.org/wiki/発達の最近接領域 発達の最近接領域]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778390112,
      "updated": 1778390130
    },
    {
      "id": "6a00146c000000000050587b",
