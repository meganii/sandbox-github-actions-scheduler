    },
    {
      "id": "69ee0b2f00000000004deefc",
      "text": "https://chromewebstore.google.com/detail/amddgdnlkmohapieeekfknakgdnpbleb",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1777208111,
      "updated": 1777208111
    },
    {
      "id": "69ee0b2f00000000004deefd",
      "text": " 開けるTabの数を制限することができる[Chrome拡張機能]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1777208111,
      "updated": 1777208328
    },
    {
      "id": "69ee0b7d00000000004deeff",
      "text": " 例えば10個までにすると、11個目のタブを開こうとしたときにブロックして開かないようにする",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1777208190,
      "updated": 1777208336
    },
    {
      "id": "69ee0b9200000000004def01",
      "text": "  または、一番古いタブを閉じる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1777208210,
      "updated": 1777208245
    },
    {
      "id": "69ee0bc600000000004def03",
      "text": "  または、最も使ってないタブを閉じる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1777208262,
      "updated": 1777208294
    },
    {
      "id": "69ee0beb00000000004def05",
      "text": " [Tabを開きすぎてしまって疲れてる人に便利な拡張機能]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1777208299,
      "updated": 1777208317
    }
  ]
