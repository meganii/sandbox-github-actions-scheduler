  "lines": [
    {
      "id": "69727ecb3f66926108e47101",
      "text": "2026/01/23",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769111260,
      "updated": 1769111260
    },
    {
      "id": "69729cc26eb40600000082587b",
      "text": "第4週: 日月火水木[[金]]土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118915,
      "updated": 1769118915
    },
    {
      "id": "69729cc26eb4060000008fb2cd",
      "text": "2026年 6.30％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118915,
      "updated": 1769118915
    },
    {
      "id": "69727edb00000000006e14d4",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769111260,
      "updated": 1769111260
    },
    {
      "id": "69729cc26eb406000000434be5",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118915,
      "updated": 1769118915
    },
    {
      "id": "69727edc00000000006e14d5",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769111260,
      "updated": 1769111261
    },
    {
      "id": "69727edc00000000006e14d7",
      "text": "\tいや寒すぎる、どうすればいいんだ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769111261,
      "updated": 1769111275
    },
    {
      "id": "69727eeb00000000006e14da",
      "text": "\t\tリビングにマットレス敷いて寝ているが、厚さが足りない可能性がある",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769111276,
      "updated": 1769111289
    },
    {
      "id": "6972810200000000006e14db",
      "text": "\t\tアルミシートやジョイントマットなるものがあるらしいので買う",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769111811,
      "updated": 1769111821
    },
    {
      "id": "69729a6e0000000000e2da81",
      "text": "\tふぇぇ、汚い独り言をメンバーに聞かれてしまった",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769118319,
      "updated": 1769149428
    },
    {
      "id": "697314b50000000000851094",
      "text": "\t\tシチュとして、5分前に定例会議のルーム入って、マイクオンにしたままNotion書いてて、それで独りごちた直後メンバーから「おはようございます」と来た感じ。そしてそのまま（今日のファシリテーターは僕だったがなぜか）その人がそのまま進めていた",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149622,
      "updated": 1769149789
    },
    {
      "id": "697313f1000000000085108f",
      "text": "\t\t\tそのときは気づかなかった。あれ、僕がファシリテーターなの忘れてる？たぶん忘れない側のキャラだと思うが。と呑気に思っていた",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149428,
      "updated": 1769149821
    },
    {
      "id": "697315640000000000851097",
      "text": "\t\t\t会議後「あ、やべ、聞かれたんじゃね」と思い出す感じで気づく",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149798,
      "updated": 1769149798
    },
    {
      "id": "6973145f0000000000851092",
      "text": "\t\t無論普段は見せないようにしているが、しょうもないミスすぎて凹む",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149536,
      "updated": 1769149834
    },
    {
      "id": "6973146e0000000000851093",
      "text": "\t俺は[プログラマの三大美徳]全部持ってる側の人間なので独りごちること自体はしゃーない",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149552,
      "updated": 1769149702
    },
    {
      "id": "697314d40000000000851096",
      "text": "\t\tまた「独り言が縛られない」は創造性を発揮するのにも重要",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769149654,
      "updated": 1769186080
    },
    {
      "id": "69739a630000000000498b63",
      "text": "\t\t わかる[yosider.icon][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769183844,
      "updated": 1769183917
    },
    {
      "id": "6973a322000000000089e718",
      "text": "\t\t [独り言を自由に言えること]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769186082,
      "updated": 1769186089
    },
    {
      "id": "697315930000000000851098",
      "text": "\t\t[ラバーダッキング]もするぜ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149844,
      "updated": 1769149849
    },
    {
      "id": "697315980000000000851099",
      "text": "\t\t\t[サイレントベアプログラミング]もつくるほどでもあるぜ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149849,
      "updated": 1769149865
    },
    {
      "id": "6a03c2bd00000000002108c6",
      "text": "\t✂ [今見てるCosense Projectのページ一覧をつくるUserScriptが欲しい]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778631358,
      "updated": 1778631402
    },
    {
      "id": "69731d2c000000000011fd9d",
      "text": "\t「[疲れてるときでもできること]」こそが実力",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769151790,
      "updated": 1769186105
    },
    {
      "id": "69731f82000000000011fdaf",
      "text": "\t\tあれだなぁ、有事のときに出る性格がその人の本性？みたいなことわざ？と同じ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769152388,
      "updated": 1769152413
    },
    {
      "id": "69731fab000000000011fdb0",
      "text": "\t\tこの実力がカスな[sta.icon]としては、そもそも疲れないよう立ち回る戦略を取ることになる",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769152429,
      "updated": 1769152445
    },
    {
      "id": "69731fbc000000000011fdb1",
      "text": "\t\t\tストイックになっていく",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769152445,
      "updated": 1769152450
    },
    {
      "id": "69731f6c000000000011fdae",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769152366,
      "updated": 1769152366
    },
    {
      "id": "69729a6e0000000000e2da82",
      "text": "[blu3mo.icon]",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1769118319,
      "updated": 1769118320
    },
    {
      "id": "69729a6f0000000000e2da84",
      "text": " 渡米後から精神的にも肉体的にもコンディションが最悪",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1769118320,
      "updated": 1769118337
    },
    {
      "id": "69729a800000000000e2da86",
      "text": "  昼は意識が朦朧としていて、夜は寝れない中、悩みと焦りだけがぐるぐる回り続けている",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1769118337,
      "updated": 1769118337
    },
    {
      "id": "69729a7f0000000000e2da85",
      "text": "　 一旦これを治すのを最優先に生きている",
      "userId": "5d89b1f60230ae001779e113",
      "created": 1769118335,
      "updated": 1769118417
    },
    {
      "id": "6972f89000000000000ae223",
      "text": "　 健康第一[nishio.icon][Hiro Aki.icon][taktamur.icon][takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1769142416,
      "updated": 1769168416
    },
    {
      "id": "69729a8a0000000000e2da8b",
      "text": "　✂ [衆院選のAIボートマッチを作ってみました]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769118347,
      "updated": 1778631466
    },
    {
      "id": "6972ec09000000000075421a",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1769139210,
      "updated": 1769139210
    },
    {
      "id": "69729cdb000000000020ea63",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118940,
      "updated": 1769118942
    },
    {
      "id": "69729cde000000000020ea65",
      "text": " 週末どこ行こう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118943,
      "updated": 1769118947
    },
    {
      "id": "69729cfa000000000020ea66",
      "text": "  [https://www.webtsc.com/event/hataraku-saibou-tokyo/ はたらく細胞展IN東京ソラマチ]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118972,
      "updated": 1769120010
    },
    {
      "id": "69729cfd000000000020ea67",
      "text": "  \t気になるが、規模が小さそうだなぁ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118974,
      "updated": 1769120049
    },
    {
      "id": "6972a10e00000000001a0c51",
      "text": "  \t\tその割に混みそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769120015,
      "updated": 1769120049
    },
    {
      "id": "6972a12600000000001a0c52",
      "text": "  [https://www.jsf.or.jp/event/202601/godzilla/ ゴジラサイエンス展 | 科学技術館]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769120038,
      "updated": 1769120042
    },
    {
      "id": "6972a12900000000001a0c53",
      "text": "  \t超混みそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769120042,
      "updated": 1769131763
    },
    {
      "id": "6972cef20000000000c64a08",
      "text": " Geminiの無料で利用できる枠が少なくなり、[LLMのボーナスタイム]の終わりを感じる",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769131763,
      "updated": 1769133354
    },
    {
      "id": "6972cf100000000000c64a09",
      "text": " \tサーバを持ちたい時に自宅サーバにするかVPSを借りるかみたいなものと同じ感じになるんだろうな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769131793,
      "updated": 1769131843
    },
    {
      "id": "69729cdb000000000020ea64",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769118940,
      "updated": 1769118940
    },
    {
      "id": "69729d4f0000000000f6bbcf",
      "text": "[suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1769119056,
      "updated": 1769119061
    },
    {
      "id": "69729d490000000000f6bbcd",
      "text": " 遅くなってしまいましたが、[mrsekut.icon]さん、おめでとうございます[[めでたい.icon]]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1769119050,
      "updated": 1769119192
    },
    {
      "id": "69729d9b0000000000f6bbd0",
      "text": " 　[/mrsekut-p/2026/1/2 出産の立ち会いをした]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1769119132,
      "updated": 1769119148
    },
    {
      "id": "6972aa9a000000000075bcfb",
      "text": " 　おお、おめでとうございます[sta.icon][inajob.icon][Hiro Aki.icon][takker.icon][terang.icon][caki.icon][koyoshi.icon][nishio.icon][W7kA9pX2.icon][mtane0412.icon][基素.icon][nomadoor.icon][meganii.icon][imo.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1769122459,
      "updated": 1769180658
    },
    {
      "id": "6972abaf00000000001a0c54",
      "text": " 　貴重な記録だ[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769122736,
      "updated": 1769122741
    },
    {
      "id": "69729d4e0000000000f6bbce",
      "text": "\t\t\t[/mrsekut-p/寝れずに泣くのを観察する時間を徐々に伸ばす]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1769119055,
      "updated": 1769127678
    },
    {
      "id": "6972befe0000000000c649ff",
      "text": "\t\t\t\tわかるわー [Exponential Backoff]だよね！ってとこまで同じ感想だ",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769127678,
      "updated": 1769184788
    },
    {
      "id": "6972c080000000000034987b",
      "text": "\t\t\t\t\tおもしろ[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769128064,
      "updated": 1769128074
    },
    {
      "id": "6975eac9000000000082e7b0",
      "text": "\t\t見てなかった！みなさんありがとうございます！！！[mrsekut.icon*9]",
      "userId": "5b4ea932de544f0014198270",
      "created": 1769335499,
      "updated": 1769335512
    },
    {
      "id": "6972befc0000000000c649fe",
      "text": "　#天気図",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1769127677,
      "updated": 1769144100
    },
    {
      "id": "6972fef4000000000044d889",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1769144052,
      "updated": 1769144052
    },
    {
      "id": "6972b1a400000000001e3411",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1769124260,
      "updated": 1769124262
    },
    {
      "id": "6972b1a500000000001e3412",
      "text": "\tおはようございます",
      "userId": "65e1289acd012200235729c0",
      "created": 1769124262,
      "updated": 1769124266
    },
    {
      "id": "6972b1aa00000000001e3413",
      "text": "\t寒いけど雪が降らない、積もらないならまぁいいか感",
      "userId": "65e1289acd012200235729c0",
      "created": 1769124266,
      "updated": 1769124314
    },
    {
      "id": "6972b1d900000000001e3414",
      "text": "\t\t積雪確率低い地域なのでノーマルタイヤ、だから雪積もったら、路面凍結したら車移動自主制限",
      "userId": "65e1289acd012200235729c0",
      "created": 1769124314,
      "updated": 1769124400
    },
    {
      "id": "6972b29d00000000001e3415",
      "text": "\t\tタイヤも傘と似て、[生まれた時の姿の延長線上な進化]しか出来ていなさそうと思う",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769124510,
      "updated": 1769185018
    },
    {
      "id": "6972b30a00000000001e3416",
      "text": "\t\t移動において、円筒形を転がす以上に効率面で優秀な方法を人類が見つけていないから仕方がない",
      "userId": "65e1289acd012200235729c0",
      "created": 1769124619,
      "updated": 1769124667
    },
    {
      "id": "6972e0ee00000000001e3424",
      "text": "\t早く生成AIが当たり前になって、分かりにくい文が撲滅されないかな",
      "userId": "65e1289acd012200235729c0",
      "created": 1769136367,
      "updated": 1769136386
    },
    {
      "id": "6972e10100000000001e3425",
      "text": "\t\t来たメール、読みにくいなと、これって主語がふわふわあっちこっち飛んでるからだろうな、と思いつつChatGPTに聞いてみた",
      "userId": "65e1289acd012200235729c0",
      "created": 1769136386,
      "updated": 1769136417
    },
    {
      "id": "6972e12300000000001e3426",
      "text": "\t\t主語の暗黙切替、接続助詞の多用による[一文過積載]によって読解負荷が高い文章だとのこと",
      "userId": "65e1289acd012200235729c0",
      "created": 1769136420,
      "updated": 1769148786
    },
    {
      "id": "6972e15d00000000001e3427",
      "text": "\t\t一文にイロイロ詰め込む、典型的な悪い文章のことを一文[過積載]と表現するのが面白いので今後使いたい",
      "userId": "65e1289acd012200235729c0",
      "created": 1769136477,
      "updated": 1769148788
    },
    {
      "id": "6972e18300000000001e3428",
      "text": "\t\tこういった文章、間に生成AIが入っていい感じに読みやすくなってくれることを期待",
      "userId": "65e1289acd012200235729c0",
      "created": 1769136515,
      "updated": 1769136545
    },
    {
      "id": "697313e100000000001e3429",
      "text": "\t詐欺メールは常に流れているけど、最近の流行りは偽の社長とな",
      "userId": "65e1289acd012200235729c0",
      "created": 1769149410,
      "updated": 1769149441
    },
    {
      "id": "6973140200000000001e342a",
      "text": "\t\t[https://news.yahoo.co.jp/expert/articles/d9e17b5c86e4a0012b60b5a1f6ac9c1ef7915096 なぜ1億円の被害に！？ニセ社長詐欺の巧妙さに迫る 詐欺メールからの被害に遭わないために知っておくこと #エキスパートトピ（多田文明） - エキスパート - Yahoo!ニュース]",
      "userId": "65e1289acd012200235729c0",
      "created": 1769149442,
      "updated": 1769149452
    },
    {
      "id": "6973146100000000001e342c",
      "text": "\t\t[ニセ社長詐欺]、だと何か語感が悪いが、いい感じに短く出来ぬ",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769149537,
      "updated": 1769185065
    },
    {
      "id": "6972b2830000000000595ae9",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1769124482,
      "updated": 1769124482
    },
    {
      "id": "6972b2830000000000595aea",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1769124482,
      "updated": 1769124484
    },
    {
      "id": "6972b2860000000000595aeb",
      "text": " 卒論の試験方法と研究背景を最低限書いて25日までに先生に提出するのを最優先にする",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1769124485,
      "updated": 1769124561
    },
    {
      "id": "6972b2d40000000000595aec",
      "text": " この3日間はこれだけをやる。何とかなれ～",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1769124564,
      "updated": 1769124599
    },
    {
      "id": "6972b34c00000000001e3417",
      "text": " \t[加油.icon][Hiro Aki.icon][caki.icon][nishio.icon][W7kA9pX2.icon][suto3.icon][Mijikko.icon][blu3mo.icon][koyoshi.icon][Summer498.icon][sta.icon][nomadoor.icon][meganii.icon][ふーこ心配.icon][mtane0412.icon][カイト.icon][imo.icon][yosider.icon][mrsekut.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1769124685,
      "updated": 1769335563
    },
    {
      "id": "6972f4ff0000000000c9245b",
      "text": " \tなんとかなると思ったら大体なんとかなる！[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1769141503,
      "updated": 1769141513
    },
    {
      "id": "6972f50a0000000000c9245c",
      "text": " \t　がんばえ〜〜〜[!- [Mijikko.icon]]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1769141513,
      "updated": 1769141535
    },
    {
      "id": "69731556000000000077b39a",
      "text": " \t　[なんとかなれーッ][!- [caki.icon]][基素.icon][!- [mtane0412.icon]]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1769149783,
      "updated": 1769163018
    },
    {
      "id": "69730d3e0000000000b88123",
      "text": " \t2日目3日目の日付ページに宣言をコピペしておいたのだ。[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769147709,
      "updated": 1769147774
    },
    {
      "id": "6972b1a300000000001e3410",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1769124259,
      "updated": 1769124259
    },
    {
      "id": "6972b76800000000005fe806",
      "text": "[カイト.icon]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769125736,
      "updated": 1769125738
    },
    {
      "id": "6972b76b00000000005fe807",
      "text": " 起きてもいないことを心配することを[予期不安]というらしい",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769125739,
      "updated": 1769125852
    },
    {
      "id": "6972b81500000000005fe80a",
      "text": "  自分も気にすることはあるが、大半起こらないから気にしても無駄という結論に至る",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769125911,
      "updated": 1769125963
    },
    {
      "id": "697313c9000000000085108d",
      "text": "  [杞憂リスト]というテクニックがまさにあるのを思い出した[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1769149386,
      "updated": 1769149395
    },
    {
      "id": "6972bd5e000000000045b0bf",
      "text": " [ららぽーと名古屋みなとアクルス]の隣に多目的[アリーナ]ができることを知った",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127262,
      "updated": 1769127321
    },
    {
      "id": "6972bedb000000000045b0c5",
      "text": "\t\tキャパ：約10,000人",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127643,
      "updated": 1769127660
    },
    {
      "id": "6972bd99000000000045b0c1",
      "text": " \t2028年開業ということで、開業後は行くことになりそう",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127321,
      "updated": 1769127643
    },
    {
      "id": "6972bf01000000000045b0c7",
      "text": " \t最寄駅から徒歩2分だし[ライブ]行くときは楽そう",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127682,
      "updated": 1769127739
    },
    {
      "id": "6972bded000000000045b0c2",
      "text": " \tららぽーと名古屋みなとアクルス自体は去年初めて行ったが広い[蔦屋書店]が印象的だった",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127405,
      "updated": 1769127525
    },
    {
      "id": "6972be8c000000000045b0c3",
      "text": " \tちかくの[名古屋港水族館]は2回くらい訪問",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127565,
      "updated": 1769127602
    },
    {
      "id": "6972bf7e000000000045b0c8",
      "text": " 今日も友人が我が家に宿泊予定",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127807,
      "updated": 1769127825
    },
    {
      "id": "6972bf90000000000045b0c9",
      "text": " \t21時すぎに合流後、夕飯を食べに行く",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127825,
      "updated": 1769127862
    },
    {
      "id": "6972bfba000000000045b0ca",
      "text": " \t寝不足だから仕事から帰宅したらすぐ仮眠する予定",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127866,
      "updated": 1769127897
    },
    {
      "id": "697320ed00000000007d239a",
      "text": " \t\tとりあえず友人に事情説明完了",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769152750,
      "updated": 1769152765
    },
    {
      "id": "697320fd00000000007d239b",
      "text": " \t\t\t爆睡してたら勝手に家に入ってきて起こしてくれる模様、助かる",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769152766,
      "updated": 1769152802
    },
    {
      "id": "6972db9900000000008c3add",
      "text": " ✂ [衆院選のAIボートマッチを作ってみました]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769135001,
      "updated": 1778632445
    },
    {
      "id": "6972e33e0000000000b8e5f2",
      "text": " [理性が蒸発]して心がないことを書かない・言わないようにしているが難しい時がある",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769145375,
      "updated": 1769145375
    },
    {
      "id": "6972e3af0000000000b8e5f3",
      "text": "  何もかも睡眠不足が悪い",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769137071,
      "updated": 1769137095
    },
    {
      "id": "6972e3c70000000000b8e5f4",
      "text": "   [睡眠の重要性]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769137096,
      "updated": 1769137111
    },
    {
      "id": "6972e4280000000000b8e5f5",
      "text": "  [自分の機嫌は自分でとる]というキーワードが頭にずっとよぎっている",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769137193,
      "updated": 1769137254
    },
    {
      "id": "6972f27e000000000030e046",
      "text": "  1日中「食う・寝る・歌う」をする日を作ると良いと思う[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769140861,
      "updated": 1769140894
    },
    {
      "id": "6972f2a0000000000030e047",
      "text": "  \t運動は疲れるので筋肉の使用量の割にストレス解消効果が大きい歌唱を勧める。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769140894,
      "updated": 1769140943
    },
    {
      "id": "6972f2d1000000000030e048",
      "text": "  \t気兼ねなく大きな声を出せる空間に行き、大きな声を出すだけでも良い。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769140943,
      "updated": 1769140980
    },
    {
      "id": "6972ffc90000000000502a66",
      "text": "  \t\t自分の場合、ライブでコーレスすることが該当[カイト.icon]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769144266,
      "updated": 1769144711
    },
    {
      "id": "6972ffe80000000000502a67",
      "text": "  \t\t\t明日と来週末に行くからちょうど良さそう",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769144296,
      "updated": 1769144357
    },
    {
      "id": "697302250000000000502a6d",
      "text": " [劇場版 魔法少女まどか☆マギカ〈ワルプルギスの廻天〉]、公開延期...",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769144869,
      "updated": 1769144913
    },
    {
      "id": "697302590000000000502a6e",
      "text": " \t当初、[2026/02]公開予定",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769144921,
      "updated": 1769144941
    },
    {
      "id": "697302990000000000502a6f",
      "text": " \t[ムビチケ]買ってあるしひたすら待つしかない",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769144985,
      "updated": 1769145013
    },
    {
      "id": "697302b90000000000502a70",
      "text": " \t2月は[新劇場版 銀魂 -吉原大炎上-]と[転スラ]の映画と[涼宮ハルヒの消失]を観に行くか",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769145018,
      "updated": 1769145150
    },
    {
      "id": "69733d310000000000af1b56",
      "text": " [初恋サイダー]、懐かしい",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769159986,
      "updated": 1769160000
    },
    {
      "id": "69733d420000000000af1b57",
      "text": "  [https://youtu.be/cz6sVjhfDsI?si=PIF3oRMAhK9XrmuW]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769160003,
      "updated": 1769160006
    },
    {
      "id": "69733d450000000000af1b58",
      "text": "  [Buono!]の楽曲は、[しゅごキャラ!]にハマった時にまとめて聞いた",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769160006,
      "updated": 1769160077
    },
    {
      "id": "69733d970000000000af1b59",
      "text": "   しゅごキャラ!のキャラソンアルバムは全てレンタルしてデータで所持",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769160087,
      "updated": 1769160134
    },
    {
      "id": "69734718000000000013ba05",
      "text": " [小泉進次郎]のポッドキャストが面白い",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769162521,
      "updated": 1769162583
    },
    {
      "id": "6973474e000000000013ba06",
      "text": "  公式の切り抜きをきっかけに本編も見始めた",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769162575,
      "updated": 1769162610
    },
    {
      "id": "69734775000000000013ba07",
      "text": "  公式ハッシュタグが[小泉進次郎のポッドキャスト]なのは…",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769162613,
      "updated": 1769186178
    },
    {
      "id": "6973482c000000000013ba08",
      "text": "  [防衛大臣]が小泉さんだったらまだ続けていたのかもと思いつつも自衛隊の束縛とetcで結局辞めてたんだろうな",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769162797,
      "updated": 1769162894
    },
    {
      "id": "697366e300000000000545e2",
      "text": " 仮眠した後に外出たら体温が下がってるのも相まってくっそ寒い",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769170660,
      "updated": 1769170726
    },
    {
      "id": "6972bed7000000000045b0c4",
      "text": "",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769127639,
      "updated": 1769127642
    },
    {
      "id": "6972b7cb00000000005fe808",
      "text": "",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1769125836,
      "updated": 1769125836
    },
    {
      "id": "6972bac7000000000099c8ed",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769126601,
      "updated": 1769126601
    },
    {
      "id": "6972bac7000000000099c8ee",
      "text": "\t寒くて体が縮こまる。ﾁﾁﾞ困る。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769126601,
      "updated": 1769126621
    },
    {
      "id": "6972da4100000000006f50e1",
      "text": "\t外で食べた[かやくご飯]に髪の毛が1本炊き込まれており、店員に言うべきかちょっと迷ったが、まあ死にやしねーか、と傍に置いて見なかったことにした",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769134658,
      "updated": 1769134719
    },
    {
      "id": "6973a2240000000000498b67",
      "text": "\t [髪の毛混入]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1769185828,
      "updated": 1769185834
    },
    {
      "id": "6973044100000000006f50e9",
      "text": "\t✂ [衆院選のAIボートマッチを作ってみました]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1769145412,
      "updated": 1778632438
    },
    {
      "id": "6973501000000000009d4c1f",
      "text": " [Hasbro] CEOらが株主から訴えられている",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769164817,
      "updated": 1769165267
    },
    {
      "id": "6973501100000000009d4c20",
      "text": "  [https://www.golocalprov.com/business/hasbro-ceo-cocks-and-execs-sued-for-alleged-securities-violations GoLocalProv | Hasbro CEO Cocks and Execs Sued for Alleged Securities Violations]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769164817,
      "updated": 1769164822
    },
    {
      "id": "6973501100000000009d4c21",
      "text": "  \t訴えられたのはCEOの[Chris Cocks]氏と同社幹部",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769164817,
      "updated": 1769165310
    },
    {
      "id": "6973501100000000009d4c22",
      "text": "  \t同社主力製品の[マジック：ザ・ギャザリング]カードの過剰増刷を、経営陣が他部門の収益不足を補うために行い、カードの希少性を低下させることでブランドの長期的な価値を損なった、と主張",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769164817,
      "updated": 1769165310
    },
    {
      "id": "6973501100000000009d4c23",
      "text": "  \t経営陣は投資家やアナリストに対して、過剰増刷の疑いを繰り返し否定していたが、その説明が虚偽であった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769164817,
      "updated": 1769165310
    },
    {
      "id": "697351f600000000009d4c24",
      "text": " \tMtGって[Hasbro]が出してたんだ。[TCG]全然やらないから知らなかったや[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769165302,
      "updated": 1769165331
    },
    {
      "id": "6973531300000000009d4c26",
      "text": " 寒すぎサムスミス/寒すぎサムシングエルス/寒すぎサムアルトマン",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769165588,
      "updated": 1769165628
    },
    {
      "id": "6973539100000000009d4c27",
      "text": " \t[2026/01/23#69732a4500000000009f888f]見て連想遊び",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769165714,
      "updated": 1769165717
    },
    {
      "id": "6973554600000000009d4c2b",
      "text": " [/blu3mo-public/ここから始める政治理論]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769166151,
      "updated": 1769166151
    },
    {
      "id": "6973554700000000009d4c2c",
      "text": " \tここはじはいい本だった記憶",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769166152,
      "updated": 1769166156
    },
    {
      "id": "697379d30000000000235913",
      "text": " [KinKi Kids]の名前が変わっていること知った",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769175508,
      "updated": 1769175544
    },
    {
      "id": "697379fb0000000000235914",
      "text": " \tきっと明日には忘れそう",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1769175547,
      "updated": 1769175551
    },
