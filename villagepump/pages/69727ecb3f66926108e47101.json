      "id": "6972bf4d0000000000382ff7",
      "text": "[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769127757,
      "updated": 1769127758
    },
    {
      "id": "6972bf4d0000000000382ff8",
      "text": "\tチートス食べたい",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769127758,
      "updated": 1769127762
    },
    {
      "id": "6972bf520000000000382ff9",
      "text": "\tいつか死ぬらしいなー",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769127762,
      "updated": 1769127963
    },
    {
      "id": "6972c01b0000000000382ffa",
      "text": "\t死ぬ時主観で5億年ボタンとかだったら嫌すぎる",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769127963,
      "updated": 1769127976
    },
    {
      "id": "6972f36a00000000003a82ba",
      "text": "\tそもそも人生が5億年ボタンみたいなもんなんだが",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769141099,
      "updated": 1769141551
    },
    {
      "id": "6972f3b300000000003a82bb",
      "text": " \t昔のアニメて3Dっぽい映像が使われているというだけでエキサイティングだった",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769141172,
      "updated": 1769141442
    },
    {
      "id": "6972f46a00000000003a82bc",
      "text": " \tデジモン的な　デジモン見てなかったけど",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769141354,
      "updated": 1769141431
    },
    {
      "id": "6972c0280000000000382ffb",
      "text": " 日本からノルウェーの直行便はないのか",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769127976,
      "updated": 1769128947
    },
    {
      "id": "6972c4880000000000382ffc",
      "text": " ヘルシンキからオスロも近くはないんだな～～",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1769129096,
      "updated": 1769130057
    },
    {
      "id": "6972e4050000000000b32fb9",
      "text": " ヘルシンキ矢野",
      "userId": "60c9f2f6c225a50020b8bbfc",
