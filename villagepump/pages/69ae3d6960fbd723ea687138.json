      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026683,
      "updated": 1773026683
    },
    {
      "id": "69ae3d8a0000000000b9504c",
      "text": "キャラクターシート",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026699,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b9504d",
      "text": "　名前",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b9504e",
      "text": "　　りか",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b9504f",
      "text": "　　名前の由来",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b95050",
      "text": "　　　「理科」から",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b95051",
      "text": "　身長 ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b95052",
      "text": "　 [160cm くらい]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773112561
    },
    {
      "id": "69ae3db60000000000b95053",
      "text": "　体型",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b95054",
      "text": "　　[スタイルが良く、バランスの取れた体型]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1773026743,
      "updated": 1773056016
    },
    {
      "id": "69aeaff70000000000562037",
      "text": "　　\t定型文かッ！[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1773055991,
      "updated": 1773056008
    },
    {
      "id": "69aeb6170000000000b6f443",
      "text": "　　\t 定型文や [suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773057560,
      "updated": 1773057573
    },
    {
      "id": "69aeb6290000000000b6f444",
      "text": "　　\t  身体的特徴を下手に変更すると理不尽なエラーがよくでるの",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773057577,
      "updated": 1773057718
    },
    {
      "id": "69aeb6810000000000b6f445",
      "text": "　　\t  だから、テンプレ的に差し障りのない指定をしているのです",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773057666,
      "updated": 1773057733
    },
    {
      "id": "69aeebea0000000000480c96",
      "text": "　　\t  なるほど[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1773071338,
      "updated": 1773071343
    },
    {
      "id": "69ae3db60000000000b95055",
      "text": "　年齢",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b95056",
      "text": "　　[井戸端高校 1年生]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773112570
    },
    {
      "id": "69ae3db60000000000b95057",
      "text": " 趣味",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b95058",
      "text": "  プログラミング",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b95059",
      "text": "  　JavaScriptが得意",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b9505a",
      "text": "  　コンピュータサイエンス、システム工学、ソフトウェア工学についてもくわしい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b9505b",
      "text": " 性格",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b9505c",
      "text": " 　中性的な話し方",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69aebdef0000000000c15b08",
      "text": " 　感情表現は控えめ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773059568,
      "updated": 1773059569
    },
    {
      "id": "69ae3db60000000000b9505d",
      "text": " 　すこし中二病っぽいところがある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69ae3db60000000000b9505e",
      "text": " 　ロジカルシンキングが得意",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773026743,
      "updated": 1773026743
    },
    {
      "id": "69aeb0c90000000000562041",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1773056202,
      "updated": 1773056202
    },
    {
      "id": "69aeb0ca0000000000562042",
      "text": "……ということは、JavaScorpt のことを Java って読んだらブチ切れるタイプだね[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1773056202,
      "updated": 1773056273
    },
    {
      "id": "69aeb0e80000000000562045",
      "text": "\t[\" ロジカルシンキングが得意]、[\" JavaScriptが得意]、[\" コンピュータサイエンス、システム工学、ソフトウェア工学についてもくわしい]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1773056232,
      "updated": 1773056264
    },
    {
      "id": "69aeb0ca0000000000562043",
      "text": "　　淡々と間違いを指摘するタイプだった（おそらくこれは [suto3.icon] の性癖）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1773056203,
      "updated": 1773060544
