      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771814828,
      "updated": 1771814828
    },
    {
      "id": "699bbfab0000000000dd5716",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771814828,
      "updated": 1771814829
    },
    {
      "id": "699bbfad0000000000dd5717",
      "text": "\tあたたたたたかい",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771814829,
      "updated": 1771814835
    },
    {
      "id": "699c6141000000000038389b",
      "text": "\t会話のさしすせそを思い出そうと試みる",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771856194,
      "updated": 1771856202
    },
    {
      "id": "699c6149000000000038389c",
      "text": "\t\tさ…さすが！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771856202,
      "updated": 1771856207
    },
    {
      "id": "699c614f000000000038389d",
      "text": "\t\tし…しらんけど！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771856207,
      "updated": 1771856212
    },
    {
      "id": "699c6153000000000038389e",
      "text": "\t\tす…すべってるでー",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771856212,
      "updated": 1771856217
    },
    {
      "id": "699c6159000000000038389f",
      "text": "\t\tせ…せやろか",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771856217,
      "updated": 1771856221
    },
    {
      "id": "699c615e00000000003838a0",
      "text": "\t\tそ…ｿｯｽﾈ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771856223,
      "updated": 1771856227
    },
