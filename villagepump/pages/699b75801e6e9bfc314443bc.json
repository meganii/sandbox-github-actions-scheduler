      "created": 1771807427,
      "updated": 1771807427
    },
    {
      "id": "699bc93400000000003bf0e9",
      "text": "[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1771817268,
      "updated": 1771817270
    },
    {
      "id": "699bc93600000000003bf0eb",
      "text": "\t[COFO Chair Premium 2]快適じゃ～～～",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1771817270,
      "updated": 1771817284
    },
    {
      "id": "699bcaaf0000000000828578",
      "text": "\t\t細かいことは[COFO Chair Premium 2]ページに書く",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1771817648,
      "updated": 1771817653
    },
    {
      "id": "699bd61500000000008285c4",
      "text": "\tさて、飯食ってシャワー浴びて掃除するか",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1771820565,
      "updated": 1771820585
    },
    {
      "id": "699bc93400000000003bf0ea",
      "text": "",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1771817268,
      "updated": 1771817268
    },
    {
      "id": "699bcae000000000002a0c64",
      "text": "[ぬね.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1771817697,
      "updated": 1771817698
    },
    {
      "id": "699bcae200000000002a0c66",
      "text": "　家の中より外のがあたたかいくておかしなるで",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1771817698,
      "updated": 1771817728
    },
    {
      "id": "699bcc2000000000003a39a9",
      "text": "",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1771818016,
      "updated": 1771818016
    },
    {
      "id": "699bcc2000000000003a39aa",
      "text": "[takker.icon]",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1771818016,
      "updated": 1771818017
    },
    {
      "id": "699bcc2300000000003a39ab",
      "text": " 眠れなかった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1771818018,
      "updated": 1771818027
    },
    {
      "id": "699bcc2b00000000003a39ac",
      "text": " 寝坊しちゃった",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1771818027,
      "updated": 1771818036
    },
    {
      "id": "699bcc3400000000003a39ad",
      "text": "  ずっと寝坊してる気がする",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1771818036,
      "updated": 1771818430
    },
    {
      "id": "699bcd9e00000000008fe69b",
      "text": " そういえば2日もお風呂入ってない",
      "userId": "5ef2bdebb60650001e1280f0",
      "created": 1771818398,
      "updated": 1771818415
    },
    {
