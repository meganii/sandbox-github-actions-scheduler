      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb4060000001e50fe",
      "text": "第9週: 日[[月]]火水木金土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb406000000e589ef",
      "text": "2026年 14.79％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb4060000006e5c5e",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb4060000009bda23",
      "text": "今日のn年前",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb406000000d64025",
      "text": " [2025/02/23]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb4060000003a2da7",
      "text": " [2024/02/23]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb4060000007859c0",
      "text": " [2023/02/23]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb406000000a15d63",
      "text": " [2022/02/23]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb406000000720af0",
      "text": " [2021/02/23]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb4060000009465e3",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771795840
    },
    {
      "id": "699b75806eb406000000271e1f",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771801716
    },
    {
      "id": "699b8c7400000000005f73a6",
      "text": " 旅行3日目、最終日",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771801717,
      "updated": 1771801728
    },
    {
      "id": "699b8c7f00000000005f73a7",
      "text": "  天候不順で帰りの手段が怪しい",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771801728,
      "updated": 1771801738
    },
    {
      "id": "699bce8c0000000000e6f73b",
      "text": "   予定していた帰り方はできなそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771818637,
      "updated": 1771818645
    },
    {
      "id": "699bce940000000000e6f73c",
      "text": "   あてはついたので頑張るだけ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771818645,
      "updated": 1771818660
    },
    {
      "id": "699bda6d000000000018a46b",
      "text": "   朝の時点で想定していた最悪ケースだが、なんとかなったかな",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771821678,
      "updated": 1771821696
    },
    {
      "id": "699b99500000000000ee482b",
      "text": "  すっかり自宅気分でくつろぐ5歳の娘",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771805009,
      "updated": 1771805020
    },
    {
      "id": "699b995d0000000000ee482c",
      "text": "  宿の女将さんがおばあちゃんという感じ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771805022,
      "updated": 1771805032
    },
    {
      "id": "699b9a0f0000000000ee482d",
      "text": "   自分はおばあちゃん的な人とのコミュニケーションは得意な気がする",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771805201,
      "updated": 1771805214
    },
    {
      "id": "699c43910000000000443316",
      "text": "  ペーパードライバーなりに運転を頑張った",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771848594,
      "updated": 1771848638
    },
    {
      "id": "699c43bf0000000000443317",
      "text": "   一人でガソリンスタンドで給油してレンタカー返せた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771848641,
      "updated": 1771848720
    },
    {
      "id": "699c54fc0000000000b81773",
      "text": "   [偉業.icon][Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1771853054,
      "updated": 1771853061
    },
    {
      "id": "699bee8f0000000000e74bc5",
      "text": "  子供を連れて船のなかで情報収集",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771826832,
      "updated": 1771826846
    },
    {
      "id": "699beee20000000000e74bc6",
      "text": "   子供をダシに話をきり出すスタイル",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771826915,
      "updated": 1771826925
    },
    {
      "id": "699bef6b0000000000e74bc7",
      "text": "   デッキ？で酒盛りしてるおじさんは大体フレンドリー",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771827052,
      "updated": 1771827073
    },
    {
      "id": "699c11100000000000a776d0",
      "text": "   この行動はRPGっぽくて楽しい",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771835665,
      "updated": 1771835677
    },
    {
      "id": "699c11230000000000a776d1",
      "text": "   おじさんたちの1グループと子連れのファミリー1グループと仲良くなったので、飽きない船旅となりそう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771835684,
      "updated": 1771835725
    },
    {
      "id": "699c11eb0000000000a776d2",
      "text": "   子供達もお菓子外交してる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771835884,
      "updated": 1771835898
    },
    {
      "id": "699c171600000000009897a7",
      "text": "   幼稚園児-低学年児5人くらいの面倒を見てた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771837219,
      "updated": 1771837239
    },
    {
      "id": "699c176f00000000009897a8",
      "text": "    どうも特殊能力だぞ、これ",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771837301,
      "updated": 1771837304
    },
    {
      "id": "699c284600000000006ecd0f",
      "text": "   夜景がきれいだった",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771841607,
      "updated": 1771841657
    },
    {
      "id": "699c287d00000000006ecd10",
      "text": "   予想外の5時間近い[船旅]だったけど楽しめた",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1771841662,
      "updated": 1771946076
    },
    {
      "id": "699c0fdc0000000000a776cc",
      "text": "  [https://gyazo.com/c942ce842c646635f5c78499fd062e12]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771835357,
      "updated": 1771835487
    },
    {
      "id": "699b75806eb4060000000142ec",
      "text": "    富士山を探せ2",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771795840,
      "updated": 1771835523
    },
    {
      "id": "699c10a50000000000a776cf",
      "text": "  船が移動すると日没を何度も見られる",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771835559,
      "updated": 1771835579
    },
    {
      "id": "699c357a000000000042ba8d",
      "text": "  船旅いいなあ[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771844988,
      "updated": 1771844995
    },
    {
      "id": "699c3ced0000000000421f65",
      "text": "  天候で帰れるか不安という話を見て飛行機か船かかなと思った[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771846893,
      "updated": 1771846921
    },
    {
      "id": "699c10780000000000a776ce",
      "text": " 帰宅",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771835513,
      "updated": 1771854556
    },
    {
      "id": "699c5adc0000000000f646ab",
      "text": "  5歳の娘がまだ元気で、明日の朝が辛そう",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771854557,
      "updated": 1771854572
    },
    {
      "id": "699c5ad70000000000f646aa",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1771854552,
      "updated": 1771854552
    },
    {
      "id": "699b90e600000000009ff226",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1771802854,
      "updated": 1771802855
    },
    {
      "id": "699b90e700000000009ff227",
      "text": "\tおはようございます",
      "userId": "65e1289acd012200235729c0",
      "created": 1771802855,
      "updated": 1771802859
    },
    {
      "id": "699b90eb00000000009ff228",
      "text": "\t空気が悪い",
      "userId": "65e1289acd012200235729c0",
      "created": 1771802860,
      "updated": 1771802868
    },
    {
      "id": "699b90f300000000009ff229",
      "text": "\t\t一気に暖かくなった結果、イロイロと花粉が飛び出しているのかそれとも空気が停滞しているからなのか、妙な匂い",
      "userId": "65e1289acd012200235729c0",
      "created": 1771802868,
      "updated": 1771802909
    },
    {
      "id": "699b911d00000000009ff22a",
      "text": "\t\t甘いような刺激のような変な感覚",
      "userId": "65e1289acd012200235729c0",
      "created": 1771802909,
      "updated": 1771802920
    },
    {
      "id": "699b912800000000009ff22b",
      "text": "\t\t少なくとも鼻に悪そうなのでマスク着用ヨシ！",
      "userId": "65e1289acd012200235729c0",
      "created": 1771802920,
      "updated": 1771803580
    },
    {
      "id": "699b937b00000000009ff22c",
      "text": "\t週のはじめの朝から近くの席でヒエヒエな会話してて怖い",
      "userId": "65e1289acd012200235729c0",
      "created": 1771803515,
      "updated": 1771803546
    },
    {
      "id": "699b93cf00000000009ff22d",
      "text": "\t\t物理的に空気が悪いだけでなく、空気感の意味でも悪いのは勘弁",
      "userId": "65e1289acd012200235729c0",
      "created": 1771803600,
      "updated": 1771803631
    },
    {
      "id": "699b94ce00000000009ff22e",
      "text": "\t鼻関連で、鼻が効く、とは何だろなとふと思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1771803855,
      "updated": 1771803868
    },
    {
      "id": "699b94db00000000009ff22f",
      "text": "\t\t物理的な方ではない方、察する能力の方",
      "userId": "65e1289acd012200235729c0",
      "created": 1771803868,
      "updated": 1771803928
    },
    {
      "id": "699b951b00000000009ff230",
      "text": "\t\tパソコントラブルを相談され対処しているけど、初めて遭遇する案件でも１日以上原因が分からず彷徨うことは稀で、どこかで気付けるのが大半であることから、比較的鼻が効く方だとは思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1771803932,
      "updated": 1771804016
    },
    {
      "id": "699b957000000000009ff231",
      "text": "\t\t頼まれ解決する事はいいけど、各自で解決してくれたほうがうれしいので、この鼻の効き具合を他の人にも備わってくれたらいいなと思うが、何で鼻が効くのかぜんぜんわからん",
      "userId": "65e1289acd012200235729c0",
      "created": 1771804016,
      "updated": 1771804120
    },
    {
      "id": "699bfc3100000000001d78e5",
      "text": "\t雑誌を通してChatGPTが搭載されたブラウザーなるものがあると知る",
      "userId": "65e1289acd012200235729c0",
      "created": 1771830321,
      "updated": 1771830404
    },
    {
      "id": "699bfc4200000000001d78e6",
      "text": "\t\t生成AIがくっついたブラウザーって一般名称だとどのような表現になるのか分からんのでページ作りしにくい",
      "userId": "65e1289acd012200235729c0",
      "created": 1771830339,
      "updated": 1771830364
    },
    {
      "id": "699bfc5e00000000001d78e7",
      "text": "\t\tとりあえずChatGPTが入ったのは[ChatGPT Atlas]と言うのか",
      "userId": "65e1289acd012200235729c0",
      "created": 1771830366,
      "updated": 1771830380
    },
    {
      "id": "699bfc8600000000001d78e8",
      "text": "\t\tEgdeのCopilotと差別化もきちんとされているようで、エージェント機能が優秀なのか",
      "userId": "65e1289acd012200235729c0",
      "created": 1771830407,
      "updated": 1771830464
    },
    {
      "id": "699bfcdc00000000001d78e9",
      "text": "\t\tなんとなくEdgeは使いたくないというChromeユーザーなので、AtlasがWindowsでも提供が始まったら使う、と思うたぶん",
      "userId": "65e1289acd012200235729c0",
      "created": 1771830493,
      "updated": 1771830559
    },
    {
      "id": "699c025f00000000007e9897",
      "text": "\t[https://project.nikkeibp.co.jp/mirai/research/ 未来調査2026-2030 全産業編｜日経BP【公式】]",
      "userId": "65e1289acd012200235729c0",
      "created": 1771831904,
      "updated": 1771831907
    },
    {
      "id": "699c026300000000007e9898",
      "text": " \tこういう冊子、結構なお値段するけど何冊くらい売れるのだろうかとふと思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1771831907,
      "updated": 1771831922
    },
    {
      "id": "699b90e500000000009ff225",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1771802854,
      "updated": 1771802854
    },
    {
      "id": "699b9581000000000041a05c",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771804034,
      "updated": 1771804036
    },
    {
      "id": "699cf68700000000004933fc",
      "text": "\t[ウェルビーイングと人間関係]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771894407,
      "updated": 1771894438
    },
    {
      "id": "699b98f10000000000e264d1",
      "text": "　https://x.com/nazonodesigner/status/2025571282407100677?s=46&t=gkSZtjGEtUZPO0JCzBxCBw",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771804913,
      "updated": 1771847212
    },
    {
      "id": "699b9c000000000000e264d8",
      "text": "　　5番目の文字が意味不明だな？としばらく考えたが[~ 背景ごと回転してるのが切り欠きで表現されてる]のか",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771805696,
      "updated": 1771805781
    },
    {
      "id": "699c37a70000000000ba53bd",
      "text": "　　\tなるほど、納得[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1771845544,
      "updated": 1771845552
    },
    {
      "id": "699c3e380000000000f31af8",
      "text": "　公園の木の下で昼ごはん",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847224,
      "updated": 1771847224
    },
    {
      "id": "699c3e380000000000f31af9",
      "text": "　部屋が27度もあった、夏！",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847224,
      "updated": 1771847224
    },
    {
      "id": "699c3e380000000000f31afa",
      "text": "　[もらってあげてくれませんか]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847224,
      "updated": 1771847224
    },
    {
      "id": "699b9c540000000000e264da",
      "text": "\t[ラブカ] / [ブブカ] / [ラブブ] / [バブカ]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771805781,
      "updated": 1771847223
    },
    {
      "id": "699bbc3d0000000000c4b574",
      "text": "\t\t全部赤リンクだと？！",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771813949,
      "updated": 1771814006
    },
    {
      "id": "699bc0410000000000dd5718",
      "text": "\t\t1つは[LABUBU]のことだろうか[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1771814977,
      "updated": 1771815006
    },
    {
      "id": "699bbc760000000000c4b575",
      "text": "\t[Forgive or Finalize]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771814006,
      "updated": 1771814730
    },
    {
      "id": "699c0f020000000000f31aef",
      "text": "\t\thttps://unityroom.com/games/forgive_of_finalize",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771835139,
      "updated": 1771835139
    },
    {
      "id": "699c080d0000000000c4b578",
      "text": "\t\t日記を読んだ",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771833358,
      "updated": 1771833364
    },
    {
      "id": "699c0aec0000000000c4b579",
      "text": "\t\tこれをマダミス的なゲームにできないかな",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771834092,
      "updated": 1771834188
    },
    {
      "id": "699c0b4b0000000000c4b57a",
      "text": "\t\t\tミステリーがない",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771834188,
      "updated": 1771834194
    },
    {
      "id": "699c0b820000000000c4b57c",
      "text": "\t\t\t毒の性質(なにとなにを組み合わせたら死ぬか、どれが解毒薬か)を情報カードに分割して配る",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771834242,
      "updated": 1771834323
    },
    {
      "id": "699c0bd30000000000c4b57d",
      "text": "\t\t\t目的設定も人によって違う？",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771834323,
      "updated": 1771847312
    },
    {
      "id": "699c40c900000000003fb653",
      "text": "\t\t\tマダミス会で遊んでるので何でもマダミスに結びつけてしまうがゲームの実現方法はもっと色々ある",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847881,
      "updated": 1771848006
    },
    {
      "id": "699c42bb00000000003fb654",
      "text": "\t\t\t[/nishio/ハグル]をオンラインでやるとか",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771848380,
      "updated": 1771848385
    },
    {
      "id": "699c0f050000000000f31af0",
      "text": "\t\tゲーム性あった？(僕が見落としているだけ？)",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771835141,
      "updated": 1771835150
    },
    {
      "id": "699c3e200000000000f31af1",
      "text": "　[マダムと理想のアンドロイド]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847201,
      "updated": 1771847201
    },
    {
      "id": "699c3e210000000000f31af2",
      "text": "　\t読んだ、面白かった",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847201,
      "updated": 1771847207
    },
    {
      "id": "699c3e2f0000000000f31af4",
      "text": "　[Tiling Forest]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847216,
      "updated": 1771847216
    },
    {
      "id": "699c3e2f0000000000f31af5",
      "text": "　 コーナータイルを4つ出した後何をしたらいいかわからなくなった",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847216,
      "updated": 1771847216
    },
    {
      "id": "699c3e2f0000000000f31af6",
      "text": "　 縦の道が必要じゃないかな感",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847216,
      "updated": 1771847216
    },
    {
      "id": "699cf63300000000004933f7",
      "text": "　 [Tiling Forest(ネタバレ注意)]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771894324,
      "updated": 1771894326
    },
    {
      "id": "699c3e260000000000f31af3",
      "text": " 振り返り以外の有益なことを何もしない休日",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771847207,
      "updated": 1771847220
    },
    {
      "id": "699c6d1a00000000004933ed",
      "text": " 陰謀論という単語をふわっと解像度低い使い方していたことに気づいた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771859226,
      "updated": 1771859245
    },
    {
      "id": "699c6d2c00000000004933ee",
      "text": " \t「仮説Xを裏付ける証拠が見つからないのは、権力が証拠を消しているからだ」",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771859245,
      "updated": 1771859298
    },
    {
      "id": "699c6da400000000004933ef",
      "text": " \t証拠が見つからないことをもって自説の証拠にする構図",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771859365,
      "updated": 1771859381
    },
    {
      "id": "699bced30000000000ed31bf",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771818709,
      "updated": 1771818709
    },
    {
      "id": "699b9cc40000000000a97dcf",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771805895,
      "updated": 1771805895
    },
    {
      "id": "699cf6b800000000004933fe",
      "text": "\t[ウェルビーイングと人間関係]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771894457,
      "updated": 1771894469
    },
    {
      "id": "699b9cc40000000000a97dce",
      "text": "\t花粉用の目薬と鼻薬？のおかげか、まだ致命的な事態にはなってない",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771805893,
      "updated": 1771806130
    },
    {
      "id": "699b9db60000000000a97dd7",
      "text": "\t\t散歩は1日2回まで、かつ1回30分もかけてないくらい",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806135,
      "updated": 1771806154
    },
    {
      "id": "699b9db10000000000a97dd6",
      "text": "\t\t目が多少しょぼしょぼする程度",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806130,
      "updated": 1771806134
    },
    {
      "id": "699b9d180000000000a97dd4",
      "text": "\tお、俺好みのマトリックス",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771805977,
      "updated": 1771806299
    },
    {
      "id": "699b9e590000000000b252c0",
      "text": "\t\t[「あの人、しゃべらないけどすごい」実は成果を出す人に共通する“特徴”（ダイヤモンド・オンライン） - Yahoo!ニュース https://news.yahoo.co.jp/articles/70c4bc6fe3e068729d90829c7211accc0bfa2482]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806299,
      "updated": 1771806299
    },
    {
      "id": "699b9e590000000000b252c1",
      "text": "\t\t[https://gyazo.com/49a64a63e14a6bcd430168330e7c0800]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806299,
      "updated": 1771806318
    },
    {
      "id": "699b9e6c0000000000b252c2",
      "text": "\tシャイって少なくとも二軸あるよなぁ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806318,
      "updated": 1771806341
    },
    {
      "id": "699b9e840000000000b252c3",
      "text": "\t\tオンラインとオフライン",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806341,
      "updated": 1771806345
    },
    {
      "id": "699b9e870000000000b252c4",
      "text": " \t\tオフラインでは陽気な人でもオンラインだと全然書かないとかざらにある",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806345,
      "updated": 1771806389
    },
    {
      "id": "699b9e950000000000b252c5",
      "text": " \t\t逆に俺はオンラインだとめっちゃ書くけど、オフラインだと全然喋れん",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806358,
      "updated": 1771806389
    },
    {
      "id": "699b9eef0000000000b252ca",
      "text": " \tシャイとはなんだ？",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806448,
      "updated": 1771806468
    },
    {
      "id": "699b9eb70000000000b252c7",
      "text": " \t\tオンラインでもオフラインでも出さない人ではないか？と思ったりする",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806392,
      "updated": 1771806403
    },
    {
      "id": "699b9ec20000000000b252c8",
      "text": " \t\t手段ではなく、もっと根っこのところではないのかと",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806403,
      "updated": 1771806414
    },
    {
      "id": "699b9e540000000000b252bf",
      "text": "\t[髪型こだわってないなら坊主でいい]と思う",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806294,
      "updated": 1771806596
    },
    {
      "id": "699b9f3c0000000000b252cc",
      "text": "\t\t[旦那が毎月5000円もかけて角刈りみたいな髪型で帰ってくんのイライラする、1000円カット行けや→なお1000円カットの腕前「盆栽でしぬww」 (2ページ目) - Togetter https://togetter.com/li/2667140?page=2]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806526,
      "updated": 1771806526
    },
    {
      "id": "699b9f5f0000000000b252cf",
      "text": "\t\t「坊主nミリで」で通じるし、自宅でバリカンで処理もできる",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806560,
      "updated": 1771806571
    },
    {
      "id": "699b9f860000000000b252d1",
      "text": "\t\tブームになってもいい気がするけど、まだ来たことないよなぁ",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806599,
      "updated": 1771806611
    },
    {
      "id": "699b9f360000000000b252cb",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1771806521,
      "updated": 1771806521
    },
    {
      "id": "699ba2c20000000000c0fc78",
      "text": "[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771807427,
      "updated": 1771807428
    },
    {
      "id": "699ba2c40000000000c0fc7a",
      "text": " [/mtane0412/Macで日本語入力が早いときに1文字目が勝手に確定される]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771807428,
      "updated": 1771807435
    },
    {
      "id": "699ba2ca0000000000c0fc7c",
      "text": "  Github Projectsからissueに入力するときだけ発生",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771807435,
      "updated": 1771807466
    },
    {
      "id": "699bb8130000000000168c8b",
      "text": "  GithubにはFeedback飛ばしておいた",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771812884,
      "updated": 1771812892
    },
    {
      "id": "699be33b0000000000d5e913",
      "text": " [パノラマサイト FILE23 本所七不思議]クリア",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771823932,
      "updated": 1771837119
    },
    {
      "id": "699c16c0000000000049aa33",
      "text": "  勧められてやったけどめちゃくちゃ面白かった",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771837122,
      "updated": 1771837160
    },
    {
      "id": "699c16e8000000000049aa35",
      "text": "  ジョジョは格ゲーで出しがちだけどこの形式で出せばいいのでは",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771837160,
      "updated": 1771837178
    },
    {
      "id": "699bea4400000000003a83f3",
      "text": "  いいね！[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771825732,
      "updated": 1771825738
    },
    {
      "id": "699bea4b00000000003a83f4",
      "text": "   うちは昨日の夜、人魚のほうを始めた",
      "userId": "582e63d27c56960011aff09e",
      "created": 1771825739,
      "updated": 1771825753
    },
    {
      "id": "699c66fb00000000009a1dd2",
      "text": "   やりたい！[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771857660,
      "updated": 1771857665
    },
    {
      "id": "699c670100000000009a1dd3",
      "text": " マリオテニスSに到達",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771857665,
      "updated": 1771857674
    },
    {
      "id": "699c670a00000000009a1dd4",
      "text": "  [https://gyazo.com/49c74f4ebab0d67b44b11113f70eae9e]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771857675,
      "updated": 1771857676
    },
    {
      "id": "699c671300000000009a1dd6",
      "text": "  S+で終わりたい",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771857683,
      "updated": 1771857689
    },
    {
      "id": "699c670c00000000009a1dd5",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1771857676,
      "updated": 1771857676
    },
    {
