{
  "id": "69c25401df174ad7b90aa122",
  "title": "四元素説や五元素説",
  "created": 1774343195,
  "updated": 1774346561,
  "lines": [
    {
      "id": "69c25401df174ad7b90aa122",
      "text": "四元素説や五元素説",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774343195,
      "updated": 1774343195
    },
    {
      "id": "69c2586a000000000056cc0b",
      "text": "table:色々な元素説",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774344298,
      "updated": 1774344314
    },
    {
      "id": "69c2541b000000000056cbdc",
      "text": "\t\t四元素説\t火\t水\t風\t土\t\tエーテル\t\t\t",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774343195,
      "updated": 1774345398
    },
    {
      "id": "69c25858000000000056cc0a",
      "text": "\t\t仏教\t火\t水\t風\t地\t\t空\t\t\t",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774344911,
      "updated": 1774345397
    },
    {
      "id": "69c25ae5000000000056cc0e",
      "text": "\t\tインド\tアグニ\tジャラ\tヴァーユ\tプリティヴィー\t\tアーカーシャ\t\t\t",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774344934,
      "updated": 1774345408
    },
    {
      "id": "69c2545b000000000056cbeb",
      "text": "\t\t道教\t火\t水\t\t土\t金\t\t木\t陰\t陽",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345408,
      "updated": 1774345408
    },
    {
      "id": "69c254c0000000000056cbf9",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774343361,
      "updated": 1774343361
    },
    {
      "id": "69c259e2000000000056cc0c",
      "text": "インド哲学がヨーロッパにも受け継がれているように見える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774344675,
      "updated": 1774345016
    },
    {
      "id": "69c25b42000000000056cc10",
      "text": "\t中国哲学とは大きく異なる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345027,
      "updated": 1774345055
    },
    {
      "id": "69c25a18000000000056cc0d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774344729,
      "updated": 1774344729
    },
    {
      "id": "69c25ff2000000000056cc39",
      "text": "十干",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346227,
      "updated": 1774346230
    },
    {
      "id": "69c25ddc000000000056cc1e",
      "text": " table:十干",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345692,
      "updated": 1774346231
    },
    {
      "id": "69c25df2000000000056cc1f",
      "text": "  \t兄\t\t弟\t",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345715,
      "updated": 1774346231
    },
    {
      "id": "69c25e49000000000056cc2e",
      "text": "  木\t甲\tきのえ\t乙\tきのと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345802,
      "updated": 1774346231
    },
    {
      "id": "69c25e50000000000056cc2f",
      "text": "  火\t丙\tひのえ\t丁\tひのと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345808,
      "updated": 1774346231
    },
    {
      "id": "69c25bd4000000000056cc15",
      "text": " \t土\t戊\tつちのえ\t己\tつちのと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345172,
      "updated": 1774346231
    },
    {
      "id": "69c25e94000000000056cc31",
      "text": " \t金\t庚\tかのえ\t辛\tかのと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345876,
      "updated": 1774346231
    },
    {
      "id": "69c25e97000000000056cc32",
      "text": " \t水\t壬\tみずのえ\t癸\tみずのと",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774345879,
      "updated": 1774346231
    },
    {
      "id": "69c25feb000000000056cc36",
      "text": " 兄弟の概念は陰陽とは異なる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346219,
      "updated": 1774346234
    },
    {
      "id": "69c25f67000000000056cc35",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346088,
      "updated": 1774346088
    },
    {
      "id": "69c25fee000000000056cc37",
      "text": "三体説",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346223,
      "updated": 1774346265
    },
    {
      "id": "69c26018000000000056cc3b",
      "text": "\ttable:三体説",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346265,
      "updated": 1774346284
    },
    {
      "id": "69c26020000000000056cc3c",
      "text": "\t 四元素説\t火\t水\t風\t土\tエーテル",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346273,
      "updated": 1774346316
    },
    {
      "id": "69c26021000000000056cc3d",
      "text": " \t\tプラズマ\t液体\t気体\t固体\t真空",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346273,
      "updated": 1774346319
    },
    {
      "id": "69c2604e000000000056cc3f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774346319,
      "updated": 1774346319
    }
  ]
}