{
  "id": "69e398abcb59f330ef359984",
  "title": "生け花の三代流派",
  "created": 1776523437,
  "updated": 1776523671,
  "lines": [
    {
      "id": "69e398abcb59f330ef359984",
      "text": "生け花の三代流派",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523437,
      "updated": 1776523440
    },
    {
      "id": "69e398af0000000000e4ec8a",
      "text": "\t[池坊] いけのぼう",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523440,
      "updated": 1776523456
    },
    {
      "id": "69e3993d0000000000e4ec95",
      "text": "\t\t日本最古の流派である。室町時代からといわれる。",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523581,
      "updated": 1776523671
    },
    {
      "id": "69e398bf0000000000e4ec8c",
      "text": "\t[草月流]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523456,
      "updated": 1776523460
    },
    {
      "id": "69e399750000000000e4ec97",
      "text": "\t\t1927年創流",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523637,
      "updated": 1776523649
    },
    {
      "id": "69e398c30000000000e4ec8d",
      "text": "\t[小原流] おはらりゅう",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523460,
      "updated": 1776523464
    },
    {
      "id": "69e399820000000000e4ec98",
      "text": "\t\t明治時代創流",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523651,
      "updated": 1776523664
    },
    {
      "id": "69e3991f0000000000e4ec8f",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523551,
      "updated": 1776523551
    },
    {
      "id": "69e399250000000000e4ec94",
      "text": "[華道]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776523558,
      "updated": 1776523558
    },
    {
      "id": "69e3991f0000000000e4ec90",
