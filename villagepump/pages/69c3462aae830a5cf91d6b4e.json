    {
      "id": "69d853bb0000000000551420",
      "text": "同じ国旗を使用（微妙な違いがあるかも）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775784892,
      "updated": 1775784932
    },
    {
      "id": "69d8539f000000000055141e",
      "text": " 1791年9月3日―1792年9月21日：[フランス立憲王国]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775784864,
      "updated": 1775790947
    },
    {
      "id": "69d853ab000000000055141f",
      "text": " 1792年9月21日―1804年5月18日：[フランス第一共和政]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775784876,
      "updated": 1775790948
    },
    {
      "id": "69d8550f0000000000551424",
      "text": " 1804年3月18日―1814年4月4日：[フランス第一帝政]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1775785231,
      "updated": 1775790950
    },
    {
      "id": "69d855100000000000551425",
      "text": " 1815年3月20日―7月7日：[フランス第一帝政]",
