    },
    {
      "id": "69a7b9380000000000bfef83",
      "text": " ╎┆┊║╏┇┋",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772599609,
      "updated": 1772611455
    },
    {
      "id": "69a7e6610000000000bff0c4",
      "text": " ╶─╴╶╼╾╴╺━╸╶╌╴╶┄╴╶┈╴═╺╍╸╺┅╸╺┉╸",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772611169,
      "updated": 1772611540
    },
    {
      "id": "69a7dfc30000000000bff081",
      "text": " ┌┬┐╷┌┮┭┐┍┯┑┌┬┐╷┌┮┭┐┍┯┑┎┰┒╻┎┲┱┒┏┳┓╒╤╕╓╥╖╔╦╗",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772609476,
      "updated": 1772611155
    },
    {
      "id": "69a7e5fc0000000000bff0bb",
      "text": " ├┼┤│├┾┽┤┝┿┥┟╁┧╽┟╆╅┧┢╈┪┠╂┨┃┠╊╉┨┣╋┫╞╪╡╟╫╢╠╬╣",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772611069,
      "updated": 1772611160
    },
    {
      "id": "69a7e5fc0000000000bff0bc",
      "text": " ├┼┤│├┾┽┤┝┿┥┞╀┦╿┞╄╃┦┡╇┩┠╂┨┃┠╊╉┨┣╋┫╞╪╡╟╫╢╠╬╣",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772611069,
      "updated": 1772611165
    },
    {
      "id": "69a7e1a70000000000bff0a3",
      "text": " └┴┘╵└┶┵┘┕┷┙└┴┘╵└┶┵┘┕┷┙┖┸┚╹┖┺┹┚┗┻┛╘╧╛╙╨╜╚╩╝",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772609960,
      "updated": 1772611172
    },
    {
      "id": "69a7bbae0000000000bfef9b",
      "text": " ╭╮",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772600238,
      "updated": 1772611244
    },
    {
      "id": "69a7bbaf0000000000bfef9c",
      "text": " ╰╯",
