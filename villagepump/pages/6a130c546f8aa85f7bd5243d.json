  "lines": [
    {
      "id": "6a130c546f8aa85f7bd5243d",
      "text": "井戸端の個別ページに対しての言及の迷い",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc606e",
      "text": "from [2026/05/18]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc606f",
      "text": "井戸端の個別ページに対しての言及の迷い",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6070",
      "text": " 日記に書くか、そのページ内に追記するか",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6071",
      "text": " 日記に書けば他の人から見られやすい",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6072",
      "text": "  んで言及部分をあとで該当ページにマージすればよさげ？",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633335
    },
    {
      "id": "6a130c540000000000cc6073",
      "text": " こういう迷いも個人Cosenseでは気づかなかった",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6074",
      "text": "  共同日記があるからこそか？",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6075",
      "text": " 私の中にデフォルト動作がまだ規定されてない",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6076",
      "text": "  そのうち勘所がわかってくると信じる",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6077",
      "text": " 井戸端に閉じないデフォルト動作は持ってた[zatsma.icon]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6078",
      "text": "  デライトで[Cosenseのページを輪郭として描き出す]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc6079",
      "text": "  ページ輪郭に引き入れた「あれ」を作り、その中でページに言及する",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
    {
      "id": "6a130c540000000000cc607a",
      "text": "  [このように https://dlt.kitetu.com/KNo.FD7E/CA3C]",
      "userId": "58d101391094b20011d8c2f4",
      "created": 1779633237,
      "updated": 1779633237
    },
