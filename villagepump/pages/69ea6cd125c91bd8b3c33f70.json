      "created": 1776970961,
      "updated": 1776970961
    },
    {
      "id": "69ea6cd100000000008c0535",
      "text": "　まあ、[shields.io]を使っているだけなんですが",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1776970961,
      "updated": 1776971244
    },
    {
      "id": "69ea6de20000000000e091df",
