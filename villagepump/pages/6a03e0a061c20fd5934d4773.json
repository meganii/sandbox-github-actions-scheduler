  "lines": [
    {
      "id": "6a03e0a061c20fd5934d4773",
      "text": "ドーサというものを初めて食べた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df94",
      "text": "from [2026/02/28]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df95",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639030
    },
    {
      "id": "6a03e0a0000000000013df96",
      "text": "[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df97",
      "text": " [ドーサ]というものを初めて食べた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df98",
      "text": " パリパリでうまい",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df99",
      "text": " 付け合わせの白っぽい何かがとんでもなくうますぎた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df9a",
      "text": "  何なのかはわからない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df9b",
      "text": "  何だろう　食べたーいー[はるひ.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df9c",
      "text": "  調べたらチャトニというものっぽいが、[チャトニ]は付け合わせのディップソースっぽいやつの総称っぽく、いろんな種類があるので結局なんだかわからない[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df9d",
      "text": " ドーサにギーが塗ってあり、ボリュームがあった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df9e",
      "text": " [ワダやウプマ、ドーサが付いたミールス]で調べたやつだ！[inajob.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013df9f",
      "text": "  ミールス、日本でいう定食みたいなものだと思うんだけど、日本の定食はカーボのほうは白米に決まっているのでおかず側のバリエーションをいうけど、インドはカーボ側のバリエーションいっぱいあるからそっちの種類を言ってるのおもしろい[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013dfa0",
      "text": "   [カーボ]って[炭水化物]か [知らんインド用語]かとおもた[はるひ.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013dfa1",
      "text": "   炭水化物長くて言いにくいから筋肉界隈ではカーボがよく使われている[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    },
    {
      "id": "6a03e0a0000000000013dfa2",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778639009,
      "updated": 1778639009
    }
  ]
}