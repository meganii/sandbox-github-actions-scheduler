      "created": 1775276858,
      "updated": 1775276858
    },
    {
      "id": "69d0933a0000000000e298b1",
      "text": " const now = new Date()",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775276858,
      "updated": 1775276858
    },
    {
      "id": "69d0933a0000000000e298b2",
      "text": " const year  = now.getYear() + 1900",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775276858,
      "updated": 1775276858
    },
    {
      "id": "69d0933a0000000000e298b3",
      "text": " const month = ('0' + (now.getMonth()+1)).slice(-2)",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775276858,
      "updated": 1775276858
    },
    {
      "id": "69d0933a0000000000e298b4",
      "text": " const day   = ('0' + now.getDate()).slice(-2)",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775276858,
      "updated": 1775276858
    },
    {
      "id": "69d0933a0000000000e298b5",
      "text": " const ymd = `${year}-${month}-${day}`",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775276858,
      "updated": 1775276871
    },
    {
      "id": "69d0933a0000000000e298b7",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
