    },
    {
      "id": "69d093200000000000e298ac",
      "text": "code:script.js",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775276833,
      "updated": 1775276858
    },
    {
      "id": "69d0933a0000000000e298ad",
      "text": " const prefix=`log-${cosense.User.name}`",
