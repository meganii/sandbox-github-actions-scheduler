      "updated": 1774406368
    },
    {
      "id": "69c348c30000000000021fc5",
      "text": "細い部分の上下にネパール・ブータン・バングラデシュがある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774405827,
      "updated": 1774406060
    },
