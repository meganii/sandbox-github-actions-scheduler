  "lines": [
    {
      "id": "69c348be2e7515751857f41d",
      "text": "インドの千切れそうな地域",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774405827,
      "updated": 1774406394
    },
    {
      "id": "69c34b180000000000021fd5",
      "text": "インド北東部にある地域",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406424,
      "updated": 1774406441
    },
    {
      "id": "69c34c4a0000000000021fd9",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406730,
      "updated": 1774406730
    },
    {
      "id": "69c34c4c0000000000021fdb",
      "text": "> [https://gyazo.com/23948fb2046075bde2653b9f4cd47798]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406732,
      "updated": 1774406810
    },
    {
      "id": "69c34c9500000000001a26e5",
      "text": "> https://ja.wikipedia.org/wiki/インドの地方行政区画",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406806,
      "updated": 1774406807
    },
    {
      "id": "69c34afb0000000000021fd3",
      "text": " 千切れそうだが繋がっているので飛び地ではない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406395,
      "updated": 1774406818
    },
    {
      "id": "69c34b7a0000000000021fd7",
      "text": "\tこの領土によりインドと[ミャンマー]（[ビルマ]）が隣接している",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406523,
      "updated": 1774406561
    },
    {
      "id": "69c34ba70000000000021fd8",
      "text": "\t悪名高い[インパール]がこの千切れそうな部分にある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406568,
      "updated": 1774406632
    },
    {
      "id": "69c34c9f00000000001a26e6",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406816,
      "updated": 1774406816
    },
    {
      "id": "69c34caa00000000001a26e7",
      "text": "全体と見比べてみよう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774406826,
      "updated": 1774406860
    },
    {
      "id": "69c348c20000000000021fc4",
      "text": "> https://ja.wikipedia.org/wiki/インド",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774405827,
      "updated": 1774406816
    },
    {
      "id": "69c348c80000000000021fc7",
      "text": "> [https://scrapbox.io/files/69c348cb9ea0767ac852dd6f.webp]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774405832,
      "updated": 1774405837
    },
    {
      "id": "69c348d40000000000021fc9",
      "text": "> 薄緑色は領有権をめぐり紛争中の地域。（パキスタンや中国と隣接）",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774405845,
      "updated": 1774406356
    },
    {
      "id": "69c348cc0000000000021fc8",
