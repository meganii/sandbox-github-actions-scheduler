{
  "id": "69d2e2a5aa5397426ec8f26a",
  "title": "二十四節気七十二候",
  "created": 1775428266,
  "updated": 1775428728,
  "lines": [
    {
      "id": "69d2e2a5aa5397426ec8f26a",
      "text": "二十四節気七十二候",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428266,
      "updated": 1775428266
    },
    {
      "id": "69d2e2a900000000005e484d",
      "text": "[二十四節気]と[七十二候]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428266,
      "updated": 1775428274
    },
    {
      "id": "69d2e2a900000000005e484e",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428266,
      "updated": 1775428266
    },
    {
      "id": "69d2e2b300000000005e484f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428276,
      "updated": 1775428276
    },
    {
      "id": "69d2e2b300000000005e4850",
      "text": "二十四節気",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428276,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4851",
      "text": "\t候\t略本暦（日本）\t意味",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4852",
      "text": "立春",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4853",
      "text": "\t初候\t東風解凍（はるかぜこおりをとく）\t東風が厚い氷を解かし始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4854",
      "text": "\t次候\t黄鶯睍睆（うぐいすなく）\t鶯が山里で鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4855",
      "text": "\t末候\t魚上氷（うおこおりをいずる）\t割れた氷の間から魚が飛び出る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4856",
      "text": "雨水",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4857",
      "text": "\t初候\t土脉潤起（つちのしょううるおいおこる）\t雨が降って土が湿り気を含む",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4858",
      "text": "\t次候\t霞始靆（かすみはじめてたなびく）\t霞がたなびき始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4859",
      "text": "\t末候\t草木萌動（そうもくめばえいずる）\t草木が芽吹き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e485a",
      "text": "啓蟄",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e485b",
      "text": "\t初候\t蟄虫啓戸（すごもりむしとをひらく）\t冬籠りの虫が出て来る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e485c",
      "text": "\t次候\t桃始笑（ももはじめてさく）\t桃の花が咲き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e485d",
      "text": "\t末候\t菜虫化蝶（なむしちょうとなる）\t青虫が羽化して紋白蝶になる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e485e",
      "text": "春分",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e485f",
      "text": "\t初候\t雀始巣（すずめはじめてすくう）\t雀が巣を構え始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4860",
      "text": "\t次候\t桜始開（さくらはじめてひらく）\t桜の花が咲き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4861",
      "text": "\t末候\t雷乃発声（かみなりすなわちこえをはっす）\t遠くで雷の音がし始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4862",
      "text": "清明",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4863",
      "text": "\t初候\t玄鳥至（つばめきたる）\t燕が南からやって来る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4864",
      "text": "\t次候\t鴻雁北（こうがんきたへかえる）\t雁が北へ渡って行く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4865",
      "text": "\t末候\t虹始見（にじはじめてあらわる）\t雨の後に虹が出始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4866",
      "text": "穀雨",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4867",
      "text": "\t初候\t葭始生（あしはじめてしょうず）\t葦が芽を吹き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4868",
      "text": "\t次候\t霜止出苗（しもやんでなえいづる）\t霜が終り稲の苗が生長する",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4869",
      "text": "\t末候\t牡丹華（ぼたんはなさく）\t牡丹の花が咲く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e486a",
      "text": "立夏",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e486b",
      "text": "\t初候\t蛙始鳴（かわずはじめてなく）\t蛙が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e486c",
      "text": "\t次候\t蚯蚓出（みみずいづる）\t蚯蚓が地上に這出る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e486d",
      "text": "\t末候\t竹笋生（たけのこしょうず）\t筍が生えて来る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e486e",
      "text": "小満",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e486f",
      "text": "\t初候\t蚕起食桑（かいこおきてくわをはむ）\t蚕が桑を盛んに食べ始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4870",
      "text": "\t次候\t紅花栄（べにばなさかう）\t紅花が盛んに咲く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4871",
      "text": "\t末候\t麦秋至（むぎのときいたる）\t麦が熟し麦秋となる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4872",
      "text": "芒種",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4873",
      "text": "\t初候\t螳螂生（かまきりしょうず）\t螳螂が生まれ出る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4874",
      "text": "\t次候\t腐草為蛍（くされたるくさほたるとなる）\t腐った草が蒸れ蛍になる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4875",
      "text": "\t末候\t梅子黄（うめのみきばむ）\t梅の実が黄ばんで熟す",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4876",
      "text": "夏至",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4877",
      "text": "\t初候\t乃東枯（なつかれくさかるる）\t夏枯草が枯れる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4878",
      "text": "\t次候\t菖蒲華（あやめはなさく）\tあやめの花が咲く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4879",
      "text": "\t末候\t半夏生（はんげしょうず）\t烏柄杓が生える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e487a",
      "text": "小暑",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e487b",
      "text": "\t初候\t温風至（あつかぜいたる）\t暖い風が吹いて来る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e487c",
      "text": "\t次候\t蓮始開（はすはじめてひらく）\t蓮の花が開き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e487d",
      "text": "\t末候\t鷹乃学習（たかすなわちわざをなす）\t鷹の幼鳥が飛ぶことを覚える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e487e",
      "text": "大暑",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e487f",
      "text": "\t初候\t桐始結花（きりはじめてはなをむすぶ）\t桐の花が（来年の）蕾をつける",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4880",
      "text": "\t次候\t土潤溽暑（つちうるおうてむしあつし）\t土が湿って蒸暑くなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4881",
      "text": "\t末候\t大雨時行（たいうときどきにふる）\t時として大雨が降る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4882",
      "text": "立秋",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4883",
      "text": "\t初候\t涼風至（すづかぜいたる）\t涼しい風が立ち始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4884",
      "text": "\t次候\t寒蝉鳴（ひぐらしなく）\t蜩が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4885",
      "text": "\t末候\t蒙霧升降（ふかききりまとう）\t深い霧が立ち込める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4886",
      "text": "処暑",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4887",
      "text": "\t初候\t綿柎開（わたのはなしべひらく）\t綿を包む萼（がく）が開く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4888",
      "text": "\t次候\t天地始粛（てんちはじめてさむし）\tようやく暑さが鎮まる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4889",
      "text": "\t末候\t禾乃登（こくものすなわちみのる）\t稲が実る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e488a",
      "text": "白露",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e488b",
      "text": "\t初候\t草露白（くさのつゆしろし）\t草に降りた露が白く光る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e488c",
      "text": "\t次候\t鶺鴒鳴（せきれいなく）\t鶺鴒（せきれい）が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e488d",
      "text": "\t末候\t玄鳥去（つばめさる）\t燕が南へ帰って行く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e488e",
      "text": "秋分",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e488f",
      "text": "\t初候\t雷乃収声（かみなりすなわちこえをおさむ）\t雷が鳴り響かなくなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4890",
      "text": "\t次候\t蟄虫坏戸（むしかくれてとをふさぐ）\t虫が土中に掘った穴をふさぐ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4891",
      "text": "\t末候\t水始涸（みずはじめてかる）\t田畑の水を干し始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4892",
      "text": "寒露",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4893",
      "text": "\t初候\t鴻雁来（こうがんきたる）\t雁が飛来し始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4894",
      "text": "\t次候\t菊花開（きくのはなひらく）\t菊の花が咲く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4895",
      "text": "\t末候\t蟋蟀在戸（きりぎりすとにあり）\t蟋蟀が戸の辺りで鳴く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4896",
      "text": "霜降",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4897",
      "text": "\t初候\t霜始降（しもはじめてふる）\t霜が降り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4898",
      "text": "\t次候\t霎時施（こさめときどきふる）\t小雨がしとしと降る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4899",
      "text": "\t末候\t楓蔦黄（もみじつたきばむ）\tもみじや蔦が黄葉する",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e489a",
      "text": "立冬",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e489b",
      "text": "\t初候\t山茶始開（つばきはじめてひらく）\t山茶花が咲き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e489c",
      "text": "\t次候\t地始凍（ちはじめてこおる）\t大地が凍り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e489d",
      "text": "\t末候\t金盞香（きんせんかさく）\t水仙の花が咲く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e489e",
      "text": "小雪",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e489f",
      "text": "\t初候\t虹蔵不見（にじかくれてみえず）\t虹を見かけなくなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a0",
      "text": "\t次候\t朔風払葉（きたかぜこのはをはらう）\t北風が木の葉を払い除ける",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a1",
      "text": "\t末候\t橘始黄（たちばなはじめてきばむ）\t橘の実が黄色くなり始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a2",
      "text": "大雪",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a3",
      "text": "\t初候\t閉塞成冬（そらさむくふゆとなる）\t天地の気が塞がって冬となる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a4",
      "text": "\t次候\t熊蟄穴（くまあなにこもる）\t熊が冬眠のために穴に隠れる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a5",
      "text": "\t末候\t鱖魚群（さけのうおむらがる）\t鮭が群がり川を上る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a6",
      "text": "冬至",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a7",
      "text": "\t初候\t乃東生（なつかれくさしょうず）\t夏枯草が芽を出す",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a8",
      "text": "\t次候\t麋角解（おおしかのつのおつる）\t大鹿が角を落とす",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48a9",
      "text": "\t末候\t雪下出麦（ゆきわたりてむぎいづる）\t雪の下で麦が芽を出す",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48aa",
      "text": "小寒",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ab",
      "text": "\t初候\t芹乃栄（せりすなわちさかう）\t芹がよく生育する",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ac",
      "text": "\t次候\t水泉動（しみずあたたかをふくむ）\t地中で凍った泉が動き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ad",
      "text": "\t末候\t雉始雊（きじはじめてなく）\t雄の雉が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ae",
      "text": "大寒",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48af",
      "text": "\t初候\t款冬華（ふきのはなさく）\t蕗の薹（ふきのとう）が蕾を出す",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b0",
      "text": "\t次候\t水沢腹堅（さわみずこおりつめる）\t沢に氷が厚く張りつめる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b1",
      "text": "\t末候\t鶏始乳（にわとりはじめてとやにつく）\t鶏が卵を産み始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b2",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b3",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b4",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b5",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b6",
      "text": "二十四節気\t候\t宣明暦（中国）\t意味",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b7",
      "text": "立春",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b8",
      "text": "\t初候\t東風解凍\t東風が厚い氷を解かし始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48b9",
      "text": "\t次候\t蟄虫始振\t冬籠りの虫が動き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ba",
      "text": "\t末候\t魚上氷\t割れた氷の間から魚が飛び出る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48bb",
      "text": "雨水",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48bc",
      "text": "\t初候\t獺祭魚\t獺が捕らえた魚を並べて食べる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48bd",
      "text": "\t次候\t鴻雁来\t雁が越路して飛来し始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48be",
      "text": "\t末候\t草木萌動\t草木が芽吹き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48bf",
      "text": "啓蟄",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c0",
      "text": "\t初候\t桃始華\t桃の花が咲き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c1",
      "text": "\t次候\t倉庚鳴\t倉庚が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c2",
      "text": "\t末候\t鷹化為鳩\t鷹が鳩に姿を変える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c3",
      "text": "春分",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c4",
      "text": "\t初候\t玄鳥至\t燕が南からやって来る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c5",
      "text": "\t次候\t雷乃発声\t遠くで雷の音がし始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c6",
      "text": "\t末候\t始電\t稲光が初めて光る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c7",
      "text": "清明",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c8",
      "text": "\t初候\t桐始華\t桐の花が咲き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48c9",
      "text": "\t次候\t田鼠化為鴽\t田鼠が鴽になる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ca",
      "text": "\t末候\t虹始見\t雨の後に虹が出始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48cb",
      "text": "穀雨",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48cc",
      "text": "\t初候\t萍始生\t浮き草が芽を出し始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48cd",
      "text": "\t次候\t鳴鳩払其羽\t鳴鳩が羽を払う",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ce",
      "text": "\t末候\t戴勝降于桑\t戴勝が桑の木に止って蚕を生む",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48cf",
      "text": "立夏",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d0",
      "text": "\t初候\t螻蟈鳴\t螻蟈が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d1",
      "text": "\t次候\t蚯蚓出\t蚯蚓が地上に這出る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d2",
      "text": "\t末候\t王瓜生\t王瓜（からすうり）の実が生り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d3",
      "text": "小満",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d4",
      "text": "\t初候\t苦菜秀\t苦菜（にがな）がよく茂る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d5",
      "text": "\t次候\t靡草死\t薺（なずな）など田に生える草が枯れる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d6",
      "text": "\t末候\t小暑至\tようやく暑さが加わり始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d7",
      "text": "芒種",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d8",
      "text": "\t初候\t螳螂生\t螳螂が生まれ出る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48d9",
      "text": "\t次候\t鵙始鳴\t鵙が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48da",
      "text": "\t末候\t反舌無声\t反舌鳥が鳴かなくなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48db",
      "text": "夏至",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48dc",
      "text": "\t初候\t鹿角解\t鹿が角を落とす",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48dd",
      "text": "\t次候\t蜩始鳴\t蝉が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48de",
      "text": "\t末候\t半夏生\t烏柄杓が生える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48df",
      "text": "小暑",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e0",
      "text": "\t初候\t温風至\t暖い風が吹いて来る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e1",
      "text": "\t次候\t蟋蟀居壁\t蟋蟀が壁で鳴く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e2",
      "text": "\t末候\t鷹乃学習\t鷹の幼鳥が飛ぶことを覚える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e3",
      "text": "大暑",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e4",
      "text": "\t初候\t腐草為蛍\t腐った草が蒸れ蛍となる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e5",
      "text": "\t次候\t土潤溽暑\t土が湿って蒸暑くなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e6",
      "text": "\t末候\t大雨時行\t時として大雨が降る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e7",
      "text": "立秋",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e8",
      "text": "\t初候\t涼風至\t涼しい風が立ち始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48e9",
      "text": "\t次候\t白露降\t朝露が降り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ea",
      "text": "\t末候\t寒蝉鳴\t蜩が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48eb",
      "text": "処暑",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ec",
      "text": "\t初候\t鷹乃祭鳥\t鷹が捕らえた鳥を並べて食べる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ed",
      "text": "\t次候\t天地始粛\tようやく暑さが鎮まる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ee",
      "text": "\t末候\t禾乃登\t稲が実る",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ef",
      "text": "白露",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f0",
      "text": "\t初候\t鴻雁来\t雁が南へ飛来し始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f1",
      "text": "\t次候\t玄鳥帰\t燕が南へ帰って行く",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f2",
      "text": "\t末候\t羣鳥養羞\t多くの鳥が食べ物を蓄える",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f3",
      "text": "秋分",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f4",
      "text": "\t初候\t雷乃収声\t雷が鳴り響かなくなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f5",
      "text": "\t次候\t蟄虫坏戸\t虫が土中に掘った穴をふさぐ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f6",
      "text": "\t末候\t水始涸\t田畑の水を干し始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f7",
      "text": "寒露",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f8",
      "text": "\t初候\t鴻雁来賓\t雁が多数飛来して客人となる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48f9",
      "text": "\t次候\t雀入大水為蛤\t雀が海に入って蛤になる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48fa",
      "text": "\t末候\t菊有黄華\t菊の花が咲き出す",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48fb",
      "text": "霜降",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48fc",
      "text": "\t初候\t豺乃祭獣\t山犬が捕らえた獣を並べて食べる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48fd",
      "text": "\t次候\t草木黄落\t草木の葉が黄ばんで落ち始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48fe",
      "text": "\t末候\t蟄虫咸俯\t虫がみな穴に潜って動かなくなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e48ff",
      "text": "立冬",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4900",
      "text": "\t初候\t水始氷\t水が凍り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4901",
      "text": "\t次候\t地始凍\t大地が凍り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4902",
      "text": "\t末候\t雉入大水為蜃\t雉が海に入って大蛤になる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4903",
      "text": "小雪",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4904",
      "text": "\t初候\t虹蔵不見\t虹を見かけなくなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4905",
      "text": "\t次候\t天気上騰地気下降\t天地の寒暖が逆になる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4906",
      "text": "\t末候\t閉塞而成冬\t天地の気が塞がって冬となる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4907",
      "text": "大雪",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4908",
      "text": "\t初候\t鶡鴠不鳴\tミミキジが鳴かなくなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4909",
      "text": "\t次候\t虎始交\t虎が交尾を始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e490a",
      "text": "\t末候\t茘挺出\tネジアヤメが芽を出し始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e490b",
      "text": "冬至",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e490c",
      "text": "\t初候\t蚯蚓結\t蚯蚓が地中で塊となる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e490d",
      "text": "\t次候\t麋角解\t大鹿が角を落とす",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e490e",
      "text": "\t末候\t水泉動\t地中で凍った泉が動き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e490f",
      "text": "小寒",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4910",
      "text": "\t初候\t雁北郷\t雁が北に渡り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4911",
      "text": "\t次候\t鵲始巣\t鵲が巣を作り始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4912",
      "text": "\t末候\t雉始雊\t雄の雉が鳴き始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4913",
      "text": "大寒",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4914",
      "text": "\t初候\t鶏始乳\t鶏が卵を産み始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4915",
      "text": "\t次候\t鷙鳥厲疾\t鷲・鷹などが空高く速く飛び始める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    },
    {
      "id": "69d2e47700000000005e4916",
      "text": "\t末候\t水沢腹堅\t沢に氷が厚く張りつめる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1775428728,
      "updated": 1775428728
    }
  ]
}