      "created": 1772711524,
      "updated": 1772711524
    },
    {
      "id": "69a96e630000000000ea2298",
      "text": "天皇",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772711524,
      "updated": 1772711681
    },
    {
      "id": "69a96e6f0000000000ea229a",
      "text": "\t華族",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772711535,
      "updated": 1772711536
    },
    {
      "id": "69a96e700000000000ea229b",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772711537,
      "updated": 1772711691
    },
    {
      "id": "69a970280000000000ea22a0",
      "text": "日近な身分",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772711977,
      "updated": 1772711986
    },
    {
      "id": "69a96f0a0000000000ea229d",
      "text": " 正社員",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772711691,
      "updated": 1772711989
    },
    {
      "id": "69a96f170000000000ea229e",
      "text": " 非正規雇用",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772711703,
      "updated": 1772711989
    },
    {
      "id": "69a96f1a0000000000ea229f",
      "text": " 無職",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772711707,
      "updated": 1772711989
    },
    {
      "id": "69a9705b0000000000ea22a1",
      "text": " 住所不定無職",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712028,
      "updated": 1772712034
    },
    {
      "id": "69a970620000000000ea22a2",
      "text": " 戸籍なし",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712034,
      "updated": 1772712038
    },
    {
      "id": "69a970e30000000000ea22a3",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712164,
      "updated": 1772712164
    },
    {
      "id": "69a972d30000000000ea22ad",
      "text": "社内身分",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712660,
      "updated": 1772712668
    },
    {
      "id": "69a972dc0000000000ea22ae",
      "text": "\t社長・次長・課長・部長……",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712668,
      "updated": 1772712691
    },
    {
      "id": "69a972f40000000000ea22af",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712692,
      "updated": 1772712712
    },
    {
      "id": "69a9730a0000000000ea22b0",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712715,
      "updated": 1772712715
    },
    {
      "id": "69a9729e0000000000ea22ab",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712607,
      "updated": 1772712607
    },
    {
      "id": "69a970eb0000000000ea22a4",
      "text": "身分らしきものが垣間見える場所",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772712172,
      "updated": 1772733999
    },
    {
      "id": "69a9721c0000000000ea22a6",
      "text": "\t自分よりもハイソサエティな場所",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712476,
      "updated": 1772712522
    },
    {
      "id": "69a9726d0000000000ea22a9",
      "text": " \t宝飾店、ブランドショップ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712557,
      "updated": 1772712577
    },
    {
      "id": "69a972490000000000ea22a7",
      "text": " 自分よりもローソサエティな場所",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712522,
      "updated": 1772712543
    },
    {
      "id": "69a972620000000000ea22a8",
      "text": " \tスラム",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772712546,
      "updated": 1772712626
    },
    {
      "id": "69a9721c0000000000ea22a5",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
