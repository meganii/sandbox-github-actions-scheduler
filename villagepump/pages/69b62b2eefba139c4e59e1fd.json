{
  "id": "69b62b2eefba139c4e59e1fd",
  "title": "言っていない",
  "created": 1773546291,
  "updated": 1773546656,
  "lines": [
    {
      "id": "69b62b2eefba139c4e59e1fd",
      "text": "言っていない",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546291,
      "updated": 1773546291
    },
    {
      "id": "69b62b5e000000000070ace3",
      "text": "[言ってない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546335,
      "updated": 1773546335
    },
    {
      "id": "69b62b5f000000000070ace4",
      "text": "[実は言ってない名言]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546336,
      "updated": 1773546341
    },
    {
      "id": "69b62c4b000000000070ad03",
      "text": " [はそんなこと言ってない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546572,
      "updated": 1773546582
    },
    {
      "id": "69b62b66000000000070ace5",
      "text": " [言ってないシリーズ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546343,
      "updated": 1773546576
    },
    {
      "id": "69b62b68000000000070ace6",
      "text": "[原作で言ってないだけ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546345,
      "updated": 1773546347
    },
    {
      "id": "69b62b6c000000000070ace8",
      "text": "[俺そんなこと言ってない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546350,
      "updated": 1773546352
    },
    {
      "id": "69b62b31000000000070acd2",
      "text": "[何でもやるとは言っていない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546291,
      "updated": 1773546296
    },
    {
      "id": "69b62b38000000000070acd4",
      "text": "[私はそういう意図では言っていない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546297,
      "updated": 1773546299
    },
    {
      "id": "69b62b3a000000000070acd5",
      "text": "[触っていないです]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546299,
      "updated": 1773546301
    },
    {
      "id": "69b62b3d000000000070acd6",
      "text": "[言ってないセリフ]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546302,
      "updated": 1773546304
    },
    {
      "id": "69b62b3f000000000070acd7",
      "text": "[目が笑っていない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546304,
      "updated": 1773546306
    },
    {
      "id": "69b62b42000000000070acd8",
      "text": "[心がこもっていない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546307,
      "updated": 1773546309
    },
    {
      "id": "69b62b32000000000070acd3",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546291,
      "updated": 1773546291
    },
    {
      "id": "69b62c95000000000070ad18",
      "text": "[言わんこっちゃない]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546646,
      "updated": 1773546646
    },
    {
      "id": "69b62b4a000000000070acd9",
      "text": "[言った言わない論争]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546315,
      "updated": 1773546324
    },
    {
      "id": "69b62b4c000000000070acda",
      "text": "[言った]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546317,
      "updated": 1773546595
    },
    {
      "id": "69b62c63000000000070ad07",
      "text": "[ん？]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546596,
      "updated": 1773546599
    },
    {
      "id": "69b62c60000000000070ad06",
      "text": "",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1773546593,
      "updated": 1773546593
    }
  ]
}