  "lines": [
    {
      "id": "69f7bd2e25acaa239bd0e46e",
      "text": "2026/03/27―hoshihara",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19a2",
      "text": "from [2026/03/27]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19a3",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843505
    },
    {
      "id": "69f7bd2e00000000008a19a4",
      "text": "[hoshihara.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19a5",
      "text": "\t手作り最中の面倒なところ：手作りしなければ食べられない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19a6",
      "text": "\tもなか食べまーすモナモナモナモナ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19a7",
      "text": "\t\t謎テンション[imo.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19a8",
      "text": "\t私もクロッキするか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19a9",
      "text": "\t\t30秒クロッキーをやってみたとき、30秒の速さにこれ無理やろとなって以来、5分などの長い時間でしかやらなくなった。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19aa",
      "text": "\t\t\t短時間で描くやつ、輪郭での印象を捉えるとかの目的がありそうわよね[imo.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19ab",
      "text": "\t\t\t\tありそう[hoshihara.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19ac",
      "text": "\t\t[魚を描く]か",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19ad",
      "text": "\t\t\t[https://gyazo.com/3d0d133b06467690a662bcfd35600441]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19ae",
      "text": "\t\t\t魚を描いた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19af",
      "text": "\t肩こり and site:ac.jp and シラバス　で検索したら[お茶の水はりきゅう専門学校]のはり師きゅう師学科というものの存在を知れた。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
      "id": "69f7bd2e00000000008a19b0",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843502,
      "updated": 1777843502
    },
    {
