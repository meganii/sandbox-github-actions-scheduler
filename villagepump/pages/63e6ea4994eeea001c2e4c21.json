      "created": 1676161544,
      "updated": 1676161548
    },
    {
      "id": "63e6ea4be600350000706fa8",
      "text": "　[サイコパス]",
      "userId": "62a91a7a083437001de60035",
      "created": 1676077644,
      "updated": 1676161539
    },
    {
      "id": "682b5ef50000000000a00783",
      "text": "　[マキャヴェリズム]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1747672821,
      "updated": 1747672839
    },
    {
      "id": "6a5784050000000000fce4b9",
      "text": "　[サディズム]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1784120327,
      "updated": 1784120333
    },
    {
      "id": "6a57842c0000000000fce4ba",
