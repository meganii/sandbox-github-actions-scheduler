{
  "id": "66578f1a30e116001cb81ce5",
  "title": "ラーメンタイマー",
  "created": 1717014301,
  "updated": 1772065993,
  "lines": [
    {
      "id": "66578f1a30e116001cb81ce5",
      "text": "ラーメンタイマー",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1717014301,
      "updated": 1717014301
    },
    {
      "id": "66578f1d5b98c200005a12e5",
      "text": "[カップラーメン]を作るための単機能のタイマー",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1717014301,
      "updated": 1717014328
    },
    {
      "id": "66578f225b98c200005a12e7",
      "text": "[キッチンタイマー]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1717014306,
      "updated": 1717014323
    },
    {
      "id": "66578f1e5b98c200005a12e6",
      "text": "[エッグタイマー]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1717014302,
      "updated": 1717014426
    },
    {
      "id": "66578f955b98c200005a12e8",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1717014421,
      "updated": 1717014421
    },
    {
      "id": "699f5af00000000000f8094c",
      "text": "svg画像でラーメンタイマーを実装してみる [suto3.icon]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051184,
      "updated": 1772051367
    },
    {
      "id": "699f5b2c0000000000f8094d",
      "text": "　針は1分間に一周する",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051244,
      "updated": 1772051298
    },
    {
      "id": "699f5b630000000000f8094e",
      "text": "　3周すると止まる（色が変わる）",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051299,
      "updated": 1772051351
    },
    {
      "id": "699f5bab0000000000f8094f",
      "text": "　リロードでやり直し",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051371,
      "updated": 1772051406
    },
    {
      "id": "699f5bcf0000000000f80950",
      "text": "　一時停止とか、そういう機能はない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051407,
      "updated": 1772051441
    },
    {
      "id": "699f5a7c0000000000f8094b",
      "text": "[https://svg-hosting.vercel.app/api/svg?url=https://scrapbox.io/api/code/villagepump/ラーメンタイマー/r.svg]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051069,
      "updated": 1772051167
    },
    {
      "id": "699f5a600000000000f8093a",
      "text": "code:r.svg",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051040,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f8093b",
      "text": " <svg width=\"200\" height=\"200\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\">",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f8093c",
      "text": "   <circle cx=\"50\" cy=\"50\" r=\"45\" fill=\"lightblue\" stroke=\"black\" stroke-width=\"5\">",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f8093d",
      "text": "     <animate",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772065959
    },
    {
      "id": "699f94a70000000000b9593f",
      "text": "       attributeName=\"fill\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772065959,
      "updated": 1772065964
    },
    {
      "id": "699f94ab0000000000b95940",
      "text": "       from=\"lightblue\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772065964,
      "updated": 1772065971
    },
    {
      "id": "699f94b30000000000b95941",
      "text": "       to=\"gray\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772065971,
      "updated": 1772065979
    },
    {
      "id": "699f94bb0000000000b95942",
      "text": "       begin=\"180s\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772065979,
      "updated": 1772065984
    },
    {
      "id": "699f94c00000000000b95943",
      "text": "       dur=\"0.1s\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772065984,
      "updated": 1772065988
    },
    {
      "id": "699f94c30000000000b95944",
      "text": "       fill=\"freeze\"",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772065988,
      "updated": 1772065991
    },
    {
      "id": "699f94c70000000000b95945",
      "text": "     />",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772065991,
      "updated": 1772065993
    },
    {
      "id": "699f5a7a0000000000f8093e",
      "text": "   </circle>",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f8093f",
      "text": "   <line x1=\"50\" y1=\"5\" x2=\"50\" y2=\"50\" fill=\"none\" stroke=\"black\" stroke-width=\"5\" >",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80940",
      "text": "     <!-- 60秒で0度から360度まで回転 -->",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80941",
      "text": "     <animateTransform ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80942",
      "text": "       attributeName=\"transform\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80943",
      "text": "       type=\"rotate\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80944",
      "text": "       from=\"0 50 50\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80945",
      "text": "       to=\"360 50 50\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80946",
      "text": "       dur=\"60s\" ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80947",
      "text": "       repeatCount=\"3\" />",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80948",
      "text": "   </line> ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f80949",
      "text": " </svg>",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    },
    {
      "id": "699f5a7a0000000000f8094a",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772051067,
      "updated": 1772051067
    }
  ]
}