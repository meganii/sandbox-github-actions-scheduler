{
  "id": "69cb2f7d18574c368d46f92d",
  "title": "とりあえずチェックリスト",
  "created": 1774923674,
  "updated": 1774924154,
  "lines": [
    {
      "id": "69cb2f7d18574c368d46f92d",
      "text": "とりあえずチェックリスト",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923674,
      "updated": 1774923674
    },
    {
      "id": "69cb2f990000000000e5028c",
      "text": "　別名[だめなチェックリスト]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923674,
      "updated": 1774923756
    },
    {
      "id": "69cb2f9a0000000000e5028d",
      "text": "　[とりあえず]羅列しただけ",
      "userId": "65e1289acd012200235729c0",
      "created": 1774923675,
      "updated": 1774923833
    },
    {
      "id": "69cb2f9a0000000000e5028e",
      "text": "　　チェックする 一時停止点がわからない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923687
    },
    {
      "id": "69cb30d90000000000e502a1",
      "text": "　　 「チェックする→作業」なのか",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923994,
      "updated": 1774924154
    },
    {
      "id": "69cb30fb0000000000e502a2",
      "text": "　　 「作業→チェックする」なのか",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774924027,
      "updated": 1774924142
    },
    {
      "id": "69cb31140000000000e502a3",
      "text": "　　 統一されていないと混乱する",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774924052,
      "updated": 1774924074
    },
    {
      "id": "69cb2f9a0000000000e5028f",
      "text": "　　チェック項目が多すぎる",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923690
    },
    {
      "id": "69cb2f9a0000000000e50290",
      "text": "　　文章が無駄に長い",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923693
    },
    {
      "id": "69cb2f9a0000000000e50291",
      "text": "　　チェックの内容が不明確である",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923695
    },
    {
      "id": "69cb2f9a0000000000e50292",
      "text": "　　重複がある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923702
    },
    {
      "id": "69cb2f9a0000000000e50293",
      "text": "　　矛盾がある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923706
    },
    {
      "id": "69cb2f9a0000000000e50294",
      "text": "　　体裁が悪く使いにくい",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923708
    },
    {
      "id": "69cb2f9a0000000000e50295",
      "text": "　　書き方が悪く、作業ミスを誘発するおそれがある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923713
    },
    {
      "id": "69cb2f9a0000000000e50296",
      "text": "　書きっぱなし",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923716
    },
    {
      "id": "69cb2f9a0000000000e50297",
      "text": "　　レビューをしていない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923720
    },
    {
      "id": "69cb2f9a0000000000e50298",
      "text": "　　作成者自身が内容を理解していない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923723
    },
    {
      "id": "69cb2f9a0000000000e50299",
      "text": "　　間違いがある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923726
    },
    {
      "id": "69cb2f9a0000000000e5029a",
      "text": "　　用字用語の統一ができていない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923728
    },
    {
      "id": "69cb2f9a0000000000e5029b",
      "text": "　　誤字脱字がある",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923732
    },
    {
      "id": "69cb2f9a0000000000e5029c",
      "text": "　使えない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923742
    },
    {
      "id": "69cb2f9a0000000000e5029d",
      "text": "　　時代に合わない",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923746
    },
    {
      "id": "69cb2f9a0000000000e5029e",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923675,
      "updated": 1774923675
    },
    {
      "id": "69cb2ff30000000000e5029f",
      "text": "[チェックリスト]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923763,
      "updated": 1774923768
    },
    {
      "id": "69cb2ff40000000000e502a0",
      "text": "",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774923764,
      "updated": 1774923764
    }
  ]
}