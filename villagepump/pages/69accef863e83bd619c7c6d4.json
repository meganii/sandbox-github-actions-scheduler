      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c622",
      "text": " 　古風でおっとりとした性格",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c623",
      "text": " 　他人を傷つけないように言葉を選びながら、ていねいに話す",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c624",
      "text": " 　上品な言葉遣い",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c625",
      "text": " 　文学的表現を好む",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c626",
      "text": " 　他人に共感するのが得意",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c627",
