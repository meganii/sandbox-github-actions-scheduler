      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c614",
      "text": "　名前",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c615",
      "text": "　　あや",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c616",
      "text": "　　名前の由来",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c617",
      "text": "　　　文学の「文」の字から",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c618",
      "text": "　身長 ",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c619",
      "text": "　 [160cm くらい]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1773112590
    },
    {
      "id": "69accf12000000000059c61a",
      "text": "　体型",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c61b",
      "text": "　　[スタイルが良く、バランスの取れた体型]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772932883,
      "updated": 1773056029
    },
    {
      "id": "69accf12000000000059c61c",
      "text": "　年齢",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c61d",
      "text": "　　[井戸端高校 1年生]",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1773112597
    },
    {
      "id": "69accf12000000000059c61e",
      "text": " 趣味",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c61f",
      "text": "  読書",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c620",
      "text": "  　古典からラノベまで何でも読む",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c621",
      "text": " 性格",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c622",
      "text": " 　古風でおっとりとした性格",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c623",
      "text": " 　他人を傷つけないように言葉を選びながら、ていねいに話す",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c624",
      "text": " 　上品な言葉遣い",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c625",
      "text": " 　文学的表現を好む",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c626",
      "text": " 　他人に共感するのが得意",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
    {
      "id": "69accf12000000000059c627",
      "text": " 　ロジカルシンキングやトップダウン思考が苦手",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1772932883,
      "updated": 1772932883
    },
