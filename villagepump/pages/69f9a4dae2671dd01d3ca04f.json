    {
      "id": "69f9a4dae2671dd01d3ca04f",
      "text": "ザナドゥ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968355,
      "updated": 1777968355
    },
    {
      "id": "69f9a4e7000000000024baf1",
      "text": "[https://ja.wikipedia.org/wiki/ザナドゥ計画 ザナドゥ計画]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968360,
      "updated": 1777968382
    },
    {
      "id": "69f9a4e2000000000024baf0",
      "text": "世界最初の[ハイパーテキスト]開発プロジェクト。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968355,
      "updated": 1777968664
    },
    {
      "id": "69f9a503000000000024baf3",
      "text": "1960年、テッド・ネルソンにより創始。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968387,
      "updated": 1777968400
    },
    {
      "id": "69f9a502000000000024baf2",
      "text": "1998年にProject Udanaxとしてソースコードを公開。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968387,
      "updated": 1777968411
    },
    {
      "id": "69f9a51a000000000024baf6",
      "text": "2014年に開発開始から54年間を経てOpenXanaduが公開。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968411,
      "updated": 1777968430
    },
    {
      "id": "69f9a52c000000000024baf7",
      "text": "その間に、[[ザナドゥ]]計画に影響を受けて1989年に開発が開始された[World Wide Web]が全世界に普及。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968429,
      "updated": 1777968594
    },
    {
      "id": "69f9a53c000000000024baf8",
      "text": " [[ザナドゥ]]は実装が困難で人間の協調を必要とするのに対し、Webは[ファイルシステム]を拡張して実装することが容易であり、個人個人が独立して参加できることが普及の差を分けた。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968444,
      "updated": 1777968603
    },
    {
      "id": "69f9a587000000000024baf9",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968519,
      "updated": 1777968519
    },
    {
      "id": "69f9a609000000000024bafa",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777968649,
      "updated": 1777968649
    },
    {
