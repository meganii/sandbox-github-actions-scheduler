    {
      "id": "69f7bc905e1280cdfc8a5553",
      "text": "2026/03/27―takker",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc90000000000026181b",
      "text": "from [2026/03/27]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc90000000000026181c",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843347
    },
    {
      "id": "69f7bc90000000000026181d",
      "text": "[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc90000000000026181e",
      "text": " 二時間[寝坊]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc90000000000026181f",
      "text": " 　🍵[Mijikko.icon][nyarla.icon][Hiro Aki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261820",
      "text": " あさごはん略さざるを得なかった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261821",
      "text": " \tかなしい[sta.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261822",
      "text": " \t電車降りてから大学行くまで歩きながらパンを食べました[takker.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261823",
      "text": " \tあ！薬飲み忘れてた！",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261824",
      "text": " 先方に2時間遅らせていただく旨を一報した後、一面せん断試験を仕掛けて出発",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261825",
      "text": "  3時間でギリギリ終えられた",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261826",
      "text": "  文脈のせいか一面せん断試験が「面談試験断る」みたいななにかに見えてヒョッとした[yosider.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261827",
      "text": " 電車の中で試験の様子をモニタリング",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261828",
      "text": "  [Deno tunnel]便利",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc900000000000261829",
      "text": " 電車乗り過ごしちゃった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc90000000000026182a",
      "text": "  急行だからすごく遠くまで連れてかれる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc90000000000026182b",
      "text": " 楽しかった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777843345,
      "updated": 1777843345
    },
    {
      "id": "69f7bc90000000000026182c",
