  "lines": [
    {
      "id": "69caa5f2c9a60554e64569ba",
      "text": "外製和語",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888443,
      "updated": 1774888443
    },
    {
      "id": "69caa60c0000000000752c33",
      "text": "[俺語][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888461,
      "updated": 1774888470
    },
    {
      "id": "69caa5f90000000000752c30",
      "text": "和製英語ならぬ外国製の日本語",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888443,
      "updated": 1774888460
    },
    {
      "id": "69caa6020000000000752c32",
      "text": "\t和製漢語等の他の用語との整合性も良き",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888452,
      "updated": 1774888515
    },
    {
      "id": "69caa6410000000000752c34",
      "text": "\t英製和語とも思ったけど、英製じゃなくてもいいと思って外製にした",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888515,
      "updated": 1774888564
    },
    {
      "id": "69caa6730000000000752c35",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888565,
      "updated": 1774888565
    },
    {
      "id": "69caa6730000000000752c36",
      "text": "見つけると、和製英語を聞かされた時の英語話者の気持ちがわかると思う",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888565,
      "updated": 1774888598
    },
    {
      "id": "69caa7da0000000000752c3c",
      "text": " 日本語由来のように書かれていると「まちなさいw」ってなる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888924,
      "updated": 1774888956
    },
    {
      "id": "69caa68e0000000000752c37",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888591,
      "updated": 1774888591
    },
    {
      "id": "69caa68e0000000000752c38",
      "text": "[yeredere]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1774888592,
      "updated": 1774888611
    },
    {
