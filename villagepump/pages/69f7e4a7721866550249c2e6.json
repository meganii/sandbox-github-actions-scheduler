    {
      "id": "69f7e56b000000000089eb89",
      "text": " [1991年]生まれ",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853803,
      "updated": 1777853866
    },
    {
      "id": "69f7e5c1000000000089eb8c",
      "text": " [2001年]より個人サイト上で楽曲を発表",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853889,
      "updated": 1777853944
    },
    {
      "id": "69f7e713000000000089eb97",
      "text": " \t[ファミコン宇宙人]名義",
      "userId": "688c296691686a314f82fb52",
      "created": 1777854227,
      "updated": 1777854233
    },
    {
      "id": "69f7e73d000000000089eb9b",
      "text": " 中学生時代の代表作の一つ「kamikaze」が発表",
      "userId": "688c296691686a314f82fb52",
      "created": 1777854269,
      "updated": 1777854327
    },
    {
      "id": "69f7e77b000000000089eb9d",
      "text": " \t[ジョージ・ウィリアムズ]のラジオで紹介される",
      "userId": "688c296691686a314f82fb52",
      "created": 1777854331,
      "updated": 1777854542
    },
    {
      "id": "69f7e779000000000089eb9c",
      "text": " \t\t[http://blog.livedoor.jp/imoutoid/archives/51862638.html imoutoid's websitoid:バカ親の回想　Kamikaze]",
      "userId": "688c296691686a314f82fb52",
      "created": 1777854329,
      "updated": 1777854547
    },
    {
      "id": "69f7e5ae000000000089eb8b",
      "text": " [2006年]よりimoutoid名義での活動を開始",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853869,
      "updated": 1777853888
    },
    {
      "id": "69f7e5fa000000000089eb8d",
      "text": " [2007年]に代表作「[ADEPRESSIVE CANNOT GOTO THECEREMONY]」を発表",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853946,
      "updated": 1777854038
    },
    {
      "id": "69f7e5a9000000000089eb8a",
      "text": " [2009年]に初音ミクのコンピ盤で[メジャーデビュー]するも同年4月に[急性心不全]により死去(享年18歳)",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853865,
      "updated": 1777854054
    },
    {
      "id": "69f7e559000000000089eb86",
      "text": "",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853785,
      "updated": 1777853785
    },
    {
      "id": "69f7e4c5000000000089eb80",
      "text": "[ファミコン宇宙人]、[sjyamato]、[Yamato Yoshioka]名義でも活動",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853637,
      "updated": 1777854370
    },
    {
      "id": "69f7e4b4000000000089eb7e",
      "text": " 「[Otophilia]」という名義で[Supercollider]に[プログラマ]として貢献している",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853620,
      "updated": 1777854064
    },
    {
      "id": "69f7e528000000000089eb81",
      "text": "  [https://qiita.com/Yohei_Suda/items/52a080fb81c1df738c66 imoutoid(otophilia)の現存するコードまとめ＆最新のSuperColliderで動かしてみる #SuperCollider - Qiita]",
      "userId": "688c296691686a314f82fb52",
      "created": 1777853736,
      "updated": 1777854066
    },
    {
