    {
      "id": "69a845340000000000822006",
      "text": "1. 様々な言語における[アポストロフィー]の使用",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772639568
    },
    {
      "id": "69a845340000000000822007",
      "text": "1.1. エスペラント語では",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772636595
    },
    {
      "id": "69a845340000000000822008",
      "text": "1.2. フランス",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635513
    },
    {
      "id": "69a845340000000000822009",
      "text": "1.3. イギリス",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635518
    },
    {
      "id": "69a84534000000000082200a",
      "text": "2. [引用符]について",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772636598
    },
    {
      "id": "69a84534000000000082200b",
      "text": "2.1. 引用文の中の引用文",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635539
    },
    {
      "id": "69a84534000000000082200c",
      "text": "2.2. 自己言及と意味定義",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635575
    },
    {
      "id": "69a84534000000000082200d",
      "text": "2.3. 直接話法",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635584
    },
    {
      "id": "69a84534000000000082200e",
      "text": "2.3.1. フランス・ポーランド・ロシア方式",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635610
    },
    {
      "id": "69a84534000000000082200f",
      "text": "2.3.2. ゲルマン方式（イギリス・ドイツ方式）",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635692
    },
    {
      "id": "69a845340000000000822010",
      "text": "2.3.3. その他の類似記号",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772635445,
      "updated": 1772635706
    },
    {
      "id": "69a845340000000000822011",
