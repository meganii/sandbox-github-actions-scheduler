      "id": "696024e9ee89ed766a2f771a",
      "text": "2026/01/09",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767908585,
      "updated": 1767908585
    },
    {
      "id": "696024ea6eb4060000009cd341",
      "text": "第2週: 日月火水木[[金]]土",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767908585,
      "updated": 1767908585
    },
    {
      "id": "696024ea6eb406000000697a10",
      "text": "2026年 2.47％経過",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767908585,
      "updated": 1767908585
    },
    {
      "id": "696024ea6eb40600000005023f",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767908585,
      "updated": 1767908585
    },
    {
      "id": "696024ea6eb406000000b4eca0",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767908585,
      "updated": 1767908585
    },
    {
      "id": "69602efc00000000004c45f7",
      "text": "[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767911164,
      "updated": 1767911165
    },
    {
      "id": "69602efe00000000004c45f8",
      "text": "\t明日から三連休だ！",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767911165,
      "updated": 1767911173
    },
    {
      "id": "69602f0500000000004c45f9",
      "text": "\t\tこの時期は屋外は寒いので科学館・博物館など室内施設に行くのが例年",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767911173,
      "updated": 1767911197
    },
    {
      "id": "6960813c0000000000020d0b",
      "text": "\t[Svelte]やってみたい",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767932221,
      "updated": 1767932229
    },
    {
      "id": "6960c0b400000000007e522d",
      "text": "\t公園で自作のゲーム機を披露できた",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767948469,
      "updated": 1767948479
    },
    {
      "id": "6960ca2900000000002f19fc",
      "text": "\t\tすごい[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1767950890,
      "updated": 1767950907
    },
    {
      "id": "6960fa8a000000000049637c",
      "text": "\t\t自作ゲーム「機」なの凄い[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963274,
      "updated": 1767963298
    },
    {
      "id": "696024ea6eb406000000bec58b",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767908585,
      "updated": 1767908585
    },
    {
      "id": "69603b640000000000931fb2",
      "text": "[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767914341,
      "updated": 1767914342
    },
    {
      "id": "69603b660000000000931fb3",
      "text": "\t寒波にご注意。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767914342,
      "updated": 1767914374
    },
    {
      "id": "69603dd900000000005e72b9",
      "text": "\t\t+1、本当に寒い[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1767914970,
      "updated": 1767914975
    },
    {
      "id": "6960696500000000007937a3",
      "text": "\t\t;:(∩´﹏`∩):;[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767926117,
      "updated": 1767926120
    },
    {
      "id": "69607dac00000000004d4004",
      "text": "\t\t炭水化物をメインにカロリーの高いものを食べましょう（Wii Fit トレーナーボイス）[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767931309,
      "updated": 1767931422
    },
    {
      "id": "69607dd300000000004d4005",
      "text": "\t\t\t食べ過ぎて体が火照る現象を逆に利用するのだ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767931348,
      "updated": 1767931396
    },
    {
      "id": "6960d81f0000000000103758",
      "text": "\t\t\t\t+1[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1767954464,
      "updated": 1767954467
    },
    {
      "id": "69609cf80000000000c992d9",
      "text": "\t\t🌶️ [terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767939320,
      "updated": 1767939329
    },
    {
      "id": "69609c980000000000c992d7",
      "text": "\t長野駅にきた",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767939224,
      "updated": 1767939231
    },
    {
      "id": "69609c9f0000000000c992d8",
      "text": "\t 覚悟していたがそんなに極寒というわけではなかった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767939231,
      "updated": 1767939250
    },
    {
      "id": "6960c1c2000000000062d37f",
      "text": "\t空いた時間で、フォローしてる[個人public project]の未読を消化",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767948739,
      "updated": 1767948794
    },
    {
      "id": "6960c204000000000062d380",
      "text": "\t 自分が読んでる公開プロジェクト、みたいなページがどこかにあった気がする",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767948805,
      "updated": 1767948836
    },
    {
      "id": "6961094200000000007a7895",
      "text": "\t羊を食べた",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767967042,
      "updated": 1767967047
    },
    {
      "id": "6961091500000000007a7893",
      "text": "\t長野は案外どのスキー場も雪が少ない！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767966997,
      "updated": 1767967016
    },
    {
      "id": "6961092c00000000007a7894",
      "text": "\t 連休後半の方が冬型が強まるっぽいので、明日は白馬コルチナに行ってみようということになった",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767967021,
      "updated": 1767967067
    },
    {
      "id": "6961095d00000000007a7896",
      "text": "\t メンバー全員行ったことのないところで楽しみ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767967069,
      "updated": 1767967089
    },
    {
      "id": "6961097100000000007a7897",
      "text": "\t最近外国人のゲレンデマナーがかなり悪いという話を聞いた",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767967089,
      "updated": 1767967116
    },
    {
      "id": "696109af00000000007a7899",
      "text": "\t 例えば前の滑走者優先とか",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767967151,
      "updated": 1767967217
    },
    {
      "id": "696109f300000000007a789a",
      "text": "\t  危険な追い抜きが増えているとのこと",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767967219,
      "updated": 1767967231
    },
    {
      "id": "6961098c00000000007a7898",
      "text": "\t 昔はスキーなりスノボなりを習うときは、最初の段階で結構叩き込まれるものだったのにな。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1767967117,
      "updated": 1767967147
    },
    {
      "id": "696024ea6eb406000000b19bfe",
      "text": "",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767908585,
      "updated": 1767908585
    },
    {
      "id": "69603d9b000000000033c1c5",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1767914908,
      "updated": 1767914910
    },
    {
      "id": "69603d9e000000000033c1c7",
      "text": "\tおはようございます",
      "userId": "65e1289acd012200235729c0",
      "created": 1767914910,
      "updated": 1767914914
    },
    {
      "id": "69603da2000000000033c1c8",
      "text": "\t昨日見かけた話だけど今書きたくなったからここに書いてしまう",
      "userId": "65e1289acd012200235729c0",
      "created": 1767914915,
      "updated": 1767915286
    },
    {
      "id": "69603f16000000000033c1c9",
      "text": "\t\t昨日の昼のNHKニュースにて、次の記事の順に放送",
      "userId": "65e1289acd012200235729c0",
      "created": 1767915286,
      "updated": 1767915301
    },
    {
      "id": "69603f24000000000033c1ca",
      "text": "\t\t[https://news.web.nhk/newsweb/na/na-k10015021441000 米 移民税関捜査局職員が発砲 女性が死亡 事件受け抗議活動も | NHKニュース | アメリカ、事件・事故、トランプ大統領]",
      "userId": "65e1289acd012200235729c0",
      "created": 1767915301,
      "updated": 1767915309
    },
    {
      "id": "69603f2c000000000033c1cb",
      "text": "  [https://news.web.nhk/newsweb/na/na-k10015022241000 大阪 岸和田で車暴走“容疑者は当時 無免許運転” 捜査関係者 | NHKニュース | 事件・事故、大阪府、自動車]",
      "userId": "65e1289acd012200235729c0",
      "created": 1767915309,
      "updated": 1767915316
    },
    {
      "id": "69603f34000000000033c1cc",
      "text": "  車で轢き殺されそうだからと発砲したアメリカ、車に轢き殺されそうだからとボンネットに飛び乗って対応した日本という対比",
      "userId": "65e1289acd012200235729c0",
      "created": 1767915316,
      "updated": 1767915413
    },
    {
      "id": "69603f73000000000033c1cd",
      "text": "  これを連続で放送したのは意図的なのかたまたまなのか、どっちなんだと今も気になる",
      "userId": "65e1289acd012200235729c0",
      "created": 1767915379,
      "updated": 1767915427
    },
    {
      "id": "69605f35000000000033c1ce",
      "text": " 記録を残さない、口頭確認のみなのは本当に大丈夫なのか？と今日も思う",
      "userId": "65e1289acd012200235729c0",
      "created": 1767923510,
      "updated": 1767923528
    },
    {
      "id": "696082a3000000000024bdbf",
      "text": " 植物ではない、というとキノコもそうだったなと思い出す",
      "userId": "65e1289acd012200235729c0",
      "created": 1767932580,
      "updated": 1767932590
    },
    {
      "id": "696082ae000000000024bdc0",
      "text": " \tよく知らないのでChatGPTに、[水生のキノコ]はあるのかと聞いてみたらあるとのこと",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1767932590,
      "updated": 1767970393
    },
    {
      "id": "696082d4000000000024bdc1",
      "text": " \t食べられるような種類は存在しないらしい",
      "userId": "65e1289acd012200235729c0",
      "created": 1767932628,
      "updated": 1767932657
    },
    {
      "id": "69603d9c000000000033c1c6",
      "text": "",
      "userId": "65e1289acd012200235729c0",
      "created": 1767914909,
      "updated": 1767914909
    },
    {
      "id": "69604dcd000000000069d83c",
      "text": "[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767919053,
      "updated": 1767919055
    },
    {
      "id": "69604dcf000000000069d83d",
      "text": "　シンポジウム会場に向かう",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767919055,
      "updated": 1767919064
    },
    {
      "id": "69607b0400000000007ff905",
      "text": "　ジオゲッサーは去年と同じなので代わりに「うろ覚えブランドゲッサー」",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767930628,
      "updated": 1767930841
    },
    {
      "id": "69607b2100000000007ff906",
      "text": "　　「なんかTとかHとかついてそうな爆弾みたいなやつ」",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767930658,
      "updated": 1767930674
    },
    {
      "id": "69607e4500000000004d4006",
      "text": " 　　[https://gyazo.com/0c2b4dd66459844d1bdeffb382b8a49a][Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767931462,
      "updated": 1767931783
    },
    {
      "id": "6960d6170000000000e4c70c",
      "text": " 　　\t大体あってる(あってない)[nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767953944,
      "updated": 1767953951
    },
    {
      "id": "69607b4a00000000007ff907",
      "text": "　　[~ TもHもついてないし爆弾でもないので酷い][nishio.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767930699,
      "updated": 1767953954
    },
    {
      "id": "6960d4fc0000000000345070",
      "text": "　　[~ [トミーヒルフィルガー]みたいなやつかな][caki.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767953660,
      "updated": 1767953958
    },
    {
      "id": "696053c800000000002bc155",
      "text": "\t\t[TとH]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767920585,
      "updated": 1767955367
    },
    {
      "id": "69634d0a00000000005c923b",
      "text": "\t\t　[阪神タイガース]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1768115466,
      "updated": 1768115471
    },
    {
      "id": "69634d1800000000005c923c",
      "text": "\t\t　　[IHS]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1768115480,
      "updated": 1768115485
    },
    {
      "id": "69634d2000000000005c923d",
      "text": "\t\t　　 [君主の宝珠]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1768115489,
      "updated": 1768115499
    },
    {
      "id": "6963aba400000000004515a1",
      "text": "\t\t　　 \t正解: [~ [vivian westwood]]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1768139685,
      "updated": 1768139692
    },
    {
      "id": "6960dba60000000000e4c712",
      "text": "",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767955367,
      "updated": 1767955367
    },
    {
      "id": "69604dd9000000000069d83f",
      "text": "[カイト.icon]",
      "userId": "582e63d27c56960011aff09e",
      "created": 1767919066,
      "updated": 1767955314
    },
    {
      "id": "696055d300000000002bc15e",
      "text": "\t職場がすごく乾燥していて、喉がイガイガして咳が出る",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767921108,
      "updated": 1767921143
    },
    {
      "id": "696055f700000000002bc15f",
      "text": "\t\t帰って[加湿器]がある環境で過ごしたい",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767921144,
      "updated": 1767921174
    },
    {
      "id": "6960565100000000002bc162",
      "text": "\t\tのど飴と水分が手放せない",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767921233,
      "updated": 1767921251
    },
    {
      "id": "69605f1900000000001c802e",
      "text": "\t[3連休　11日から強烈寒波襲来か　日本海側を中心にドカ雪の恐れ　太平洋側で降雪も_tenki.jp https://tenki.jp/forecaster/t_yoshida/2026/01/06/37293.html]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767923481,
      "updated": 1767923508
    },
    {
      "id": "69605f3500000000001c8030",
      "text": "\t\t3連休は[寒波]直撃だから、引き籠もって[年末年始やりたいことリスト（2025年末）]の残りをやる予定",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767923511,
      "updated": 1767923582
    },
    {
      "id": "6960609400000000001c8031",
      "text": "\t[学園アイドルマスター Story of Re;IRIS]、昨夜視聴終わった",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767923861,
      "updated": 1767923885
    },
    {
      "id": "696060ad00000000001c8032",
      "text": "\t\t前に[YouTube]でストーリー完結記念特番があったということもあって今回が[初星コミュ]の視聴3周目",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767923885,
      "updated": 1767945769
    },
    {
      "id": "696060fc00000000001c8033",
      "text": "\t\t[Re;IRIS]と[Begrazia]のアイドルたちの関係性が好きということも相まって終始楽しかった",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767923964,
      "updated": 1767924208
    },
    {
      "id": "6960621900000000001c8036",
      "text": "\t\t\t自分では気づいていなかったけど[関係性オタク]だったのかもしれない",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767924250,
      "updated": 1767924281
    },
    {
      "id": "6960616500000000001c8035",
      "text": "\t\t今回、はじめて[プロデューサー]に声が当てられたが、最初はまんま[シャア]（ジークアクス）ということもあって慣れなかったが物語が進むにつれていい感じだった",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767924070,
      "updated": 1767925101
    },
    {
      "id": "696062c700000000001c803f",
      "text": "\t\t1話毎にOP・EDが無いから気づいたら話が進んでいることが多かった",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767924423,
      "updated": 1767924423
    },
    {
      "id": "696065cb00000000001c8048",
      "text": "\t\t\tストーリーが面白いということもあって止めどころがない",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767925195,
      "updated": 1767925209
    },
    {
      "id": "696062ce00000000001c8040",
      "text": "\t\t[学マス]に興味あるけど何から触れればいいという質問に対して今回のアニメが最適解",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767924430,
      "updated": 1767924490
    },
    {
      "id": "6960630200000000001c8041",
      "text": "\t\t\t次点、楽曲・[MV]",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767924482,
      "updated": 1767924511
    },
    {
      "id": "6960669f00000000001c8049",
      "text": "\t[東九フェリー]で[東京]から[北九州]まで行く計画を友人と計画中",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767925407,
      "updated": 1767925712
    },
    {
      "id": "6960671200000000001c804a",
      "text": "\t\t調べると思ったより安価で驚いている",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767925522,
      "updated": 1767925688
    },
    {
      "id": "696067e000000000001c804c",
      "text": "\t\t今年中に行く予定",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767925728,
      "updated": 1767925752
    },
    {
      "id": "696067ff00000000001c804d",
      "text": "\t\t最悪、個別で行くかもという話も上がっている",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767925760,
      "updated": 1767925778
    },
    {
      "id": "6960ba980000000000210f35",
      "text": "\t最近、[漬物]に醤油をかけるのは[九州]だけということを、友人との食事で知った",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767946904,
      "updated": 1767947700
    },
    {
      "id": "6960bdba0000000000210f39",
      "text": "\t\t一部、味が濃いのが好きな人は除外",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767947707,
      "updated": 1767947764
    },
    {
      "id": "6960badc0000000000210f36",
      "text": "\t\t[肉まんに酢醤油]をかけるのも九州だけだし、九州は食べ物に何か調味料をかけないといけなかった歴史でもあったのかね",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1767946973,
      "updated": 1767970456
    },
    {
      "id": "6960c8540000000000b39c37",
      "text": "\t\t　関東だけど家庭ではやってた。九州出身の影響なのか…[基素.icon]",
      "userId": "59fb21121207900012774b17",
      "created": 1767950420,
      "updated": 1767950448
    },
    {
      "id": "6960bd670000000000210f38",
      "text": "\t\t肉まんに[酢醤油]をかけるようになった歴史はなんとなくわかった",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767947623,
      "updated": 1767947648
    },
    {
      "id": "6960c3030000000000cec06c",
      "text": "\tここ数年で、既存CDの[レコード]版が販売されることが増えている",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767949059,
      "updated": 1767949125
    },
    {
      "id": "6960c3450000000000cec06d",
      "text": " \t[レコードプレーヤー]買うか",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767949126,
      "updated": 1767949161
    },
    {
      "id": "6960d0910000000000d00872",
      "text": " \t[防振ゴム]も同時に買った方がいいかも、とふと思う。環境とかによって振動を拾い針が飛ぶことを想定[Hiro Aki.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1767952529,
      "updated": 1767970474
    },
    {
      "id": "69610f3200000000000062f7",
      "text": "  \t[防振]ゴムに関して思いついて無かった。ありがてえ[カイト.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1767968562,
      "updated": 1767970488
    },
    {
      "id": "6960561600000000002bc161",
      "text": " [東方アレンジ]、一時期凄く聴いてた",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767921174,
      "updated": 1767969439
    },
    {
      "id": "6961129f0000000000006316",
      "text": "  [東方ダンマクカグラ]はリリース後即プレイしていた",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767969439,
      "updated": 1767969491
    },
    {
      "id": "696112d20000000000006318",
      "text": "   [オフライン]版はタイミング逃してまだ買えてない",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767969491,
      "updated": 1767969548
    },
    {
      "id": "6961129f0000000000006317",
      "text": "",
      "userId": "65d0d54ba4356b00242d00f4",
      "created": 1767969440,
      "updated": 1767969440
    },
    {
      "id": "696068c100000000007b1e63",
      "text": "[koyoshi.icon]",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767925953,
      "updated": 1767925956
    },
    {
      "id": "696068c400000000007b1e64",
      "text": " 来週に向けて忙しいところに、急な仕事が舞い込んできた",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767925956,
      "updated": 1767926025
    },
    {
      "id": "6960692a00000000007b1e66",
      "text": "  それでもまだ余裕はある",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767926058,
      "updated": 1767926066
    },
    {
      "id": "6960697f00000000007b1e67",
      "text": " 魚介類レースは意識して食べないとポイントを稼げない",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767926143,
      "updated": 1767926178
    },
    {
      "id": "696069aa00000000007b1e68",
      "text": "  今朝は魚を食べたけど、またサバだった",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767926187,
      "updated": 1767926203
    },
    {
      "id": "6960acde000000000089830a",
      "text": "  お昼のツナパンのツナは「マグロ」か「カツオ」か、それとも別の魚なのか？",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767943390,
      "updated": 1767943444
    },
    {
      "id": "6960face000000000049637d",
      "text": "  \tめんどいから寿司でも食って確定させておこう[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963342,
      "updated": 1767963352
    },
    {
      "id": "696129c900000000002f0f93",
      "text": "  \tそう言われてみるとツナ缶のツナがマグロだったことあんまりないや[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1767975370,
      "updated": 1767975397
    },
    {
      "id": "69612b5e00000000002f0f95",
      "text": "  \t 正直ツナ缶はマグロよりカツオのが好き",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1767975774,
      "updated": 1767975788
    },
    {
      "id": "69606bfd00000000007b1e74",
      "text": " 自分のところにも[意味のわからないメール 2026/1/8]が届いていた",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767926782,
      "updated": 1767926809
    },
    {
      "id": "69606c1900000000007b1e75",
      "text": "  iPhoneユーザーなので、使ってもいない[Google Play]のこと言われても、どうして良いのか困ってしまう",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767926810,
      "updated": 1767932697
    },
    {
      "id": "69606c7500000000007b1e76",
      "text": "  なにもしないけどね",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767926902,
      "updated": 1767926907
    },
    {
      "id": "696068c700000000007b1e65",
      "text": "",
      "userId": "6606ca1148e7150024f0f07d",
      "created": 1767925959,
      "updated": 1767925959
    },
    {
      "id": "6960691d00000000007937a0",
      "text": "[W7kA9pX2.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767926045,
      "updated": 1767926046
    },
    {
      "id": "6960691f00000000007937a2",
      "text": "　ぼんやりするか",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767926047,
      "updated": 1767926056
    },
    {
      "id": "6960f8e100000000005380ec",
      "text": "　湯たんぽが欲しい",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767962849,
      "updated": 1767962860
    },
    {
      "id": "6960f8ea00000000005380ed",
      "text": "　　昔ながらのやつがいい",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767962861,
      "updated": 1767962864
    },
    {
      "id": "6960691d00000000007937a1",
      "text": "",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767926045,
      "updated": 1767926045
    },
    {
      "id": "696071080000000000da3694",
      "text": "[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1767928073,
      "updated": 1767928074
    },
    {
      "id": "696071090000000000da3695",
      "text": "\t年始明けから忙しくててんてこまいん",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1767928074,
      "updated": 1767928088
    },
    {
      "id": "696071230000000000da3696",
      "text": "\t\t早くコンテキストスイッチのリズムを確立せねば",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1767928100,
      "updated": 1767928110
    },
    {
      "id": "696071080000000000da3693",
      "text": "",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1767928073,
      "updated": 1767928073
    },
    {
      "id": "696071cb0000000000cb7ef4",
      "text": "[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928268,
      "updated": 1767928270
    },
    {
      "id": "696071cd0000000000cb7ef6",
      "text": "\t1年間魚に興味を持ち続けられない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928270,
      "updated": 1767928286
    },
    {
      "id": "696071de0000000000cb7ef7",
      "text": " \tゆるりと行きましょう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928287,
      "updated": 1767928296
    },
    {
      "id": "696071e70000000000cb7ef8",
      "text": " \t漁港に旅行した時に気合入れる等",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928296,
      "updated": 1767928316
    },
    {
      "id": "696072660000000000cb7efc",
      "text": " マウント",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928423,
      "updated": 1767963429
    },
    {
      "id": "696072390000000000cb7efa",
      "text": "  「ボクなら3日でやっちゃうけどね」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928378,
      "updated": 1767963429
    },
    {
      "id": "696072530000000000cb7efb",
      "text": "  「なんでできないのかわからない」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928404,
      "updated": 1767963429
    },
    {
      "id": "696071cb0000000000cb7ef5",
      "text": " どうでも良いか。考えるだけ腹が立つだけやし",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767928268,
      "updated": 1767963495
    },
    {
      "id": "6960fb6f000000000049637f",
      "text": " 詰め切らないと満足できない性格が無くなったような気がする",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963503,
      "updated": 1767963562
    },
    {
      "id": "6960fbaa0000000000496380",
      "text": " \tあれも煩悩の一種なのかもしれない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963562,
      "updated": 1767963578
    },
    {
      "id": "6960fbbf0000000000496381",
      "text": " \t不安傾向→詰め切ると安定するので安定を目指して詰める",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963583,
      "updated": 1767963616
    },
    {
      "id": "6960fbe80000000000496382",
      "text": " \t[ネガティブ・ケイパビリティ]の欠如",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963624,
      "updated": 1767963650
    },
    {
      "id": "6960fc240000000000496383",
      "text": " なんで感情が上手く安定するようになったのか分からん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963684,
      "updated": 1767963817
    },
    {
      "id": "6960fca90000000000496384",
      "text": " \t自分の一番認めたくない部分を認めたからだろうか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963817,
      "updated": 1767963871
    },
    {
      "id": "6960fd620000000000496386",
      "text": " \t不足していた愛を偽りの形でも体験したからだろうか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964001,
      "updated": 1767964082
    },
    {
      "id": "6960fdc70000000000496387",
      "text": " \t\t愛を知らない割に、一回体験したらすぐに満足したので割安なものだと思う",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964103,
      "updated": 1767964162
    },
    {
      "id": "6960fe030000000000496388",
      "text": " \t\tモデル化したらそれでおしまいだから満足したんかもしれん",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964163,
      "updated": 1767964198
    },
    {
      "id": "6960fe920000000000496389",
      "text": "  \t世界はこうあらねばならぬという理想が、実現されることで成仏していったような感じがする",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964306,
      "updated": 1767964358
    },
    {
      "id": "6960fee9000000000049638a",
      "text": "  \t\t不足していたものに敏感に反応して、言語野がたちまちに説を組み上げて強固な信念を構築したような感じがする。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964393,
      "updated": 1767964449
    },
    {
      "id": "6960ff2b000000000049638b",
      "text": "  \t\t若い時は説明可能な度し難い怒りが多かった。説明できてしまったので信念が揺らぐことはなかった。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964459,
      "updated": 1767964621
    },
    {
      "id": "6960ffce000000000049638c",
      "text": " 感情が安定しようがしまいが、信心深さは変わらんな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964622,
      "updated": 1767964764
    },
    {
      "id": "6961005c000000000049638d",
      "text": " \t科学を信仰したり、ある種の理想を信仰したり、論理を信仰したり",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964765,
      "updated": 1767964950
    },
    {
      "id": "696100dd000000000049638e",
      "text": " \t対象は変われどもとにかく信仰深いという一点は変わらんな",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964893,
      "updated": 1767964921
    },
    {
      "id": "696100fa000000000049638f",
      "text": " \t\t所謂堅物で頭が硬い",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767964922,
      "updated": 1767964934
    },
    {
      "id": "6961062d0000000000496390",
      "text": " 何も信じていない人は居るのだろうか",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767966253,
      "updated": 1767966262
    },
    {
      "id": "6961063d0000000000496391",
      "text": " \t何も信じていないというのは、無神論者のことではない。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767966269,
      "updated": 1767966331
    },
    {
      "id": "6961067b0000000000496392",
      "text": " \t神はいないという信念もない人のことを考えている。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767966331,
      "updated": 1767966331
    },
    {
      "id": "6960fb27000000000049637e",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1767963431,
      "updated": 1767963431
    },
    {
      "id": "6960849000000000003ea299",
      "text": "[taktamur.icon]",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933071,
      "updated": 1767933073
    },
    {
      "id": "6960849300000000003ea29b",
      "text": " 退院してきました。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933074,
      "updated": 1767933081
    },
    {
      "id": "6960849b00000000003ea29c",
      "text": "  入院中井戸端に入り浸るかも？と思ってたけどそんなことはなかった",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933082,
      "updated": 1767933107
    },
    {
      "id": "696084c500000000003ea29d",
      "text": "  mac持って行ってたけど、結局広げなかった。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933123,
      "updated": 1767933151
    },
    {
      "id": "696084e000000000003ea29e",
      "text": "   点滴用の管がつけっぱなしなので、あんまり腕を使う気にならなかった。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933151,
      "updated": 1767933195
    },
    {
      "id": "6960850d00000000003ea29f",
      "text": "  動画ばっかり見てた",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933196,
      "updated": 1767933204
    },
    {
      "id": "696088e30000000000a9853d",
      "text": "  ☕️[基素.icon][Hiro Aki.icon][はるひ.icon][W7kA9pX2.icon][koyoshi.icon][カイト.icon][sta.icon][caki.icon][terang.icon][yosider.icon][nomadoor.icon]",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767934180,
      "updated": 1767996671
    },
    {
      "id": "6960853900000000003ea2a0",
      "text": " タバコが美味い",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933241,
      "updated": 1767933248
    },
    {
      "id": "6960854200000000003ea2a1",
      "text": " ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933249,
      "updated": 1767933249
    },
    {
      "id": "6960849100000000003ea29a",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1767933071,
      "updated": 1767933071
    },
    {
      "id": "69608bd100000000007c8ab4",
      "text": "[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1767934930,
      "updated": 1767934931
    },
    {
      "id": "69608bd400000000007c8ab6",
      "text": "　図書館に行くことに成功",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1767934932,
      "updated": 1767934946
    },
    {
      "id": "69609d5d000000000029e0fe",
      "text": "　すれ違ったクラスメートが声かけてくれた！厚かましくも一緒に勉強させてもらっている",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1767939422,
      "updated": 1767939605
    },
    {
      "id": "69609d7d000000000029e0ff",
      "text": "　かつてないほど集中できている",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1767939463,
      "updated": 1767939463
    },
    {
      "id": "69609e530000000000a9ef8a",
      "text": "　 いい話[terang.icon][taktamur.icon][caki.icon][yosider.icon]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1767939667,
      "updated": 1767970701
    },
    {
      "id": "69608bd100000000007c8ab5",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1767934930,
      "updated": 1767934930
    },
    {
      "id": "69609d3f00000000003ae033",
      "text": "[Mijikko.icon]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939390,
      "updated": 1767939391
    },
    {
      "id": "69609d4100000000003ae035",
      "text": "　[Svelte]は[Svelte 5]になってからようやく謎記法（$）をやめて標準のES記法になったわね",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939391,
      "updated": 1767939430
    },
    {
      "id": "69609d6700000000003ae036",
      "text": "　　ツール開発者にとっても良くなかっただろうし",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939430,
      "updated": 1767939460
    },
    {
      "id": "69609d8600000000003ae037",
      "text": "　　読む側にとってもJavaScriptかと思って読んでたら急に知らん記法出てわけわからんかったし",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939460,
      "updated": 1767939483
    },
    {
      "id": "69609d8d00000000003ae038",
      "text": "　[visual studio - How do I find and replace multiple different key-value pairs at once? - Stack Overflow https://stackoverflow.com/questions/72322164/how-do-i-find-and-replace-multiple-different-key-value-pairs-at-once]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1767939467,
      "updated": 1767970750
    },
    {
      "id": "69609da400000000003ae039",
      "text": " 　これみたいに[複数パターンの文字列置換をまとめて行いたい]時がちょくちょくあるんだけど",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939490,
      "updated": 1767939649
    },
    {
      "id": "69609dbc00000000003ae03a",
      "text": " 　　仕事でよく[CSV]データ扱うので",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939514,
      "updated": 1767939526
    },
    {
      "id": "69609dc900000000003ae03b",
      "text": " 　ツール見当たんないんだよな",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939527,
      "updated": 1767939537
    },
    {
      "id": "69609dd900000000003ae03c",
      "text": " 　自分でスクリプト組んでもいいっちゃいいんだけど、誰でも簡単に扱えるようにある程度グラフィカルにしたい",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939544,
      "updated": 1767939564
    },
    {
      "id": "69609e5100000000003ae03d",
      "text": " 　できれば単体の静的HTMLとかにして、コピペするだけで動くとかにするとなお良い",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939663,
      "updated": 1767939681
    },
    {
      "id": "69609e6d00000000003ae03e",
      "text": " 　　もしくはVS Codeの拡張機能でも良い",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939692,
      "updated": 1767939702
    },
    {
      "id": "6960a3bf0000000000020d0c",
      "text": " 　変な間違いしそう[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767941056,
      "updated": 1767941063
    },
    {
      "id": "6960a3c60000000000020d0d",
      "text": " 　\t1つ目のパターンを変換したものが2つ目のパターンの一部になるとかのケース",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767941063,
      "updated": 1767941078
    },
    {
      "id": "6960a4080000000000020d0e",
      "text": " 　\t多くの場合そんなことないので気にしなくて良いのだけど・・気になっちゃうエンジニア",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1767941128,
      "updated": 1767941150
    },
    {
      "id": "6960afe200000000006deefd",
      "text": " 　文字列置換機能は[Microsoft Power Automate]にもあるわね。自然言語Aを自然言語Bの正書法に変換＆Edgeブラウザ内蔵の自然言語BのTTSに読み上げさせるのに使った[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1767944162,
      "updated": 1767944815
    },
    {
      "id": "69609d3f00000000003ae034",
      "text": "",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1767939390,
      "updated": 1767939390
    },
    {
      "id": "6960f86600000000004e7077",
      "text": "[seibe.icon]",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962727,
      "updated": 1767962729
    },
    {
      "id": "6960f86800000000004e7079",
      "text": " [ポモドーロ・テクニック]の記録のいいところは",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962729,
      "updated": 1767962748
    },
    {
      "id": "6960f87b00000000004e707a",
      "text": "  信頼性が高いところ",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962748,
      "updated": 1767962751
    },
    {
      "id": "6960f88100000000004e707b",
      "text": "  集中して1🍅やってこれくらいの出力だというのが分かるところ",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962753,
      "updated": 1767962773
    },
    {
      "id": "6960f89500000000004e707c",
      "text": "  普通のしたことの記録だと、どれだけ集中したかがわからない",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962773,
      "updated": 1767962792
    },
    {
      "id": "6960f8cc00000000004e707d",
      "text": "   「もっと本気出せばもっとできるはず」という期待が出る余地がある",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962830,
      "updated": 1767962870
    },
    {
      "id": "6960f8f600000000004e707e",
      "text": "  ポモドーロは、まあそれなりに集中しての出力なのでその期待が出る余地は少ない",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962871,
      "updated": 1767962895
    },
    {
      "id": "6960f91400000000004e707f",
      "text": "  ということで信頼性が高くなる",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962900,
      "updated": 1767962911
    },
    {
      "id": "6960f92200000000004e7080",
      "text": "  高くなると、それを元にした見通しの信頼性も高くなる、予測がしやすいと諸々組み立てやすい、それがいい",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962914,
      "updated": 1767962940
    },
    {
      "id": "69612aad00000000002f0f94",
      "text": "   すばらし[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1767975598,
      "updated": 1767975603
    },
    {
      "id": "6960f94400000000004e7081",
      "text": "  …的なことは以前書かれていた気がする",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767962949,
      "updated": 1767962956
    },
    {
      "id": "696114f20000000000380a2f",
      "text": "   これだ：[ポモドーロテクニック#627dbeceaff09e00001a3b44]",
      "userId": "5eb247ae6474d4001ea56fda",
      "created": 1767970035,
      "updated": 1767970036
    },
    {
      "id": "696108210000000000254960",
      "text": "  [自分の能力の見積もり][はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1767966754,
      "updated": 1767966762
    },
    {
      "id": "6960f8db00000000005380ea",
      "text": "",
      "userId": "644fa04c7142e4001b4b5d09",
      "created": 1767962844,
      "updated": 1767962844
    },
    {
      "id": "6961059000000000006cfd34",
      "text": "[zatto.icon]",
      "userId": "67026b2a4d8cae001d9e390a",
      "created": 1767966095,
      "updated": 1767966099
    },
    {
      "id": "6961059400000000006cfd36",
      "text": "　「曲」って記事見て思ったけど、一文字記事ってなかなか作らないからinfobox用のタグにしやすいなぁ〜っと",
      "userId": "67026b2a4d8cae001d9e390a",
      "created": 1767966099,
      "updated": 1767966145
    },
    {
      "id": "6961059000000000006cfd35",
      "text": "",
      "userId": "67026b2a4d8cae001d9e390a",
      "created": 1767966095,
      "updated": 1767966095
    },
    {
      "id": "69610dfd00000000001e2e39",
      "text": "[Nrem.icon]",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1767968254,
      "updated": 1767968262
    },
    {
      "id": "69610e0700000000001e2e3b",
      "text": " いくら磁気式でラピッドトリガー付きだろうと、USB端子の製造不良でキーが反応したりしなかったりする安物のキーボードは今後一切買わないと誓った",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1767968263,
      "updated": 1767968552
    },
    {
      "id": "69610e9200000000001e2e3c",
      "text": " 　控えめに言ってうんち💩",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1767968403,
      "updated": 1767968582
    },
    {
      "id": "69617478000000000069301f",
      "text": " 　安物で[うんちを見る]のは勘弁なので日頃使うものは歯食いしばってでも高価なものを買うようにしている[sta.icon]",
      "userId": "5a4873ab2e26fb001479d3a9",
      "created": 1767994491,
      "updated": 1767994519
    },
    {
      "id": "69618edc0000000000ce93cd",
      "text": " 　安物を買いがち[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1768001245,
      "updated": 1768001251
    },
