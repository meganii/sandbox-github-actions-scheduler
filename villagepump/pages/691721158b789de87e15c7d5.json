  "lines": [
    {
      "id": "691721158b789de87e15c7d5",
      "text": "ポケモンごいた",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123518,
      "updated": 1763123518
    },
    {
      "id": "6917213d0000000000ce5c1e",
      "text": ">[https://x.com/poke_times/status/1989196597964554525 @poke_times]: 読み合いが当たってヤッター！ハズれてワハハ！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123518,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c1f",
      "text": ">╋━━━━━━━",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c20",
      "text": ">新作ボードゲーム",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c21",
      "text": ">『ポケモンごいた』発売決定",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c22",
      "text": ">━━━━━━━━━╋",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c23",
      "text": ">📅2025年12月18日（木） 発売",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c24",
      "text": ">✅ルールを覚えられる無料のティーチングアプリも開発中",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c25",
      "text": ">ルールなど詳細は👇",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c26",
      "text": ">[https://www.pokemon.co.jp/ex/pokemon-goita/ トップページ｜『ポケモンごいた』公式サイト]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123554
    },
    {
      "id": "6917214b0000000000ce5c27",
      "text": ">[https://gyazo.com/a645c1c5376c5a6c1715d4a7cacc2309]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c28",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c29",
      "text": ">[https://x.com/Pokemon_cojp/status/1989211695374385437 @Pokemon_cojp]: 4人そろえば『ポケモンごいた』！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c2a",
      "text": ">ポケモンの新しいボードゲーム『ポケモンごいた』が、12月18日（木）に発売するよ！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c2b",
      "text": ">なんと、無料アプリも開発中！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c2c",
      "text": ">特設サイトもオープンしたので、ぜひチェックしてみてね！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "6917214b0000000000ce5c2d",
      "text": ">[https://www.pokemon.co.jp/ex/pokemon-goita/ トップページ｜『ポケモンごいた』公式サイト] #ポケモン #ポケモンごいた #ごいた #ボードゲーム #ボドゲ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123550
    },
    {
      "id": "6917214b0000000000ce5c2e",
      "text": ">[https://video.twimg.com/amplify_video/1988928300480122880/vid/avc1/1920x1080/nPrfYBFwvU0rgxHO.mp4?tag=16#.mp4]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "691960700000000000e68d26",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270769,
      "updated": 1763270769
    },
    {
      "id": "691960700000000000e68d27",
      "text": "[ゲムマ2025秋]に出展",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270769,
      "updated": 1763270775
    },
    {
      "id": "691960770000000000e68d28",
      "text": "\t>[https://x.com/Pokemon_cojp/status/1989226794541568202 @Pokemon_cojp]: 12月18日（木）発売の『ポケモンごいた』が最速で遊べるブースが、ゲームマーケット2025秋に登場！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270775,
      "updated": 1763270778
    },
    {
      "id": "691960790000000000e68d29",
      "text": " >なんと「ポケモンタルカ」「ポケモンババ抜き」も遊べるよ。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270778,
      "updated": 1763270778
    },
    {
      "id": "691960790000000000e68d2a",
      "text": " >くわしくはこちら！",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270778,
      "updated": 1763270778
    },
    {
      "id": "691960790000000000e68d2b",
      "text": " >https://gamemarket.jp/ #ポケモンごいた #ポケモンボドゲくらぶ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270778,
      "updated": 1763270791
    },
    {
      "id": "691960790000000000e68d2c",
      "text": " >[https://gyazo.com/1c7c42859929933f39579a0020d7ce26]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270778,
      "updated": 1763270799
    },
    {
      "id": "6917214b0000000000ce5c2f",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763123532,
      "updated": 1763123532
    },
    {
      "id": "691960050000000000e68d24",
      "text": "ポッポが`し`っぽいから、ポッポが5匹きたら配り直しか判定入るのか笑[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270662,
      "updated": 1763270666
    },
    {
      "id": "691960050000000000e68d25",
      "text": "",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1763270662,
      "updated": 1763270662
    },
    {
      "id": "693bb662000000000076ee7f",
      "text": ">[https://x.com/yb1rider/status/1989285238628135236 @yb1rider]: #ポケモンごいた 名言集（予言）",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520995,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee80",
      "text": ">４コラ、３コラはい、つよい～。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee81",
      "text": ">初手コラを即コラ受けは危険じゃ（オーキド博士）",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee82",
      "text": ">はい～ポニータは伏せがち～",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee83",
      "text": ">はりまミュウ",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee84",
      "text": ">野生攻め（し攻め。ポッポはボール入ってないから）",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee85",
      "text": ">６ポで４０点～",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee86",
      "text": ">バランス手持ちはドラゴンタイプから打て。",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee87",
      "text": ">ピカチュウかかってるね",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765520997
    },
    {
      "id": "693bb665000000000076ee88",
      "text": "\tわかる[terang.icon]",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1765520997,
      "updated": 1765521000
    },
    {
      "id": "693d093100000000006e76b1",
      "text": "\tいいね[着地鳩.icon]",
      "userId": "60508ed36a7abc00235e90c0",
      "created": 1765607728,
      "updated": 1765607730
    },
