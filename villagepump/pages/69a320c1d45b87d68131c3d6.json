    {
      "id": "69a3f915000000000060000e",
      "text": "  花粉症なので。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353813,
      "updated": 1772353896
    },
    {
      "id": "69a3f9380000000000600010",
      "text": "  医者の処方箋の薬の方が、市販薬よりも効くイメージ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353848,
      "updated": 1772353870
    },
    {
      "id": "69a3f94e0000000000600011",
      "text": "   プラシボ込み",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353870,
      "updated": 1772353883
    },
    {
      "id": "69a3f919000000000060000f",
      "text": "   鼻対策に点鼻薬ももらっている",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353817,
      "updated": 1772353886
    },
    {
      "id": "69a3f96a0000000000600012",
      "text": "  あとはマスクしてたら凌げる感じ",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353898,
      "updated": 1772353909
    },
    {
      "id": "69a3f9760000000000600013",
      "text": " 昨日は1.6万歩、今日は1.1万歩歩けた。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353909,
      "updated": 1772353976
    },
    {
      "id": "69a3f9c70000000000600014",
      "text": " 昨日は整体にも行って、体中をペキパキしてもらった",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353991,
      "updated": 1772354017
    },
    {
      "id": "69a3f9f80000000000600015",
      "text": " 良き週末であった。",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772354040,
      "updated": 1772354047
    },
    {
      "id": "69a3f90e000000000060000d",
      "text": "",
      "userId": "58a90dd3ee5de7001150db17",
      "created": 1772353806,
      "updated": 1772353806
    },
    {
      "id": "69a405d30000000000cb836c",
      "text": "[Hiro Aki.icon]",
      "userId": "65e1289acd012200235729c0",
      "created": 1772357075,
      "updated": 1772357085
    },
    {
      "id": "69a405dd0000000000cb836d",
      "text": "\t墓石掃除して分かる、ここ最近の空気の汚れ具合",
      "userId": "65e1289acd012200235729c0",
      "created": 1772357086,
      "updated": 1772357098
    },
    {
      "id": "69a405ec0000000000cb836e",
      "text": "\t\t花粉が飛んでたと思ってたが意外と綺麗で、感覚は当てにならぬなと",
      "userId": "65e1289acd012200235729c0",
      "created": 1772357100,
      "updated": 1772357128
    },
    {
      "id": "69a406090000000000cb836f",
      "text": "\t新しい電子レンジはテーブルが回らないタイプ",
      "userId": "65e1289acd012200235729c0",
      "created": 1772357130,
      "updated": 1772357317
    },
    {
      "id": "69a406c40000000000cb8370",
      "text": "\t\t複数個の、ラップで包んだ冷凍ごはんを入れると温めムラが出来るのでなんとかしたい",
      "userId": "65e1289acd012200235729c0",
      "created": 1772357317,
      "updated": 1772357346
    },
    {
      "id": "69a4447d0000000000ca0ce7",
      "text": "",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1772373118,
      "updated": 1772373118
    },
    {
      "id": "69a4447d0000000000ca0ce8",
      "text": "[kumoridai.icon]",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1772373118,
      "updated": 1772373125
    },
    {
      "id": "69a444850000000000ca0ce9",
      "text": " 暖かくなってきたので[ペットのアリ]のお世話を再開",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772373126,
      "updated": 1772375424
    },
    {
      "id": "69a448240000000000ca0ceb",
      "text": " ドバイが大変なことに",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1772374053,
      "updated": 1772374053
    },
    {
      "id": "69a4482a0000000000ca0cec",
      "text": "  [ポケットモンスター ウインド・ウェーブ]の舞台はモルディブとかインドネシアかな、ドバイかな～とか思ってた矢先",
      "userId": "68afcc9b93f1844fed9e3b89",
      "created": 1772374059,
      "updated": 1772379071
    },
    {
      "id": "69a44c160000000000f03e94",
      "text": "",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375064,
      "updated": 1772375064
    },
    {
      "id": "69a44c170000000000f03e95",
      "text": "[vlzs.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375064,
      "updated": 1772375066
    },
    {
      "id": "69a44c1a0000000000f03e96",
      "text": " 近所にパン屋さんがあるので買って食べたい",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375067,
      "updated": 1772375086
    },
    {
      "id": "69a44c2e0000000000f03e97",
      "text": "  食べ物は食べるとすぐになくなってしまう",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375087,
      "updated": 1772375433
    },
    {
      "id": "69a44c660000000000f03e99",
      "text": "  同じ五百円なら本を読むほうが長く楽しめる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375143,
      "updated": 1772375435
    },
    {
      "id": "69a44c850000000000f03e9b",
      "text": "  本を買っておきたい",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375174,
      "updated": 1772375437
    },
    {
      "id": "69a44c970000000000f03e9d",
      "text": "  パンが食べたい……",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375192,
      "updated": 1772375438
    },
    {
      "id": "69a44cce0000000000f03ea0",
      "text": "  オーブントースターで焼くバナナケーキを作ろうかな",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375247,
      "updated": 1772375442
    },
    {
      "id": "69a44ca20000000000f03e9e",
      "text": "   ホットケーキミックスの生地とバナナをグラタン皿に入れて作る",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375202,
      "updated": 1772375445
    },
    {
      "id": "69a44d2f0000000000f03ea3",
      "text": " [サバカンビスバス]のことを思い出すときいつも、サバ缶びしばしだと思う",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375344,
      "updated": 1772375389
    },
    {
      "id": "69a44e9d0000000000507f22",
      "text": "  [サバカンビシバシ][サカバンバスピス.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772375710,
      "updated": 1772375751
    },
    {
      "id": "69a44eb30000000000507f23",
      "text": "  [サカバンバスピス][サカバンバスピス.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772375731,
      "updated": 1772375776
    },
    {
      "id": "69a44f4d0000000000f03ea7",
      "text": "  そもそも`ビスバス`じゃなかった[vlzs.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375886,
      "updated": 1772375909
    },
    {
      "id": "69a44ff90000000000507f24",
      "text": "   正しく覚えている人のが少なそうだしどれでも通じそう[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1772376058,
      "updated": 1772376086
    },
    {
      "id": "69a450530000000000f03ea8",
      "text": "  カタカナを間違って覚えていたのが、[横文字がちゃんと読めない]だ",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772376148,
      "updated": 1772376196
    },
    {
      "id": "69a456d00000000000591980",
      "text": "  自分も発音しようとすると毎回サバカンになる[hoshihara.icon]",
      "userId": "640b5ab62ffe46001b897bef",
      "created": 1772377809,
      "updated": 1772377832
    },
    {
      "id": "69a44e1d0000000000f03ea4",
      "text": " 「[スケールする]/しない」という言い方が接地しなくて「機能する」を使ってる",
      "userId": "6780c5dd585ee07f1dc50b2b",
      "created": 1772375582,
      "updated": 1772387307
    },
    {
      "id": "69a44e550000000000f03ea5",
      "text": "  たまに英文(や日本語に翻訳したもの）でスケールするという言い方を見る",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375645,
      "updated": 1772375652
    },
    {
      "id": "69a44e640000000000f03ea6",
      "text": "   そして三角スケール(長さを測る道具)を思い浮かべる",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772375656,
      "updated": 1772375736
    },
    {
      "id": "69a44c860000000000f03e9c",
      "text": "\t\t同じ仕組みでも大規模化すると破綻する場合はスケールしない、大規模化しても同じ仕組みのままやっていけるならスケールする[Summer498.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772375174,
      "updated": 1772375668
    },
    {
      "id": "69a44e7d0000000000680c30",
      "text": "\t\t\t熱血（？）中小企業のやり方で大企業になるとビッグモーターみたいになる",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772375677,
      "updated": 1772375713
    },
    {
      "id": "69a44ecd0000000000680c31",
      "text": "\t\t\t逆に大規模で成立している方法論を小規模に導入すると成立しなくなることもあり、それもスケールしていない",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772375757,
      "updated": 1772375821
    },
    {
      "id": "69a44f0f0000000000680c32",
      "text": " \t\t\tどんなスケール（縮尺）感でも上手くいくという感じ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772375824,
      "updated": 1772375846
    },
    {
      "id": "69a45171000000000008503e",
      "text": " 魔法使いとしての自分の魔法の属性を選んだ",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772376434,
      "updated": 1772376472
    },
    {
      "id": "69a45198000000000008503f",
      "text": "  あれかなーこれかなーと楽しく迷ってみたけれど、自分のアイコン[vlzs.icon]・死神からして闇属性だった",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1772376473,
      "updated": 1772377129
    },
    {
      "id": "69a44e4f0000000000680c2f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1772375638,
      "updated": 1772375638
    },
    {
      "id": "69a320c37838e3000000a1965a",
      "text": "[2026/02/28]←2026/03/01→[2026/03/02]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1772298434,
      "updated": 1772298434
    },
    {
      "id": "69a320c37838e30000009e17c4",
      "text": "[/ [2026/03.icon]]",
      "userId": "60fb0a79f3364000237838e3",
      "created": 1772298434,
      "updated": 1772298434
    }
  ]
}