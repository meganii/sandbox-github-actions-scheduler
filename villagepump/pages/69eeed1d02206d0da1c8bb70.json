  "lines": [
    {
      "id": "69eeed1d02206d0da1c8bb70",
      "text": "パロタ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265954,
      "updated": 1777265954
    },
    {
      "id": "69eeed220000000000d3877e",
      "text": "「ナンですかこれ」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265954,
      "updated": 1777265964
    },
    {
      "id": "69eeed2c0000000000d38781",
      "text": "「いいえ、パロタです」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265965,
      "updated": 1777265973
    },
    {
      "id": "69eeedb00000000000d38789",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266096,
      "updated": 1777266096
    },
    {
      "id": "69eeeda60000000000d38788",
      "text": "英：parotta [/icons/slowparrot.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266086,
      "updated": 1777266148
    },
    {
      "id": "69eeed280000000000d3877f",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265961,
      "updated": 1777265961
    },
    {
      "id": "6a05aeb00000000000d40350",
      "text": "南インドで作られるパン",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757296,
      "updated": 1778757300
    },
    {
      "id": "6a05aeb00000000000d40351",
      "text": " ケララ、タミル",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757296,
      "updated": 1778757300
    },
    {
      "id": "6a05aeb10000000000d40352",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757297,
      "updated": 1778757297
    },
    {
      "id": "69eeed510000000000d38784",
      "text": "from [2026/04/27]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777266001,
      "updated": 1778757297
    },
    {
      "id": "69eeed360000000000d38782",
      "text": " [https://gyazo.com/87916254ac1bee4410069a57505f12b5]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265975,
      "updated": 1777266009
    },
    {
      "id": "69eeed360000000000d38783",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265975,
      "updated": 1777265975
    },
    {
      "id": "69eeed690000000000d38787",
      "text": "[https://note.com/philosophycurry/n/n27a846ce872e parotta のある生活 | note]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266025,
      "updated": 1777266181
    },
    {
      "id": "69eeee080000000000d3878c",
      "text": " > [/ 平たいパン（[フラットブレッド]）で、渦巻き状かつ層になっており、サクサクとした食感ともっちりとした食感を兼ね備えている。噛んだ時の内側の食感は麺のようでもなる。]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1777266184,
      "updated": 1778757048
    },
    {
      "id": "69eeedfa0000000000d3878b",
      "text": "\t\t麺のようなパンとはこれ如何に？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266171,
      "updated": 1777266230
    },
    {
      "id": "69eeee240000000000d3878d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266212,
      "updated": 1777266212
    },
    {
      "id": "69eeed5d0000000000d38785",
      "text": "形がナンではないのでナンとは違う焼き方をしてそう。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266014,
      "updated": 1777266184
    },
    {
      "id": "69eeee890000000000d3878e",
      "text": "\t油をつけて生地を引き伸ばし、練り、カットを入れ、ねじり、渦巻き状にし、鉄板に油を敷いて焼くらしい。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266314,
      "updated": 1777266680
    },
    {
      "id": "69eef0e60000000000f83b36",
      "text": "\t作っているところを見るととんでもない量の油を使っている[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1777266918,
      "updated": 1777266931
    },
    {
      "id": "6a05adcb0000000000d40329",
      "text": "\t焼く前の赤ちゃんパロタ見せてもらったことある[はるひ.icon]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757067,
      "updated": 1778757125
    },
    {
      "id": "6a05ae690000000000d4032b",
      "text": "\t\thttps://www.instagram.com/p/DYD6fpVj29_/?img_index=1 調べた",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757225,
      "updated": 1778757250
    },
    {
      "id": "6a05b016000000000091513b",
      "text": "\t\t つやつやだ[caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1778757655,
      "updated": 1778757658
    },
    {
      "id": "6a05adde0000000000d4032a",
      "text": "\t\tちなみにフォカッチャの赤ちゃんは[フォカチャン]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757087,
      "updated": 1778757100
    },
    {
      "id": "69eeed670000000000d38786",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266024,
      "updated": 1777266024
    },
    {
      "id": "6a05ad790000000000d40318",
      "text": "\t[レイヤーブレッド]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778756985,
      "updated": 1778757039
    },
    {
      "id": "6a05adb90000000000d40327",
      "text": "\t\tクロワッサン、デニッシュ的な",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757049,
      "updated": 1778757053
    },
    {
      "id": "6a05ad790000000000d4031b",
      "text": "\tパロタにも色々種類や地域性があるようだ",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778756985,
      "updated": 1778756985
    },
    {
      "id": "6a05ad980000000000d40326",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757016,
      "updated": 1778757042
    },
    {
      "id": "6a05ad790000000000d4031d",
      "text": "\tカレーなくそのまま食べたい[はるひ.icon][caki.icon]",
      "userId": "6923e3b6e09f0be0924872ef",
      "created": 1778756985,
      "updated": 1778757666
    },
    {
      "id": "6a05ad790000000000d4031e",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778756985,
      "updated": 1778756985
    },
    {
      "id": "6a05aeb70000000000d40353",
      "text": "[南インド料理]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778757304,
      "updated": 1778757309
    },
    {
      "id": "6a05ad830000000000d40325",
      "text": "[インドのパン]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1778756996,
      "updated": 1778756996
    }
  ]
}