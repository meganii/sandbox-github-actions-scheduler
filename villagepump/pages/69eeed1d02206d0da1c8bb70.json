      "updated": 1777265954
    },
    {
      "id": "69eeed220000000000d3877e",
      "text": "「ナンですかこれ」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265954,
      "updated": 1777265964
    },
    {
      "id": "69eeed2c0000000000d38781",
      "text": "「いいえ、パロタです」",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777265965,
      "updated": 1777265973
    },
    {
      "id": "69eeedb00000000000d38789",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777266096,
      "updated": 1777266096
    },
    {
      "id": "69eeeda60000000000d38788",
      "text": "英：parotta [/icons/slowparrot.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
