    {
      "id": "69cad1385311cf27c6cc99c9",
      "text": "イングリッシュネーム",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774899515,
      "updated": 1774899515
    },
    {
      "id": "69cad13b0000000000789183",
      "text": "英語での名前",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774899515,
      "updated": 1774899518
    },
    {
      "id": "69cad13d0000000000789184",
      "text": "アジア圏などの非英語圏の人が、英語圏で生活・仕事をする際に使う「英語のニックネーム」のこと。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774899518,
      "updated": 1774899518
    },
    {
      "id": "69cad13d0000000000789185",
      "text": "本名が英語話者にとって発音・記憶しにくいため、親しみやすく円滑にコミュニケーションをとる目的で使われる。",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1774899518,
      "updated": 1774899518
    },
