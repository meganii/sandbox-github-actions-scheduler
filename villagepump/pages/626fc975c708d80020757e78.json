      "updated": 1776141302
    },
    {
      "id": "69ddc3f70000000000188b09",
      "text": "[新聞のスクラップ]のことかと",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1776141304,
      "updated": 1776143157
    },
    {
      "id": "69ddc3f20000000000188b07",
