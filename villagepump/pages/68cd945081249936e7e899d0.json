    {
      "id": "68cd945081249936e7e899d0",
      "text": "寝方（一歳向け）",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af11",
      "text": "> [@ponpomponchan https://twitter.com/ponpomponchan/status/1964286312674127938]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1758303313,
      "updated": 1782227991
    },
    {
      "id": "68cd9451000000000072af12",
      "text": ">息子が大興奮で寝そうになかったから",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af13",
      "text": "> おめめをぎゅーしてごらん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af14",
      "text": "> 👦🏻ぎゅー",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af15",
      "text": "> おててと[あんよ]をだらーんしてごらん",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1758303313,
      "updated": 1777143012
    },
    {
      "id": "68cd9451000000000072af16",
      "text": "> 👦🏻だらーん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af17",
      "text": "> 👦🏻なんぷならた⭐︎△※…←宇宙語",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af18",
      "text": "> おくちんーで黙ってごらん",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af19",
      "text": "> 👦🏻……",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af1a",
      "text": "> で5秒で寝た",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "68cd9451000000000072af1b",
      "text": "> [一歳]もしかして[寝方]を分かってない？？？？",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303333
    },
    {
      "id": "68cd9451000000000072af1c",
      "text": "",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1758303313,
      "updated": 1758303313
    },
    {
      "id": "6a3a8766000000000021d56d",
      "text": "[寝るのが下手くそ]",
      "userId": "60c9f2f6c225a50020b8bbfc",
      "created": 1782220646,
      "updated": 1782220655
    },
    {
      "id": "6a3aa43f0000000000e745f9",
      "text": "[眠れないときにすること]",
      "userId": "5c30ba88e98efe0017e5172d",
      "created": 1782228030,
      "updated": 1782228031
    },
    {
      "id": "6a3aa3fa0000000000e745e7",
