    {
      "id": "69a7fe950000000000f7058d",
      "text": "書評からはちょっとズレるかもけど[hoagecko.icon]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617366,
      "updated": 1772617406
    },
    {
      "id": "69a7febd0000000000f70591",
      "text": "[HON.jp News Blog | 本（HON）のつくり手をエンパワーするメディア Since 2004 https://hon.jp/news/]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617406,
      "updated": 1772617413
    },
    {
      "id": "69a7ff200000000000f70592",
      "text": "\t出版・メディア・書店関連のニュースのリンクブログをしている",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617505,
      "updated": 1772617522
    },
    {
      "id": "69a7ff320000000000f70593",
      "text": "\t\t同様のブログはネット上には結構ある",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617522,
      "updated": 1772617549
    },
    {
      "id": "69a7ff500000000000f70594",
      "text": "\t\t\tmizuho furuharaさん等",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617553,
      "updated": 1772617856
    },
    {
      "id": "69a7fe960000000000f7058e",
      "text": "[本屋ライター和氣正幸（BOOKSHOP TRAVELLER 店主）｜note https://note.com/bookshoplover] #和氣正幸",
      "userId": "5d69dde930e3c500170f1ffd",
      "created": 1772617366,
      "updated": 1772629066
    },
    {
      "id": "69a7ff880000000000f70596",
      "text": "\t独立系書店のニュース",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617608,
      "updated": 1772617625
    },
    {
      "id": "69a7ff5b0000000000f70595",
      "text": "[本好きが集うニュースメディア - BookLink https://book-link.jp/media/]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617563,
      "updated": 1772617737
    },
    {
      "id": "69a8000a0000000000f70598",
      "text": "\t出版業界紙の新文化社が運営するメディア",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617738,
      "updated": 1772617766
    },
    {
      "id": "69a801440000000000f7059f",
      "text": "\t\t[新文化オンライン - 出版業界唯一の専門紙 https://www.shinbunka.co.jp/]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772618053,
      "updated": 1772618053
    },
    {
      "id": "69a800260000000000f70599",
      "text": "\t\tRSSがよくバグる",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617767,
      "updated": 1772617776
    },
    {
      "id": "69a800090000000000f70597",
      "text": "[書店FAX | 版元ドットコム https://www.hanmoto.com/soushin-fax]",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617737,
      "updated": 1772617951
    },
    {
      "id": "69a800df0000000000f7059d",
      "text": " Webメディアではないが、出版社が書店に送った販促FAXが読める",
      "userId": "688c296691686a314f82fb52",
      "created": 1772617951,
      "updated": 1772618222
    },
    {
      "id": "69a802330000000000f705a3",
      "text": "[ダ・ヴィンチWeb | 読みたい本がここにある https://ddnavi.com/]",
