    },
    {
      "id": "69da1c7a0000000000b455f1",
      "text": "        line-height: 1.3;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f2",
      "text": "        color: #111;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f3",
      "text": "        margin-bottom: 6px;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f4",
      "text": "        display: -webkit-box;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f5",
      "text": "        -webkit-line-clamp: 2;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f6",
      "text": "        -webkit-box-orient: vertical;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f7",
      "text": "        overflow: hidden;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f8",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455f9",
      "text": "      #hover-card .hc-desc {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455fa",
      "text": "        font-size: 12px;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455fb",
      "text": "        line-height: 1.5;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455fc",
      "text": "        color: #666;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455fd",
      "text": "        display: -webkit-box;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455fe",
      "text": "        -webkit-line-clamp: 3;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b455ff",
      "text": "        -webkit-box-orient: vertical;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45600",
      "text": "        overflow: hidden;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45601",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45602",
      "text": "    `;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45603",
      "text": "    document.head.appendChild(style);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45604",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45605",
      "text": "    async function fetchPage(title) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45606",
      "text": "      if (CACHE.has(title)) return CACHE.get(title);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45607",
      "text": "      try {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45608",
      "text": "        const res = await fetch(`/api/pages/${PROJECT}/${encodeURIComponent(title)}`);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45609",
      "text": "        if (!res.ok) return null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4560a",
      "text": "        const data = await res.json();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4560b",
      "text": "        CACHE.set(title, data);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4560c",
      "text": "        return data;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4560d",
      "text": "      } catch {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4560e",
      "text": "        return null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4560f",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45610",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45611",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45612",
      "text": "    function extractImage(page) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45613",
      "text": "      if (page.image) return page.image;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45614",
      "text": "      for (const line of (page.descriptions || [])) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45615",
      "text": "        const m = line.match(/https?:\\/\\/[^\\s\\]]+\\.(?:png|jpe?g|gif|webp|svg)/i);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45616",
      "text": "        if (m) return m[0];",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45617",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45618",
      "text": "      for (const l of (page.lines || []).slice(0, 10)) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45619",
      "text": "        const m = l.text?.match(/https?:\\/\\/[^\\s\\]]+\\.(?:png|jpe?g|gif|webp|svg)/i);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4561a",
      "text": "        if (m) return m[0];",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4561b",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4561c",
      "text": "      return null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4561d",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4561e",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4561f",
      "text": "    function show(link, data) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45620",
      "text": "      if (!card) card = createCard();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45621",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45622",
      "text": "      const imgEl = card.querySelector('.hc-image');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45623",
      "text": "      const titleEl = card.querySelector('.hc-title');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45624",
      "text": "      const descEl = card.querySelector('.hc-desc');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45625",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45626",
      "text": "      titleEl.textContent = data.title || '';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45627",
      "text": "      descEl.textContent = (data.descriptions || []).join(' ').slice(0, 200);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45628",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45629",
      "text": "      const imgUrl = extractImage(data);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4562a",
      "text": "      imgEl.innerHTML = '';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4562b",
      "text": "      if (imgUrl) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4562c",
      "text": "        imgEl.classList.add('has-img');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4562d",
      "text": "        const img = document.createElement('img');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4562e",
      "text": "        img.src = imgUrl;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4562f",
      "text": "        img.loading = 'lazy';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45630",
      "text": "        imgEl.appendChild(img);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45631",
      "text": "      } else {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45632",
      "text": "        imgEl.classList.remove('has-img');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45633",
      "text": "      }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45634",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45635",
      "text": "      const rect = link.getBoundingClientRect();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45636",
      "text": "      let top = rect.bottom + 8;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45637",
      "text": "      let left = rect.left;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45638",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45639",
      "text": "      if (left + 270 > window.innerWidth) left = window.innerWidth - 275;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4563a",
      "text": "      if (left < 5) left = 5;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4563b",
      "text": "      if (top + 280 > window.innerHeight) top = rect.top - 280;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4563c",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4563d",
      "text": "      card.style.top = top + 'px';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4563e",
      "text": "      card.style.left = left + 'px';",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4563f",
      "text": "      card.classList.add('visible');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45640",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45641",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45642",
      "text": "    function hide() {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45643",
      "text": "      if (card) card.classList.remove('visible');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45644",
      "text": "      currentLink = null;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45645",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45646",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45647",
      "text": "    function scheduleHide() {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45648",
      "text": "      clearTimeout(hideTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45649",
      "text": "      hideTimer = setTimeout(hide, 250);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4564a",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4564b",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4564c",
      "text": "    // リンクに直接 mouseenter/mouseleave を付与",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4564d",
      "text": "    const attachedLinks = new WeakSet();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4564e",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4564f",
      "text": "    function attachLink(link) {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45650",
      "text": "      if (attachedLinks.has(link)) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45651",
      "text": "      attachedLinks.add(link);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45652",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45653",
      "text": "      link.addEventListener('mouseenter', () => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45654",
      "text": "        clearTimeout(hideTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45655",
      "text": "        clearTimeout(showTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45656",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45657",
      "text": "        if (link === currentLink && card && card.classList.contains('visible')) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45658",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45659",
      "text": "        currentLink = link;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4565a",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4565b",
      "text": "        showTimer = setTimeout(async () => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4565c",
      "text": "          const title = link.getAttribute('data-page-title');",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4565d",
      "text": "          if (!title) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4565e",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4565f",
      "text": "          const data = await fetchPage(title);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45660",
      "text": "          if (!data || currentLink !== link) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45661",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45662",
      "text": "          show(link, data);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45663",
      "text": "        }, 300);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45664",
      "text": "      });",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45665",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45666",
      "text": "      link.addEventListener('mouseleave', (e) => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45667",
      "text": "        clearTimeout(showTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45668",
      "text": "        const related = e.relatedTarget;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45669",
      "text": "        if (card && (card === related || card.contains(related))) return;",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4566a",
      "text": "        scheduleHide();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4566b",
      "text": "      });",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4566c",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4566d",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4566e",
      "text": "    function scanLinks() {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4566f",
      "text": "      document.querySelectorAll('a.page-link').forEach(attachLink);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45670",
      "text": "    }",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45671",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45672",
      "text": "    scanLinks();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45673",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45674",
      "text": "    const observer = new MutationObserver(() => scanLinks());",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45675",
      "text": "    observer.observe(document.body, { childList: true, subtree: true });",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45676",
      "text": "  ",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45677",
      "text": "    document.addEventListener('scroll', () => {",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45678",
      "text": "      clearTimeout(showTimer);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b45679",
      "text": "      hide();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4567a",
      "text": "    }, true);",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c7a0000000000b4567b",
      "text": "  })();",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901818,
      "updated": 1775901818
    },
    {
      "id": "69da1c6c0000000000b454d5",
      "text": "",
      "userId": "5f938a902ea5180024085116",
      "created": 1775901804,
      "updated": 1775901804
    },
    {
      "id": "69db14790000000000fefae7",
      "text": "#UserScript ← これは infobox用",
      "userId": "5b5e7121417cf700145b98c2",
      "created": 1775965306,
      "updated": 1775965380
    },
    {
      "id": "69db147e0000000000fefae8",
      "text": "[UserScript.icon] ← これは[アイコンフィルター]用",
      "userId": "5b5e7121417cf700145b98c2",
