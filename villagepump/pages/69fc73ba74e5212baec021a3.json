      "updated": 1778152379
    },
    {
      "id": "69fc73bb0000000000405576",
      "text": "from [国家レベルのサイバー攻撃]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778152379,
      "updated": 1778152379
    },
    {
      "id": "69fc7432000000000040557f",
