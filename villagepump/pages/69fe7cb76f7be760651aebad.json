    },
    {
      "id": "69fe7cba0000000000d1c06d",
      "text": "[波ダッシュ・全角チルダ問題]における、[全角チルダ]の方。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778285755,
      "updated": 1778285761
    },
    {
      "id": "69fe7cba0000000000d1c06e",
      "text": "Unicode は U+FF5E。",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1778285755,
      "updated": 1778285770
    },
    {
      "id": "69fe7cba0000000000d1c06f",
