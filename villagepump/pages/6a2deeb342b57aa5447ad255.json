      "updated": 1781395380
    },
    {
      "id": "6a2defb200000000005b42d2",
      "text": "読み方：らっこおっとせいりょうかくとりしまりほう",
      "userId": "65e1289acd012200235729c0",
      "created": 1781395380,
      "updated": 1781395384
    },
    {
      "id": "6a2defb700000000005b42d4",
