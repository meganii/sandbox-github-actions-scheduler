  "lines": [
    {
      "id": "6a1183228a3fd95cf8a45b07",
      "text": "ファースト恥知らずペンギン",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779532581,
      "updated": 1779532581
    },
    {
      "id": "6a1183090000000000ff6f70",
      "text": " 恥知らずな[ファーストペンギン][hiro.icon]",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779532581,
      "updated": 1779532640
    },
    {
      "id": "6a11830d0000000000ff6f71",
      "text": "",
      "userId": "5f11a68e5fc065001ecf5795",
      "created": 1779532585,
      "updated": 1779532585
    },
    {
      "id": "6a1183dc00000000008b50a5",
      "text": " [アホな質問をたくさんするぞ〜]と近そう[inajob.icon]",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1779532765,
      "updated": 1779532782
    },
    {
      "id": "6a118d2400000000008b50b1",
      "text": "  [マクドナルド理論]も追加",
      "userId": "58442db3ee4a2400116eb406",
      "created": 1779535141,
      "updated": 1779535152
    },
    {
      "id": "6a1183dc00000000008b50a6",
      "text": " [2人目に踊るバカ]があとに続く[mtane0412.icon]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1779532765,
      "updated": 1779533319
    },
    {
      "id": "6a1185ff00000000009436e0",
      "text": "  [2人目に踊るバカになれ]",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1779533312,
      "updated": 1779533313
    },
    {
      "id": "6a1185eb00000000009436df",
      "text": "",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1779533291,
      "updated": 1779533291
    },
    {
      "id": "6a118afb0000000000ec3371",
      "text": "[ファースト〇〇ペンギン]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779534588,
      "updated": 1779537736
    },
    {
      "id": "6a118b000000000000ec3373",
      "text": " [ファースト質問ペンギン][vlzs.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779534593,
      "updated": 1779537739
    },
    {
      "id": "6a118bb10000000000ec3379",
      "text": "  「質問をどうぞ」と言われて遠慮してしまう集団の中にいる、最初に質問をするペンギン",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779534769,
      "updated": 1779534810
    },
    {
      "id": "6a118b080000000000ec3375",
      "text": " [ファースト挨拶ペンギン][vlzs.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779534601,
      "updated": 1779537741
    },
    {
      "id": "6a118afc0000000000ec3372",
      "text": "  集団の中で最初に挨拶の声を上げるペンギン。その人に続いて他の人も挨拶する",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779534588,
      "updated": 1779534822
    },
    {
      "id": "6a118b3f0000000000ec3378",
      "text": "  [でびでび・でびるさんに似た声の小学生#69f5dbc500000000007d7a15]で会った",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779534655,
      "updated": 1779534655
    },
    {
      "id": "6a118be9000000000074990b",
      "text": " [ファースト退勤ペンギン][mtane0412.icon]",
      "userId": "63042e42f2ab90001d68385a",
      "created": 1779534826,
      "updated": 1779537743
    },
    {
      "id": "6a118cec000000000074990e",
      "text": "  「先上がります」の一言で退勤してもよい空気を醸成するペンギン",
      "userId": "5ae7fecf7766b7001455cbd3",
      "created": 1779535085,
      "updated": 1779535098
    },
