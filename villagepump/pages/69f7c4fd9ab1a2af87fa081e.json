      "id": "69f7c4fd9ab1a2af87fa081e",
      "text": "2026/03/29―caki",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a50",
      "text": "from [2026/03/29]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a51",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845505
    },
    {
      "id": "69f7c4fe0000000000ed2a52",
      "text": "[caki.icon]",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a53",
      "text": " 同人誌+ぽこぽけ",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a54",
      "text": "  同人誌の舞台として設定してる部屋のある地点からの眺めをいちいち考えるのがめんどくさいのでぽこポケ内で似たような間取りを作ってそれを見ながら絵を書けば良いじゃないかとなった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a55",
      "text": "  今夜作ろう",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a56",
      "text": " 花見に行った",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a57",
      "text": "  知っている花見(新宿御苑)とは違うパリピの花見だった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a58",
      "text": "  文化が違う！",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a59",
      "text": " 知的生産がなんなのか実はまだよくわかっていなかったので[知的生産]のページを見てきたらなんとなく雰囲気はわかった",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a5a",
      "text": "  それは人類の普遍的な活動じゃないのか、思ったが、人類皆ブロガー時代以前はそうでもなかったのか？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a5b",
      "text": "  まだいまいちピンときてない部分がある",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a5c",
      "text": "   知的ってなんだ？",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
      "id": "69f7c4fe0000000000ed2a5d",
      "text": "",
      "userId": "6436266c7ac3c0001bed60e6",
      "created": 1777845502,
      "updated": 1777845502
    },
    {
